open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T092 helper: Finset additivity of `peterssonInner` in the first arg.** -/
theorem peterssonInner_sum_left
    {╬╣ : Type*} [DecidableEq ╬╣] (s : Finset ╬╣) (F : ╬╣ тЖТ тДН тЖТ тДВ)
    (g : тДН тЖТ тДВ) (D : Set тДН)
    (h_int : тИА i тИИ s, IntegrableOn (fun ╧Д => petersson k g (F i) ╧Д) D ╬╝_hyp) :
    peterssonInner k D (тИС i тИИ s, F i) g = тИС i тИИ s, peterssonInner k D (F i) g := by
  induction s using Finset.induction_on with
  | empty => simp [peterssonInner_zero_left]
  | insert i t hi ih =>
    rw [Finset.sum_insert hi]
    have h_i := h_int i (Finset.mem_insert_self i t)
    have h_t := fun j hj => h_int j (Finset.mem_insert_of_mem hj)
    have h_sum_int :
        IntegrableOn (fun ╧Д => petersson k g (тИС j тИИ t, F j) ╧Д) D ╬╝_hyp := by
      have h_eq :
          (fun ╧Д => petersson k g (тИС j тИИ t, F j) ╧Д) =
            fun ╧Д => тИС j тИИ t, petersson k g (F j) ╧Д := by
        funext ╧Д; exact petersson_sum_right t g F ╧Д
      rw [h_eq]
      exact MeasureTheory.integrable_finset_sum _ h_t
    rw [peterssonInner_add_left D (F i) (тИС j тИИ t, F j) g h_i h_sum_int,
      ih h_t, Finset.sum_insert hi]

