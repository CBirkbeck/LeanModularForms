open CongruenceSubgroup in
/-- **Phase M (e) вҖ” natural quotient map `SL в§ё О“_p(Оұ) вҶ’ SL в§ё О“вӮҒ(N)`.**

Sends each `О“_p(Оұ)`-coset `[g]` to its `О“вӮҒ(N)`-coset `[g]`.  Well-defined by
the inclusion `О“_p(Оұ) вүӨ О“вӮҒ(N)` (`Gamma_p_Оұ_le_Gamma1`). -/
noncomputable def slGamma_p_ОұToGamma1 (Оұ : GL (Fin 2) в„ҡ) :
    SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ вҶ’
      SL(2, в„Ө) в§ё Gamma1 N :=
  Quotient.lift
    (fun g : SL(2, в„Ө) =>
      (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma1 N))
    (by
      intro a b hab
      change (QuotientGroup.leftRel _).r _ _ at hab
      rw [QuotientGroup.leftRel_apply] at hab
      apply (QuotientGroup.eq).mpr
      exact (Gamma_p_Оұ_le_Gamma1 Оұ) hab)

@[simp]
theorem slGamma_p_ОұToGamma1_mk (Оұ : GL (Fin 2) в„ҡ) (g : SL(2, в„Ө)) :
    slGamma_p_ОұToGamma1 (N := N) Оұ
        (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) =
      QuotientGroup.mk g := rfl

theorem slGamma_p_ОұToGamma1_surjective (Оұ : GL (Fin 2) в„ҡ) :
    Function.Surjective (slGamma_p_ОұToGamma1 (N := N) Оұ) := by
  intro q'
  obtain вҹЁg, hgвҹ© := QuotientGroup.mk_surjective q'
  refine вҹЁQuotientGroup.mk g, ?_вҹ©
  rw [slGamma_p_ОұToGamma1_mk, hg]

open CongruenceSubgroup Classical in
/-- **Phase M (e) вҖ” uniform fiber cardinality** of `slGamma_p_ОұToGamma1`.

Mirror of `slToPslQuot_Gamma_p_Оұ_fiber_card_uniform` (Phase M(b)) at the
SL/О“вӮҒ(N) target.  The proof uses the same left-multiplication bijection
between fibers, exploiting the SL-equivariance of the quotient map. -/
theorem slGamma_p_ОұToGamma1_fiber_card_uniform (Оұ : GL (Fin 2) в„ҡ)
    (qвӮҒ' qвӮӮ' : SL(2, в„Ө) в§ё Gamma1 N) :
    haveI : DecidableEq (SL(2, в„Ө) в§ё Gamma1 N) := Classical.decEq _
    (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
        slGamma_p_ОұToGamma1 (N := N) Оұ q = qвӮҒ')).card =
      (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
        slGamma_p_ОұToGamma1 (N := N) Оұ q = qвӮӮ')).card := by
  haveI : DecidableEq (SL(2, в„Ө) в§ё Gamma1 N) := Classical.decEq _
  obtain вҹЁqвӮҒ, hqвӮҒвҹ© := slGamma_p_ОұToGamma1_surjective (N := N) Оұ qвӮҒ'
  obtain вҹЁqвӮӮ, hqвӮӮвҹ© := slGamma_p_ОұToGamma1_surjective (N := N) Оұ qвӮӮ'
  induction qвӮҒ using QuotientGroup.induction_on with | _ gвӮҒ => ?_
  induction qвӮӮ using QuotientGroup.induction_on with | _ gвӮӮ => ?_
  set h := gвӮӮ * gвӮҒвҒ»В№ with hh_def
  refine Finset.card_bij'
    (fun q _ => slLeftMul_Gamma_p_Оұ (N := N) Оұ h q)
    (fun q _ => slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№ q)
    (fun q hq => ?_) (fun q hq => ?_)
    (fun q _ => by
      show slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№
        (slLeftMul_Gamma_p_Оұ (N := N) Оұ h q) = q
      rw [slLeftMul_Gamma_p_Оұ_comp, inv_mul_cancel, slLeftMul_Gamma_p_Оұ_one])
    (fun q _ => by
      show slLeftMul_Gamma_p_Оұ (N := N) Оұ h
        (slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№ q) = q
      rw [slLeftMul_Gamma_p_Оұ_comp, mul_inv_cancel, slLeftMul_Gamma_p_Оұ_one])
  В· simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hq вҠў
    induction q using QuotientGroup.induction_on with | _ g => ?_
    show slGamma_p_ОұToGamma1 (N := N) Оұ (QuotientGroup.mk (h * g)) = qвӮӮ'
    rw [slGamma_p_ОұToGamma1_mk]
    -- `hqвӮӮ : slGamma_p_ОұToGamma1 Оұ вҶ‘gвӮӮ = qвӮӮ'` reduces to `вҶ‘gвӮӮ = qвӮӮ'` via the simp lemma.
    have h_gвӮӮ : (QuotientGroup.mk gвӮӮ : SL(2, в„Ө) в§ё Gamma1 N) = qвӮӮ' := hqвӮӮ
    have h_g : (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma1 N) = qвӮҒ' := hq
    have h_gвӮҒ : (QuotientGroup.mk gвӮҒ : SL(2, в„Ө) в§ё Gamma1 N) = qвӮҒ' := hqвӮҒ
    rw [вҶҗ h_gвӮӮ, hh_def, QuotientGroup.eq]
    -- Need: (gвӮӮ * gвӮҒвҒ»В№ * g)вҒ»В№ * gвӮӮ вҲҲ Gamma1 N.
    -- = gвҒ»В№ * gвӮҒ вҲҲ Gamma1 N (from h_g.trans h_gвӮҒ.symm via QuotientGroup.eq).
    have hq_eq : (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma1 N) = QuotientGroup.mk gвӮҒ :=
      h_g.trans h_gвӮҒ.symm
    rw [QuotientGroup.eq] at hq_eq
    have : (gвӮӮ * gвӮҒвҒ»В№ * g)вҒ»В№ * gвӮӮ = gвҒ»В№ * gвӮҒ := by group
    rw [this]; exact hq_eq
  В· simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hq вҠў
    induction q using QuotientGroup.induction_on with | _ g => ?_
    show slGamma_p_ОұToGamma1 (N := N) Оұ (QuotientGroup.mk (hвҒ»В№ * g)) = qвӮҒ'
    rw [slGamma_p_ОұToGamma1_mk]
    have h_gвӮҒ : (QuotientGroup.mk gвӮҒ : SL(2, в„Ө) в§ё Gamma1 N) = qвӮҒ' := hqвӮҒ
    have h_g : (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma1 N) = qвӮӮ' := hq
    have h_gвӮӮ : (QuotientGroup.mk gвӮӮ : SL(2, в„Ө) в§ё Gamma1 N) = qвӮӮ' := hqвӮӮ
    rw [вҶҗ h_gвӮҒ, hh_def, QuotientGroup.eq]
    have hq_eq : (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma1 N) = QuotientGroup.mk gвӮӮ :=
      h_g.trans h_gвӮӮ.symm
    rw [QuotientGroup.eq] at hq_eq
    have : ((gвӮӮ * gвӮҒвҒ»В№)вҒ»В№ * g)вҒ»В№ * gвӮҒ = gвҒ»В№ * gвӮӮ := by group
    rw [this]; exact hq_eq

