    (hint_LHS : IntegrableOn
      (fun ╧Д => petersson k
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)) тИг[k]
          (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) ╧Д)
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН)) ╬╝_hyp)
    (hint_RHS : IntegrableOn
      (fun ╧Д => petersson k
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f))
        ((тЗСg) тИг[k] (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН)) ╬╝_hyp)
    (h_per_tile : тИА q : SL(2, тДд) тз╕ Gamma1 N,
