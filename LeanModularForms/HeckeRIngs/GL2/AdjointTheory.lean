              ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k]
                (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ))) := by
  rw [petN_heckeT_p_LHS_as_tile_aggregate p hp hpN f g]
