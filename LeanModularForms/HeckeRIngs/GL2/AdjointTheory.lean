/-- **T205-d-SYMM SL(2,тДд) tile family**: the (p+1) SL(2,тДд) elements
that index the per-tile decomposition of `T_p_lower тАв Hecke_FD`. -/
private noncomputable def T_p_lower_tile_family
    (N p : тДХ) [NeZero N] (hpN : Nat.Coprime p N) :
    Option (Fin p) тЖТ SL(2, тДд)
  | none => M_infty_Gamma1_factor N p hpN 0
  | some b => shiftSL_loc (b.val : тДд)

/-- **T205-d-SYMM Hecke representative family** as a function. -/
private noncomputable def Hecke_rep_family
    (N p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) :
    Option (Fin p) тЖТ GL (Fin 2) тДЭ
  | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ)
  | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) тДЭ)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM Hecke FD tile decomposition under T_p_lower**:
`T_p_lower тАв (тЛГ_X ╬▒_X тАв S) = тЛГ_X (mapGL ╧Д_X) тАв S` where each ╧Д_X is the
corresponding SL(2,тДд) element (`shiftSL_loc(b)` for the upper branches,
`M_infty_Gamma1_factor` for the M_тИЮ branch).

This is the geometric heart of the per-tile ╧Г_p Q-permutation: the Hecke
FD shifted by T_p_lower decomposes as a union of (p+1) SL(2,тДд)-tiles. -/
private theorem T_p_lower_smul_Hecke_FD_eq_iUnion_tile
    (p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (S : Set тДН) :
    (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) тАв
      (тЛГ i : Option (Fin p), Hecke_rep_family N p hp hpN i тАв S) =
    тЛГ i : Option (Fin p),
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S := by
  rw [Set.smul_set_iUnion]
  refine Set.iUnion_congr fun i => ?_
  match i with
  | none =>
    show (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) тАв
      ((glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) тАв S) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) тДЭ) тАв S
    rw [тЖР mul_smul]
    exact T_p_lower_mul_M_infty_smul_set_eq_M_infty_Gamma1_factor_smul
      (N := N) p hp hpN S
  | some b =>
    show (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) тАв
      ((glMap (T_p_upper p hp b.val) : GL (Fin 2) тДЭ) тАв S) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (shiftSL_loc (b.val : тДд)) : GL (Fin 2) тДЭ) тАв S
    rw [тЖР mul_smul]
    exact T_p_lower_mul_T_p_upper_smul_set_eq_shift_smul p hp b.val S

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM per-tile slash conversion**: applying
`peterssonInner_mapGL_smul_eq_slash` to each tile of the
`T_p_lower тАв Hecke_FD` decomposition converts each tile integral on
`mapGL ╧Д_X тАв S` into a slash form on `S` with both slots slashed by `╧Д_X`. -/
private theorem peterssonInner_T_p_lower_tile_eq_slash
    (p : тДХ) [NeZero N] (hpN : Nat.Coprime p N) (S : Set тДН) (F G : тДН тЖТ тДВ)
    (i : Option (Fin p)) :
    peterssonInner k
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) F G =
    peterssonInner k S
      (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))
      (G тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ)) :=
  peterssonInner_mapGL_smul_eq_slash _ (T_p_lower_tile_family N p hpN i) F G

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM iUnion-to-sum conversion** for the T_p_lowerтАвHecke_FD
tile decomposition under AE-disjoint + null-measurable + integrable hypotheses:

`pet (тЛГ_X (mapGL ╧Д_X)тАв╬УтВБ_FD) F G = тИС_X pet ((mapGL ╧Д_X)тАв╬УтВБ_FD) F G`

