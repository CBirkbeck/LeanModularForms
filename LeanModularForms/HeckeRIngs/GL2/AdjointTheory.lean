open CongruenceSubgroup in
/-- **Phase M (b) вҖ” natural quotient map `SL в§ё О“_p(Оұ) вҶ’ PSL в§ё image_О“_p(Оұ)_PSL`.**

Mirror of `slToPslQuot` (`PeterssonLevelN.lean:811`) at the О“_p(Оұ) subgroup.
Sends each `О“_p(Оұ)`-coset `[g]` to its `image_Gamma_p_Оұ_PSL`-coset
`[PSL.mk g]`.  Well-defined by the inclusion `О“_p(Оұ).map (PSL.mk') вҠҶ image_О“_p(Оұ)_PSL`. -/
noncomputable def slToPslQuot_Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ) :
    SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ вҶ’
      PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ :=
  Quotient.lift
    (fun g : SL(2, в„Ө) =>
      (QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ))
    (by
      intro a b hab
      change (QuotientGroup.leftRel _).r _ _ at hab
      rw [QuotientGroup.leftRel_apply] at hab
      apply (QuotientGroup.eq).mpr
      have h_psl : (QuotientGroup.mk a : PSL(2, в„Ө))вҒ»В№ * QuotientGroup.mk b =
          QuotientGroup.mk (aвҒ»В№ * b) := by
        rw [вҶҗ QuotientGroup.mk_inv, вҶҗ QuotientGroup.mk_mul]
      rw [h_psl]
      exact вҹЁaвҒ»В№ * b, hab, rflвҹ©)

@[simp]
theorem slToPslQuot_Gamma_p_Оұ_mk (Оұ : GL (Fin 2) в„ҡ) (g : SL(2, в„Ө)) :
    slToPslQuot_Gamma_p_Оұ (N := N) Оұ
        (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) =
      QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :=
  rfl

theorem slToPslQuot_Gamma_p_Оұ_surjective (Оұ : GL (Fin 2) в„ҡ) :
    Function.Surjective (slToPslQuot_Gamma_p_Оұ (N := N) Оұ) := by
  intro q'
  obtain вҹЁg_psl, hg_pslвҹ© := QuotientGroup.mk_surjective q'
  obtain вҹЁg_sl, hg_slвҹ© := QuotientGroup.mk_surjective g_psl
  refine вҹЁQuotientGroup.mk g_sl, ?_вҹ©
  rw [slToPslQuot_Gamma_p_Оұ_mk, hg_sl, hg_psl]

open CongruenceSubgroup in
/-- **Phase M (b) вҖ” left-multiplication action on `SL в§ё О“_p(Оұ)`.**

Mirror of `slLeftMul` (`PeterssonLevelN.lean:852`) at the О“_p(Оұ) subgroup.
Although `О“_p(Оұ)` is generally not normal in `SL(2, в„Ө)`, the left-multiplication
action of `SL(2, в„Ө)` on `SL в§ё О“_p(Оұ)` is well-defined and respects
`slToPslQuot_Gamma_p_Оұ`. -/
noncomputable def slLeftMul_Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ) (h : SL(2, в„Ө)) :
    SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ вҶ’ SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ :=
  Quotient.lift (fun g : SL(2, в„Ө) =>
      (QuotientGroup.mk (h * g) : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ))
    (by
      intro a b hab
      change (QuotientGroup.leftRel _).r _ _ at hab
      rw [QuotientGroup.leftRel_apply] at hab
      apply QuotientGroup.eq.mpr
      have : (h * a)вҒ»В№ * (h * b) = aвҒ»В№ * b := by group
      rw [this]; exact hab)

@[simp]
theorem slLeftMul_Gamma_p_Оұ_mk (Оұ : GL (Fin 2) в„ҡ) (h g : SL(2, в„Ө)) :
    slLeftMul_Gamma_p_Оұ (N := N) Оұ h
        (QuotientGroup.mk g : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) =
      QuotientGroup.mk (h * g) :=
  rfl

theorem slLeftMul_Gamma_p_Оұ_one (Оұ : GL (Fin 2) в„ҡ)
    (q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) :
    slLeftMul_Gamma_p_Оұ (N := N) Оұ 1 q = q := by
  induction q using QuotientGroup.induction_on with | _ g => simp

theorem slLeftMul_Gamma_p_Оұ_comp (Оұ : GL (Fin 2) в„ҡ) (hвӮҒ hвӮӮ : SL(2, в„Ө))
    (q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) :
    slLeftMul_Gamma_p_Оұ (N := N) Оұ hвӮҒ (slLeftMul_Gamma_p_Оұ (N := N) Оұ hвӮӮ q) =
      slLeftMul_Gamma_p_Оұ (N := N) Оұ (hвӮҒ * hвӮӮ) q := by
  induction q using QuotientGroup.induction_on with | _ g => simp [mul_assoc]

open CongruenceSubgroup Classical in
/-- **Phase M (b) вҖ” uniform fiber size of `slToPslQuot_Gamma_p_Оұ`.**

Mirror of `slToPslQuot_fiber_card_uniform` (`PeterssonLevelN.lean:921`)
at the О“_p(Оұ) subgroup.  Any two fibers of `slToPslQuot_Gamma_p_Оұ` have
equal cardinality, by left-multiplication bijection between fibers using
the SL(2, в„Ө)-equivariance of the quotient map. -/
theorem slToPslQuot_Gamma_p_Оұ_fiber_card_uniform (Оұ : GL (Fin 2) в„ҡ)
    (qвӮҒ' qвӮӮ' : PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) :
    haveI : DecidableEq (PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) := Classical.decEq _
    (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
        slToPslQuot_Gamma_p_Оұ (N := N) Оұ q = qвӮҒ')).card =
      (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
        slToPslQuot_Gamma_p_Оұ (N := N) Оұ q = qвӮӮ')).card := by
  haveI : DecidableEq (PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) := Classical.decEq _
  obtain вҹЁqвӮҒ, hqвӮҒвҹ© := slToPslQuot_Gamma_p_Оұ_surjective (N := N) Оұ qвӮҒ'
  obtain вҹЁqвӮӮ, hqвӮӮвҹ© := slToPslQuot_Gamma_p_Оұ_surjective (N := N) Оұ qвӮӮ'
  induction qвӮҒ using QuotientGroup.induction_on with | _ gвӮҒ => ?_
  induction qвӮӮ using QuotientGroup.induction_on with | _ gвӮӮ => ?_
  set h := gвӮӮ * gвӮҒвҒ»В№ with hh_def
  refine Finset.card_bij'
    (fun q _ => slLeftMul_Gamma_p_Оұ (N := N) Оұ h q)
    (fun q _ => slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№ q)
    (fun q hq => ?_)
    (fun q hq => ?_)
    (fun q _ => by
      show slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№
        (slLeftMul_Gamma_p_Оұ (N := N) Оұ h q) = q
      rw [slLeftMul_Gamma_p_Оұ_comp, inv_mul_cancel, slLeftMul_Gamma_p_Оұ_one])
    (fun q _ => by
      show slLeftMul_Gamma_p_Оұ (N := N) Оұ h
        (slLeftMul_Gamma_p_Оұ (N := N) Оұ hвҒ»В№ q) = q
      rw [slLeftMul_Gamma_p_Оұ_comp, mul_inv_cancel, slLeftMul_Gamma_p_Оұ_one])
  В· simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hq вҠў
    induction q using QuotientGroup.induction_on with | _ g => ?_
    show slToPslQuot_Gamma_p_Оұ (N := N) Оұ (QuotientGroup.mk (h * g)) = qвӮӮ'
    rw [slToPslQuot_Gamma_p_Оұ_mk]
    have hq_psl : (QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) = qвӮҒ' := hq
    have h_psl : (QuotientGroup.mk (h * g) : PSL(2, в„Ө)) =
        (QuotientGroup.mk h : PSL(2, в„Ө)) * (QuotientGroup.mk g : PSL(2, в„Ө)) :=
      (QuotientGroup.mk_mul _ _ _).symm
    rw [h_psl]
    have h_h_psl : (QuotientGroup.mk h : PSL(2, в„Ө)) =
        QuotientGroup.mk gвӮӮ * (QuotientGroup.mk gвӮҒ)вҒ»В№ := by
      rw [hh_def, вҶҗ QuotientGroup.mk_inv, вҶҗ QuotientGroup.mk_mul]
    rw [h_h_psl]
    have hq_eq_gвӮҒ : (QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) =
        QuotientGroup.mk (QuotientGroup.mk gвӮҒ : PSL(2, в„Ө)) := by
      rw [hq_psl]; exact hqвӮҒ.symm
    rw [QuotientGroup.eq] at hq_eq_gвӮҒ
    rw [show qвӮӮ' = QuotientGroup.mk (QuotientGroup.mk gвӮӮ : PSL(2, в„Ө)) from hqвӮӮ.symm,
      QuotientGroup.eq]
    have : (QuotientGroup.mk gвӮӮ * (QuotientGroup.mk gвӮҒ)вҒ»В№ *
          (QuotientGroup.mk g : PSL(2, в„Ө)))вҒ»В№ * QuotientGroup.mk gвӮӮ =
        (QuotientGroup.mk g : PSL(2, в„Ө))вҒ»В№ * QuotientGroup.mk gвӮҒ := by group
    rw [this]; exact hq_eq_gвӮҒ
  В· simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hq вҠў
    induction q using QuotientGroup.induction_on with | _ g => ?_
    show slToPslQuot_Gamma_p_Оұ (N := N) Оұ (QuotientGroup.mk (hвҒ»В№ * g)) = qвӮҒ'
    rw [slToPslQuot_Gamma_p_Оұ_mk]
    have hq_psl : (QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) = qвӮӮ' := hq
    have h_psl : (QuotientGroup.mk (hвҒ»В№ * g) : PSL(2, в„Ө)) =
        (QuotientGroup.mk h : PSL(2, в„Ө))вҒ»В№ * (QuotientGroup.mk g : PSL(2, в„Ө)) := by
      rw [show (hвҒ»В№ * g : SL(2, в„Ө)) = hвҒ»В№ * g from rfl,
        вҶҗ QuotientGroup.mk_inv, вҶҗ QuotientGroup.mk_mul]
    rw [h_psl]
    have h_h_psl : (QuotientGroup.mk h : PSL(2, в„Ө)) =
        QuotientGroup.mk gвӮӮ * (QuotientGroup.mk gвӮҒ)вҒ»В№ := by
      rw [hh_def, вҶҗ QuotientGroup.mk_inv, вҶҗ QuotientGroup.mk_mul]
    rw [h_h_psl]
    have hq_eq_gвӮӮ : (QuotientGroup.mk (QuotientGroup.mk g : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) =
        QuotientGroup.mk (QuotientGroup.mk gвӮӮ : PSL(2, в„Ө)) := by
      rw [hq_psl]; exact hqвӮӮ.symm
    rw [QuotientGroup.eq] at hq_eq_gвӮӮ
    rw [show qвӮҒ' = QuotientGroup.mk (QuotientGroup.mk gвӮҒ : PSL(2, в„Ө)) from hqвӮҒ.symm,
      QuotientGroup.eq]
    have : ((QuotientGroup.mk gвӮӮ * (QuotientGroup.mk gвӮҒ)вҒ»В№)вҒ»В№ *
          (QuotientGroup.mk g : PSL(2, в„Ө)))вҒ»В№ * QuotientGroup.mk gвӮҒ =
        (QuotientGroup.mk g : PSL(2, в„Ө))вҒ»В№ * QuotientGroup.mk gвӮӮ := by group
    rw [this]; exact hq_eq_gвӮӮ

