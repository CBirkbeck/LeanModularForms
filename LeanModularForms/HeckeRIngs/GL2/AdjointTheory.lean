            (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))
          (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) =
        peterssonInner k
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН))
          (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f))
          ((тЗСg) тИг[k] (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))) :
    peterssonInner k
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)) тИг[k]
          (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) =
      peterssonInner k
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
