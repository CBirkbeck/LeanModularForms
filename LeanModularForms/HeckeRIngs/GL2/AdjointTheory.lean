open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 residual slash-adjoint transfer helper at `╬▓ = glMap T_p_lower`
with ╬УтВБ(N)-twist**: for each `q ╬│ : SL(2, тДд)` with `╬│ тИИ Gamma1 N`,

```
peterssonInner k fd (тЗСf тИг[k] mapGL qтБ╗┬╣)
    (тЗСg тИг[k] (glMap T_p_lower * mapGL ╬│ * mapGL qтБ╗┬╣))
= peterssonInner k (glMap T_p_lower тАв mapGL (q * ╬│тБ╗┬╣)тБ╗┬╣ тАв fd)
    (тЗСf тИг[k] glMap T_p_upper(0))
    тЗСg
```

**Proof.** Introduce the twisted coset rep `q' := q * ╬│тБ╗┬╣`.  Then
`mapGL q'тБ╗┬╣ = mapGL ╬│ * mapGL qтБ╗┬╣` (via `map_mul` on the MonoidHom `mapGL тДЭ`
composed with `(q * ╬│тБ╗┬╣)тБ╗┬╣ = ╬│ * qтБ╗┬╣`).  The `mapGL ╬│` slash on `тЗСf` is
absorbed by `slash_Gamma1_eq` (using `h╬│ : ╬│ тИИ Gamma1 N`), so
`тЗСf тИг[k] mapGL qтБ╗┬╣ = тЗСf тИг[k] mapGL q'тБ╗┬╣`.  After these rewrites the LHS is in
the direct form accepted by `peterssonInner_slash_adjoint_coset_right` at
`╬▓ = glMap T_p_lower`, giving the domain-shifted form whose `f`-slot is
`тЗСf тИг[k] peterssonAdj (glMap T_p_lower)`.  Finally
`peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero` rewrites the `f`-slot
to `тЗСf тИг[k] glMap T_p_upper(0)`.

**Role in T128 closure.**  This is the per-q per-branch slash-adjoint transfer
for the RHS of `petN_heckeT_p_adjoint_standard_form`: specialising `╬│` to the
`ds_p_plus_one_family_Gamma1_factor` correction factor for each branch yields
the single-tile transfer for M_тИЮ (`╬│ = gamma0_T_p_upper_Gamma1_factor 0 *
M_infty_Gamma1_factor 0`) or upper b (`╬│ = gamma0_T_p_upper_Gamma1_factor b`).
Each branch's ╬УтВБ(N)-membership is supplied by
`ds_p_plus_one_family_Gamma1_factor_mem_Gamma1`. -/
private lemma peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q ╬│ : SL(2, тДд)) (h╬│ : ╬│ тИИ Gamma1 N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗСg тИг[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) =
    peterssonInner k
        ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) тАв
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q * ╬│тБ╗┬╣)тБ╗┬╣ : GL (Fin 2) тДЭ) тАв
            (ModularGroup.fd : Set UpperHalfPlane)))
        (тЗСf тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ))
        тЗСg := by
  -- Twisted coset rep: q' = q * ╬│тБ╗┬╣, so q'тБ╗┬╣ = ╬│ * qтБ╗┬╣.
  have hq'_inv : ((q * ╬│тБ╗┬╣)тБ╗┬╣ : SL(2, тДд)) = ╬│ * qтБ╗┬╣ := by
    rw [mul_inv_rev, inv_inv]
  -- ╬УтВБ-invariance absorbs the mapGL ╬│ slash on f.
  have h_slash_╬│ : (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ :
      GL (Fin 2) тДЭ)) = тЗСf := by
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) =
          ((╬│ : SL(2, тДд)) : GL (Fin 2) тДЭ) from rfl, тЖР ModularForm.SL_slash]
    exact slash_Gamma1_eq f ╬│ h╬│
  -- Rewrite goal LHS: g-slash chain `T_p_lower * mapGL ╬│ * mapGL qтБ╗┬╣ =
  -- T_p_lower * mapGL (q * ╬│тБ╗┬╣)тБ╗┬╣`.
  have h_g_slash_chain :
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ((q * ╬│тБ╗┬╣)тБ╗┬╣ : SL(2, тДд)) :
          GL (Fin 2) тДЭ) := by
    rw [hq'_inv, map_mul, тЖР mul_assoc]
  -- Rewrite goal LHS: f-slash `mapGL qтБ╗┬╣ = mapGL (q * ╬│тБ╗┬╣)тБ╗┬╣` via ╬УтВБ-inv.
  have h_f_slash_eq :
      (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
      (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ((q * ╬│тБ╗┬╣)тБ╗┬╣ : SL(2, тДд)) :
        GL (Fin 2) тДЭ)) := by
    rw [hq'_inv, map_mul, SlashAction.slash_mul, h_slash_╬│]
  rw [h_g_slash_chain, h_f_slash_eq]
  -- Determinant positivity of `glMap T_p_lower`: det = p > 0.
  have h_det_pos : 0 < (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).map
        (algebraMap тДЪ тДЭ)).det =
        (algebraMap тДЪ тДЭ) (((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp.pos
  rw [peterssonInner_slash_adjoint_coset_right
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) h_det_pos (q * ╬│тБ╗┬╣) тЗСf тЗСg]
  rw [peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero p hp.pos]

/-- **T128 R2 тАФ M_тИЮ branch tile-domain matrix identity.**  The algebraic
rewrite exposing the LHS M_тИЮ tile
`glMap M_тИЮ ┬╖ mapGL qтБ╗┬╣` as the RHS shifted-tile form
`glMap T_p_lower ┬╖ mapGL (q ┬╖ ╬│_MтБ╗┬╣)тБ╗┬╣` **up to a leading
`mapGL ╬│тВАтБ╗┬╣` prefix**, where
`╬│тВА := (adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)` and
`╬│_M := gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
  M_infty_Gamma1_factor N p hpN 0`.

Derived by left-multiplying the landed matrix identity
`mapGL ╬│тВА ┬╖ glMap M_тИЮ = glMap T_p_lower ┬╖ mapGL ╬│_M`
(`mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon`) on the right
by `mapGL qтБ╗┬╣` and regrouping, using
`(q ┬╖ ╬│_MтБ╗┬╣)тБ╗┬╣ = ╬│_M ┬╖ qтБ╗┬╣` (from `mul_inv_rev` + `inv_inv`).

**Role in T128 closure (R2 of the shifted-tile тЖФ union-tile bridge).**
Exposes the precise prefix discrepancy between LHS M_тИЮ tile and RHS
shifted M_тИЮ tile; the leading `mapGL ╬│тВАтБ╗┬╣ = (mapGL adjointGamma0Rep)тБ╗┬╣`
factor will cancel against the residual slot-3 `тИг[k] mapGL
adjointGamma0Rep` slash in the LHS union-tile form via R1 (slot swap
+ slash redistribution), yielding the per-q bridge equality.  The
analogous upper-family identity follows from
`mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta` by the same
rearrangement. -/
private lemma glMap_M_infty_mul_mapGL_inv_eq_gamma0_inv_mul_shifted
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (q : SL(2, тДд)) :
    (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
          GL (Fin 2) тДЭ)тБ╗┬╣ *
        ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q * (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)тБ╗┬╣)тБ╗┬╣ :
            GL (Fin 2) тДЭ)) := by
  have h_core :=
    mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon N p hp.pos hpN
  have h_inv_rewrite :
      ((q * (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0)тБ╗┬╣)тБ╗┬╣ : SL(2, тДд)) =
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
