  rw [show (((q.out : SL(2, тДд)) * ╬│)тБ╗┬╣ тАв (fd : Set тДН) : Set тДН) =
      ((╬│ : SL(2, тДд))тБ╗┬╣ тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set тДН))) from by
    rw [mul_inv_rev, mul_smul]]
  -- Step 3: change of variables ╧Д тЖж ╬│ тАв ╧Г on the ╬│тБ╗┬╣-shifted set, then use ╬УтВБ-invariance.
  symm
  rw [show ((╬│тБ╗┬╣ : SL(2, тДд)) тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set тДН)) : Set тДН) =
