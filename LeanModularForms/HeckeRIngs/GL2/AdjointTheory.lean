/-- **T024 petN T_p-side, per-q T_p_lower form**: applies the per-q
union-tile T_p_lower form
(`peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form`) to each
summand of `petN(T_p f, g) = вҲ‘_q peterssonInner k fd (T_p f вҲЈ qвҒ»В№) (g вҲЈ qвҒ»В№)`,
producing the per-q union-tile decomposition with **uniform slot-2
= `g вҲЈ T_p_lower`** and **uniform combined-GL domain shape
`(glMap Оұ * mapGL qвҒ»В№) вҖў fd`**.

This is the entry point for the per-Оұ aggregate reduction: each per-q
summand has an M_вҲһ-tile `peterssonInner` plus a `Finset.range p`-union
tile `peterssonInner` (over the `T_p_upper` family), ready for q-aggregation
via `peterssonInner_iUnion_finite_aedisjoint`.

**Composes**:
1. `Finset.sum_congr` over `q : SL(2, в„Ө) в§ё О“вӮҒ(N)` to apply the per-q lemma.
2. Per-q lemma `peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form`,
   which itself composes the per-q distribution + union-tile collapse +
   slot-2 collapse to `g вҲЈ T_p_lower`. -/
private theorem petN_heckeT_p_eq_per_q_T_p_lower_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane))
        вҮ‘f (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) +
       peterssonInner k
        (вӢғ b вҲҲ Finset.range p,
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane))
        вҮ‘f (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ))) := by
  show вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k] ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k] ((q.out : SL(2, в„Ө))вҒ»В№)) = _
  refine Finset.sum_congr rfl fun q _ => ?_
  change peterssonInner k ModularGroup.fd
      (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
          GL (Fin 2) в„қ))
      (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
        GL (Fin 2) в„қ)) = _
  exact peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form
    p hp hpN (q.out : SL(2, в„Ө)) f g

