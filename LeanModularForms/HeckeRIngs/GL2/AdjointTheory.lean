open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 / T205 specialization to the T_p Hecke double-coset family.**

Concrete consumer of `peterssonInner_T_p_family_sum_slashes_eq_aggregate_of_integrable`
specialized to the `Option (Fin p) вҶ’ GL (Fin 2) в„қ` family:
* `none вҶҰ glMap (M_infty p)`
* `some b вҶҰ glMap (T_p_upper p b.val)`

with common adjoint RHS `вҮ‘g вҲЈ[k] (glMap (T_p_lower p))`.

**Hypotheses (all dischargeable from existing helpers at the call site):**
* `hm` (per-tile null-measurable): `вҲҖ i, NullMeasurableSet (...) Ој_hyp`.
* `h_int_per` (per-tile integrability): `вҲҖ i, IntegrableOn ...`.
* `hfi` (RHS biUnion integrability): `IntegrableOn (fun П„ => petersson k вҮ‘f
  (вҮ‘g вҲЈ[k] glMap T_p_lower) П„) (вӢғ i вҲҲ Finset.univ, ...)`.

**Discharged automatically:**
* `hОұ` (positive determinant): `glMap_M_infty_det_pos` + `glMap_T_p_upper_det_pos`.
* `hadj` (common adjoint = T_p_lower slash):
  `slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_lower` (M_вҲһ branch) +
  `slash_peterssonAdj_glMap_T_p_upper_eq_slash_T_p_lower` (upper-b branch).
* `hd` (pairwise AE-disjoint): `aedisjoint_pairwise_T_p_family`.

**Output.** The aggregate Hecke-FD form
```
peterssonInner k О“вӮҒ_FD (вҲ‘_{i вҲҲ Finset.univ} f вҲЈ[k] Оұ_i) g =
  peterssonInner k (вӢғ_{i вҲҲ Finset.univ} Оұ_i вҖў О“вӮҒ_FD) f (g вҲЈ[k] T_p_lower)
```
where Оұ_i ranges over the T_p Hecke double-coset family. -/
private theorem peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD
    {N : в„•} [NeZero N] (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (hm : вҲҖ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
      NullMeasurableSet ((match i with
        | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
        | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
        (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp)
    (h_int_per : вҲҖ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
      IntegrableOn (fun П„ => petersson k вҮ‘g
        (вҮ‘f вҲЈ[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ))) П„)
        (Gamma1_fundDomain_PSL N) Ој_hyp)
    (hfi : IntegrableOn (fun П„ => petersson k вҮ‘f
        (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N)
      (вҲ‘ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        вҮ‘f вҲЈ[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ))) вҮ‘g =
    peterssonInner k
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ))
      вҮ‘f
      (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) := by
  -- Factor the Hecke family once so the apply target uses a clean `Оұ i` shape.
  let Оұ : Option (Fin p) вҶ’ GL (Fin 2) в„қ := fun i => match i with
    | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
    | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)
  -- Establish the set equality between the dependent-union shape and the
  -- compact `вӢғ i вҲҲ s, Оұ i вҖў ...` shape via per-index case analysis.
  have hset_eq : (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) =
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ)) := by
    refine Set.iUnion_congr ?_
    intro i
    refine Set.iUnion_congr ?_
    intro _
    cases i <;> rfl
  -- Re-cast `hfi` into the compact `вӢғ i вҲҲ s, Оұ i вҖў ...` shape.
  have hfi_compact : IntegrableOn (fun П„ => petersson k вҮ‘f
        (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp := by
    rw [hset_eq]; exact hfi
  -- Local statement in compact form so the helper applies cleanly.
  have hmain : peterssonInner k (Gamma1_fundDomain_PSL N)
      (вҲ‘ i вҲҲ (Finset.univ : Finset (Option (Fin p))), вҮ‘f вҲЈ[k] Оұ i) вҮ‘g =
    peterssonInner k
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
      вҮ‘f
      (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) := by
    apply peterssonInner_T_p_family_sum_slashes_eq_aggregate_of_integrable
      (s := Finset.univ) (Оұ := Оұ) (f := f) (g := g)
      (g' := вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ))
    В· -- positive determinant
      intro i _
      cases i with
      | none => exact glMap_M_infty_det_pos N p hp.pos hpN
      | some b => exact glMap_T_p_upper_det_pos p hp.pos b.val
    В· -- common adjoint = T_p_lower slash
      intro i _
      cases i with
      | none => exact slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_lower p hp hpN g
      | some b => exact slash_peterssonAdj_glMap_T_p_upper_eq_slash_T_p_lower p hp.pos b.val g
    В· -- per-tile null-measurable
      exact hm
    В· -- pairwise AE-disjoint
      exact aedisjoint_pairwise_T_p_family p hp hpN
    В· -- per-tile integrability
      exact h_int_per
    В· -- biUnion integrability
      exact hfi_compact
  -- Close the original goal: rewrite the RHS union into the compact `Оұ i` form
  -- (via `hset_eq.symm`) and close by `hmain`.  The sum on the LHS aligns
  -- definitionally because `Оұ i` ОІ-reduces to the original `match i` form.
  rw [вҶҗ hset_eq]
  exact hmain

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **Phase F вҖ” projective T_p aggregate adapter for `Оұ_T_p_PSL_R`.**

Variant of `peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD` whose
biUnion (RHS Petersson integration domain) and per-tile measurability
hypothesis are stated in projective form via
`Оұ_T_p_PSL_R p hp hpN i вҖў Gamma1_fundDomain_PSL N`, matching the projective
FD-shift adapters from Phases AвҖ“E (`Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_auto`
and friends).

The slash-action LHS and per-tile integrability hypothesis remain in
`GL (Fin 2) в„қ` match-form, since `SlashAction` in mathlib is only registered
on `GL (Fin 2) в„қ` (and `SL(2, в„Ө)`); both are fed into the existing GL
consumer without further conversion.

**Proof.** Rewrite the projective biUnion via
`Оұ_T_p_PSL_R_biUnion_eq_match_GL_biUnion` and per-tile via
`Оұ_T_p_PSL_R_smul_set_eq_match_GL` to deliver to the existing GL-tile
consumer `peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD`.

**Use site.**  Direct consumer of `Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_auto`
+ `aedisjoint_pairwise_T_p_family_PSL_R` for the projective-aligned variant
of the `DSDoubleCosetTileBridge` aggregate-Hecke-FD identity. -/
private theorem peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD_PSL_R
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (hm : вҲҖ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
      NullMeasurableSet
        (Оұ_T_p_PSL_R p hp hpN i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp)
    (h_int_per : вҲҖ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
      IntegrableOn (fun П„ => petersson k вҮ‘g
        (вҮ‘f вҲЈ[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ))) П„)
        (Gamma1_fundDomain_PSL N) Ој_hyp)
    (hfi : IntegrableOn (fun П„ => petersson k вҮ‘f
        (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        Оұ_T_p_PSL_R p hp hpN i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N)
      (вҲ‘ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        вҮ‘f вҲЈ[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ))) вҮ‘g =
    peterssonInner k
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        Оұ_T_p_PSL_R p hp hpN i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
      вҮ‘f
      (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) := by
  -- biUnion bridge: projective вҶ” GL match form.
  have h_biUnion := Оұ_T_p_PSL_R_biUnion_eq_match_GL_biUnion (N := N) p hp hpN
    (Gamma1_fundDomain_PSL N : Set в„Қ)
  -- Per-tile measurability transfer (projective вҶ’ GL match-form).
  have hm_GL : вҲҖ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
      NullMeasurableSet ((match i with
        | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
        | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp := by
    intro i hi
    have h_per := Оұ_T_p_PSL_R_smul_set_eq_match_GL p hp hpN i
      (Gamma1_fundDomain_PSL N : Set в„Қ)
    rw [вҶҗ h_per]
    exact hm i hi
  -- Re-cast biUnion integrability into GL match-form.
  have hfi_GL : IntegrableOn (fun П„ => petersson k вҮ‘f
        (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ i вҲҲ (Finset.univ : Finset (Option (Fin p))),
        ((match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ))) Ој_hyp := by
    rw [вҶҗ h_biUnion]; exact hfi
  -- Apply the existing GL-tile consumer and rewrite the conclusion biUnion
  -- back to projective form.
  rw [h_biUnion]
  exact peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD
    p hp hpN f g hm_GL h_int_per hfi_GL

