    have hq_eq : (QuotientGroup.mk g : SL(2, тДд) тз╕ Gamma1 N) = QuotientGroup.mk gтВБ :=
      h_g.trans h_gтВБ.symm
    rw [QuotientGroup.eq] at hq_eq
    have : (gтВВ * gтВБтБ╗┬╣ * g)тБ╗┬╣ * gтВВ = gтБ╗┬╣ * gтВБ := by group
    rw [this]; exact hq_eq
  ┬╖ simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hq тКв
    induction q using QuotientGroup.induction_on with | _ g => ?_
    show slGamma_p_╬▒ToGamma1 (N := N) ╬▒ (QuotientGroup.mk (hтБ╗┬╣ * g)) = qтВБ'
    rw [slGamma_p_╬▒ToGamma1_mk]
