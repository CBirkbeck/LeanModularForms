      (QuotientGroup.mk (1 : SL(2, в„Ө)) : SL(2, в„Ө) в§ё Gamma1 N))).card

theorem slGamma_p_ОұToGamma1_fiberCard_eq (Оұ : GL (Fin 2) в„ҡ)
