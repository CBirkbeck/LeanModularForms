/-- **T106 helper: `glMap M_тИЮ` has positive determinant `p` in `GL (Fin 2) тДЭ`.** -/
theorem glMap_M_infty_det_pos
    (N p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) :
    0 < (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ).det.val := by
  show 0 < ((glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) :
    Matrix (Fin 2) (Fin 2) тДЭ).det
  rw [show ((glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ) =
      ((M_infty N p hp hpN : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
  rw [show (((M_infty N p hp hpN : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
    (algebraMap тДЪ тДЭ) (((M_infty N p hp hpN : GL (Fin 2) тДЪ).val).det) from
      (RingHom.map_det _ _).symm]
  -- det(M_тИЮ) in GL(Fin 2) тДЪ equals p (since M_тИЮ has det p by construction).
  have h_det_Q : ((M_infty N p hp hpN : GL (Fin 2) тДЪ).val).det = (p : тДЪ) := by
    have hmem := N_mul_mIdx_eq N p hpN
    simp only [M_infty_val, Matrix.det_fin_two_of]
    have hmem_q : ((N : тДд) * mIdxOfCoprime N p hpN : тДЪ) =
        (aInvOfCoprime N p hpN : тДд) * p - 1 := by exact_mod_cast hmem
    rw [hmem_q]
    ring
  rw [h_det_Q]
  show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
  rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
  exact_mod_cast hp

