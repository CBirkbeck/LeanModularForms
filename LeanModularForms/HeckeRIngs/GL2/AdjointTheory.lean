        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (qтВБ.out : SL(2, тДд))тБ╗┬╣ :
            GL (Fin 2) тДЭ)) тАв (ModularGroup.fd : Set тДН))
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (qтВВ.out : SL(2, тДд))тБ╗┬╣ :
            GL (Fin 2) тДЭ)) тАв (ModularGroup.fd : Set тДН))))
    (h_M_infty_meas : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      NullMeasurableSet
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
            GL (Fin 2) тДЭ)) тАв (ModularGroup.fd : Set тДН)) ╬╝_hyp)
    (h_M_infty_int : IntegrableOn
      (fun ╧Д => petersson k тЗСg
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
            GL (Fin 2) тДЭ)) тАв (ModularGroup.fd : Set тДН)) ╬╝_hyp)
    (h_upper_disj : тИА b тИИ Finset.range p,
      Pairwise (fun (qтВБ qтВВ : SL(2, тДд) тз╕ Gamma1 N) =>
        AEDisjoint ╬╝_hyp
          (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
