      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g) :
      CuspForm ((Gamma1 N).map (mapGL в„қ)) k) = g from by
    show diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (diamondOpCusp k (ZMod.unitOfCoprime p hpN) g) = g
    rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN) g) =
        ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№).comp
