    {╬╣ : Type*} [Fintype ╬╣] {T : Set UpperHalfPlane}
    (F : FiniteTileFundamentalDomain ╬╝_hyp ╬╣ T)
    (g_const : UpperHalfPlane тЖТ тДВ)
    (h_LHS_eq_target : peterssonInner k ModularGroup.fd
