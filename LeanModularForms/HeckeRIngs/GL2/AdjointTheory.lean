theorem peterssonInner_biUnion_finset_ae
    {О№ : Type*} (s : Finset О№) {D : О№ вҶ’ Set в„Қ}
    (hm : вҲҖ i вҲҲ s, NullMeasurableSet (D i) Ој_hyp)
    (hd : (вҶ‘s : Set О№).Pairwise (fun i j => AEDisjoint Ој_hyp (D i) (D j)))
