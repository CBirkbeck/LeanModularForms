/-- **T024 closed-form M_тИЮ branch per-tile match.**

Strict refinement of `peterssonInner_per_tile_match_M_infty_branch`: by **fixing
the bundle's slot-2 form to `g_const := g тИг (M_тИЮ * mapGL ╬│тВА)`**, this theorem
discharges:

* `h_╬▓_pos` (╬▓ positivity) inline тАФ `╬▓ = mapGL ╬│тВАтБ╗┬╣ * mapGL q.outтБ╗┬╣` is the
  cast of an `SL(2, тДд)` element, hence has determinant 1 > 0;
* `h_slash_slot2` (slot-2 matrix algebra) inline тАФ the matrix identity
  `(peterssonAdj ╬▓)тБ╗┬╣ = ╬▓` for `╬▓ тИИ image(mapGL тДЭ)` (via `peterssonAdj_inv_mapGL_SL_eq_self`)
  collapses the slot-2 slash to `g тИг (M_тИЮ * mapGL ╬│тВА * mapGL ╬│тВАтБ╗┬╣ * mapGL q.outтБ╗┬╣)`,
  which simplifies by `mapGL ╬│тВА * mapGL ╬│тВАтБ╗┬╣ = 1` to `g тИг (M_тИЮ * mapGL q.outтБ╗┬╣)`.

The **only remaining atomic input** is the tile-shape AE-equality `h_tile_eq`,
which is the genuine geometric content from the bundle's M_тИЮ-tile construction.

Composes upward into `peterssonInner_M_infty_T_p_upper_tile_sum_matches_per_q_distribute`'s
`h_tile_zero_match` directly, with `g_const := g тИг (M_тИЮ * mapGL ╬│тВА)`.

**Mathematical reference.**  DiamondтАУShurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b); Miyake ┬з4.5. -/
private theorem peterssonInner_per_tile_match_M_infty_branch_closed
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд) тз╕ Gamma1 N)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (F : UpperHalfPlane тЖТ тДВ)
    {tile_zero : Set UpperHalfPlane}
    (h_tile_eq : tile_zero =с╡Р[╬╝_hyp]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) тАв ModularGroup.fd) :
    peterssonInner k tile_zero F
      (тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
            GL (Fin 2) тДЭ))) =
      peterssonInner k ModularGroup.fd
        ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- ╬▓ positivity: ╬▓ = mapGL of SLтВВ(тДд) element, det = 1 > 0.
  have h_╬▓_pos : 0 < (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
        GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (q.out : SL(2, тДд))тБ╗┬╣)).det.val := by
    rw [тЖР map_mul]
    set ╬▒ := ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣ * (q.out : SL(2, тДд))тБ╗┬╣
    show 0 < ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬▒ : GL (Fin 2) тДЭ).val.det
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬▒ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix ╬▒.val) from by rw [mapGL_coe_matrix]; rfl,
      тЖР RingHom.map_det, ╬▒.property]
    norm_num
  -- Slot-2 algebra: (g тИг (M_тИЮ * mapGL ╬│тВА)) тИг (peterssonAdj ╬▓)тБ╗┬╣ = g тИг (M_тИЮ * mapGL q.outтБ╗┬╣).
  have h_slash_slot2 :
      (тЗСg тИг[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
              GL (Fin 2) тДЭ))) тИг[k]
        (peterssonAdj
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣)))тБ╗┬╣ =
      тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) := by
    rw [тЖР map_mul (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ),
      peterssonAdj_inv_mapGL_SL_eq_self, тЖР SlashAction.slash_mul, map_mul]
    congr 1
    rw [mul_assoc, тЖР mul_assoc ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) : GL (Fin 2) тДЭ),
      тЖР map_mul, mul_inv_cancel, map_one, one_mul]
  -- Apply the M_тИЮ branch theorem with the discharged hypotheses.
  exact peterssonInner_per_tile_match_M_infty_branch p hp hpN q g F
    (тЗСg тИг[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
          GL (Fin 2) тДЭ)))
    h_╬▓_pos h_tile_eq h_slash_slot2

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 closed-form `T_p_upper(b)` branch per-tile match.**

Symmetric `T_p_upper(b)`-analogue of
`peterssonInner_per_tile_match_M_infty_branch_closed`: by **fixing the bundle's
slot-2 form to `g_const_b := g тИг (T_p_upper(b) * mapGL ╬│тВА)`** (b-indexed but
q-independent), this theorem discharges ╬▓-positivity and slot-2 matrix algebra
inline using the same matrix identity `(peterssonAdj ╬▓)тБ╗┬╣ = ╬▓` for `╬▓` in the
image of `mapGL тДЭ` from `SL(2, тДд)` (via `peterssonAdj_inv_mapGL_SL_eq_self`).

The **only remaining atomic input** is the tile-shape AE-equality `h_tile_eq`
for the b-th T_p_upper tile.

Composes upward into `peterssonInner_M_infty_T_p_upper_tile_sum_matches_per_q_distribute`'s
`h_tile_succ_match b` directly, with `g_const_b := тЗСg тИг[k] (T_p_upper(b) * mapGL ╬│тВА)`.

**Mathematical reference.**  DiamondтАУShurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b); Miyake ┬з4.5. -/
private theorem peterssonInner_per_tile_match_T_p_upper_branch_closed
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : тДХ)
    (q : SL(2, тДд) тз╕ Gamma1 N)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (F : UpperHalfPlane тЖТ тДВ)
    {tile_b : Set UpperHalfPlane}
    (h_tile_eq : tile_b =с╡Р[╬╝_hyp]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) тАв ModularGroup.fd) :
    peterssonInner k tile_b F
      (тЗСg тИг[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
            GL (Fin 2) тДЭ))) =
      peterssonInner k ModularGroup.fd
        ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- ╬▓ positivity: ╬▓ = mapGL of SLтВВ(тДд) element, det = 1 > 0.
  have h_╬▓_pos : 0 < (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
        GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (q.out : SL(2, тДд))тБ╗┬╣)).det.val := by
    rw [тЖР map_mul]
    set ╬▒ := ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣ * (q.out : SL(2, тДд))тБ╗┬╣
    show 0 < ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬▒ : GL (Fin 2) тДЭ).val.det
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬▒ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix ╬▒.val) from by rw [mapGL_coe_matrix]; rfl,
      тЖР RingHom.map_det, ╬▒.property]
    norm_num
  -- Slot-2 algebra: (g тИг (T_p_upper(b) * mapGL ╬│тВА)) тИг (peterssonAdj ╬▓)тБ╗┬╣
  --              = g тИг (T_p_upper(b) * mapGL q.outтБ╗┬╣).
  have h_slash_slot2 :
      (тЗСg тИг[k]
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
              GL (Fin 2) тДЭ))) тИг[k]
        (peterssonAdj
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣)))тБ╗┬╣ =
      тЗСg тИг[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) := by
    rw [тЖР map_mul (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ),
      peterssonAdj_inv_mapGL_SL_eq_self, тЖР SlashAction.slash_mul, map_mul]
    congr 1
    rw [mul_assoc, тЖР mul_assoc ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) : GL (Fin 2) тДЭ),
      тЖР map_mul, mul_inv_cancel, map_one, one_mul]
  -- Apply the T_p_upper(b) branch theorem with the discharged hypotheses.
  exact peterssonInner_per_tile_match_T_p_upper_branch p hp hpN b q g F
    (тЗСg тИг[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
          GL (Fin 2) тДЭ)))
    h_╬▓_pos h_tile_eq h_slash_slot2

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 per-q distributed form via closed branches.**

Composes the **two closed branch theorems**
(`peterssonInner_per_tile_match_M_infty_branch_closed` and
`peterssonInner_per_tile_match_T_p_upper_branch_closed`) into the per-q
distributed RHS form expected by `petN_diamond_heckeT_p_symm_RHS_sum_distributed`.

Takes a tile family `tile : Fin (p + 1) тЖТ Set тДН` and a single AE-equality
hypothesis `h_tile_eq` covering all `p + 1` tiles (since by the closed-branch
construction all tiles share the same shift `╬▓ = mapGL ╬│тВАтБ╗┬╣ * mapGL q.outтБ╗┬╣`).

The LHS uses **per-tile g_const** values produced by the closed branches:
`g тИг (M_тИЮ * mapGL ╬│тВА)` for tile `0` and `g тИг (T_p_upper(b) * mapGL ╬│тВА)` for
tile `b.succ`. The RHS is the canonical per-q distributed form.

This is the **SMO-critical theorem-level deliverable** completing the per-q
DS adjoint chain: only the tile-shape AE equality remains as the genuine
geometric atomic input from the bundle's M_тИЮ/T_p_upper coset construction.

**Mathematical reference.**  DiamondтАУShurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b); Miyake ┬з4.5. -/
private theorem peterssonInner_per_q_distributed_form_via_closed_branches
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд) тз╕ Gamma1 N)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (F : UpperHalfPlane тЖТ тДВ)
    (tile : Fin (p + 1) тЖТ Set UpperHalfPlane)
    (h_tile_eq : тИА i : Fin (p + 1), tile i =с╡Р[╬╝_hyp]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) тАв ModularGroup.fd) :
    peterssonInner k (tile 0) F
      (тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
            GL (Fin 2) тДЭ))) +
      тИС b : Fin p, peterssonInner k (tile b.succ) F
        (тЗСg тИг[k]
          ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
              GL (Fin 2) тДЭ))) =
      peterssonInner k ModularGroup.fd
          ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣))
          (тЗСg тИг[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) +
        тИС b тИИ Finset.range p,
          peterssonInner k ModularGroup.fd
            ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
                GL (Fin 2) тДЭ)) тИг[k]
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣))
            (тЗСg тИг[k]
              ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  congr 1
  ┬╖ exact peterssonInner_per_tile_match_M_infty_branch_closed p hp hpN q g F
      (h_tile_eq 0)
  ┬╖ -- тИС b : Fin p, ... = тИС b тИИ range p, ...
    rw [show (тИС b : Fin p, peterssonInner k (tile b.succ) F
            (тЗСg тИг[k]
              ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
                  GL (Fin 2) тДЭ)))) =
        тИС b : Fin p, peterssonInner k ModularGroup.fd
          ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣))
          (тЗСg тИг[k]
            ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
      from Finset.sum_congr rfl fun b _ =>
        peterssonInner_per_tile_match_T_p_upper_branch_closed p hp hpN b.val q g F
          (h_tile_eq b.succ)]
    exact Fin.sum_univ_eq_sum_range
      (fun n : тДХ => peterssonInner k ModularGroup.fd
        ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (T_p_upper p hp.pos n) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) p

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 DS adjoint standard form via closed branches.**

End-of-chain SMO-critical consumer: composes
`peterssonInner_per_q_distributed_form_via_closed_branches` (per-`q` closed-
branch identity) with `petN_diamond_heckeT_p_symm_RHS_sum_distributed`
(`petN(тЯиpтЯй f, T_p g) = тИС_q [per-q distributed RHS]`) and the existing standard-
form-of-LHS-bridge consumer to produce the DS 5.5.3 standard form
`petN(T_p f, g) = petN(f, тЯиpтЯйтБ╗┬╣ T_p g)`.

Inputs (the irreducible atomic content of DS 5.5.2(b)):

* `tile : тИА q, Fin (p + 1) тЖТ Set тДН` тАФ the q-indexed tile family; the closed
  branches require all `p + 1` tiles to AE-equal `(╬│тВАтБ╗┬╣ * q.outтБ╗┬╣) тАв fd`
  (geometric content of the bundle's coset construction).
* `h_tile_eq` тАФ per-q, per-tile shape AE-equality.
* `h_LHS_eq_closed_branch_sum` тАФ the **LHS connection bridge**:
  `petN(T_p f, g)` equals the sum over `q` of the closed-branch LHS form
  (M_тИЮ branch + ╬г_b T_p_upper(b) branch with q-independent g_const but
  q-dependent tile shapes). This is the analytic content connecting petN to
  the bundle structure (typically discharged via the Q-reindex
  `petN_heckeT_p_adjointGamma0Rep_reindex` + per-q distribute machinery).

**Mathematical reference.**  DiamondтАУShurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b) and Thm. 5.5.3; Miyake ┬з4.5. -/
private theorem petN_heckeT_p_adjoint_standard_form_via_closed_branches
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (tile : SL(2, тДд) тз╕ Gamma1 N тЖТ Fin (p + 1) тЖТ Set UpperHalfPlane)
    (h_tile_eq : тИА q : SL(2, тДд) тз╕ Gamma1 N, тИА i : Fin (p + 1),
      tile q i =с╡Р[╬╝_hyp]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) тАв ModularGroup.fd)
    (h_LHS_eq_closed_branch_sum :
      petN (heckeT_p_cusp k p hp hpN f) g =
      тИС q : SL(2, тДд) тз╕ Gamma1 N,
        (peterssonInner k (tile q 0) тЗСf
            (тЗСg тИг[k]
              ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
                  GL (Fin 2) тДЭ))) +
          тИС b : Fin p, peterssonInner k (tile q b.succ) тЗСf
            (тЗСg тИг[k]
              ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) :
                  GL (Fin 2) тДЭ))))) :
    petN (heckeT_p_cusp k p hp hpN f) g =
      petN f (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
        (heckeT_p_cusp k p hp hpN g)) := by
  refine petN_heckeT_p_adjoint_standard_form_of_LHS_bridge p hp hpN f g ?_
  rw [h_LHS_eq_closed_branch_sum,
    petN_diamond_heckeT_p_symm_RHS_sum_distributed p hp hpN f g]
  refine Finset.sum_congr rfl fun q _ => ?_
  exact peterssonInner_per_q_distributed_form_via_closed_branches p hp hpN q g тЗСf
    (tile q) (h_tile_eq q)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 LHS bridge from per-q to global closed-branch sum.**

Aggregator: lifts per-`q` LHS connection identifications to the **global**
`h_LHS_eq_closed_branch_sum` hypothesis required by
`petN_heckeT_p_adjoint_standard_form_via_closed_branches`.

The per-`q` connection equates the petN-summand at `q` (i.e.,
`peterssonInner k fd (тЗС(T_p f) тИг[k] q.outтБ╗┬╣) (тЗСg тИг[k] q.outтБ╗┬╣)`) to the
closed-branch LHS form at `q` (M_тИЮ branch + ╬г_b T_p_upper(b) branch with the
q-independent g_const choices `g тИг (M_тИЮ * ╬│тВА)` and `g тИг (T_p_upper(b) * ╬│тВА)`).

This is the **theorem-level connector** isolating the per-`q` analytic content
of DS 5.5.2(b): the bridge between the per-q DS p+1 family union collapse
(`peterssonInner_heckeT_p_LHS_per_q_to_union_tiles` at `q.out`) and the
closed-branch sum form is the single named hypothesis `h_per_q_LHS_eq_closed_branch_sum`.

**Proof.** Definitional unfold of `petN(T_p f, g)` to its `тИС_q` form at
`q.out`-coset reps, then `Finset.sum_congr` over `q` discharged by
`h_per_q_LHS_eq_closed_branch_sum` per q. -/
private theorem petN_LHS_eq_closed_branch_sum_via_per_q
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (tile : SL(2, тДд) тз╕ Gamma1 N тЖТ Fin (p + 1) тЖТ Set UpperHalfPlane)
    (h_per_q_LHS_eq_closed_branch_sum : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
