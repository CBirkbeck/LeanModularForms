/-- **T094: `╬╝_hyp` is invariant under positive-det `GL (Fin 2) тДЭ` translates.**

Uses the `(╬▒тБ╗┬╣ тАв ┬╖)` preimage formula and `MeasurePreserving.measure_preimage` on
the GL(2, тДЭ)тБ║ lift. -/
theorem measure_glPos_smul_eq (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    {S : Set тДН} (hS : NullMeasurableSet S ╬╝_hyp) :
    ╬╝_hyp (╬▒ тАв S) = ╬╝_hyp S := by
  -- Positive det of ╬▒тБ╗┬╣.
  have h╬▒_inv : 0 < (╬▒тБ╗┬╣ : GL (Fin 2) тДЭ).det.val := by
    show 0 < (((╬▒тБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show ((╬▒тБ╗┬╣ : GL (Fin 2) тДЭ)).det = ╬▒.detтБ╗┬╣ from map_inv _ _,
      Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h╬▒
  have h_mp_inv := measurePreserving_glPos_smul ╬▒тБ╗┬╣ h╬▒_inv
  -- (╬▒тБ╗┬╣ тАв ┬╖) тБ╗┬╣' S = ╬▒ тАв S.
  have h_eq : ((╬▒тБ╗┬╣ тАв ┬╖) : тДН тЖТ тДН) тБ╗┬╣' S = ╬▒ тАв S := by
    ext ╧Д; simp [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  rw [тЖР h_eq]
  exact h_mp_inv.measure_preimage hS

