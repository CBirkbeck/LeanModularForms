`slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per `b` to the upper-b
summand-1 slashes, and the diamond expansion `тЗС(тЯиuтБ╗┬╣тЯй g) = тЗСg тИг mapGL ╬│тВА`
on the slot-2 slash via `slash_mul`.

Result: `petN(T_p f, g) = тИС_q [diamond-exposed shifted-tile residual at q.out]`
with f-slot in `тЗСf тИг (T_p_lower * mapGL ╬│_X * mapGL qтБ╗┬╣)` form (╬│_X is the
ds_p_plus_one ╬УтВБ(N) factor for branch X) and g-slot in
`тЗСg тИг (mapGL ╬│тВА * mapGL qтБ╗┬╣)` form.

**Role in T024 closure.**  This is the LHS-side mirror of
`petN_diamond_heckeT_p_symm_RHS_sum_distributed` (RHS analog at line 4516).
Together with a sum-level ╧Г_p / ╬│тВА-coset Q-reindex bridging this to the
existing RHS-side distributed sum, it yields the LHS double-coset bridge
`petN(T_p f, g) = petN(тЯиuтЯй f, T_p g)` consumable by
`petN_heckeT_p_adjoint_standard_form_of_LHS_bridge`. -/
private lemma petN_T_p_heckeT_p_LHS_sum_diamond_distributed
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      (peterssonInner k ModularGroup.fd
          (тЗСf тИг[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
          (тЗСg тИг[k]
            (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) +
        тИС b тИИ Finset.range p,
          peterssonInner k ModularGroup.fd
            (тЗСf тИг[k]
              ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
            (тЗСg тИг[k]
              (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) := by
  -- Q-reindex first: `petN(T_p f, g) = petN(T_p(тЯиuтБ╗┬╣тЯй f), тЯиuтБ╗┬╣тЯй g)`.
  rw [petN_heckeT_p_adjointGamma0Rep_reindex p hp hpN f g]
  -- Sum-level distribute on the reindexed form.
  rw [petN_T_p_heckeT_p_LHS_sum_distributed p hp hpN
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)]
  -- Per-q: rewrite each branch via the diamond/T_p_lower factorization
  -- helpers (`slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` for the M_тИЮ
  -- branch slot-1, `slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per b
  -- for the upper-family summands), and expose `тЗС(тЯиuтБ╗┬╣тЯй g) тИг mapGL qтБ╗┬╣` as
  -- `тЗСg тИг mapGL ╬│тВА * mapGL qтБ╗┬╣` via `diamondOpCusp_eq` + `slash_mul`.
  refine Finset.sum_congr rfl fun q _ => ?_
  -- Diamond expansion of slot-2 g side: `тЗС(тЯиuтБ╗┬╣тЯй g) = тЗСg тИг mapGL ╬│тВА`.
  have h_diamond_g : (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) :
      UpperHalfPlane тЖТ тДВ) =
      тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) := by
    show тЗС(diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  congr 1
  ┬╖ -- M_тИЮ branch.  Slot 1 via `slash_diamond_inv_M_infty_eq_T_p_lower_epsilon`
    -- applied to `f`.  Slot 2 via `h_diamond_g` + `slash_mul`.
    rw [slash_diamond_inv_M_infty_eq_T_p_lower_epsilon p hp hpN
      (q.out : SL(2, тДд)) f]
    rw [show (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) =
      тЗСg тИг[k]
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) from by
      rw [h_diamond_g, тЖР SlashAction.slash_mul]]
  ┬╖ -- Upper branches `тИС_b`.  Slot 1 via
    -- `slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per b, slot 2 same as
    -- M_тИЮ branch.
    refine Finset.sum_congr rfl fun b _ => ?_
    rw [slash_diamond_inv_T_p_upper_eq_T_p_lower_delta p hp hpN b
      (q.out : SL(2, тДд)) f]
    rw [show (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣)) =
      тЗСg тИг[k]
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) from by
      rw [h_diamond_g, тЖР SlashAction.slash_mul]]

/-- **T128 RHS-side bridge, unsymmetric form**: derived from
`petN_diamond_heckeT_p_eq_canonical_RHS` by `T_p`/diamond commutation on
