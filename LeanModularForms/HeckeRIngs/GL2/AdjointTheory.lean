/-!
# Hecke adjoint theory and eigenform diagonalization

This file develops the adjoint theory of Hecke operators with respect to the
Petersson inner product, culminating in the existence of a simultaneous
eigenform basis for cusp form spaces.

## Main results

* `heckeT_p_adjoint` вҖ” T_p* = вҹЁpвҹ©вҒ»В№ T_p (DiamondвҖ“Shurman Thm 5.5.3)
* `diamondOp_petersson_unitary` вҖ” `вҹЁdвҹ©` is unitary for pet
* `heckeT_n_petersson_normal` вҖ” T_n is normal
* `exists_simultaneous_eigenform_basis` вҖ” spectral theorem for Hecke operators

## References

* [DS] DiamondвҖ“Shurman, *A First Course in Modular Forms*, В§5.5
* [Miy] Miyake, *Modular Forms*, В§4.5 (Thm 4.5.4вҖ“4.5.5)
-/

noncomputable section

open CongruenceSubgroup Matrix.SpecialLinearGroup
open scoped Pointwise MatrixGroups ModularForm

variable {k : в„Ө}

/-! ### CuspForm вҶӘ ModularForm coercion

In Mathlib, `CuspForm` and `ModularForm` are parallel structures over
`SlashInvariantForm`. A cusp form is also a modular form since
`IsZeroAt вҶ’ IsBoundedAt`. -/

namespace CuspForm

/-- Every cusp form is a modular form (zero at cusps implies bounded at cusps). -/
def toModularForm' {О“ : Subgroup (GL (Fin 2) в„қ)}
    (f : CuspForm О“ k) : ModularForm О“ k where
  toSlashInvariantForm := f.toSlashInvariantForm
  holo' := f.holo'
  bdd_at_cusps' hc g hg := (f.zero_at_cusps' hc g hg).boundedAtFilter

end CuspForm

namespace HeckeRing.GL2

open CuspForm

variable {N : в„•} [NeZero N]

/-! ### Hecke operators on cusp forms

The Hecke operators preserve cuspidality вҖ” `IsZeroAt` is preserved by
the coset-sum construction. -/

/-- `GLвӮӮ(в„ҡ)` maps cusps of `О“вӮҒ(N)` to cusps of `О“вӮҒ(N)`. -/
private lemma Gamma1_isCusp_glMap_smul' (A : GL (Fin 2) в„ҡ) {c : OnePoint в„қ}
    (hc : IsCusp c ((Gamma1 N).map (mapGL в„қ))) :
    IsCusp (glMap A вҖў c) ((Gamma1 N).map (mapGL в„қ)) := by
  have hc_SL : IsCusp c ((вҠӨ : Subgroup SL(2, в„Ө)).map (mapGL в„қ)) :=
    hc.mono (Subgroup.map_mono le_top)
  rw [вҶҗ MonoidHom.range_eq_map] at hc_SL
  have hsmul_SL : IsCusp (glMap A вҖў c) (mapGL в„қ : SL(2, в„Ө) вҶ’* _).range := by
    rw [isCusp_SL2Z_iff] at hc_SL вҠў
    obtain вҹЁq, rflвҹ© := hc_SL
    refine вҹЁA вҖў q, ?_вҹ©
    show OnePoint.map (algebraMap в„ҡ в„қ) (A вҖў q) =
      glMap A вҖў OnePoint.map (algebraMap в„ҡ в„қ) q
    simp [OnePoint.map_smul, glMap]
  rw [MonoidHom.range_eq_map] at hsmul_SL
  haveI : ((Gamma1 N).map (mapGL в„қ)).IsFiniteRelIndex
      ((вҠӨ : Subgroup SL(2, в„Ө)).map (mapGL в„қ)) := вҹЁby
    rw [Subgroup.relIndex_map_map_of_injective _ _ mapGL_injective,
        Subgroup.relIndex_top_right]
    exact Subgroup.FiniteIndex.index_ne_zeroвҹ©
  exact hsmul_SL.of_isFiniteRelIndex

/-- `T_p` preserves cuspidality. -/
theorem heckeT_p_zero_at_cusps (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    {c : OnePoint в„қ} (hc : IsCusp c ((Gamma1 N).map (mapGL в„қ))) :
    c.IsZeroAt (heckeT_p k p hp hpN f.toModularForm').toFun k := by
  show c.IsZeroAt (heckeT_p_fun k p hp hpN f.toModularForm') k
  simp only [heckeT_p_fun, heckeT_p_ut]
  apply OnePoint.IsZeroAt.add
  В· apply Finset.sum_induction _ (fun g => c.IsZeroAt g k)
      (fun _ _ ha hb => ha.add hb)
      ((0 : CuspForm ((Gamma1 N).map (mapGL в„қ)) k).zero_at_cusps' hc)
    intro b _
    exact OnePoint.IsZeroAt.smul_iff.mp
      (f.zero_at_cusps' (Gamma1_isCusp_glMap_smul' _ hc))
  В· -- Diamond operator term: (вҹЁpвҹ©f) вҲЈ[k] T_p_lower
    -- Unfold IsZeroAt: need to show IsZeroAtImInfty for each Оі with Оі вҖў вҲһ = c
    intro Оі hОі
    -- Convert the GLвӮӮ(в„ҡ) slash to GLвӮӮ(в„қ) so we can combine with the GLвӮӮ(в„қ) slash by Оі
    show UpperHalfPlane.IsZeroAtImInfty
      ((вҮ‘((diamondOp k (ZMod.unitOfCoprime p hpN)) f.toModularForm') вҲЈ[k]
        glMap (T_p_lower p hp.pos)) вҲЈ[k] Оі)
    rw [вҶҗ SlashAction.slash_mul]
    -- Unfold diamondOp to expose вҮ‘f вҲЈ[k] mapGL в„қ g, then combine slashes
    set g := (Gamma0MapUnits_surjective (ZMod.unitOfCoprime p hpN)).choose
    change UpperHalfPlane.IsZeroAtImInfty
      ((вҮ‘f.toModularForm' вҲЈ[k] mapGL в„қ (g : SL(2, в„Ө))) вҲЈ[k]
        (glMap (T_p_lower p hp.pos) * Оі))
    rw [вҶҗ SlashAction.slash_mul]
    -- Goal: IsZeroAtImInfty (вҮ‘f вҲЈ[k] (mapGL в„қ g * (glMap T_p_lower * Оі)))
    -- The combined element sends вҲһ to mapGL в„қ g вҖў glMap T_p_lower вҖў c
    -- Show mapGL в„қ g вҖў (glMap T_p_lower вҖў c) is a О“вӮҒ-cusp
    have hc_lower : IsCusp (glMap (T_p_lower p hp.pos) вҖў c)
        ((Gamma1 N).map (mapGL в„қ)) := Gamma1_isCusp_glMap_smul' _ hc
    -- mapGL в„қ g preserves О“вӮҒ-cusps by О“вӮҖ-normality of О“вӮҒ
    have hconj : ConjAct.toConjAct (mapGL в„қ (g : SL(2, в„Ө))) вҖў
        (Gamma1 N).map (mapGL в„қ) = (Gamma1 N).map (mapGL в„қ) := by
      have := Gamma1_map_conjAct_eq вҹЁ(g : SL(2, в„Ө))вҒ»В№, (Gamma0 N).inv_mem g.propertyвҹ©
      simpa [map_inv, ConjAct.toConjAct_inv, inv_inv, inv_smul_eq_iff] using this
    have hcusp : IsCusp (mapGL в„қ (g : SL(2, в„Ө)) вҖў glMap (T_p_lower p hp.pos) вҖў c)
        ((Gamma1 N).map (mapGL в„қ)) :=
      hconj в–ё hc_lower.smul (mapGL в„қ (g : SL(2, в„Ө)))
    apply f.zero_at_cusps' hcusp
    have hmul : (mapGL в„қ (g : SL(2, в„Ө)) * (glMap (T_p_lower p hp.pos) * Оі)) вҖў
        (OnePoint.infty : OnePoint в„қ) =
      mapGL в„қ (g : SL(2, в„Ө)) вҖў glMap (T_p_lower p hp.pos) вҖў c := by
      simp [SemigroupAction.mul_smul, hОі]
    exact hmul

/-- `T_p` restricted to cusp forms. -/
def heckeT_p_cusp (k : в„Ө) (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    CuspForm ((Gamma1 N).map (mapGL в„қ)) k where
  toSlashInvariantForm := (heckeT_p k p hp hpN f.toModularForm').toSlashInvariantForm
  holo' := (heckeT_p k p hp hpN f.toModularForm').holo'
  zero_at_cusps' := heckeT_p_zero_at_cusps p hp hpN f

/-- `вҹЁdвҹ©` restricted to cusp forms. -/
def diamondOp_cusp (k : в„Ө) (d : (ZMod N)ЛЈ)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    CuspForm ((Gamma1 N).map (mapGL в„қ)) k :=
  diamondOpCusp k d f

/-- `T_p` (for all primes, including `p | N`) preserves cuspidality. -/
private theorem heckeT_p_all_zero_at_cusps (p : в„•) (hp : Nat.Prime p)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    {c : OnePoint в„қ} (hc : IsCusp c ((Gamma1 N).map (mapGL в„қ))) :
    c.IsZeroAt ((heckeT_p_all k p hp) f.toModularForm').toFun k := by
  unfold heckeT_p_all
  split
  В· exact heckeT_p_zero_at_cusps p hp вҖ№_вҖә f hc
  В· rename_i hpN
    show c.IsZeroAt (heckeT_p_ut k p hp.pos (вҮ‘f.toModularForm')) k
    simp only [heckeT_p_ut]
    apply Finset.sum_induction _ (fun g => c.IsZeroAt g k)
      (fun _ _ ha hb => ha.add hb)
      ((0 : CuspForm ((Gamma1 N).map (mapGL в„қ)) k).zero_at_cusps' hc)
    intro b _
    exact OnePoint.IsZeroAt.smul_iff.mp
      (f.zero_at_cusps' (Gamma1_isCusp_glMap_smul' _ hc))

/-- A `Module.End` on `ModularForm` preserves cuspidality if its output function
is zero at cusps for every cusp form input. This packages the zero-at-cusps
property for arbitrary `Module.End` operators built from cuspidality-preserving
components. -/
private def PreservesCusps (T : Module.End в„Ӯ (ModularForm ((Gamma1 N).map (mapGL в„қ)) k)) :
    Prop :=
  вҲҖ (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) {c : OnePoint в„қ},
    IsCusp c ((Gamma1 N).map (mapGL в„қ)) вҶ’ c.IsZeroAt (T f.toModularForm').toFun k

omit [NeZero N] in
private theorem preservesCusps_one :
    PreservesCusps (N := N) (k := k) 1 :=
  fun f _ hc => by simp; exact f.zero_at_cusps' hc

private theorem preservesCusps_heckeT_p_all (p : в„•) (hp : Nat.Prime p) :
    PreservesCusps (N := N) (heckeT_p_all k p hp) :=
  fun f _ hc => heckeT_p_all_zero_at_cusps p hp f hc

private theorem preservesCusps_diamondOp_ext (p : в„•) :
    PreservesCusps (N := N) (diamondOp_ext k p) := by
  intro f c hc
  unfold diamondOp_ext
  split
  В· exact (diamondOpCusp k (ZMod.unitOfCoprime p вҖ№_вҖә) f).zero_at_cusps' hc
  В· show c.IsZeroAt ((0 : ModularForm ((Gamma1 N).map (mapGL в„қ)) k).toFun) k
    exact (0 : CuspForm ((Gamma1 N).map (mapGL в„қ)) k).zero_at_cusps' hc

omit [NeZero N] in
private theorem preservesCusps_mul {TвӮҒ TвӮӮ : Module.End в„Ӯ (ModularForm ((Gamma1 N).map (mapGL в„қ)) k)}
    (hвӮҒ : PreservesCusps TвӮҒ) (hвӮӮ : PreservesCusps TвӮӮ) :
    PreservesCusps (TвӮҒ * TвӮӮ) := by
  intro f c hc
  show c.IsZeroAt (TвӮҒ (TвӮӮ f.toModularForm')).toFun k
  -- TвӮӮ f.toModularForm' is a modular form whose toFun is zero at cusps (by hвӮӮ)
  -- So we can wrap it as a cusp form, then apply hвӮҒ
  let g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k :=
    { toSlashInvariantForm := (TвӮӮ f.toModularForm').toSlashInvariantForm
      holo' := (TвӮӮ f.toModularForm').holo'
      zero_at_cusps' := hвӮӮ f }
  exact hвӮҒ g hc

omit [NeZero N] in
private theorem preservesCusps_sub {TвӮҒ TвӮӮ : Module.End в„Ӯ (ModularForm ((Gamma1 N).map (mapGL в„қ)) k)}
    (hвӮҒ : PreservesCusps TвӮҒ) (hвӮӮ : PreservesCusps TвӮӮ) :
    PreservesCusps (TвӮҒ - TвӮӮ) := by
  intro f c hc
  -- Wrap TвӮҒ f and TвӮӮ f as cusp forms
  let gвӮҒ : CuspForm ((Gamma1 N).map (mapGL в„қ)) k :=
    { toSlashInvariantForm := (TвӮҒ f.toModularForm').toSlashInvariantForm
      holo' := (TвӮҒ f.toModularForm').holo'
      zero_at_cusps' := hвӮҒ f }
  let gвӮӮ : CuspForm ((Gamma1 N).map (mapGL в„қ)) k :=
    { toSlashInvariantForm := (TвӮӮ f.toModularForm').toSlashInvariantForm
      holo' := (TвӮӮ f.toModularForm').holo'
      zero_at_cusps' := hвӮӮ f }
  -- (TвӮҒ - TвӮӮ) f = TвӮҒ f - TвӮӮ f as modular forms, and gвӮҒ - gвӮӮ is a cusp form
  have hfun : ((TвӮҒ - TвӮӮ) f.toModularForm').toFun = (gвӮҒ - gвӮӮ).toFun := rfl
  rw [hfun]
  exact (gвӮҒ - gвӮӮ).zero_at_cusps' hc

omit [NeZero N] in
private theorem preservesCusps_smul (a : в„Ӯ) {T : Module.End в„Ӯ (ModularForm ((Gamma1 N).map (mapGL в„қ)) k)}
    (hT : PreservesCusps T) :
    PreservesCusps (a вҖў T) := by
  intro f c hc
  -- (a вҖў T) f = a вҖў (T f) as modular forms
  show c.IsZeroAt ((a вҖў T f.toModularForm').toFun) k
  have hfun : (a вҖў T f.toModularForm').toFun = a вҖў (T f.toModularForm').toFun := by
    ext z; exact ModularForm.IsGLPos.smul_apply (T f.toModularForm') a z
  rw [hfun]
  intro g hg
  rw [ModularForm.smul_slash k g (T f.toModularForm').toFun a]
  exact (hT f hc g hg).smul (UpperHalfPlane.Пғ g a)

private theorem preservesCusps_heckeT_ppow (p : в„•) (hp : Nat.Prime p) :
    вҲҖ r : в„•, PreservesCusps (N := N) (heckeT_ppow k p hp r) := by
  intro r
  induction r using Nat.strong_induction_on with
  | _ r ih =>
    match r with
    | 0 => exact preservesCusps_one
    | 1 => exact preservesCusps_heckeT_p_all p hp
    | r + 2 =>
      rw [heckeT_ppow_succ_succ]
      exact preservesCusps_sub
        (preservesCusps_mul (preservesCusps_heckeT_p_all p hp) (ih (r + 1) (by omega)))
        (preservesCusps_smul _ (preservesCusps_mul (preservesCusps_diamondOp_ext p)
          (ih r (by omega))))

private theorem preservesCusps_heckeT_n (n : в„•) [NeZero n] :
    PreservesCusps (N := N) (k := k) (heckeT_n k n) := by
  -- heckeT_n k n = heckeT_n_aux k n, so it suffices to prove the aux version by induction
  show PreservesCusps (heckeT_n_aux k n)
  induction n using Nat.strong_induction_on with
  | _ m ih =>
    rw [heckeT_n_aux]
    split_ifs with hle
    В· exact preservesCusps_one
    В· push_neg at hle
      apply preservesCusps_mul (preservesCusps_heckeT_ppow m.minFac
        (Nat.minFac_prime (by omega)) _)
      exact ih _ (heckeT_n_unfold_lt m hle)

/-- `T_n` restricted to cusp forms. -/
def heckeT_n_cusp (k : в„Ө) (n : в„•) [NeZero n]
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    CuspForm ((Gamma1 N).map (mapGL в„қ)) k where
  toSlashInvariantForm := (heckeT_n k n f.toModularForm').toSlashInvariantForm
  holo' := (heckeT_n k n f.toModularForm').holo'
  zero_at_cusps' := fun hc => preservesCusps_heckeT_n n f hc

/-- Function-level decomposition for `heckeT_n_cusp`:
`T_m f = T_{p^v}(T_{m/p^v} f)` at each point. -/
theorem heckeT_n_cusp_unfold (m : в„•) [NeZero m] (hm : 1 < m)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) (z : UpperHalfPlane) :
    let p := m.minFac
    let hp := Nat.minFac_prime (by omega : m вү  1)
    let v := m.factorization p
    have : NeZero (p ^ v) := вҹЁ(pow_pos hp.pos v).ne'вҹ©
    have : NeZero (m / p ^ v) := вҹЁ(Nat.div_pos (Nat.le_of_dvd (by omega)
      (Nat.ordProj_dvd m p)) (pow_pos hp.pos v)).ne'вҹ©
    (heckeT_n_cusp k m f) z =
      (heckeT_n_cusp k (p ^ v) (heckeT_n_cusp k (m / p ^ v) f)) z := by
  have hp' := Nat.minFac_prime (show m вү  1 by omega)
  have hv_pos := hp'.factorization_pos_of_dvd (by omega) (Nat.minFac_dvd m)
  haveI : NeZero (m.minFac ^ m.factorization m.minFac) := вҹЁ(pow_pos hp'.pos _).ne'вҹ©
  haveI : NeZero (m / m.minFac ^ m.factorization m.minFac) :=
    вҹЁ(Nat.div_pos (Nat.le_of_dvd (by omega) (Nat.ordProj_dvd m m.minFac))
      (pow_pos hp'.pos _)).ne'вҹ©
  -- Work at heckeT_n_aux level
  show (heckeT_n_aux k m f.toModularForm').toFun z =
    (heckeT_n_aux k _ (heckeT_n_aux k _ f.toModularForm')).toFun z
  rw [heckeT_n_aux, dif_neg (not_le.mpr hm), Module.End.mul_apply]
  -- LHS: heckeT_ppow(heckeT_n_aux(m/p^v)(f)).toFun z
  -- RHS: heckeT_n_aux(p^v)(heckeT_n_aux(m/p^v)(f)).toFun z
  -- heckeT_ppow = heckeT_n вҹЁp^v, _вҹ© = heckeT_n_aux(p^v) by prime_pow
  conv_lhs => rw [show heckeT_ppow (N := N) k m.minFac hp' (m.factorization m.minFac) =
      heckeT_n_aux k (m.minFac ^ m.factorization m.minFac) from
    (heckeT_n_prime_pow k hp' _ hv_pos).symm]

@[simp]
theorem heckeT_n_cusp_toModularForm' (n : в„•) [NeZero n]
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (heckeT_n_cusp k n f).toModularForm' = heckeT_n k n f.toModularForm' := by
  apply DFunLike.ext; intro П„; rfl

variable (N) in
/-- `heckeT_n` decomposes into prime-power * quotient, with explicit arguments. -/
theorem heckeT_n_mul_ppow_quot [NeZero N] (m : в„•) [NeZero m] (hm : 1 < m)
    (p : в„•) (hp : Nat.Prime p)
    (hmp : p = m.minFac) (v : в„•) (hmv : v = m.factorization p)
    (hv_pos : 0 < v) (hdiv_pos : 0 < m / p ^ v) :
    haveI : NeZero (p ^ v) := вҹЁ(pow_pos hp.pos v).ne'вҹ©
    haveI : NeZero (m / p ^ v) := вҹЁhdiv_pos.ne'вҹ©
    heckeT_n (N := N) k m =
      heckeT_n (N := N) k (p ^ v) *
        heckeT_n (N := N) k (m / p ^ v) := by
  haveI : NeZero (p ^ v) := вҹЁ(pow_pos hp.pos v).ne'вҹ©
  haveI : NeZero (m / p ^ v) := вҹЁhdiv_pos.ne'вҹ©
  subst hmp; subst hmv
  have h := heckeT_n_unfold (N := N) k m hm
  simp only [h]
  -- Goal: heckeT_ppow * heckeT_n = heckeT_n * heckeT_n
  congr 1
  exact (heckeT_n_prime_pow k (Nat.minFac_prime (by omega : m вү  1)) _
    ((Nat.minFac_prime (by omega : m вү  1)).factorization_pos_of_dvd (by omega)
      (Nat.minFac_dvd m))).symm

/-- `heckeT_n_cusp` decomposes as composition at each point:
`(T_n f)(z) = (T_{nвӮҒ}(T_{nвӮӮ} f))(z)` when `heckeT_n k n = heckeT_n k nвӮҒ * heckeT_n k nвӮӮ`
at the Module.End level. -/
theorem heckeT_n_cusp_mul_apply (nвӮҒ nвӮӮ : в„•) [NeZero nвӮҒ] [NeZero nвӮӮ]
    (h_eq : haveI : NeZero (nвӮҒ * nвӮӮ) := вҹЁNat.mul_pos (NeZero.pos nвӮҒ) (NeZero.pos nвӮӮ) |>.ne'вҹ©
            heckeT_n (N := N) k (nвӮҒ * nвӮӮ) = heckeT_n k nвӮҒ * heckeT_n k nвӮӮ)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (z : UpperHalfPlane) :
    haveI : NeZero (nвӮҒ * nвӮӮ) := вҹЁNat.mul_pos (NeZero.pos nвӮҒ) (NeZero.pos nвӮӮ) |>.ne'вҹ©
    (heckeT_n_cusp k (nвӮҒ * nвӮӮ) f) z =
      (heckeT_n_cusp k nвӮҒ (heckeT_n_cusp k nвӮӮ f)) z := by
  haveI : NeZero (nвӮҒ * nвӮӮ) := вҹЁNat.mul_pos (NeZero.pos nвӮҒ) (NeZero.pos nвӮӮ) |>.ne'вҹ©
  show (heckeT_n k (nвӮҒ * nвӮӮ) f.toModularForm').toFun z =
    (heckeT_n k nвӮҒ (heckeT_n k nвӮӮ f.toModularForm')).toFun z
  rw [h_eq]; rfl

/-! ### Double coset identity for the adjoint (DS Theorem 5.5.3, algebraic part)

For `p` coprime to `N`, choose `m, n вҲҲ в„Ө` with `mp - nN = 1` (Bezout).
Then the matrix factorization `[p,0;0,1] = [1,n;N,mp]вҒ»В№ В· [1,0;0,p] В· [p,n;N,m]`
(where `[1,n;N,mp] вҲҲ О“вӮҒ(N)` and `[p,n;N,m] вҲҲ О“вӮҖ(N)` with `m вүЎ pвҒ»В№ mod N`)
gives the double coset identity:

  `О“вӮҒ(N) [p,0;0,1] О“вӮҒ(N) = О“вӮҒ(N) [1,0;0,p] О“вӮҒ(N) В· ОівӮҖ`

where `ОівӮҖ = [p,n;N,m]` represents `вҹЁpвҒ»В№вҹ©`. This is the algebraic heart of
`T_p* = вҹЁpвҹ©вҒ»В№ T_p`. -/

/-- The О“вӮҖ(N) representative for the T_p adjoint double coset.

Given `p` coprime to `N`, use Bezout to find `m, n` with `mp - nN = 1`,
and construct `ОівӮҖ = [p, n; N, m] вҲҲ О“вӮҖ(N)` with `m вүЎ pвҒ»В№ mod N`.
This is the element from DS Theorem 5.5.3 that relates
`О“вӮҒ(N)[p,0;0,1]О“вӮҒ(N) = О“вӮҒ(N)[1,0;0,p]О“вӮҒ(N) В· ОівӮҖ`. -/
private noncomputable def adjointGamma0Rep (p N : в„•) (hpN : Nat.Coprime p N) :
    вҶҘ(Gamma0 N) :=
  -- Use Bezout: gcdA(p,N) * p + gcdB(p,N) * N = gcd(p,N) = 1
  -- Build [p, -gcdB; N, gcdA] вҲҲ О“вӮҖ(N). det = pВ·gcdA + NВ·gcdB = 1.
  let m := Int.gcdA p N
  let n := -(Int.gcdB p N)
  вҹЁвҹЁ!![(p : в„Ө), n; (N : в„Ө), m], by
      -- det = p * m - n * N = p * gcdA + gcdB * N = 1 (Bezout)
      have hbez := Int.gcd_eq_gcd_ab p N
      rw [show (Int.gcd (вҶ‘p) (вҶ‘N) : в„Ө) = 1 from by exact_mod_cast hpN] at hbez
      simp only [Matrix.det_fin_two_of]
      linarithвҹ©, by
      -- О“вӮҖ(N) membership: the (1,0) entry is N, and (N : ZMod N) = 0
      rw [Gamma0_mem]; simpвҹ©

/-- The bottom-right entry of `adjointGamma0Rep` is `pвҒ»В№ mod N`:
`Gamma0MapUnits(ОівӮҖ) = вҹЁpвҹ©вҒ»В№`. This is because `mВ·p вүЎ 1 mod N` (Bezout). -/
private lemma adjointGamma0Rep_units (p N : в„•) (hpN : Nat.Coprime p N) [NeZero N] :
    Gamma0MapUnits (adjointGamma0Rep p N hpN) =
      (ZMod.unitOfCoprime p hpN)вҒ»В№ := by
  -- The bottom-right entry of adjointGamma0Rep is gcdA(p,N).
  -- From Bezout: gcdA * p + gcdB * N = 1, so (gcdA : ZMod N) * p = 1,
  -- hence Gamma0MapUnits = unitOfCoprime(p)вҒ»В№.
  have hbez := Int.gcd_eq_gcd_ab p N
  rw [show (Int.gcd (вҶ‘p) (вҶ‘N) : в„Ө) = 1 from by exact_mod_cast hpN] at hbez
  -- Bezout in ZMod N: gcdA * p = 1
  have hmod : (Int.gcdA (вҶ‘p) (вҶ‘N) : ZMod N) * (p : ZMod N) = 1 := by
    have h := congr_arg (Int.cast : в„Ө вҶ’ ZMod N) hbez
    simp only [Int.cast_one, Int.cast_add, Int.cast_mul, Int.cast_natCast,
      ZMod.natCast_self, zero_mul, add_zero] at h
    rw [mul_comm] at h; exact h.symm
  -- ОівӮҖ-units * unitOfCoprime = 1, hence ОівӮҖ-units = unitOfCoprimeвҒ»В№
  rw [eq_comm, inv_eq_of_mul_eq_one_left]
  ext
  simp only [Units.val_mul, Units.val_one, Gamma0MapUnits_val, ZMod.coe_unitOfCoprime]
  -- Goal: Gamma0Map N ОівӮҖ * p = 1, where Gamma0Map extracts (1,1) entry
  -- Unfold to get the gcdA entry
  unfold adjointGamma0Rep Gamma0Map
  simp only [MonoidHom.coe_mk, OneHom.coe_mk]
  exact hmod

/-- **T128 R1 identity вҖ” diamond via inverse `adjointGamma0Rep`**.
`вҮ‘(вҹЁuвҹ© f) = вҮ‘f вҲЈ[k] mapGL ОівӮҖвҒ»В№` where `u = ZMod.unitOfCoprime p hpN` and
`ОівӮҖ = adjointGamma0Rep p N hpN`.  Direct consequence of
`Gamma0MapUnits ОівӮҖ = uвҒ»В№` (`adjointGamma0Rep_units`) plus the MonoidHom
`map_inv` giving `Gamma0MapUnits ОівӮҖвҒ»В№ = u`, combined with
`diamondOpCusp_eq` at `(d := u, g := ОівӮҖвҒ»В№)`.

**Role in T128 symmetric closure.**  The residual `f вҲЈ[k] mapGL ОівӮҖвҒ»В№`
exposed by the per-q ОівӮҖ change-of-variable matches exactly the
first-slot `вҮ‘вҹЁuвҹ© f` of the symmetric form `petN(T_p f, g) = petN(вҹЁuвҹ©f, T_p g)`
once this identification is applied. -/
private lemma coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) :
        UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
          GL (Fin 2) в„қ) := by
  -- `Gamma0MapUnits ОівӮҖвҒ»В№ = (Gamma0MapUnits ОівӮҖ)вҒ»В№ = (uвҒ»В№)вҒ»В№ = u`.
  have h_units : Gamma0MapUnits ((adjointGamma0Rep p N hpN)вҒ»В№ : Gamma0 N) =
      ZMod.unitOfCoprime p hpN := by
    rw [map_inv, adjointGamma0Rep_units, inv_inv]
  -- Apply `diamondOpCusp_eq` with the inverse representative.
  show (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f : UpperHalfPlane вҶ’ в„Ӯ) = _
  rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)
    ((adjointGamma0Rep p N hpN)вҒ»В№ : Gamma0 N) h_units]
  -- `diamondOpCuspAux k g f = f вҲЈ[k] mapGL (g : SL(2, в„Ө))` at function level.
  rfl

/-- The О“вӮҒ(N) representative ОівӮҒвҒ»В№ for the triple product identity. Constructed
using Bezout coefficients `gcdAВ·p + gcdBВ·N = 1`, this is the matrix
`[[pВ·gcdA, gcdB], [-N, 1]] вҲҲ SL(2,в„Ө)` with determinant `pВ·gcdA - gcdBВ·(-N) =
pВ·gcdA + gcdBВ·N = 1`. Its top-left entry is `pВ·gcdA вүЎ 1 mod N`, and (1,0)
entry is `-N вүЎ 0`, so it lies in `О“вӮҒ(N)`. -/
private noncomputable def adjointGamma1Rep (p N : в„•) (hpN : Nat.Coprime p N) :
    SL(2, в„Ө) :=
  let a := Int.gcdA p N
  let b := Int.gcdB p N
  вҹЁ!![(p : в„Ө) * a, b; -(N : в„Ө), 1], by
    -- det = (p*a)*1 - b*(-N) = p*a + b*N = 1 (Bezout)
    have hbez := Int.gcd_eq_gcd_ab p N
    rw [show (Int.gcd (вҶ‘p) (вҶ‘N) : в„Ө) = 1 from by exact_mod_cast hpN] at hbez
    simp only [Matrix.det_fin_two_of]
    linarithвҹ©

/-- `adjointGamma1Rep вҲҲ О“вӮҒ(N)`: top-left entry is `pВ·gcdA вүЎ 1 mod N`,
bottom-right is `1 вүЎ 1`, (1,0) entry is `-N вүЎ 0`. -/
private lemma adjointGamma1Rep_mem_Gamma1 (p N : в„•) [NeZero N]
    (hpN : Nat.Coprime p N) :
    adjointGamma1Rep p N hpN вҲҲ Gamma1 N := by
  rw [Gamma1_mem]
  -- Top-left: p*gcdA, bottom-right: 1, (1,0): -N
  -- From Bezout: p*gcdA + gcdB*N = 1, so p*gcdA = 1 - gcdB*N вүЎ 1 mod N.
  have hbez := Int.gcd_eq_gcd_ab p N
  rw [show (Int.gcd (вҶ‘p) (вҶ‘N) : в„Ө) = 1 from by exact_mod_cast hpN] at hbez
  refine вҹЁ?_, ?_, ?_вҹ©
  В· -- (p*gcdA : ZMod N) = 1
    show (((adjointGamma1Rep p N hpN).val 0 0 : в„Ө) : ZMod N) = 1
    unfold adjointGamma1Rep
    -- Goal: ((p * Int.gcdA p N : в„Ө) : ZMod N) = 1
    have h : ((p : в„Ө) * Int.gcdA p N + Int.gcdB p N * N : ZMod N) = 1 := by
      have := congr_arg (Int.cast : в„Ө вҶ’ ZMod N) hbez
      simp only [Int.cast_one, Int.cast_add, Int.cast_mul, Int.cast_natCast] at this
      push_cast; linear_combination -this
    simpa [ZMod.natCast_self] using h
  В· -- (1 : ZMod N) = 1
    show (((adjointGamma1Rep p N hpN).val 1 1 : в„Ө) : ZMod N) = 1
    unfold adjointGamma1Rep; simp
  В· -- (-N : ZMod N) = 0
    show (((adjointGamma1Rep p N hpN).val 1 0 : в„Ө) : ZMod N) = 0
    unfold adjointGamma1Rep; simp

/-! ### Hermitian adjoint of Hecke operators

The adjoint is defined via the Petersson inner product:
`вҹЁT f, gвҹ© = вҹЁf, T* gвҹ©` for all cusp forms f, g.

DiamondвҖ“Shurman Proposition 5.5.2 gives the key identity:
`вҹЁf|[Оұ], gвҹ© = вҹЁf, g|[Оұ']вҹ©` where `Оұ' = det(Оұ) В· ОұвҒ»В№`.

For T_p, this yields T_p* = вҹЁpвҹ©вҒ»В№ T_p (Theorem 5.5.3). -/

/-! ### DS Proposition 5.5.2: GLвӮӮвҒә change of variables for Petersson

The key analytic lemma for the Hecke adjoint. For `Оұ вҲҲ GLвӮӮвҒә(в„қ)`:

```
вҲ«_{D} petersson k (f|Оұ) g dОј = вҲ«_{ОұвҒ»В№вҖўD} petersson k f (g|Оұ') dОј
```
where `Оұ' = det(Оұ)В·ОұвҒ»В№`, using `instSMulInvMeasure_GLpos` for the change of
variables and `petersson_slash` for the integrand transformation.

This is combined with the coset sum structure of `petN` and the algebraic
double coset identity to prove `T_p* = вҹЁpвҹ©вҒ»В№ T_p` (DS Theorem 5.5.3). -/

section PeterssonAdjoint

open UpperHalfPlane MeasureTheory

-- Proof sketch for peterssonInner_slash_adjoint (DS Lemma 5.5.1 / Prop 5.5.2a):
-- 1. Insert `g = (gвҲЈОұ)вҲЈОұвҒ»В№` to get both functions slashed by Оұ:
--    `petersson k (fвҲЈОұ) ((gвҲЈОұвҒ»В№)вҲЈОұ) П„ = |det Оұ|^{k-2} В· Пғ Оұ В· petersson k f (gвҲЈОұвҒ»В№) (ОұвҖўП„)`.
-- 2. Change variables `П„ вҶ’ ОұвҒ»В№вҖўП„` using `instSMulInvMeasure_GLpos`:
--    `вҲ«_D h(П„) dОј = вҲ«_{ОұвҒ»В№вҖўD} h(ОұвҖўП„) dОј`.
-- 3. Simplify: the `|det Оұ|^{k-2}` factor combines with `gвҲЈОұвҒ»В№` to give
--    `gвҲЈ(det(Оұ)В·ОұвҒ»В№) = gвҲЈadjugate(Оұ)` in the `petersson` integrand.

/-- The "Petersson adjoint" of a GLвӮӮ(в„қ) element: `ОұвҖ  = det(Оұ) В· ОұвҒ»В№ = adjugate(Оұ)`.
As a 2x2 matrix, `adjugate [[a,b],[c,d]] = [[d,-b],[-c,a]]`.
Since `det(adjugate Оұ) = det(Оұ)^{n-1} вү  0`, the adjugate is in GLвӮӮ(в„қ). -/
noncomputable def peterssonAdj (Оұ : GL (Fin 2) в„қ) : GL (Fin 2) в„қ :=
  .mkOfDetNeZero (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate (by
    rw [Matrix.det_adjugate]
    exact pow_ne_zero _ Оұ.det_ne_zero)

-- API for `slash_peterssonAdj_eq`: key facts about adjugate in GLвӮӮ.

/-- `det(peterssonAdj Оұ) = det(Оұ)` for 2Г—2 matrices (since det(adjugate) = det^{n-1}). -/
lemma peterssonAdj_det (Оұ : GL (Fin 2) в„қ) :
    (peterssonAdj Оұ).det = Оұ.det := by
  have hcoe : (peterssonAdj Оұ : Matrix (Fin 2) (Fin 2) в„қ) =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate := by
    simp [peterssonAdj]
  ext
  show (peterssonAdj Оұ : Matrix (Fin 2) (Fin 2) в„қ).det =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ).det
  rw [hcoe, Matrix.det_adjugate, Fintype.card_fin]
  ring

/-- Coercion: `peterssonAdj Оұ` as a matrix equals the adjugate of `Оұ`. -/
lemma peterssonAdj_coe (Оұ : GL (Fin 2) в„қ) :
    (peterssonAdj Оұ : Matrix (Fin 2) (Fin 2) в„қ) =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate := by
  simp [peterssonAdj]

/-- `peterssonAdj` is anti-multiplicative: `peterssonAdj(Оұ * ОІ) = peterssonAdj ОІ * peterssonAdj Оұ`.
Follows from `Matrix.adjugate_mul_distrib`. -/
private lemma peterssonAdj_mul (Оұ ОІ : GL (Fin 2) в„қ) :
    peterssonAdj (Оұ * ОІ) = peterssonAdj ОІ * peterssonAdj Оұ := by
  apply Units.ext
  show (peterssonAdj (Оұ * ОІ) : Matrix (Fin 2) (Fin 2) в„қ) =
    (peterssonAdj ОІ * peterssonAdj Оұ : GL (Fin 2) в„қ).val
  rw [Units.val_mul, peterssonAdj_coe, peterssonAdj_coe, peterssonAdj_coe,
    Units.val_mul, Matrix.adjugate_mul_distrib]

/-- **T128 quotient helper вҖ” right О“вӮҒ absorption**: for any
`Оі вҲҲ Gamma1 N`, multiplying a representative `q` on the right by `ОівҒ»В№`
keeps its class in `SL(2, в„Ө) в§ё Gamma1 N`.

Direct application of `QuotientGroup.leftRel_apply`: the
left-coset-equivalence condition `(q * ОівҒ»В№)вҒ»В№ * q вҲҲ Gamma1 N` reduces to
`Оі вҲҲ Gamma1 N` after `mul_inv_rev` + `inv_inv` + `mul_assoc` +
`inv_mul_cancel` + `mul_one`.

**Role in T128 aggregate bridge**: after the twist helper
`peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist` introduces
`(q В· ОівҒ»В№)вҒ»В№` factors in per-q shifted tiles, summing over `q :
SL(2, в„Ө) в§ё Gamma1 N` preserves the index class by this lemma, enabling
sum-level reindexing that absorbs the `ОівҒ»В№` discrepancy without
appealing to any per-q representative change. -/
private lemma Gamma1Quot_mk_mul_right_inv_eq
    (q Оі : SL(2, в„Ө)) (hОі : Оі вҲҲ Gamma1 N) :
    (вҹҰq * ОівҒ»В№вҹ§ : SL(2, в„Ө) в§ё Gamma1 N) = (вҹҰqвҹ§ : SL(2, в„Ө) в§ё Gamma1 N) := by
  rw [QuotientGroup.eq]
  show (q * ОівҒ»В№)вҒ»В№ * q вҲҲ Gamma1 N
  rw [mul_inv_rev, inv_inv, mul_assoc, inv_mul_cancel, mul_one]
  exact hОі

/-- **T128 aggregate quotient-sum invariance**: reindex-identity form of
`Gamma1Quot_mk_mul_right_inv_eq`.  For any `Оі вҲҲ Gamma1 N` and any
function `F : SL(2, в„Ө) в§ё Gamma1 N вҶ’ в„Ӯ`, summing `F` applied to the
`ОівҒ»В№`-twisted-out representative equals summing `F` directly over the
quotient.  Combines `Gamma1Quot_mk_mul_right_inv_eq` (class equality
`вҹҰq.out В· ОівҒ»В№вҹ§ = вҹҰq.outвҹ§`) with `Quotient.out_eq q` (`вҹҰq.outвҹ§ = q`)
pointwise. -/
private lemma sum_Gamma1Quot_mul_right_inv_eq
    (Оі : SL(2, в„Ө)) (hОі : Оі вҲҲ Gamma1 N)
    (F : SL(2, в„Ө) в§ё Gamma1 N вҶ’ в„Ӯ) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
        F (вҹҰ(q.out : SL(2, в„Ө)) * ОівҒ»В№вҹ§)) =
      вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N, F q := by
  refine Finset.sum_congr rfl ?_
  intro q _
  rw [Gamma1Quot_mk_mul_right_inv_eq _ Оі hОі]
  exact congrArg F (Quotient.out_eq q)

/-- **Double-adjoint identity**: `peterssonAdj (peterssonAdj Оұ) = Оұ` for
any `Оұ : GL (Fin 2) в„қ`.  Follows from `Matrix.adjugate_adjugate` at
`Fintype.card (Fin 2) = 2`, where `(det Оұ)^(2 - 2) вҖў Оұ = Оұ`. -/
lemma peterssonAdj_peterssonAdj (Оұ : GL (Fin 2) в„қ) :
    peterssonAdj (peterssonAdj Оұ) = Оұ := by
  apply Units.ext
  ext i j
  have hОұcoe := peterssonAdj_coe Оұ
  change ((peterssonAdj Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate) i j =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ) i j
  rw [hОұcoe, Matrix.adjugate_fin_two, Matrix.adjugate_fin_two]
  fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]

/-- For an SL(2, в„Ө) element cast to GL(2, в„қ), the `peterssonAdj` equals the group inverse.
Since SL elements have determinant 1, their adjugate equals their inverse. -/
lemma peterssonAdj_mapGL_SL_eq_inv (q : SL(2, в„Ө)) :
    peterssonAdj ((mapGL в„қ q : GL (Fin 2) в„қ)) = (mapGL в„қ q : GL (Fin 2) в„қ)вҒ»В№ := by
  apply Units.ext
  rw [peterssonAdj_coe, Matrix.coe_units_inv]
  -- Matrix.adjugate A = AвҒ»В№ when det A = 1. Use Matrix.inv_def + det = 1.
  have hdet : (mapGL в„қ q : Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
    have : (mapGL в„қ q : Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix q.val) := by
      ext i j; simp [mapGL_coe_matrix, Int.castRingHom]
    rw [this, вҶҗ RingHom.map_det, q.property]
    simp
  rw [Matrix.inv_def, Ring.inverse_eq_inv', hdet]
  simp

/-- For an SL(2, в„Ө) element cast to GL(2, в„қ), `(peterssonAdj Оұ)вҒ»В№ = Оұ`.
Direct corollary of `peterssonAdj_mapGL_SL_eq_inv` + `inv_inv`. -/
private lemma peterssonAdj_inv_mapGL_SL_eq_self (q : SL(2, в„Ө)) :
    (peterssonAdj ((mapGL в„қ q : GL (Fin 2) в„қ)))вҒ»В№ = (mapGL в„қ q : GL (Fin 2) в„қ) := by
  rw [peterssonAdj_mapGL_SL_eq_inv, inv_inv]

/-- Entry-level: `(ОұвҒ»В№) i j = det(Оұ)вҒ»В№ * adjugate(Оұ) i j`. -/
private lemma GL_inv_entry (Оұ : GL (Fin 2) в„қ) (i j : Fin 2) :
    (ОұвҒ»В№ : GL (Fin 2) в„қ) i j =
      (Оұ.det.val)вҒ»В№ * (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate i j := by
  set A := (Оұ : Matrix (Fin 2) (Fin 2) в„қ)
  have hdet : A.det вү  0 := Оұ.det_ne_zero
  -- вҶ‘ОұвҒ»В№ = AвҒ»В№ (nonsingular inverse)
  have hcoe : (вҶ‘ОұвҒ»В№ : Matrix (Fin 2) (Fin 2) в„қ) = AвҒ»В№ := Matrix.coe_units_inv Оұ
  -- AвҒ»В№ = Ring.inverse(det A) вҖў adjugate(A), and Ring.inverse = inv for a field
  have hinv : AвҒ»В№ = A.detвҒ»В№ вҖў A.adjugate := by
    rw [Matrix.inv_def]
    congr 1
    exact Ring.inverse_eq_inv _
  have hdet_eq : A.det = Оұ.det.val := rfl
  show (вҶ‘ОұвҒ»В№ : Matrix _ _ в„қ) i j = _
  rw [hcoe, hinv, Matrix.smul_apply, smul_eq_mul, hdet_eq]

/-- The peterssonAdj has the same MГ¶bius action as ОұвҒ»В№: `peterssonAdj Оұ вҖў П„ = ОұвҒ»В№ вҖў П„`.
This is because adjugate(Оұ) = det(Оұ) В· ОұвҒ»В№ as MГ¶bius maps (scalar matrices act trivially). -/
private lemma peterssonAdj_smul_eq (Оұ : GL (Fin 2) в„қ) (П„ : в„Қ) :
    (peterssonAdj Оұ) вҖў П„ = ОұвҒ»В№ вҖў П„ := by
  -- num/denom of peterssonAdj Оұ differ from ОұвҒ»В№ by the factor det(Оұ), which cancels
  have hdet_ne : (Оұ.det.val : в„Ӯ) вү  0 :=
    Complex.ofReal_ne_zero.mpr (Units.ne_zero Оұ.det)
  have hadj_entry : вҲҖ i j, (peterssonAdj Оұ : Matrix _ _ в„қ) i j =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate i j := by
    intro i j; simp [peterssonAdj]
  have hdet_ne' : Оұ.det.val вү  0 := Units.ne_zero Оұ.det
  have hnum : num (peterssonAdj Оұ) (П„ : в„Ӯ) = вҶ‘Оұ.det.val * num ОұвҒ»В№ (П„ : в„Ӯ) := by
    simp only [num, hadj_entry, GL_inv_entry]
    push_cast; field_simp
  have hdenom : denom (peterssonAdj Оұ) (П„ : в„Ӯ) = вҶ‘Оұ.det.val * denom ОұвҒ»В№ (П„ : в„Ӯ) := by
    simp only [denom, hadj_entry, GL_inv_entry]
    push_cast; field_simp
  -- Пғ agrees because det(peterssonAdj Оұ) and det(ОұвҒ»В№) have the same sign
  have hПғ_eq : Пғ (peterssonAdj Оұ) = Пғ ОұвҒ»В№ := by
    have hdet1 : (peterssonAdj Оұ).det.val = Оұ.det.val :=
      congr_arg Units.val (peterssonAdj_det Оұ)
    have hdet2 : (ОұвҒ»В№).det.val = (Оұ.det.val)вҒ»В№ := by
      show (ОұвҒ»В№).det.val = _
      rw [show (ОұвҒ»В№).det = Оұ.detвҒ»В№ from map_inv (Matrix.GeneralLinearGroup.det) Оұ]
      exact Units.val_inv_eq_inv_val _
    simp only [Пғ, hdet1, hdet2, inv_pos]
  ext1
  simp only [coe_smul, hПғ_eq]
  congr 1
  rw [hnum, hdenom, mul_div_mul_left _ _ hdet_ne]

/-- `denom(peterssonAdj Оұ, П„) = det(Оұ) В· denom(ОұвҒ»В№, П„)`.
For adjugate `[[d,-b],[-c,a]]` vs inverse `[[d,-b],[-c,a]]/det`: the denominators
(bottom row В· [П„, 1]) differ by the factor det(Оұ). -/
private lemma peterssonAdj_denom (Оұ : GL (Fin 2) в„қ) (П„ : в„Қ) :
    UpperHalfPlane.denom (peterssonAdj Оұ) П„ =
      вҶ‘(Оұ.det.val) * UpperHalfPlane.denom ОұвҒ»В№ П„ := by
  have hadj_entry : вҲҖ i j, (peterssonAdj Оұ : Matrix _ _ в„қ) i j =
      (Оұ : Matrix (Fin 2) (Fin 2) в„қ).adjugate i j := by
    intro i j; simp [peterssonAdj]
  simp only [denom, hadj_entry, GL_inv_entry]
  push_cast
  have hdet_ne : (Оұ.det.val : в„Ӯ) вү  0 :=
    Complex.ofReal_ne_zero.mpr (Units.ne_zero Оұ.det)
  field_simp

/-- Pointwise: `g вҲЈ[k] peterssonAdj Оұ = |det Оұ|^{k-2} вҖў (g вҲЈ[k] ОұвҒ»В№)`.

Proof: By `ext П„; simp [slash_apply]`, both sides evaluate to
`g(ОұвҒ»В№вҖўП„) * (det-power) * (denom)^{-k}`. Using `peterssonAdj_smul_eq` (same MГ¶bius
action), `peterssonAdj_det` (same det), and `peterssonAdj_denom` (denom scales by det),
the det powers `|det|^{k-1} В· det^{-k}` on the LHS vs `|det|^{k-2} В· |detвҒ»В№|^{k-1}`
on the RHS both equal `det^{-1}`, so the ratio is `|det|^{k-2}`. -/
lemma slash_peterssonAdj_eq (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val)
    (g : в„Қ вҶ’ в„Ӯ) :
    g вҲЈ[k] peterssonAdj Оұ = (вҶ‘(|Оұ.det.val| ^ (k - 2)) : в„Ӯ) вҖў (g вҲЈ[k] ОұвҒ»В№) := by
  have habs : |Оұ.det.val| = Оұ.det.val := abs_of_pos hОұ
  have hdet_ne : (Оұ.det.val : в„Ӯ) вү  0 :=
    Complex.ofReal_ne_zero.mpr (ne_of_gt hОұ)
  have hdet_eq : (peterssonAdj Оұ).det.val = Оұ.det.val :=
    congr_arg Units.val (peterssonAdj_det Оұ)
  have hПғ_adj : Пғ (peterssonAdj Оұ) = Пғ ОұвҒ»В№ := by
    simp only [Пғ, hdet_eq]
    have : (ОұвҒ»В№).det.val = (Оұ.det.val)вҒ»В№ := by
      rw [show (ОұвҒ»В№).det = Оұ.detвҒ»В№ from map_inv (Matrix.GeneralLinearGroup.det) Оұ]
      exact Units.val_inv_eq_inv_val _
    simp [this, inv_pos]
  have hdet_inv_abs : |(ОұвҒ»В№).det.val| = (Оұ.det.val)вҒ»В№ := by
    rw [show (ОұвҒ»В№).det = Оұ.detвҒ»В№ from map_inv (Matrix.GeneralLinearGroup.det) Оұ,
      Units.val_inv_eq_inv_val, abs_inv, habs]
  ext П„
  have hD := denom_ne_zero ОұвҒ»В№ П„
  simp only [ModularForm.slash_apply, Pi.smul_apply, smul_eq_mul, peterssonAdj_smul_eq,
    hПғ_adj, hdet_eq, peterssonAdj_denom, mul_zpow, hdet_inv_abs, habs]
  -- Goal:
  -- Пғ(g(..)) * вҶ‘d^(k-1) * (вҶ‘d^(-k) * D^(-k))
  -- = вҶ‘(d^(k-2)) * (Пғ(g(..)) * вҶ‘dвҒ»В№^(k-1) * D^(-k))
  -- where d = det Оұ : в„қ (and вҶ‘ is the в„қвҶ’в„Ӯ cast)
  set d := Оұ.det.val with hd_def
  -- Normalize the RHS coercions: вҶ‘(d^(k-2)) = (вҶ‘d)^(k-2) and вҶ‘(dвҒ»В№) = (вҶ‘d)вҒ»В№
  rw [show (вҶ‘(d ^ (k - 2)) : в„Ӯ) = (вҶ‘d : в„Ӯ) ^ (k - 2) from by push_cast; rfl]
  rw [show (вҶ‘(dвҒ»В№) : в„Ӯ) = (вҶ‘d : в„Ӯ)вҒ»В№ from Complex.ofReal_inv d]
  -- LHS: Пғ(g(..)) * (вҶ‘d)^(k-1) * ((вҶ‘d)^(-k) * D^(-k))
  -- RHS: (вҶ‘d)^(k-2) * (Пғ(g(..)) * (вҶ‘d)вҒ»В№^(k-1) * D^(-k))
  -- Combine zpow factors on each side using zpow_add
  have hcd : (вҶ‘d : в„Ӯ) вү  0 := hdet_ne
  -- Both sides equal Пғ(g(..)) * (вҶ‘d)^(-1) * D^(-k)
  -- LHS: Пғ(g(..)) * (вҶ‘d)^(k-1) * ((вҶ‘d)^(-k) * D^(-k))
  -- RHS: (вҶ‘d)^(k-2) * (Пғ(g(..)) * (вҶ‘d)вҒ»В№^(k-1) * D^(-k))
  set G := Пғ ОұвҒ»В№ (g (ОұвҒ»В№ вҖў П„)) with hG_def
  set D := denom ОұвҒ»В№ (вҶ‘П„) with hD_def
  suffices h : G * (вҶ‘d : в„Ӯ) ^ (k - 1) * ((вҶ‘d : в„Ӯ) ^ (-k) * D ^ (-k)) =
      (вҶ‘d : в„Ӯ) ^ (k - 2) * (G * (вҶ‘d : в„Ӯ)вҒ»В№ ^ (k - 1) * D ^ (-k)) by exact h
  rw [inv_zpow']
  -- Now RHS has (вҶ‘d)^(-(k-1)) instead of (вҶ‘d)вҒ»В№^(k-1)
  -- Both sides can be shown equal by combining zpow: k-1 + (-k) = -1 = (k-2) + (-(k-1))
  have h1 : (k - 1 : в„Ө) + (-k) = -1 := by omega
  have h2 : (k - 2 : в„Ө) + (-(k - 1)) = -1 := by omega
  calc G * (вҶ‘d : в„Ӯ) ^ (k - 1) * ((вҶ‘d : в„Ӯ) ^ (-k) * D ^ (-k))
      = G * ((вҶ‘d : в„Ӯ) ^ (k - 1) * (вҶ‘d : в„Ӯ) ^ (-k)) * D ^ (-k) := by ring
    _ = G * (вҶ‘d : в„Ӯ) ^ (-1 : в„Ө) * D ^ (-k) := by rw [вҶҗ zpow_addвӮҖ hcd, h1]
    _ = G * ((вҶ‘d : в„Ӯ) ^ (k - 2) * (вҶ‘d : в„Ӯ) ^ (-(k - 1))) * D ^ (-k) := by
          rw [вҶҗ zpow_addвӮҖ hcd, h2]
    _ = (вҶ‘d : в„Ӯ) ^ (k - 2) * (G * (вҶ‘d : в„Ӯ) ^ (-(k - 1)) * D ^ (-k)) := by ring

/-- **GLвӮӮвҒә Petersson adjoint** (DS Proposition 5.5.2a):
For `Оұ вҲҲ GL(2,в„қ)` with `det(Оұ) > 0`, and any measurable set `D вҠҶ в„Қ`:
```
  peterssonInner k D (fвҲЈ[k]Оұ) g = peterssonInner k (Оұ вҖў D) f (gвҲЈ[k] adjugate(Оұ))
```

**Proof** (DS Lemma 5.5.1 / Prop 5.5.2a):
1. Write `g = (gвҲЈ[k]ОұвҒ»В№)вҲЈ[k]Оұ` (by `slash_mul` + `inv_mul_cancel` + `slash_one`).
2. Apply `petersson_slash` to `petersson k (fвҲЈОұ) ((gвҲЈОұвҒ»В№)вҲЈОұ) П„`:
   `= |det Оұ|^{k-2} * Пғ Оұ (petersson k f (gвҲЈОұвҒ»В№) (ОұвҖўП„))`
   `= |det Оұ|^{k-2} * petersson k f (gвҲЈОұвҒ»В№) (ОұвҖўП„)`  (since `det Оұ > 0`, `Пғ Оұ = id`).
3. Change variables `вҲ«_{ОұвҖўD} h dОј = вҲ«_D h(ОұвҖўВ·) dОј` (by `instSMulInvMeasure_GLpos`):
   `вҲ«_D |det Оұ|^{k-2} * petersson k f (gвҲЈОұвҒ»В№) (ОұвҖўВ·) dОј`
   `= |det Оұ|^{k-2} * вҲ«_{ОұвҖўD} petersson k f (gвҲЈОұвҒ»В№) dОј`
4. By `slash_peterssonAdj_eq`: `gвҲЈadj(Оұ) = |det Оұ|^{k-2} вҖў (gвҲЈОұвҒ»В№)`, so
   `petersson k f (gвҲЈadj(Оұ)) = |det Оұ|^{k-2} * petersson k f (gвҲЈОұвҒ»В№)`.
5. The constant factors cancel, giving `peterssonInner k (ОұвҖўD) f (gвҲЈadj(Оұ))`. -/
theorem peterssonInner_slash_adjoint
    (D : Set в„Қ) (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val)
    (f g : в„Қ вҶ’ в„Ӯ) :
    peterssonInner k D (f вҲЈ[k] Оұ) g =
      peterssonInner k (Оұ вҖў D) f (g вҲЈ[k] peterssonAdj Оұ) := by
  -- Step 1: Write g = (g вҲЈ[k] ОұвҒ»В№) вҲЈ[k] Оұ
  have hg_decomp : g = (g вҲЈ[k] ОұвҒ»В№) вҲЈ[k] Оұ := by
    rw [вҶҗ SlashAction.slash_mul, inv_mul_cancel, SlashAction.slash_one]
  -- Step 2: Rewrite using petersson_slash
  simp only [peterssonInner]
  -- Step 2: Use petersson_slash with g decomposed
  -- Key: petersson k (fвҲЈОұ) g = petersson k (fвҲЈОұ) ((gвҲЈОұвҒ»В№)вҲЈОұ) (by hg_decomp)
  --     = |det Оұ|^{k-2} * petersson k f (gвҲЈОұвҒ»В№) (ОұвҖўВ·) (by petersson_slash + Пғ Оұ = id)
  set g' := g вҲЈ[k] ОұвҒ»В№
  have h_eq : вҲҖ П„, petersson k (f вҲЈ[k] Оұ) g П„ =
      вҶ‘|Оұ.det.val| ^ (k - 2) * petersson k f g' (Оұ вҖў П„) := by
    intro П„
    -- g = g' вҲЈ[k] Оұ
    have : g = g' вҲЈ[k] Оұ := hg_decomp
    rw [this, petersson_slash, show Пғ Оұ = RingHom.id в„Ӯ from if_pos hОұ, RingHom.id_apply]
  simp_rw [h_eq]
  -- Goal: вҲ«_D c * petersson k f g' (ОұвҖўП„) dОј = вҲ«_{ОұвҖўD} petersson k f (gвҲЈadj) dОј
  -- Step 3: Change variables + absorb factor
  -- The key step: вҲ«_{ОұвҖўD} h dОј = вҲ«_D h(ОұвҖўВ·) dОј (by MeasurePreserving)
  -- Combined with the det factor, everything works out.
  --
  -- We work backwards from the RHS:
  -- вҲ«_{ОұвҖўD} petersson k f (gвҲЈadj) dОј
  -- = вҲ«_{ОұвҖўD} petersson k f (c вҖў g') dОј        (by slash_peterssonAdj_eq)
  -- = вҲ«_{ОұвҖўD} c * petersson k f g' dОј           (petersson is linear in 2nd arg)
  -- = c * вҲ«_{ОұвҖўD} petersson k f g' dОј           (pull constant)
  -- = c * вҲ«_D petersson k f g' (ОұвҖўП„) dОј         (change of variables)
  -- = вҲ«_D c * petersson k f g' (ОұвҖўП„) dОј         (push constant back)
  -- = LHS
  -- Work backwards from the RHS
  symm
  -- Step 3a: Rewrite g вҲЈ[k] peterssonAdj Оұ = c вҖў g' and simplify
  have hpet_adj : вҲҖ П„, petersson k f (g вҲЈ[k] peterssonAdj Оұ) П„ =
      вҶ‘|Оұ.det.val| ^ (k - 2) * petersson k f g' П„ := by
    intro П„
    rw [slash_peterssonAdj_eq Оұ hОұ g]
    simp [petersson, Pi.smul_apply, smul_eq_mul]; ring
  simp_rw [hpet_adj]
  -- Goal: вҲ«_{ОұвҖўD} c * petersson k f g' dОј = вҲ«_D c * petersson k f g' (ОұвҖўП„) dОј
  -- Step 3b: Change of variables using GLвӮӮвҒә invariance
  set Оұ' : GL(2, в„қ)вҒә := вҹЁОұ, hОұвҹ©
  rw [show Оұ вҖў D = (fun П„ => Оұ' вҖў П„) '' D from by rw [Set.image_smul]; rfl]
  exact (measurePreserving_smul Оұ' Ој_hyp).setIntegral_image_emb
    (measurableEmbedding_const_smul Оұ') _ D

/-- **Hecke-representative wrapper around `peterssonInner_slash_adjoint`**
(Step 1 of the T205-d-SYMM chain, per expert review 2026-05-11).

CuspForm-typed specialisation of `peterssonInner_slash_adjoint`
(DS Proposition 5.5.2(a), integrated form). The analytic content is in
`peterssonInner_slash_adjoint`; this lemma is the named interface that
subsequent steps (T205-d-ADJ-CORR finite-correspondence aggregation,
T205-d-DIAMOND-SPEC T_p adjugate identification, T205-d-UNSYMM, T205-d-SYMM)
consume.

For `ОІ вҲҲ GL(2, в„қ)` with positive determinant (in practice a Hecke
representative for `Оұ вҲҲ О”вӮҖ(N)` вҖ” e.g. `Оұ = diag(1, p)` at `О“вӮҒ(N)` gives the
`p + 1` representatives `{T_p_upper(b)}_{b<p} вҲӘ {T_p_lower}`) and any
measurable domain `D вҠҶ в„Қ`, the slash on `f` at domain `D` matches a
domain-translated slash by `peterssonAdj ОІ` on `g` over `ОІ вҖў D`. -/
theorem peterssonInner_slash_adjoint_for_heckeRep
    (D : Set в„Қ) (ОІ : GL (Fin 2) в„қ) (hОІ : 0 < ОІ.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k D ((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] ОІ) вҮ‘g =
      peterssonInner k (ОІ вҖў D) вҮ‘f ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k] peterssonAdj ОІ) :=
  peterssonInner_slash_adjoint D ОІ hОІ вҮ‘f вҮ‘g

/-- **Per-`q`-coset Hecke-rep wrapper** (companion to
`peterssonInner_slash_adjoint_for_heckeRep`, Step 1 of T205-d-SYMM chain).

For each `О“вӮҒ(N)`-coset `q` and Hecke-representative-like `ОІ вҲҲ GL(2, в„қ)` with
positive determinant, the petN per-`q` summand structure
```
  peterssonInner k fd ((вҮ‘f вҲЈ[k] ОІ) вҲЈ[k] q.outвҒ»В№) (вҮ‘g вҲЈ[k] q.outвҒ»В№)
```
re-expresses as a `ОІ`-translated tile integral via
1. `peterssonInner_smul_set_eq_slash` to swap the per-`q` slashes onto the
   domain (`fd вҶ’ q.outвҒ»В№ вҖў fd`),
2. `peterssonInner_slash_adjoint_for_heckeRep` to push `ОІ` from the `f`-slot
   onto the domain, putting the adjugate `peterssonAdj ОІ` onto the `g`-slot.

This is the form T205-d-ADJ-CORR consumes per-(`ОІ`, `q`) summand. -/
theorem peterssonInner_slash_adjoint_for_heckeRep_per_q
    (q : SL(2, в„Ө) в§ё Gamma1 N) (ОІ : GL (Fin 2) в„қ) (hОІ : 0 < ОІ.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k fd
        (((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] ОІ) вҲЈ[k] ((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө)))
        (вҮ‘g вҲЈ[k] ((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө))) =
      peterssonInner k
        (ОІ вҖў (((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө)) вҖў (fd : Set в„Қ)))
        вҮ‘f
        ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k] peterssonAdj ОІ) := by
  rw [вҶҗ peterssonInner_smul_set_eq_slash ((q.out : SL(2, в„Ө))вҒ»В№) fd
        ((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] ОІ) вҮ‘g]
  exact peterssonInner_slash_adjoint_for_heckeRep _ ОІ hОІ f g

/-- **LHS-distributed-summand вҶ’ tile-form bridge** (consumer of
`peterssonInner_slash_adjoint_for_heckeRep_per_q`, immediate use by
T205-d-ADJ-CORR).

The per-`q`-coset summand form produced by
`petN_T_p_heckeT_p_LHS_sum_distributed` carries a single GLвӮӮ(в„қ) slash
`ОІ В· mapGL в„қ q.outвҒ»В№` on the `f`-slot and a `mapGL в„қ q.outвҒ»В№` slash on
the `g`-slot.  Via `SlashAction.slash_mul` (splitting the `f`-slot slash)
and the per-q ADJ-WRAPPER, this rewrites to the tile-translated form
`peterssonInner k (ОІ вҖў (q.outвҒ»В№ вҖў fd)) вҮ‘f (вҮ‘g вҲЈ[k] peterssonAdj ОІ)`. -/
theorem peterssonInner_LHS_distributed_summand_to_tile_form
    (q : SL(2, в„Ө) в§ё Gamma1 N) (ОІ : GL (Fin 2) в„қ) (hОІ : 0 < ОІ.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k fd
        ((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] (ОІ * ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)) =
      peterssonInner k
        (ОІ вҖў (((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө)) вҖў (fd : Set в„Қ)))
        вҮ‘f
        ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k] peterssonAdj ОІ) := by
  rw [SlashAction.slash_mul k ОІ
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
          GL (Fin 2) в„қ) (вҮ‘f : в„Қ вҶ’ в„Ӯ)]
  exact peterssonInner_slash_adjoint_for_heckeRep_per_q q ОІ hОІ f g

/-- **T128 generic SL-domain-equivariance of `peterssonInner`**.  For
`Оі : SL(2, в„Ө)` and functions `F, G : в„Қ вҶ’ в„Ӯ` both fixed by the
`mapGL в„қ Оі`-slash action, the domain translation by `mapGL в„қ Оі` leaves
`peterssonInner k _ F G` invariant.

Shortcut route via `peterssonInner_slash_adjoint`: apply it with
`f := F`, `g := G вҲЈ[k] Оұ` (where `Оұ := mapGL в„қ Оі`), then use
`peterssonAdj_mapGL_SL_eq_inv` (`peterssonAdj Оұ = ОұвҒ»В№` since SL has
det 1), `SlashAction.slash_mul` + `mul_inv_cancel` +
`SlashAction.slash_one` to collapse `(G вҲЈ[k] Оұ) вҲЈ[k] ОұвҒ»В№ = G`, and
finally `hF`, `hG` to absorb the residual slashes.

**Determinant positivity of `mapGL Оі`**: det = 1 via `Оі.property`
(SL-determinant), lifted to в„қ via `RingHom.map_det` + `Int.castRingHom`. -/
private lemma peterssonInner_mapGL_smul_eq_of_slash_invariant
    (D : Set в„Қ) (Оі : SL(2, в„Ө)) (F G : в„Қ вҶ’ в„Ӯ)
    (hF : F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) = F)
    (hG : G вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) = G) :
    peterssonInner k
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) вҖў D) F G =
      peterssonInner k D F G := by
  have hОұ : 0 <
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)).det.val := by
    show 0 < (((mapGL в„қ Оі : GL (Fin 2) в„қ)) : Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((mapGL в„қ Оі : GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix Оі.val) from by rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, Оі.property]
    norm_num
  have h := peterssonInner_slash_adjoint (k := k) D
    (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)) hОұ F
    (G вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)))
  rw [peterssonAdj_mapGL_SL_eq_inv Оі] at h
  rw [show ((G вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)))
          вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ))вҒ»В№) =
        G from by
      rw [вҶҗ SlashAction.slash_mul, mul_inv_cancel, SlashAction.slash_one]] at h
  rw [hF, hG] at h
  exact h.symm

/-- **T128 О“вӮҒ(N)-specialization of SL-domain-equivariance**.  For any
`Оі вҲҲ Gamma1 N` and cusp forms `f, g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k`,
the `peterssonInner`-domain translation by `mapGL в„қ Оі` is invariant.
Discharges the two slash-invariance hypotheses of
`peterssonInner_mapGL_smul_eq_of_slash_invariant` via `slash_Gamma1_eq`
using the same coercion pattern as
`peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist`. -/
private lemma peterssonInner_mapGL_smul_eq_of_Gamma1
    (D : Set в„Қ) (Оі : SL(2, в„Ө)) (hОі : Оі вҲҲ Gamma1 N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) вҖў D)
        вҮ‘f вҮ‘g =
      peterssonInner k D вҮ‘f вҮ‘g := by
  have hf : (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі :
      GL (Fin 2) в„қ)) = вҮ‘f := by
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) =
          ((Оі : SL(2, в„Ө)) : GL (Fin 2) в„қ) from rfl, вҶҗ ModularForm.SL_slash]
    exact slash_Gamma1_eq f Оі hОі
  have hg : (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі :
      GL (Fin 2) в„қ)) = вҮ‘g := by
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) =
          ((Оі : SL(2, в„Ө)) : GL (Fin 2) в„қ) from rfl, вҶҗ ModularForm.SL_slash]
    exact slash_Gamma1_eq g Оі hОі
  exact peterssonInner_mapGL_smul_eq_of_slash_invariant D Оі вҮ‘f вҮ‘g hf hg

/-- **T090 SL-domain pullback identity for `peterssonInner`.**
For Оі : SL(2, в„Ө) and arbitrary F, G : в„Қ вҶ’ в„Ӯ, the SL-tile integral
`peterssonInner k ((mapGL в„қ Оі) вҖў D) F G` equals the fd-domain integral
with slash by mapGL Оі on both slots.  No slash-invariance hypothesis is
needed (compare with `peterssonInner_mapGL_smul_eq_of_slash_invariant`,
which assumes F, G are slash-fixed by mapGL Оі and concludes the same as
`peterssonInner k D F G`; here the conclusion is in slash-form, capturing
the genuine pullback transformation).

**Proof.**  `peterssonInner_slash_adjoint` with Оұ := mapGL Оі (det = 1
since Оі вҲҲ SL) yields
`peterssonInner k D (F вҲЈ mapGL Оі) (G вҲЈ mapGL Оі) =
peterssonInner k (mapGL Оі вҖў D) F ((G вҲЈ mapGL Оі) вҲЈ peterssonAdj (mapGL Оі))`.
For SL elements, `peterssonAdj (mapGL Оі) = (mapGL Оі)вҒ»В№`
(`peterssonAdj_mapGL_SL_eq_inv`); the RHS slot collapses
`(G вҲЈ mapGL Оі) вҲЈ (mapGL Оі)вҒ»В№ = G` via slash composition + group inverse. -/
private lemma peterssonInner_mapGL_smul_eq_slash
    (D : Set в„Қ) (Оі : SL(2, в„Ө)) (F G : в„Қ вҶ’ в„Ӯ) :
    peterssonInner k
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) вҖў D) F G =
      peterssonInner k D
        (F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ))
        (G вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)) := by
  have hОұ : 0 <
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)).det.val := by
    show 0 < (((mapGL в„қ Оі : GL (Fin 2) в„қ)) : Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((mapGL в„қ Оі : GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix Оі.val) from by rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, Оі.property]
    norm_num
  have h := peterssonInner_slash_adjoint (k := k) D
    (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)) hОұ F
    (G вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)))
  rw [peterssonAdj_mapGL_SL_eq_inv Оі] at h
  rw [show ((G вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ)))
          вҲЈ[k] (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ))вҒ»В№) =
        G from by
      rw [вҶҗ SlashAction.slash_mul, mul_inv_cancel, SlashAction.slash_one]] at h
  exact h.symm

end PeterssonAdjoint

/-! ### T090 Hecke conjugate intersection group `О“_p(Оұ)`

Foundational infrastructure for the **aggregate full-Hecke-family swap**
`h_HeckeFD_swap` (DS Thm 5.5.3 sum-level Hecke adjoint).  As established in
prior T090 stints, the per-Оұ individual SL-tile balance is mathematically
unsatisfiable: `(вҹЁpвҹ©вҒ»В№f) вҲЈ glMap M_вҲһ` is invariant only under
`ОұвҒ»В№ О“вӮҒ(N) Оұ вҲ© О“вӮҒ(N) =: О“_p(Оұ)`, **not** under О“вӮҒ(N).  The full DS Thm
5.5.3 route therefore necessarily passes through the conjugate
intersection group `О“_p(Оұ)` and its fundamental domain.

Mathlib provides `CongruenceSubgroup.conjGL` (`Mathlib.NumberTheory.ModularForms.CongruenceSubgroups`)
as the conjugate `ОұвҒ»В№ В· О“ В· Оұ вҲ© SL(2,в„Ө)`, plus `IsCongruenceSubgroup.conjGL`
showing it is itself a congruence subgroup.  Combined with the standard
`О“вӮҒ(N) вҠ“ K` intersection, this gives the conjugate intersection group
`О“_p(Оұ) := О“вӮҒ(N) вҠ“ conjGL О“вӮҒ(N) Оұ`, the kernel of the right Hecke action
of Оұ on the О“вӮҒ(N)-coset space.

This subsection provides the minimal foundational infrastructure
(definition + finite-index + congruence-subgroup-ness) needed downstream
for fundamental-domain transport between О“вӮҒ(N)-FD and Оұ вҖў О“_p(Оұ)-FD
(the geometric content underlying `h_HeckeFD_swap`). -/

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 Hecke conjugate intersection group `О“_p(Оұ)`.**

For `Оұ вҲҲ GL(2, в„ҡ)`, the kernel of the right Hecke action of Оұ on
`О“вӮҒ(N)`-coset space:
```
О“_p(Оұ) := О“вӮҒ(N) вҲ© ОұвҒ»В№ В· О“вӮҒ(N) В· Оұ вҠҶ SL(2, в„Ө)
```
i.e., Оі вҲҲ О“_p(Оұ) iff both Оі вҲҲ О“вӮҒ(N) and Оұ Оі ОұвҒ»В№ вҲҲ О“вӮҒ(N).

Defined via Mathlib's `conjGL` (which gives `ОұвҒ»В№ В· О“вӮҒ(N) В· Оұ вҲ© SL(2,в„Ө)`
as a Subgroup of SL(2, в„Ө)) intersected with `О“вӮҒ(N)`.

**Key role.**  This is the natural fundamental group whose FD `Оұ вҖў О“_p(Оұ)\в„Қ`
sits inside the О“вӮҒ(N)-FD and on which the slash-adjoint identity for
non-О“вӮҒ(N)-normalizing Оұ becomes valid (DS Thm 5.5.3 proof structure). -/
noncomputable def Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ) : Subgroup SL(2, в„Ө) :=
  conjGL (Gamma1 N) (Оұ.map (Rat.castHom в„қ)) вҠ“ Gamma1 N

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `О“_p(Оұ)` has finite index in `SL(2, в„Ө)`.**

Both factors of the intersection have finite index:
* `(Gamma1 N).FiniteIndex` via `instFiniteIndexGamma1`
  (mathlib `CongruenceSubgroups.lean`);
* `(conjGL (Gamma1 N) (Оұ.map (Rat.castHom в„қ))).FiniteIndex` via
  `IsCongruenceSubgroup.conjGL` + `IsCongruenceSubgroup.finiteIndex`
  (mathlib `CongruenceSubgroups.lean`).

The inf instance
`[FiniteIndex H] [FiniteIndex K] : FiniteIndex (H вҠ“ K)`
(mathlib `GroupTheory/Index.lean`) closes the goal.

**Demoted from `instance` to `theorem`** to avoid potential typeclass-search
overhead when downstream code does not need it as an instance (matching
the `Gamma_p_Оұ_finiteIndex_in_Gamma1` pattern).  Use it explicitly via
`haveI := Gamma_p_Оұ_finiteIndex Оұ`. -/
theorem Gamma_p_Оұ_finiteIndex (Оұ : GL (Fin 2) в„ҡ) :
    (Gamma_p_Оұ (N := N) Оұ).FiniteIndex := by
  show (conjGL (Gamma1 N) (Оұ.map (Rat.castHom в„қ)) вҠ“ Gamma1 N).FiniteIndex
  haveI : (conjGL (Gamma1 N) (Оұ.map (Rat.castHom в„қ))).FiniteIndex :=
    ((Gamma1_is_congruence N).conjGL Оұ).finiteIndex
  exact inferInstance

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `О“_p(Оұ) вүӨ О“вӮҒ(N)`.**

Trivial right-inf inclusion: by definition `Gamma_p_Оұ Оұ := conjGL О“вӮҒ(N) Оұ вҠ“ О“вӮҒ(N)`,
so `Gamma_p_Оұ Оұ вүӨ О“вӮҒ(N)` is `inf_le_right`. -/
lemma Gamma_p_Оұ_le_Gamma1 (Оұ : GL (Fin 2) в„ҡ) :
    Gamma_p_Оұ (N := N) Оұ вүӨ Gamma1 N :=
  inf_le_right

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `О“_p(Оұ)` has finite index in `О“вӮҒ(N)`.**

As a finite-index subgroup of `SL(2, в„Ө)` (via `Gamma_p_Оұ_finiteIndex`)
intersected with `О“вӮҒ(N)`, the corresponding subgroup of `О“вӮҒ(N)` (via
`Subgroup.subgroupOf`) is itself finite-index, by mathlib's
`instFiniteIndex_subgroupOf`.

**Demoted to a theorem** (not an instance) to avoid potential
typeclass-search overhead when downstream code does not need it as an
instance. Use it explicitly via
`have h := Gamma_p_Оұ_finiteIndex_in_Gamma1 Оұ`. -/
theorem Gamma_p_Оұ_finiteIndex_in_Gamma1 (Оұ : GL (Fin 2) в„ҡ) :
    ((Gamma_p_Оұ (N := N) Оұ).subgroupOf (Gamma1 N)).FiniteIndex := by
  haveI : (Gamma_p_Оұ (N := N) Оұ).FiniteIndex := Gamma_p_Оұ_finiteIndex Оұ
  exact Subgroup.instFiniteIndex_subgroupOf _ _

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `О“_p(Оұ)` conjugation embedding.**

For Оі вҲҲ О“_p(Оұ), the conjugate `Оұ В· Оі В· ОұвҒ»В№` (interpreted in GL(2, в„қ) via
`mapGL в„қ`) is the lift of an element of `О“вӮҒ(N) вҠҶ SL(2, в„Ө)`.  Concretely:
there exists `Оҙ вҲҲ О“вӮҒ(N)` such that `(mapGL в„қ Оҙ : GL (Fin 2) в„қ) = Оұ' В· mapGL в„қ Оі В· Оұ'вҒ»В№`,
where `Оұ' := Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ`.

This is the defining property of the conjugate intersection group: Оі
lies in `О“_p(Оұ)` iff `Оұ Оі ОұвҒ»В№` is itself an SL(2, в„Ө)-element of О“вӮҒ(N).
The map `Оі вҶҰ Оҙ` is the conjugation isomorphism `О“_p(Оұ) вү… Оұ В· О“_p(Оұ) В· ОұвҒ»В№`
(both subgroups of SL(2, в„Ө), the latter expressed via the conjugate
inclusion `Оұ Оі ОұвҒ»В№ вҲҲ О“вӮҒ(N)`).

**Direct unfolding** of `О“_p(Оұ) := conjGL О“вӮҒ(N) Оұ вҠ“ О“вӮҒ(N)` and
`mem_conjGL`. -/
lemma Gamma_p_Оұ_conj_mem_Gamma1 (Оұ : GL (Fin 2) в„ҡ)
    {Оі : SL(2, в„Ө)} (hОі : Оі вҲҲ Gamma_p_Оұ (N := N) Оұ) :
    вҲғ Оҙ вҲҲ Gamma1 N,
      ((mapGL в„қ Оҙ : GL (Fin 2) в„қ)) =
        (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
          (mapGL в„қ Оі : GL (Fin 2) в„қ) *
          ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№ := by
  rcases hОі with вҹЁh_conj, _вҹ©
  rcases mem_conjGL.mp h_conj with вҹЁОҙ, hОҙ_mem, hОҙ_eqвҹ©
  exact вҹЁОҙ, hОҙ_mem, hОҙ_eqвҹ©

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 conjGL вҶ” ConjAct.toConjAct GL-level identity.**

For a subgroup `О“ вүӨ SL(2, в„Ө)` and `g : GL (Fin 2) в„қ`, the GL-image of
`conjGL О“ g` (the `mapGL в„қ`-lift to GL(2,в„қ)) equals the GL-conjugate
`ConjAct.toConjAct gвҒ»В№ вҖў О“.map (mapGL в„қ)` intersected with the image
of `mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ`.

**Direct unfolding** of `conjGL` (defined as
`((toConjAct gвҒ»В№) вҖў (О“.map (mapGL в„қ))).comap (mapGL в„қ)`) followed by
`Subgroup.map_comap_eq`.  The `mapGL в„қ`-image of a `comap` along
`mapGL в„қ` equals the original subgroup intersected with the range.

**Direct API for `IsFundamentalDomain.smul_of_eq_conjAct`.** Combined
with the SLвҶ’GL outer-group bridge (for the FD-shift route via
PSL2Action's `instSMulInvMeasure_GLpos`), this is the precise identity
witnessing the conjugate-subgroup form `HвӮӮ = ConjAct.toConjAct gвҒ»В№ вҖў HвӮҒ`
needed by the manager's `smul_of_eq_conjAct` (PeterssonLevelN.lean:428). -/
lemma conjGL_map_eq_conjAct_inv_smul_inter
    (О“ : Subgroup SL(2, в„Ө)) (g : GL (Fin 2) в„қ) :
    (conjGL О“ g).map (mapGL в„қ) =
      (ConjAct.toConjAct gвҒ»В№ вҖў (О“.map (mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ))) вҠ“
        (mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ).range := by
  rw [conjGL, Subgroup.map_comap_eq, inf_comm]

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 conjugation-by-Оұ function `О“_p(Оұ) вҶ’ О“вӮҒ(N)`.**

Noncomputable function extracting from the existential
`Gamma_p_Оұ_conj_mem_Gamma1` the unique `Оҙ вҲҲ О“вӮҒ(N)` satisfying
`mapGL в„қ Оҙ = Оұ В· mapGL в„қ Оі В· ОұвҒ»В№`.  The element is unique by
`mapGL_injective` (the inclusion `SL(2, в„Ө) вҶ’ GL (Fin 2) в„қ` is injective),
so the function is well-defined.

**Reusable API.**  Combined with `Gamma_p_Оұ_conjBy_spec` (the defining
equality) this is the conjugation embedding `О“_p(Оұ) вҶӘ О“вӮҒ(N)` at the
SL(2, в„Ө)-element level. -/
noncomputable def Gamma_p_Оұ_conjBy (Оұ : GL (Fin 2) в„ҡ)
    (Оі : Gamma_p_Оұ (N := N) Оұ) : Gamma1 N :=
  вҹЁClassical.choose (Gamma_p_Оұ_conj_mem_Gamma1 Оұ Оі.property),
    (Classical.choose_spec (Gamma_p_Оұ_conj_mem_Gamma1 Оұ Оі.property)).1вҹ©

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 defining equality of `Gamma_p_Оұ_conjBy`.**

`mapGL в„қ (Gamma_p_Оұ_conjBy Оұ Оі : SL(2, в„Ө)) = Оұ В· mapGL в„қ Оі В· ОұвҒ»В№`
in `GL (Fin 2) в„қ`. -/
lemma Gamma_p_Оұ_conjBy_spec (Оұ : GL (Fin 2) в„ҡ)
    (Оі : Gamma_p_Оұ (N := N) Оұ) :
    (mapGL в„қ ((Gamma_p_Оұ_conjBy Оұ Оі : SL(2, в„Ө))) : GL (Fin 2) в„қ) =
      (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
        (mapGL в„қ ((Оі : SL(2, в„Ө))) : GL (Fin 2) в„қ) *
        ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№ :=
  (Classical.choose_spec (Gamma_p_Оұ_conj_mem_Gamma1 Оұ Оі.property)).2

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 injectivity of `Gamma_p_Оұ_conjBy`.**

The conjugation-by-Оұ function `О“_p(Оұ) вҶ’ О“вӮҒ(N)` is injective.

**Proof.**  If `Gamma_p_Оұ_conjBy Оұ ОівӮҒ = Gamma_p_Оұ_conjBy Оұ ОівӮӮ` as elements
of `О“вӮҒ(N)`, their `mapGL в„қ` lifts agree.  By `Gamma_p_Оұ_conjBy_spec`
applied to both sides, `Оұ В· mapGL в„қ ОівӮҒ В· ОұвҒ»В№ = Оұ В· mapGL в„қ ОівӮӮ В· ОұвҒ»В№`.
Cancellation in the GL(2, в„қ) group yields `mapGL в„қ ОівӮҒ = mapGL в„қ ОівӮӮ`,
and `mapGL_injective` recovers `ОівӮҒ = ОівӮӮ` as SL(2, в„Ө) elements; then
`Subtype.ext` finishes. -/
lemma Gamma_p_Оұ_conjBy_injective (Оұ : GL (Fin 2) в„ҡ) :
    Function.Injective (Gamma_p_Оұ_conjBy (N := N) Оұ) := by
  intro ОівӮҒ ОівӮӮ h
  apply Subtype.ext
  -- Step 1: from h, derive equality of mapGL lifts of conjugates.
  have h_mapGL :
      (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
        (mapGL в„қ ((ОівӮҒ : SL(2, в„Ө))) : GL (Fin 2) в„қ) *
        ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№ =
      (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
        (mapGL в„қ ((ОівӮӮ : SL(2, в„Ө))) : GL (Fin 2) в„қ) *
        ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№ := by
    have hh : (Gamma_p_Оұ_conjBy Оұ ОівӮҒ : SL(2, в„Ө)) =
        (Gamma_p_Оұ_conjBy Оұ ОівӮӮ : SL(2, в„Ө)) := congrArg Subtype.val h
    have h1 := Gamma_p_Оұ_conjBy_spec Оұ ОівӮҒ
    have h2 := Gamma_p_Оұ_conjBy_spec Оұ ОівӮӮ
    rw [вҶҗ h1, hh, h2]
  -- Step 2: cancel Оұ on left and ОұвҒ»В№ on right via calc.
  have h_Оі : (mapGL в„қ ((ОівӮҒ : SL(2, в„Ө))) : GL (Fin 2) в„қ) =
      mapGL в„қ ((ОівӮӮ : SL(2, в„Ө))) := by
    have h_step1 : (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
        (mapGL в„қ ((ОівӮҒ : SL(2, в„Ө))) : GL (Fin 2) в„қ) =
        (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) * mapGL в„қ ((ОівӮӮ : SL(2, в„Ө))) := by
      have hh1 := congrArg (В· * (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) h_mapGL
      simp only [inv_mul_cancel_right] at hh1
      exact hh1
    exact mul_left_cancel h_step1
  -- Step 3: mapGL_injective lifts to SL(2, в„Ө).
  exact mapGL_injective h_Оі

open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **T090 downstream bridge: slash by Оұ is `О“_p(Оұ)`-invariant on О“вӮҒ(N)-cusp forms.**

For a О“вӮҒ(N)-slash-invariant function `f : в„Қ вҶ’ в„Ӯ` (e.g. a О“вӮҒ(N)-cusp form's
underlying function) and any `Оұ вҲҲ GL (Fin 2) в„ҡ`, the function `f вҲЈ[k] Оұ`
is invariant under the slash action of `О“_p(Оұ) вҠҶ SL(2, в„Ө)` (lifted to
GL(2, в„қ) via `mapGL в„қ`).

**Mathematical content.** For Оі вҲҲ О“_p(Оұ), `Оұ Оі ОұвҒ»В№ вҲҲ О“вӮҒ(N)` (by
`Gamma_p_Оұ_conjBy_spec`), so `f вҲЈ[k] (Оұ Оі ОұвҒ»В№) = f`.  Rearranging via
slash composition: `(f вҲЈ[k] Оұ) вҲЈ[k] Оі = f вҲЈ[k] Оұ`.

**Role for h_HeckeFD_swap.** This identifies `f вҲЈ[k] Оұ` as a function
invariant under `О“_p(Оұ)` slash.  Combined with `[О“вӮҒ(N) : О“_p(Оұ)]`-finite
index, the integral `вҲ«_{Оұ вҖў О“_p(Оұ)-FD} (f вҲЈ[k] Оұ)` is well-defined and
relates to `вҲ«_{О“вӮҒ(N)-FD} f` via index multiplicity, giving the
fundamental-domain transport step underlying DS Thm 5.5.3.

This is the **first downstream consumer** of the О“_p(Оұ) / `conjBy`
infrastructure on the Hecke-FD bridge route. -/
lemma slash_Оұ_Gamma_p_Оұ_invariant (Оұ : GL (Fin 2) в„ҡ)
    (f : в„Қ вҶ’ в„Ӯ)
    (hf : вҲҖ Оҙ вҲҲ Gamma1 N,
      f вҲЈ[k] ((mapGL в„қ Оҙ : GL (Fin 2) в„қ)) = f)
    {Оі : SL(2, в„Ө)} (hОі : Оі вҲҲ Gamma_p_Оұ (N := N) Оұ) :
    (f вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))) вҲЈ[k]
      ((mapGL в„қ Оі : GL (Fin 2) в„қ)) =
    f вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) := by
  obtain вҹЁОҙ, hОҙ_mem, hОҙ_eqвҹ© := Gamma_p_Оұ_conj_mem_Gamma1 Оұ hОі
  -- From hОҙ_eq: mapGL в„қ Оҙ = Оұ' * mapGL в„қ Оі * Оұ'вҒ»В№ where Оұ' = Оұ.map (Rat.castHom в„қ).
  -- So: Оұ' * mapGL в„қ Оі = mapGL в„қ Оҙ * Оұ'.
  have hОұОі : (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) *
      (mapGL в„қ Оі : GL (Fin 2) в„қ) =
      (mapGL в„қ Оҙ : GL (Fin 2) в„қ) * (Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ) := by
    rw [hОҙ_eq]; group
  -- Compute (f вҲЈ Оұ) вҲЈ Оі via slash composition + О“вӮҒ(N)-invariance.
  rw [вҶҗ SlashAction.slash_mul, hОұОі, SlashAction.slash_mul, hf Оҙ hОҙ_mem]

open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **T090 cusp-form specialization of `slash_Оұ_Gamma_p_Оұ_invariant`.**

For a О“вӮҒ(N)-cusp form `f` and any Оұ вҲҲ GL (Fin 2) в„ҡ, the slashed function
`вҮ‘f вҲЈ[k] Оұ` is invariant under the slash action of `О“_p(Оұ) вҠҶ SL(2, в„Ө)`.

Direct corollary of `slash_Оұ_Gamma_p_Оұ_invariant` instantiated with the
underlying function `вҮ‘f`, using `slash_Gamma1_eq` (О“вӮҒ(N)-invariance of
the cusp form's underlying function via the SL slash action) plus
`ModularForm.SL_slash` to bridge to the GL slash action via `mapGL в„қ`.

**Reusable downstream API.** This is the cusp-form-shaped consumer of
the О“_p(Оұ) / `conjBy` infrastructure вҖ” directly usable by integral
identities over О“вӮҒ(N)-FD where the integrand is a О“_p(Оұ)-invariant
Оұ-slashed cusp form. -/
lemma slash_Оұ_Gamma_p_Оұ_invariant_cuspForm
    (Оұ : GL (Fin 2) в„ҡ) (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    {Оі : SL(2, в„Ө)} (hОі : Оі вҲҲ Gamma_p_Оұ (N := N) Оұ) :
    ((вҮ‘f) вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))) вҲЈ[k]
      ((mapGL в„қ Оі : GL (Fin 2) в„қ)) =
    (вҮ‘f) вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) := by
  refine slash_Оұ_Gamma_p_Оұ_invariant Оұ (вҮ‘f) ?_ hОі
  intro Оҙ hОҙ
  rw [show ((mapGL в„қ Оҙ : GL (Fin 2) в„қ)) =
        (((Оҙ : SL(2, в„Ө)) : GL (Fin 2) в„қ)) from rfl, вҶҗ ModularForm.SL_slash]
  exact slash_Gamma1_eq f Оҙ hОҙ

open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **T090 finite-index FD-transport reduction (statement-level).**

For a О“вӮҒ(N)-cusp form `f` and Оұ вҲҲ GL (Fin 2) в„ҡ, the Petersson-type
integral of `(вҮ‘f вҲЈ[k] Оұ) В· (h)` over a О“вӮҒ(N)-fundamental domain `D`
(for any О“_p(Оұ)-invariant integrand `h`) is captured by the slash
invariance:
```
((вҮ‘f вҲЈ[k] Оұ) вҲЈ[k] (mapGL Оі : GL (Fin 2) в„қ)) = вҮ‘f вҲЈ[k] Оұ   for Оі вҲҲ О“_p(Оұ).
```

**Reduction theorem.**  This is the **last build-clean reduction
checkpoint** before the genuinely missing analytic content: the
finite-index FD-transport theorem that, given a `О“_p(Оұ)`-FD `D_p` and
a О“вӮҒ(N)-FD `DвӮҒ`, expresses
```
вҲ«_{D_p} F dОј_hyp = [О“вӮҒ(N) : О“_p(Оұ)] В· вҲ«_{DвӮҒ} F dОј_hyp
```
for `F` a О“_p(Оұ)-invariant function (NOT О“вӮҒ(N)-invariant generally),
or equivalently
```
вҲ«_{DвӮҒ} F dОј_hyp = (1/[О“вӮҒ(N) : О“_p(Оұ)]) В· вҲ‘_{Оі вҲҲ О“_p(Оұ) \ О“вӮҒ(N)} вҲ«_{Оі вҖў DвӮҒ} F dОј_hyp.
```

**Reduction to representative-bijection / tile-disjointness.**  The
above formula reduces (via the abstract `Subgroup.subgroupOf`
finite-index theory + `MeasureTheory.IsFundamentalDomain`-API) to the
following named statement:

> **`Gamma_p_Оұ_FD_finite_index_decomp` (proposed downstream).**
> For О“p = `Gamma_p_Оұ Оұ` and a О“вӮҒ(N)-FD `D` (e.g.
> `Gamma1_fundDomain N`), there is a finite set of coset
> representatives `S : Finset SL(2, в„Ө)` for `О“p \ О“вӮҒ(N)` such that
> `вЁҶ_{Оі вҲҲ S} Оі вҖў D` is a О“p-FD (modulo measure-zero overlap).

This statement is the precise tile-bijection content needed to feed
`h_HeckeFD_swap`.  It depends on:
* Finite quotient `О“вӮҒ(N) / О“p` (have: via
  `Gamma_p_Оұ_finiteIndex_in_Gamma1` + `Subgroup.fintypeQuotientOfFiniteIndex`);
* Existence of an explicit set of right-coset representatives
  (have: via `Quotient.out` + `Finset.image` over the quotient);
* AE-disjointness of translates `Оі вҖў D` for distinct Оі
  (have: via `IsFundamentalDomain.pairwise_aedisjoint_of_smul`,
  applied to D as a О“вӮҒ(N)-FD);
* Coverage of a О“p-FD by the union (need: a finite-cover lemma
  bridging the SL/О“p double-coset to the SL/О“вӮҒ(N) tiling, currently
  the only **non-mechanical residual**).

**Status.**  This packet captures everything mechanically derivable
from the О“_p(Оұ) / `conjBy` infrastructure.  The next genuinely
analytic theorem-scale step is the finite-cover lemma for
`О“p \ О“вӮҒ(N)` translates of the О“вӮҒ(N)-FD; closing it would compose
with the existing `peterssonInner` aggregate machinery to discharge
the last `h_HeckeFD_swap` residual.

**Reusable witness.**  This lemma packages the slash-invariance
witness needed by the finite-cover lemma: any Оі-translate `Оі вҖў D` of a
О“вӮҒ(N)-FD has the integrand `вҮ‘f вҲЈ[k] Оұ` correctly transformed under
the slash action via `mapGL в„қ Оі`.  Concretely, for any Оі вҲҲ О“_p(Оұ),
slashing by Оі leaves `вҮ‘f вҲЈ[k] Оұ` invariant. -/
lemma slash_Оұ_Gamma_p_Оұ_invariant_at_FD_decomp_witness
    (Оұ : GL (Fin 2) в„ҡ) (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    вҲҖ {Оі : SL(2, в„Ө)}, Оі вҲҲ Gamma_p_Оұ (N := N) Оұ вҶ’
      ((вҮ‘f) вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))) вҲЈ[k]
        ((mapGL в„қ Оі : GL (Fin 2) в„қ)) =
      (вҮ‘f) вҲЈ[k] ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) :=
  fun {Оі} hОі => slash_Оұ_Gamma_p_Оұ_invariant_cuspForm Оұ f hОі

