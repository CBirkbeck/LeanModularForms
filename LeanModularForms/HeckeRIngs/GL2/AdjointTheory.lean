`q.out`-coset reps, then `Finset.sum_congr` over `q` discharged by
`h_per_q_LHS_eq_closed_branch_sum` per q. -/
private theorem petN_LHS_eq_closed_branch_sum_via_per_q
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (tile : SL(2, в„Ө) в§ё Gamma1 N вҶ’ Fin (p + 1) вҶ’ Set UpperHalfPlane)
    (h_per_q_LHS_eq_closed_branch_sum : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) =
      peterssonInner k (tile q 0) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ))) +
        вҲ‘ b : Fin p, peterssonInner k (tile q b.succ) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ)))) :
    petN (heckeT_p_cusp k p hp hpN f) g =
      вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
        (peterssonInner k (tile q 0) вҮ‘f
            (вҮ‘g вҲЈ[k]
              ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                  GL (Fin 2) в„қ))) +
          вҲ‘ b : Fin p, peterssonInner k (tile q b.succ) вҮ‘f
            (вҮ‘g вҲЈ[k]
              ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                  GL (Fin 2) в„қ)))) := by
  show вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) = _
  exact Finset.sum_congr rfl fun q _ => h_per_q_LHS_eq_closed_branch_sum q

