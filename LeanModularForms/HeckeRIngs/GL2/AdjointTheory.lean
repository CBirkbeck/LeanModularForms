    (mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta N p hp.pos hpN b)
    f g
    (h_Оұ_canonical_form_of_balanced p hp hpN
      (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) f g
      (balanced_Оұ_of_aggregate_FD_balance p hp hpN
        (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ)
        (glMap_T_p_upper_det_pos p hp.pos b) f g
