/-- **Phase M (c) вҖ” canonical FD is also a FD for `(О“_p(Оұ)).map SL2Z_to_PSL2R`.**

Lifts the PSL(2, в„Ө)-side FD `Gamma_p_Оұ_fundDomain_PSL_canonical Оұ` (for the
PSL(2, в„Ө)-subgroup `image_Gamma_p_Оұ_PSL Оұ`) to a FD at the PSL(2, в„қ)
ambient (for the PSL(2, в„қ)-subgroup `(О“_p(Оұ)).map SL2Z_to_PSL2R`).

Mirror of `isFundamentalDomain_Gamma1_PSL_R` (`PeterssonLevelN.lean:741`)
at the О“_p(Оұ) subgroup.  Uses `Subgroup.equivMapOfInjective` for the
equivalence `image_Gamma_p_Оұ_PSL вүғ* (image_Gamma_p_Оұ_PSL).map PSL2Z_to_PSL2R`
(via `PSL2Z_to_PSL2R_injective`), then `IsFundamentalDomain.image_of_equiv`
at the identity `Equiv.refl в„Қ`. -/
theorem isFundamentalDomain_Gamma_p_Оұ_PSL_canonical_at_PSL_R
    (Оұ : GL (Fin 2) в„ҡ) :
    IsFundamentalDomain ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R)
      (Gamma_p_Оұ_fundDomain_PSL_canonical (N := N) Оұ) Ој_hyp := by
  rw [map_SL2Z_to_PSL2R_eq_image_Gamma_p_Оұ_PSL_R]
  have h_base : IsFundamentalDomain (image_Gamma_p_Оұ_PSL (N := N) Оұ)
      (Gamma_p_Оұ_fundDomain_PSL_canonical (N := N) Оұ) Ој_hyp :=
    isFundamentalDomain_Gamma_p_Оұ_PSL_canonical (N := N) Оұ
  have h_image_eq : (Equiv.refl в„Қ) '' (Gamma_p_Оұ_fundDomain_PSL_canonical (N := N) Оұ) =
      Gamma_p_Оұ_fundDomain_PSL_canonical (N := N) Оұ := by
    simp
  rw [вҶҗ h_image_eq]
  refine h_base.image_of_equiv (Equiv.refl в„Қ)
    (MeasureTheory.Measure.QuasiMeasurePreserving.id Ој_hyp)
    ((Subgroup.equivMapOfInjective (image_Gamma_p_Оұ_PSL (N := N) Оұ)
      PSL2Z_to_PSL2R PSL2Z_to_PSL2R_injective).toEquiv.symm) ?_
  intro g П„
  show (Equiv.refl в„Қ) (((Subgroup.equivMapOfInjective
        (image_Gamma_p_Оұ_PSL (N := N) Оұ) PSL2Z_to_PSL2R
        PSL2Z_to_PSL2R_injective).toEquiv.symm g :
        image_Gamma_p_Оұ_PSL (N := N) Оұ) вҖў П„) =
      ((g : (image_Gamma_p_Оұ_PSL (N := N) Оұ).map PSL2Z_to_PSL2R) :
        PSL(2, в„қ)) вҖў (Equiv.refl в„Қ) П„
  simp only [Equiv.refl_apply]
  set g' : image_Gamma_p_Оұ_PSL (N := N) Оұ :=
    (Subgroup.equivMapOfInjective (image_Gamma_p_Оұ_PSL (N := N) Оұ)
      PSL2Z_to_PSL2R PSL2Z_to_PSL2R_injective).toEquiv.symm g with hg'_def
  have h_g_coe :
      ((g : (image_Gamma_p_Оұ_PSL (N := N) Оұ).map PSL2Z_to_PSL2R) : PSL(2, в„қ)) =
        PSL2Z_to_PSL2R (g' : PSL(2, в„Ө)) := by
    have : ((Subgroup.equivMapOfInjective (image_Gamma_p_Оұ_PSL (N := N) Оұ)
        PSL2Z_to_PSL2R PSL2Z_to_PSL2R_injective) g' : PSL(2, в„қ)) =
        PSL2Z_to_PSL2R (g' : PSL(2, в„Ө)) :=
      Subgroup.coe_equivMapOfInjective_apply _ _ _ _
    rw [вҶҗ this]
    congr 1
    exact ((Subgroup.equivMapOfInjective (image_Gamma_p_Оұ_PSL (N := N) Оұ)
      PSL2Z_to_PSL2R PSL2Z_to_PSL2R_injective).toEquiv.apply_symm_apply g).symm
  rw [h_g_coe, PSL2Z_to_PSL2R_smul_eq]
  rfl

