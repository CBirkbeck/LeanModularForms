theorem sum_SL_tile_eq_fiberwise_PSL_tile_Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ)
    (h : в„Қ вҶ’ в„Ӯ)
    (h_inv : вҲҖ Оі вҲҲ Gamma_p_Оұ (N := N) Оұ, вҲҖ П„ : в„Қ, h (Оі вҖў П„) = h П„) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
        вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp =
      вҲ‘ q' : PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ,
        (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
          slToPslQuot_Gamma_p_Оұ (N := N) Оұ q = q')).card вҖў
            вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp := by
  calc вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
          вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp
      = вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
          вҲ« П„ in ((slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out : PSL(2, в„Ө))вҒ»В№ вҖў
            (fdo : Set в„Қ), h П„ вҲӮОј_hyp :=
        Finset.sum_congr rfl fun q _ =>
          setIntegral_SL_tile_eq_PSL_tile_Gamma_p_Оұ (N := N) Оұ h h_inv q
    _ = вҲ‘ q' : PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ,
          вҲ‘ q вҲҲ Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
            slToPslQuot_Gamma_p_Оұ (N := N) Оұ q = q'),
            вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp :=
        (Finset.sum_fiberwise' Finset.univ
          (slToPslQuot_Gamma_p_Оұ (N := N) Оұ)
          (fun q' => вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp)).symm
    _ = вҲ‘ q' : PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ,
          (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
            slToPslQuot_Gamma_p_Оұ (N := N) Оұ q = q')).card вҖў
              вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp := by
        refine Finset.sum_congr rfl fun q' _ => ?_
        exact Finset.sum_const _

