            (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k ModularGroup.fd
            (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))
            (вҮ‘g вҲЈ[k]
              ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) := by
  show вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘(heckeT_p_cusp k p hp hpN
            (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) = _
  refine Finset.sum_congr rfl fun q _ => ?_
  rw [peterssonInner_SL_inv_eq_mapGL_inv]
  exact peterssonInner_heckeT_p_RHS_per_q_normalized p hp hpN
    (q.out : SL(2, в„Ө)) f g

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 residual slash-adjoint transfer helper at `ОІ = glMap T_p_lower`
with О“вӮҒ(N)-twist**: for each `q Оі : SL(2, в„Ө)` with `Оі вҲҲ Gamma1 N`,

```
peterssonInner k fd (вҮ‘f вҲЈ[k] mapGL qвҒ»В№)
    (вҮ‘g вҲЈ[k] (glMap T_p_lower * mapGL Оі * mapGL qвҒ»В№))
= peterssonInner k (glMap T_p_lower вҖў mapGL (q * ОівҒ»В№)вҒ»В№ вҖў fd)
    (вҮ‘f вҲЈ[k] glMap T_p_upper(0))
    вҮ‘g
```

**Proof.** Introduce the twisted coset rep `q' := q * ОівҒ»В№`.  Then
`mapGL q'вҒ»В№ = mapGL Оі * mapGL qвҒ»В№` (via `map_mul` on the MonoidHom `mapGL в„қ`
composed with `(q * ОівҒ»В№)вҒ»В№ = Оі * qвҒ»В№`).  The `mapGL Оі` slash on `вҮ‘f` is
absorbed by `slash_Gamma1_eq` (using `hОі : Оі вҲҲ Gamma1 N`), so
`вҮ‘f вҲЈ[k] mapGL qвҒ»В№ = вҮ‘f вҲЈ[k] mapGL q'вҒ»В№`.  After these rewrites the LHS is in
the direct form accepted by `peterssonInner_slash_adjoint_coset_right` at
`ОІ = glMap T_p_lower`, giving the domain-shifted form whose `f`-slot is
`вҮ‘f вҲЈ[k] peterssonAdj (glMap T_p_lower)`.  Finally
`peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero` rewrites the `f`-slot
to `вҮ‘f вҲЈ[k] glMap T_p_upper(0)`.

**Role in T128 closure.**  This is the per-q per-branch slash-adjoint transfer
for the RHS of `petN_heckeT_p_adjoint_standard_form`: specialising `Оі` to the
`ds_p_plus_one_family_Gamma1_factor` correction factor for each branch yields
the single-tile transfer for M_вҲһ (`Оі = gamma0_T_p_upper_Gamma1_factor 0 *
M_infty_Gamma1_factor 0`) or upper b (`Оі = gamma0_T_p_upper_Gamma1_factor b`).
Each branch's О“вӮҒ(N)-membership is supplied by
`ds_p_plus_one_family_Gamma1_factor_mem_Gamma1`. -/
private lemma peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q Оі : SL(2, в„Ө)) (hОі : Оі вҲҲ Gamma1 N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘g вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    peterssonInner k
        ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
          (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q * ОівҒ»В№)вҒ»В№ : GL (Fin 2) в„қ) вҖў
            (ModularGroup.fd : Set UpperHalfPlane)))
        (вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
        вҮ‘g := by
  -- Twisted coset rep: q' = q * ОівҒ»В№, so q'вҒ»В№ = Оі * qвҒ»В№.
  have hq'_inv : ((q * ОівҒ»В№)вҒ»В№ : SL(2, в„Ө)) = Оі * qвҒ»В№ := by
    rw [mul_inv_rev, inv_inv]
  -- О“вӮҒ-invariance absorbs the mapGL Оі slash on f.
  have h_slash_Оі : (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі :
      GL (Fin 2) в„қ)) = вҮ‘f := by
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) =
          ((Оі : SL(2, в„Ө)) : GL (Fin 2) в„қ) from rfl, вҶҗ ModularForm.SL_slash]
    exact slash_Gamma1_eq f Оі hОі
  -- Rewrite goal LHS: g-slash chain `T_p_lower * mapGL Оі * mapGL qвҒ»В№ =
  -- T_p_lower * mapGL (q * ОівҒ»В№)вҒ»В№`.
  have h_g_slash_chain :
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Оі : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) ((q * ОівҒ»В№)вҒ»В№ : SL(2, в„Ө)) :
          GL (Fin 2) в„қ) := by
    rw [hq'_inv, map_mul, вҶҗ mul_assoc]
  -- Rewrite goal LHS: f-slash `mapGL qвҒ»В№ = mapGL (q * ОівҒ»В№)вҒ»В№` via О“вӮҒ-inv.
  have h_f_slash_eq :
      (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
      (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) ((q * ОівҒ»В№)вҒ»В№ : SL(2, в„Ө)) :
        GL (Fin 2) в„қ)) := by
    rw [hq'_inv, map_mul, SlashAction.slash_mul, h_slash_Оі]
  rw [h_g_slash_chain, h_f_slash_eq]
  -- Determinant positivity of `glMap T_p_lower`: det = p > 0.
  have h_det_pos : 0 < (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map
        (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  rw [peterssonInner_slash_adjoint_coset_right
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) h_det_pos (q * ОівҒ»В№) вҮ‘f вҮ‘g]
  rw [peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero p hp.pos]

/-- **T128 R2 вҖ” M_вҲһ branch tile-domain matrix identity.**  The algebraic
rewrite exposing the LHS M_вҲһ tile
`glMap M_вҲһ В· mapGL qвҒ»В№` as the RHS shifted-tile form
`glMap T_p_lower В· mapGL (q В· Оі_MвҒ»В№)вҒ»В№` **up to a leading
`mapGL ОівӮҖвҒ»В№` prefix**, where
`ОівӮҖ := (adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)` and
`Оі_M := gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
  M_infty_Gamma1_factor N p hpN 0`.

Derived by left-multiplying the landed matrix identity
`mapGL ОівӮҖ В· glMap M_вҲһ = glMap T_p_lower В· mapGL Оі_M`
(`mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon`) on the right
by `mapGL qвҒ»В№` and regrouping, using
`(q В· Оі_MвҒ»В№)вҒ»В№ = Оі_M В· qвҒ»В№` (from `mul_inv_rev` + `inv_inv`).

**Role in T128 closure (R2 of the shifted-tile вҶ” union-tile bridge).**
Exposes the precise prefix discrepancy between LHS M_вҲһ tile and RHS
shifted M_вҲһ tile; the leading `mapGL ОівӮҖвҒ»В№ = (mapGL adjointGamma0Rep)вҒ»В№`
factor will cancel against the residual slot-3 `вҲЈ[k] mapGL
adjointGamma0Rep` slash in the LHS union-tile form via R1 (slot swap
+ slash redistribution), yielding the per-q bridge equality.  The
analogous upper-family identity follows from
`mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta` by the same
rearrangement. -/
private lemma glMap_M_infty_mul_mapGL_inv_eq_gamma0_inv_mul_shifted
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (q : SL(2, в„Ө)) :
    (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
          GL (Fin 2) в„қ)вҒ»В№ *
        ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q * (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)вҒ»В№)вҒ»В№ :
            GL (Fin 2) в„қ)) := by
  have h_core :=
    mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon N p hp.pos hpN
  have h_inv_rewrite :
      ((q * (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0)вҒ»В№)вҒ»В№ : SL(2, в„Ө)) =
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0) * qвҒ»В№ := by
    rw [mul_inv_rev, inv_inv]
  rw [h_inv_rewrite, map_mul,
    вҶҗ mul_assoc (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ), вҶҗ h_core]
  group

/-- **T128 R1 step вҖ” M_вҲһ branch LHS slot-3 collapse to `peterssonAdj M_вҲһ`.**
Strictly reducing one-rewrite helper that applies
`slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_upper_zero_slash_gamma0` in
reverse to rewrite the LHS M_вҲһ slot-3

  `(вҮ‘g вҲЈ[k] glMap T_p_upper 0) вҲЈ[k] mapGL ОівӮҖ`

as the single `peterssonAdj`-slashed form

  `вҮ‘g вҲЈ[k] peterssonAdj (glMap M_вҲһ)`.

This is the prerequisite rewrite for the slot-2/slot-3 swap in the full
M_вҲһ branch R1/R2 integral bridge: after this identity, the term becomes
syntactically accepted by `peterssonInner_slash_adjoint_right` at
`Оұ = peterssonAdj (glMap M_вҲһ)`, which moves the slash from slot-3 to slot-2
and produces an intermediate `(вҮ‘f вҲЈ[k] peterssonAdjВІ(glMap M_вҲһ))` form.

**Remaining obligations toward the full M_вҲһ bridge** (out of scope for
this helper):
* `peterssonAdj_peterssonAdj` (double adjoint is identity on
  positive-det GL elements) вҖ” not yet in the file.
* Domain equality
  `(glMap M_вҲһ В· mapGL qвҒ»В№) вҖў fd = (peterssonAdj (glMap M_вҲһ)) вҖў D'`
  for the shifted-tile domain `D' = glMap T_p_lower вҖў mapGL (q В· Оі_MвҒ»В№)вҒ»В№ вҖў fd`
  вҖ” requires the matching matrix identity routed through R2. -/
private lemma peterssonInner_LHS_M_infty_tile_g_slot_to_peterssonAdj
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    UpperHalfPlane.peterssonInner k
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)))
      вҮ‘f
      ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) =
    UpperHalfPlane.peterssonInner k
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)))
      вҮ‘f
      (вҮ‘g вҲЈ[k]
        peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)) := by
  rw [вҶҗ slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_upper_zero_slash_gamma0
      p hp hpN g]

/-- **T128 R2 вҖ” upper-family branch tile-domain matrix identity.**  The
upper-family analogue of `glMap_M_infty_mul_mapGL_inv_eq_gamma0_inv_mul_shifted`:
for each `b : в„•` (consumed at `b вҲҲ Finset.range p`), the LHS tile
`glMap (T_p_upper p hp.pos b) В· mapGL qвҒ»В№` rewrites to the RHS shifted
form `glMap T_p_lower В· mapGL (q В· Оі_bвҒ»В№)вҒ»В№` with the **same leading
`mapGL ОівӮҖвҒ»В№ = (mapGL adjointGamma0Rep)вҒ»В№` prefix**, where
`Оі_b := gamma0_T_p_upper_Gamma1_factor N p hpN b`.

Proof mirrors the M_вҲһ branch: right-multiply
`mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta` by `mapGL qвҒ»В№`,
regroup via `(q В· Оі_bвҒ»В№)вҒ»В№ = Оі_b В· qвҒ»В№`, close with `group`. -/
private lemma glMap_T_p_upper_mul_mapGL_inv_eq_gamma0_inv_mul_shifted
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•) (q : SL(2, в„Ө)) :
    (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
          GL (Fin 2) в„қ)вҒ»В№ *
        ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q * (gamma0_T_p_upper_Gamma1_factor N p hpN b)вҒ»В№)вҒ»В№ :
            GL (Fin 2) в„қ)) := by
  have h_core :=
    mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta N p hp.pos hpN b
  have h_inv_rewrite :
      ((q * (gamma0_T_p_upper_Gamma1_factor N p hpN b)вҒ»В№)вҒ»В№ : SL(2, в„Ө)) =
      gamma0_T_p_upper_Gamma1_factor N p hpN b * qвҒ»В№ := by
    rw [mul_inv_rev, inv_inv]
  rw [h_inv_rewrite, map_mul,
    вҶҗ mul_assoc (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ), вҶҗ h_core]
  group

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 per-q RHS normalized вҶ’ shifted-tile bridge**: applies the
per-branch slash-adjoint transfer helper
`peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist` pointwise to
each branch of the normalized per-q RHS form produced by
`peterssonInner_heckeT_p_RHS_per_q_normalized`, specialising the О“вӮҒ(N)
twist factor to the `ds_p_plus_one` correction factors:

* M_вҲһ branch: `Оі = gamma0_T_p_upper_Gamma1_factor 0 * M_infty_Gamma1_factor 0`
  (О“вӮҒ-membership via
  `gamma0_T_p_upper_Gamma1_factor_zero_mul_M_infty_Gamma1_factor_zero_mem_Gamma1`).
* upper-b branch: `Оі = gamma0_T_p_upper_Gamma1_factor b` (О“вӮҒ-membership via
  `gamma0_T_p_upper_Gamma1_factor_mem_Gamma1`).

Produces the per-q sum-of-shifted-tiles form whose f-slot is the
b-independent `вҮ‘f вҲЈ[k] glMap T_p_upper(0)`, with raw `вҮ‘g` in the third slot
and domain `glMap T_p_lower вҖў mapGL (q * ОівҒ»В№)вҒ»В№ вҖў fd`.

**Role in T128 closure.**  Consumes
`peterssonInner_heckeT_p_RHS_per_q_normalized` (RHS of the `=`) branch-by-
branch and exposes the T_p_lower-shifted-tile / T_p_upper(0)-slashed-f form.
The residual toward `petN_heckeT_p_adjoint_standard_form` is then a per-q
equality between this shifted-tile form and the LHS
union-tile form supplied by `peterssonInner_heckeT_p_LHS_per_q_to_union_tiles`
вҖ” requiring a separate tile-equality / conj-symm bridge (not in scope for
this helper). -/
private lemma peterssonInner_heckeT_p_RHS_per_q_normalized_shifted_tile
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
              GL (Fin 2) в„қ))) +
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
