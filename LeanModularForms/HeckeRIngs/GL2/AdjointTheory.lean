/-- **Phase M (b) вҖ” fiber-invariance of the SL-tile integral at H = О“_p(Оұ).**

Mirror of `setIntegral_SL_tile_eq_PSL_tile` (`PeterssonLevelN.lean:1044`)
at the О“_p(Оұ) subgroup.  For a `О“_p(Оұ)`-invariant function `h`, the integral
over the SL-tile `q.outвҒ»В№ вҖў fdo` (q вҲҲ SL в§ё О“_p(Оұ)) equals the integral over
the corresponding PSL-tile via the natural quotient map. -/
theorem setIntegral_SL_tile_eq_PSL_tile_Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ)
    (h : в„Қ вҶ’ в„Ӯ)
    (h_inv : вҲҖ Оі вҲҲ Gamma_p_Оұ (N := N) Оұ, вҲҖ П„ : в„Қ, h (Оі вҖў П„) = h П„)
    (q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) :
    вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp =
      вҲ« П„ in ((slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out : PSL(2, в„Ө))вҒ»В№ вҖў
        (fdo : Set в„Қ), h П„ вҲӮОј_hyp := by
  have h_quot_eq :
      (QuotientGroup.mk (QuotientGroup.mk q.out : PSL(2, в„Ө)) :
        PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ) =
      QuotientGroup.mk ((slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out : PSL(2, в„Ө)) := by
    have h1 : slToPslQuot_Gamma_p_Оұ (N := N) Оұ q =
        QuotientGroup.mk (QuotientGroup.mk q.out : PSL(2, в„Ө)) := by
      conv_lhs => rw [вҶҗ q.out_eq]
      rfl
    exact h1.symm.trans (slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out_eq.symm
  rw [QuotientGroup.eq] at h_quot_eq
  obtain вҹЁОі, hОі_mem, hОі_eqвҹ© := h_quot_eq
  have h_eq_PSL : ((slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out : PSL(2, в„Ө)) =
      QuotientGroup.mk q.out * QuotientGroup.mk Оі := by
    have h_mul : (QuotientGroup.mk q.out : PSL(2, в„Ө)) *
        ((QuotientGroup.mk q.out : PSL(2, в„Ө))вҒ»В№ *
          (slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out) =
        (slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out := by group
    rw [вҶҗ h_mul, вҶҗ hОі_eq]
    rfl
  rw [show ((slToPslQuot_Gamma_p_Оұ (N := N) Оұ q).out : PSL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ) =
      ((QuotientGroup.mk Оі : PSL(2, в„Ө))вҒ»В№ вҖў
        ((QuotientGroup.mk q.out : PSL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ))) from by
      rw [h_eq_PSL, mul_inv_rev, mul_smul]]
  -- Bridge PSL-action вҶ” SL-action via PSL_smul_coe (which is rfl).
  have h_psl_q : ((QuotientGroup.mk q.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ) =
      (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ) := by
    rw [show ((QuotientGroup.mk q.out : PSL(2, в„Ө)))вҒ»В№ =
          (QuotientGroup.mk q.outвҒ»В№ : PSL(2, в„Ө)) from
        (QuotientGroup.mk_inv _ _).symm]
    rfl
  have h_psl_Оі : ((QuotientGroup.mk Оі : PSL(2, в„Ө)))вҒ»В№ вҖў
        ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ)) =
      (Оі : SL(2, в„Ө))вҒ»В№ вҖў ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ)) := by
    rw [show ((QuotientGroup.mk Оі : PSL(2, в„Ө)))вҒ»В№ =
          (QuotientGroup.mk ОівҒ»В№ : PSL(2, в„Ө)) from
        (QuotientGroup.mk_inv _ _).symm]
    rfl
  rw [h_psl_q, h_psl_Оі]
  symm
  -- Goal: вҲ« П„ in (ОівҒ»В№ : SL) вҖў (q.outвҒ»В№ вҖў fdo), h П„ dОј
  --      = вҲ« П„ in q.outвҒ»В№ вҖў fdo, h П„ dОј
  rw [show ((ОівҒ»В№ : SL(2, в„Ө)) вҖў ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ)) : Set в„Қ) =
      (fun П„ => (ОівҒ»В№ : SL(2, в„Ө)) вҖў П„) '' ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ)) from rfl,
    (measurePreserving_smul (ОівҒ»В№ : SL(2, в„Ө)) Ој_hyp).setIntegral_image_emb
      (measurableEmbedding_const_smul _)]
  congr 1; ext П„
  -- `obtain вҹЁОі, hОі_mem, hОі_eqвҹ© := h_quot_eq` already destructured the image-subgroup
  -- membership into `Оі : SL(2, в„Ө)`, `hОі_mem : Оі вҲҲ Gamma_p_Оұ Оұ`, and the PSL-equality
  -- `hОі_eq`.  Apply `h_inv` directly at `ОівҒ»В№`.
  exact h_inv ОівҒ»В№ ((Gamma_p_Оұ (N := N) Оұ).inv_mem hОі_mem) П„

