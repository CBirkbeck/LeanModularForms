open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 per-q slash-adjoint inverse for `(T_p_lower В· Оі_M)`-tile**
(M_вҲһ branch, fd-domain LHS-distributed form).

For each `q : SL(2, в„Ө)`, the `(T_p_lower В· Оі_M)`-shifted-domain `peterssonInner`
with q-independent slot-2 `вҮ‘(вҹЁpвҒ»В№вҹ©g) вҲЈ[k] T_p_upper(0)` equals the fd-domain
LHS-distributed M_вҲһ branch summand:

```
peterssonInner k ((T_p_lower В· Оі_M В· qвҒ»В№) вҖў fd) вҮ‘f (вҮ‘(вҹЁpвҒ»В№вҹ©g) вҲЈ T_p_upper(0))
= peterssonInner k fd (вҮ‘f вҲЈ T_p_lower В· Оі_M В· qвҒ»В№) (вҮ‘g вҲЈ ОівӮҖ В· qвҒ»В№)
```

Per-q algebraic identity (no Пғ_p Q-permutation involved). Uses
`peterssonInner_slash_adjoint_coset` at ОІ = `glMap T_p_lower * mapGL Оі_M`,
the matrix factorization `peterssonAdj ОІ = mapGL Оі_MвҒ»В№ * glMap T_p_upper(0)`
(via `peterssonAdj_mul`, `peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero`,
`peterssonAdj_mapGL_SL_eq_inv`, `вҶҗ map_inv`), the О“вӮҒ(N)-trivial slash on the
Оі_MвҒ»В№ factor (via `slash_Gamma1_eq` +
`gamma0_T_p_upper_Gamma1_factor_zero_mul_M_infty_Gamma1_factor_zero_mem_Gamma1`),
and the diamond-shift identity `g вҲЈ mapGL ОівӮҖ = вҮ‘(вҹЁpвҒ»В№вҹ©g)` (via `diamondOpCusp_eq`
+ `adjointGamma0Rep_units`).

**Role.**  Per-summand for the next strong helper that converts the iUnion form
(output of `peterssonInner_sum_T_p_lower_gamma_M_tile_to_iUnion`) into the
RHS prefactored q-sum form via composition with
`M_infty_branch_sum_slash_adjoint_reindex_prefactored`. -/
private lemma peterssonInner_T_p_lower_gamma_M_tile_per_q_eq_fd_LHS_dist
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k
        (((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane))
        вҮ‘f
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
          (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) =
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k]
          (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) := by
  -- Determinant positivity for ОІ = glMap T_p_lower * mapGL Оі_M.
  have h_T_p_lower_det_pos : 0 <
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map
        (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  have h_gamma_M_det_one : (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
    rw [show (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
          M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix
          (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
            M_infty_Gamma1_factor N p hpN 0).val) from by
      rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det,
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0).property]
    simp
  have h_ОІ_det : 0 <
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
            M_infty_Gamma1_factor N p hpN 0))).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
          M_infty_Gamma1_factor N p hpN 0)) : GL (Fin 2) в„қ).val.det
    rw [Units.val_mul, Matrix.det_mul, h_gamma_M_det_one, mul_one]
    exact h_T_p_lower_det_pos
  -- Rewrite RHS slot-2: вҮ‘g вҲЈ (ОівӮҖ * qвҒ»В№) = вҮ‘(вҹЁpвҒ»В№вҹ©g) вҲЈ qвҒ»В№.
  have h_g_slash : (вҮ‘g вҲЈ[k]
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) := by
    rw [SlashAction.slash_mul]
    congr 1
    show вҮ‘g вҲЈ[k] _ = вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  -- Rewrite the LHS slot-2: (вҮ‘(вҹЁpвҒ»В№вҹ©g) вҲЈ T_p_upper(0)) = (вҮ‘(вҹЁpвҒ»В№вҹ©g) вҲЈ peterssonAdj ОІ).
  have h_pa_simp : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
      (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        peterssonAdj ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)))) := by
    rw [peterssonAdj_mul, peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero,
      peterssonAdj_mapGL_SL_eq_inv, вҶҗ map_inv,
      SlashAction.slash_mul]
    congr 1
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)вҒ»В№) : GL (Fin 2) в„қ) =
        ((((gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)вҒ»В№) : SL(2, в„Ө)) :
          GL (Fin 2) в„қ) from rfl,
      вҶҗ ModularForm.SL_slash]
    exact (slash_Gamma1_eq (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0)вҒ»В№
      (Subgroup.inv_mem _
        (gamma0_T_p_upper_Gamma1_factor_zero_mul_M_infty_Gamma1_factor_zero_mem_Gamma1
          N p hpN))).symm
  -- Compose: convert RHS slot-2 (ОівӮҖВ·qвҒ»В№) and LHS slot-2 (T_p_upper(0) вҶ’ peterssonAdj ОІ);
  -- expose the un-merged smul shape on the LHS domain via `mul_smul` so the slash-adjoint
  -- lemma matches; apply `вҶҗ peterssonInner_slash_adjoint_coset` backward to land the
  -- desired RHS slash form.
  rw [h_g_slash, h_pa_simp, mul_smul, вҶҗ peterssonInner_slash_adjoint_coset
    ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
          M_infty_Gamma1_factor N p hpN 0)))
    h_ОІ_det q вҮ‘f вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 strong M_вҲһ branch bridge: iUnion form вҶ’ RHS prefactored q-sum form.**

Composes `peterssonInner_sum_T_p_lower_gamma_M_tile_to_iUnion` (biUnion absorption,
.symm direction) with per-q `peterssonInner_T_p_lower_gamma_M_tile_per_q_eq_fd_LHS_dist`
(slash-adjoint inverse to LHS-distributed M_вҲһ branch summand) and the existing
`M_infty_branch_sum_slash_adjoint_reindex_prefactored` (which consumes the named
DS Prop 5.5.2(b) blocker `h_tile_shift_to_prefactored`) to produce the strong
bridge:

