  rw [show heckeT_p_ut k p hp.pos ⇑f.toModularForm' =
      ∑ b ∈ Finset.range p,
        ⇑f.toModularForm' ∣[k] (T_p_upper p hp.pos b : GL (Fin 2) ℚ) from rfl]
