    show 0 < (╬▓ * (mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ) : GL (Fin 2) тДЭ).val.det
    rw [Units.val_mul, Matrix.det_mul, hq_det_mat, mul_one]
