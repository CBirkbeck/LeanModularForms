/-- **T092 finite-union bridge (`peterssonInner` form).** -/
theorem peterssonInner_biUnion_finset_ae
    {╬╣ : Type*} (s : Finset ╬╣) {D : ╬╣ тЖТ Set тДН}
    (hm : тИА i тИИ s, NullMeasurableSet (D i) ╬╝_hyp)
    (hd : (тЖСs : Set ╬╣).Pairwise (fun i j => AEDisjoint ╬╝_hyp (D i) (D j)))
    (f g : тДН тЖТ тДВ)
    (hfi : IntegrableOn (fun ╧Д => petersson k f g ╧Д) (тЛГ i тИИ s, D i) ╬╝_hyp) :
    peterssonInner k (тЛГ i тИИ s, D i) f g = тИС i тИИ s, peterssonInner k (D i) f g :=
  setIntegral_biUnion_finset_ae s hm hd hfi

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T092: sum-of-slashes adjoint under constant-RHS hypothesis.** -/
theorem peterssonInner_sum_slash_adjoint_constantRHS
    {╬╣ : Type*} [DecidableEq ╬╣] (s : Finset ╬╣)
    (╬▒ : ╬╣ тЖТ GL (Fin 2) тДЭ) (h╬▒ : тИА i тИИ s, 0 < (╬▒ i).det.val)
    (D : Set тДН) (f g g' : тДН тЖТ тДВ)
    (hadj : тИА i тИИ s, g тИг[k] peterssonAdj (╬▒ i) = g')
    (h_int : тИА i тИИ s,
      IntegrableOn (fun ╧Д => petersson k g (f тИг[k] ╬▒ i) ╧Д) D ╬╝_hyp)
    (hm : тИА i тИИ s, NullMeasurableSet ((╬▒ i) тАв D) ╬╝_hyp)
    (hd : (тЖСs : Set ╬╣).Pairwise
      (fun i j => AEDisjoint ╬╝_hyp ((╬▒ i) тАв D) ((╬▒ j) тАв D)))
    (hfi : IntegrableOn (fun ╧Д => petersson k f g' ╧Д)
      (тЛГ i тИИ s, (╬▒ i) тАв D) ╬╝_hyp) :
    peterssonInner k D (тИС i тИИ s, f тИг[k] ╬▒ i) g =
      peterssonInner k (тЛГ i тИИ s, (╬▒ i) тАв D) f g' := by
  rw [peterssonInner_sum_slash_adjoint s ╬▒ h╬▒ D f g h_int]
  rw [peterssonInner_biUnion_finset_ae s hm hd f g' hfi]
  exact Finset.sum_congr rfl fun i hi => by rw [hadj i hi]

