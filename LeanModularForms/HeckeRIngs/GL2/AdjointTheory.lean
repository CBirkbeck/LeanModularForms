            (((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө)) вҖў (fd : Set в„Қ)))
          вҮ‘f
          ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k]
            peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ))
        + вҲ‘ b вҲҲ Finset.range p,
            peterssonInner k
