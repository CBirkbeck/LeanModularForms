open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM uniform identity** `mapGL П„_X В· peterssonAdj Оұ_X = glMap T_p_lower`.

For each `X : Option (Fin p)`, the product `mapGL П„_X В· peterssonAdj Оұ_X`
collapses **uniformly** to `glMap T_p_lower`:

- `X = some b`: shift(b) В· peterssonAdj T_p_upper(b)
              = shift(b) В· (mapGL shift(-b) В· glMap T_p_lower)
              = mapGL (shift(b)В·shift(-b)) В· glMap T_p_lower = glMap T_p_lower вң“
- `X = none`: M_infty_Gamma1_factor В· peterssonAdj M_вҲһ
            = M_infty_Gamma1_factor В· (mapGL M_infty_Gamma1_factorвҒ»В№ В· glMap T_p_lower)
            = mapGL 1 В· glMap T_p_lower = glMap T_p_lower вң“

This is the key algebraic identity making the per-X slash-adjoint reduction
collapse to a single uniform target (analog of the `gвҲЈpeterssonAdj Оұ_X = gвҲЈT_p_lower`
uniformity, but at the matrix level). -/
private theorem mapGL_tile_mul_peterssonAdj_Hecke_rep_eq_glMap_T_p_lower
    (p : в„•) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (i : Option (Fin p)) :
    ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ) *
      peterssonAdj (Hecke_rep_family N p hp.pos hpN i) =
    (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) := by
  match i with
  | none =>
    show ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (M_infty_Gamma1_factor N p hpN 0)
      : GL (Fin 2) в„қ) *
      peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)
    -- M_вҲһ = T_p_upper(0) В· M_infty_Gamma1_factor
    rw [show (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) =
        (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (M_infty_Gamma1_factor N p hpN 0)) from by
      rw [вҶҗ glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp.pos hpN 0,
        mul_inv_cancel_left]]
    rw [peterssonAdj_mul, peterssonAdj_mapGL_SL_eq_inv,
      peterssonAdj_glMap_T_p_upper_zero_eq_glMap_T_p_lower]
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (M_infty_Gamma1_factor N p hpN 0)) *
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (M_infty_Gamma1_factor N p hpN 0))вҒ»В№ *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) =
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (M_infty_Gamma1_factor N p hpN 0) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (M_infty_Gamma1_factor N p hpN 0))вҒ»В№) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) from by group]
    rw [mul_inv_cancel, one_mul]
  | some b =>
    show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b.val : в„Ө))
      : GL (Fin 2) в„қ) *
      peterssonAdj (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)
    rw [peterssonAdj_T_p_upper_eq_shift_mul_lower p hp.pos b.val]
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b.val : в„Ө))) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (-(b.val : в„Ө))) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) =
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b.val : в„Ө)) *
          (mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (-(b.val : в„Ө)))) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) from by group]
    rw [вҶҗ map_mul]
    rw [show shiftSL_loc (b.val : в„Ө) * shiftSL_loc (-(b.val : в„Ө)) =
        (1 : SL(2, в„Ө)) from by
      apply Subtype.ext; ext i j
      fin_cases i <;> fin_cases j <;>
        simp [shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply]]
    rw [map_one, one_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM per-X swap identity** via slot-2 slash-adjoint + uniformity.

For each `X : Option (Fin p)`, slot-2 slash-adjoint applied with `Оұ = Оұ_X`
plus the uniform identity `П„_X В· peterssonAdj Оұ_X = T_p_lower` yields:

  pet О“вӮҒ_FD F (GвҲЈОұ_X) = pet (Оұ_XвҖўО“вӮҒ_FD) (FвҲЈpeterssonAdj Оұ_X) G

Specialized at F = "anything вҲЈ П„_X" form:
  pet О“вӮҒ_FD (F'вҲЈП„_X) (GвҲЈОұ_X) = pet (Оұ_XвҖўО“вӮҒ_FD) (F'вҲЈT_p_lower) G

where the slash by `П„_X В· peterssonAdj Оұ_X` simplifies to slash by T_p_lower
uniformly via the previous lemma. -/
private theorem peterssonInner_swap_via_uniform_adj
    (p : в„•) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (F G : в„Қ вҶ’ в„Ӯ) (i : Option (Fin p)) :
    peterssonInner k (fd : Set в„Қ)
      (F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ))
      (G вҲЈ[k] (Hecke_rep_family N p hp.pos hpN i)) =
    peterssonInner k (Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ))
      (F вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) G := by
  have hОұ : 0 < (Hecke_rep_family N p hp.pos hpN i).det.val := by
    match i with
    | none =>
      exact glMap_M_infty_det_pos N p hp.pos hpN
    | some b =>
      show 0 < ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det
      rw [show ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) =
          ((T_p_upper p hp.pos b.val : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
      rw [show (((T_p_upper p hp.pos b.val : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
          (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b.val : GL (Fin 2) в„ҡ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_upper p hp.pos b.val : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
        simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
      rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
      exact_mod_cast hp.pos
  rw [peterssonInner_slash_adjoint_right _ _ hОұ]
  rw [show (F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ)) вҲЈ[k]
        peterssonAdj (Hecke_rep_family N p hp.pos hpN i) =
        F вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) from by
    rw [вҶҗ SlashAction.slash_mul,
      mapGL_tile_mul_peterssonAdj_Hecke_rep_eq_glMap_T_p_lower (N := N) p hp hpN i]]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM LHS-side per-X swap identity** via slot-1 slash-adjoint
+ uniformity.

For each X, slot-1 slash-adjoint at Оұ = Оұ_X combined with the uniform
identity yields:

  pet О“вӮҒ_FD (G вҲЈ Оұ_X) (F вҲЈ П„_X) = pet (Оұ_X вҖў О“вӮҒ_FD) G (F вҲЈ T_p_lower)

Summing over X (AE-disjoint): converts the slot-1 sum into pet Hecke_FD G (F вҲЈ T_p_lower).

This is the LHS analog of `peterssonInner_swap_via_uniform_adj`. -/
private theorem peterssonInner_swap_via_uniform_adj_slot1
    (p : в„•) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (F G : в„Қ вҶ’ в„Ӯ) (i : Option (Fin p)) :
    peterssonInner k (fd : Set в„Қ)
      (G вҲЈ[k] (Hecke_rep_family N p hp.pos hpN i))
      (F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ)) =
    peterssonInner k (Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ)) G
      (F вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) := by
  -- Apply petersson_symm twice: pet (GвҲЈОұ_X) (FвҲЈП„_X) = conj(pet (FвҲЈП„_X) (GвҲЈОұ_X))
  -- Then use the slot-2 swap, then conj back.
  rw [вҶҗ peterssonInner_conj_symm,
      peterssonInner_swap_via_uniform_adj (N := N) p hp hpN F G i,
      peterssonInner_conj_symm]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM aggregate-form characterization**: combining the per-X
swap identities (slot-1 and slot-2) under AE-disjoint hypotheses converts the
Пғ_p Q-permutation aggregate residual

  `вҲ‘_X pet О“вӮҒ_FD (fвҲЈОұ_X) (gвҲЈП„_X) = вҲ‘_X pet О“вӮҒ_FD ((вҹЁuвҹ©f)вҲЈП„_X) (gвҲЈОұ_X)`

(itself equivalent to the symmetric form `petN(T_p f, g) = petN(вҹЁuвҹ©f, T_p g)`)
into a SINGLE integral equality on the Hecke FD:

  `pet Hecke_FD f (gвҲЈT_p_lower) = pet Hecke_FD ((вҹЁuвҹ©f)вҲЈT_p_lower) g`

This is the FINAL form of the residual at the integral level вҖ” both sides
are integrals on the SAME Hecke FD with different (slot-1, slot-2) slash
structure. The remaining content is to prove this integral equality
directly via measure-theoretic change of variables.

The wrapper composes:
* `peterssonInner_swap_via_uniform_adj_slot1` (LHS per-X collapse)
* `peterssonInner_swap_via_uniform_adj` (RHS per-X collapse)
* `peterssonInner_iUnion_finite_aedisjoint` (sum-to-iUnion absorption,
  requires the AE-disjoint hypothesis). -/
private theorem peterssonInner_per_X_sum_iff_Hecke_FD_residual
    (p : в„•) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : в„Қ вҶ’ в„Ӯ)
    (hm : вҲҖ i : Option (Fin p), NullMeasurableSet
      (Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ)) Ој_hyp)
    (hd : Pairwise (fun i j : Option (Fin p) => AEDisjoint Ој_hyp
      (Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ))
      (Hecke_rep_family N p hp.pos hpN j вҖў (fd : Set в„Қ))))
    (hfi_LHS : IntegrableOn (fun П„ => petersson k f
        (g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ)) Ој_hyp)
    (hfi_RHS : IntegrableOn (fun П„ => petersson k
        (f вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) g П„)
      (вӢғ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ)) Ој_hyp) :
    (вҲ‘ i : Option (Fin p), peterssonInner k (fd : Set в„Қ)
      (f вҲЈ[k] (Hecke_rep_family N p hp.pos hpN i))
      (g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ))) =
      peterssonInner k
        (вӢғ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ))
        f (g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) вҲ§
    (вҲ‘ i : Option (Fin p), peterssonInner k (fd : Set в„Қ)
      (f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ))
      (g вҲЈ[k] (Hecke_rep_family N p hp.pos hpN i))) =
      peterssonInner k
        (вӢғ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i вҖў (fd : Set в„Қ))
        (f вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) g := by
  refine вҹЁ?_, ?_вҹ©
  В· -- LHS aggregation: вҲ‘_X pet О“вӮҒ_FD (fвҲЈОұ_X) (gвҲЈП„_X) = pet Hecke_FD f (gвҲЈT_p_lower)
    have h_per_X : вҲҖ i : Option (Fin p), peterssonInner k (fd : Set в„Қ)
        (f вҲЈ[k] (Hecke_rep_family N p hp.pos hpN i))
        (g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ)) =
