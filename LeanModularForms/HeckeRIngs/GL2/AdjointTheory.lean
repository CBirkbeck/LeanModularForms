      (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
        ((M_infty N p hp.pos hpN).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) тИг[k]
