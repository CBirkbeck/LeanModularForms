/-- **T094 matrix identity M2: `(T_p_upper(b))тБ╗┬╣ ┬╖ M_тИЮ = mapGL тДЭ
(M_infty_Gamma1_factor)`.**  Verified via `M_тИЮ = T_p_upper(b) ┬╖ ╬│'` computation. -/
theorem glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1
    (N p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (b : тДХ) :
    (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ)тБ╗┬╣ *
        (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b)) := by
  have h_mul : (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) =
      (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b)) := by
    apply Units.ext
    ext i j
    have h_L : ((glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        !![((aInvOfCoprime N p hpN : тДд) : тДЭ) * (p : тДЭ), 1;
           (((N : тДд) * mIdxOfCoprime N p hpN : тДд) : тДЭ) * (p : тДЭ), (p : тДЭ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, M_infty, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R1 : ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) = !![(1 : тДЭ), (b : тДЭ); 0, (p : тДЭ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R2 : (((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b)) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        !![((aInvOfCoprime N p hpN : тДд) : тДЭ) * (p : тДЭ) -
             (b : тДЭ) * (((N : тДд) * mIdxOfCoprime N p hpN : тДд) : тДЭ),
           (1 : тДЭ) - (b : тДЭ);
           (((N : тДд) * mIdxOfCoprime N p hpN : тДд) : тДЭ), 1] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [mapGL_coe_matrix, M_infty_Gamma1_factor, algebraMap_int_eq,
          Matrix.of_apply]
    show ((glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) : Matrix _ _ тДЭ) i j =
      ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) *
       ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b)) :
       GL (Fin 2) тДЭ).val i j
    rw [h_L, Units.val_mul, h_R1, h_R2]
    fin_cases i <;> fin_cases j <;>
      simp [Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply] <;> ring
  rw [h_mul, тЖР mul_assoc, inv_mul_cancel, one_mul]

