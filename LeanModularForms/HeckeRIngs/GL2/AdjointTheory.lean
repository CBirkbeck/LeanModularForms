/-- **T094: finite hyperbolic measure of a `glMap`-translate of the О“вӮҒ(N)-FD.** -/
theorem measure_glPos_smul_Gamma1_fundDomain_lt_top
    {N : в„•} [NeZero N] (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val) :
    Ој_hyp (Оұ вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) < вҠӨ := by
  rw [measure_glPos_smul_eq Оұ hОұ
    isFundamentalDomain_Gamma1_PSL.nullMeasurableSet]
  exact hyperbolicMeasure_Gamma1_fundDomain_PSL_lt_top

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: Petersson integrand integrable on a single `glMap`-translate of
`Gamma1_fundDomain_PSL N`.** -/
theorem integrableOn_petersson_glMap_smul_Gamma1_fundDomain
    {N : в„•} [NeZero N] (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    IntegrableOn (fun П„ => petersson k вҮ‘f вҮ‘g П„)
      (Оұ вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp := by
  obtain вҹЁC, hCвҹ© := CuspFormClass.petersson_bounded_left k
    ((Gamma1 N).map (mapGL в„қ)) f g
  exact IntegrableOn.of_bound (measure_glPos_smul_Gamma1_fundDomain_lt_top Оұ hОұ)
    ((petersson_continuous k (ModularFormClass.continuous f)
      (ModularFormClass.continuous g)).aestronglyMeasurable.restrict)
    C (ae_of_all _ fun П„ => hC П„)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: Petersson integrand integrable on a `Finset`-biUnion of
positive-det `glMap`-translates.** -/
theorem integrableOn_petersson_biUnion_glMap_smul
    {N : в„•} [NeZero N] {О№ : Type*} (s : Finset О№) (Оұ : О№ вҶ’ GL (Fin 2) в„қ)
    (hОұ : вҲҖ i вҲҲ s, 0 < (Оұ i).det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
  IntegrableOn (fun П„ => petersson k вҮ‘f вҮ‘g П„)
      (вӢғ i вҲҲ s, Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp := by
  obtain вҹЁC, hCвҹ© := CuspFormClass.petersson_bounded_left k
    ((Gamma1 N).map (mapGL в„қ)) f g
  -- biUnion measure вүӨ ОЈ of finite measures.
