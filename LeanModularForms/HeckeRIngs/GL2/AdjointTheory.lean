/-- **T024 RHS per-Оұ HeckeFD aggregate (symmetric form, DS Thm 5.5.3 RHS).**

Symmetric counterpart of `petN_heckeT_p_eq_per_alpha_HeckeFD_form`:
aggregates `petN(вҹЁpвҹ©f, T_p g)` into the same per-Оұ HeckeFD aggregate form,
but with **slot-1 = `вҹЁpвҹ©f вҲЈ T_p_lower`** and **slot-2 = `g`**. This is the
RHS reduction needed for the `petN_heckeT_p_diamond_shift_core_from_HeckeFD_swap`
bridge composer.

**Derivation**: composes `petN_heckeT_p_eq_per_alpha_HeckeFD_form` (LHS reduction
applied with `f := g`, `g := вҹЁpвҹ©f`) with:
* `petN_conj_symm`: `petN(вҹЁpвҹ©f, T_p g) = conj(petN(T_p g, вҹЁpвҹ©f))`;
* `RingHom.map_add` + `map_sum`: distribute conjugation over `+` and `вҲ‘`;
* `peterssonInner_conj_symm`: `conj(pInner D F G) = pInner D G F` per Оұ.

**Hypotheses**: same shape as LHS reduction, but with the integrability
hypothesis stating `IntegrableOn (petersson k g (вҹЁpвҹ©f вҲЈ T_p_lower))` over
each per-Оұ tile union (slot-1 = `g`, slot-2 = `вҹЁpвҹ©f вҲЈ T_p_lower` вҖ” these are
the slot positions in the LHS reduction's perspective when `f := g`,
`g := вҹЁpвҹ©f`). -/
private theorem petN_diamond_heckeT_p_eq_per_alpha_HeckeFD_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (h_M_infty_disj : Pairwise (fun (qвӮҒ qвӮӮ : SL(2, в„Ө) в§ё Gamma1 N) =>
      AEDisjoint Ој_hyp
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (qвӮҒ.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (qвӮӮ.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))))
    (h_M_infty_meas : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      NullMeasurableSet
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp)
    (h_M_infty_int : IntegrableOn
      (fun П„ => petersson k вҮ‘g
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp)
    (h_upper_disj : вҲҖ b вҲҲ Finset.range p,
      Pairwise (fun (qвӮҒ qвӮӮ : SL(2, в„Ө) в§ё Gamma1 N) =>
        AEDisjoint Ој_hyp
          (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (qвӮҒ.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
          (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (qвӮӮ.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))))
    (h_upper_meas : вҲҖ b вҲҲ Finset.range p, вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      NullMeasurableSet
        (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp)
    (h_upper_int : вҲҖ b вҲҲ Finset.range p, IntegrableOn
      (fun П„ => petersson k вҮ‘g
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp)
    (h_upper_per_q_disj : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      ((Finset.range p : Finset в„•) : Set в„•).Pairwise (fun bвӮҒ bвӮӮ =>
        AEDisjoint Ој_hyp
          (((glMap (T_p_upper p hp.pos bвӮҒ) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
          (((glMap (T_p_upper p hp.pos bвӮӮ) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))))
    (h_upper_per_q_meas : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N, вҲҖ b вҲҲ Finset.range p,
      NullMeasurableSet
        (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp)
    (h_upper_per_q_int : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      IntegrableOn (fun П„ => petersson k вҮ‘g
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) П„)
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ)) Ој_hyp) :
    petN (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
        (heckeT_p_cusp k p hp hpN g) =
    peterssonInner k
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) вҮ‘g +
    вҲ‘ b вҲҲ Finset.range p,
      peterssonInner k
        (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
              GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) вҮ‘g := by
  -- Step 1: petN(вҹЁuвҹ©f, T_p g) = conj(petN(T_p g, вҹЁuвҹ©f)) via petN_conj_symm.
  rw [вҶҗ petN_conj_symm]
  -- Step 2: apply LHS reduction with f := g, g := вҹЁuвҹ©f.
  rw [petN_heckeT_p_eq_per_alpha_HeckeFD_form p hp hpN g
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
    h_M_infty_disj h_M_infty_meas h_M_infty_int
    h_upper_disj h_upper_meas h_upper_int
    h_upper_per_q_disj h_upper_per_q_meas h_upper_per_q_int]
  -- Step 3: distribute conjugation over `+` and `вҲ‘`.
  rw [map_add, map_sum]
  -- Step 4: apply peterssonInner_conj_symm to swap slot-1 вҶ” slot-2 per branch.
  congr 1
  В· exact peterssonInner_conj_symm k _ _ _
  В· refine Finset.sum_congr rfl fun b _ => ?_
    exact peterssonInner_conj_symm k _ _ _

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 fixed-q RHS distribution helper** (slot-2 version): distributes
`peterssonInner fd (вҮ‘f вҲЈ[k] mapGL qвҒ»В№) (вҮ‘(heckeT_p_cusp (вҹЁuвҒ»В№вҹ©g)) вҲЈ[k] mapGL qвҒ»В№)`
over the `M_вҲһ + вҲ‘_b (T_p_upper b)` decomposition of
`вҮ‘(heckeT_p_cusp (вҹЁuвҒ»В№вҹ©g))` via `heckeT_p_fun_eq_coset_sum` +
`SlashAction.add_slash` + `SlashAction.sum_slash` +
`peterssonInner_add_finset_sum_right`. Mirrors the LHS distribute helper
via the slot-2 additivity helpers landed at
`peterssonInner_add_finset_sum_right` / `peterssonInner_sum_right`. -/
private lemma peterssonInner_heckeT_p_RHS_per_q_distribute
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘(heckeT_p_cusp k p hp hpN
            (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) +
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) := by
  have h_Tp_ug : (вҮ‘(heckeT_p_cusp k p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) :
      UpperHalfPlane вҶ’ в„Ӯ) =
      heckeT_p_ut k p hp.pos
        вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g).toModularForm' +
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g).toModularForm' вҲЈ[k]
        (M_infty N p hp.pos hpN : GL (Fin 2) в„ҡ) :=
    heckeT_p_fun_eq_coset_sum k hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g).toModularForm'
  rw [h_Tp_ug, SlashAction.add_slash]
  rw [show heckeT_p_ut k p hp.pos
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g).toModularForm' =
      вҲ‘ b вҲҲ Finset.range p,
        вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g).toModularForm' вҲЈ[k]
          (T_p_upper p hp.pos b : GL (Fin 2) в„ҡ) from rfl]
  rw [SlashAction.sum_slash]
  simp_rw [slash_glQ_mapGLSL_to_combinedGL]
  rw [add_comm]
  set F : UpperHalfPlane вҶ’ в„Ӯ :=
    вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) with hF_def
  set G0 : UpperHalfPlane вҶ’ в„Ӯ :=
    вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hG0_def
  set G : в„• вҶ’ UpperHalfPlane вҶ’ в„Ӯ := fun b =>
    вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hG_def
  have h0 : IntegrableOn (fun П„ => petersson k F G0 П„) ModularGroup.fd Ој_hyp := by
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) f (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
      (M_infty N p hp.pos hpN) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((M_infty N p hp.pos hpN).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
        (M_infty N p hp.pos hpN) qвҒ»В№).symm]
    exact h
  have hG_int : вҲҖ b вҲҲ Finset.range p,
      IntegrableOn (fun П„ => petersson k F (G b) П„) ModularGroup.fd Ој_hyp := by
    intro b _
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) f (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
      (T_p_upper p hp.pos b) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((T_p_upper p hp.pos b).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
        (T_p_upper p hp.pos b) qвҒ»В№).symm]
    exact h
  exact peterssonInner_add_finset_sum_right (Finset.range p) F G0 G ModularGroup.fd h0 hG_int

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 symmetric-form fixed-q distribution helper**: symmetric
counterpart of `peterssonInner_heckeT_p_RHS_per_q_distribute`, for the
aggregate
`petN (diamondOp_cusp k u f) (heckeT_p_cusp k p hp hpN g)`
with `u := ZMod.unitOfCoprime p hpN`.  Slot-1 is the **diamond-twisted**
`вҮ‘(вҹЁuвҹ© f) вҲЈ[k] mapGL qвҒ»В№` identified with
`(вҮ‘f вҲЈ[k] mapGL ОівӮҖвҒ»В№) вҲЈ[k] mapGL qвҒ»В№` via
`coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv`; slot-2 is
`вҮ‘(heckeT_p_cusp k p hp hpN g) вҲЈ[k] mapGL qвҒ»В№` distributed over the
`M_вҲһ + вҲ‘_b T_p_upper(b)` decomposition of `heckeT_p_cusp` via
`heckeT_p_fun_eq_coset_sum` + `SlashAction.add_slash` +
`SlashAction.sum_slash`.  The `ОівӮҖвҒ»В№` residual on slot-1 is preserved
intentionally; it matches the correct symmetric DS 5.5.3 first-slot twist. -/
private lemma peterssonInner_heckeT_p_symm_RHS_per_q_distribute
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘(heckeT_p_cusp k p hp hpN g) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k ModularGroup.fd
        ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
            GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) +
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) := by
  -- Rewrite slot-1 using the new diamond-vs-adjointGamma0Rep-inverse identity.
  rw [coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
  -- Distribute slot-2 via the T_p coset sum on plain g.
  have h_Tp_g : (вҮ‘(heckeT_p_cusp k p hp hpN g) : UpperHalfPlane вҶ’ в„Ӯ) =
      heckeT_p_ut k p hp.pos вҮ‘g.toModularForm' +
      вҮ‘g.toModularForm' вҲЈ[k]
        (M_infty N p hp.pos hpN : GL (Fin 2) в„ҡ) :=
    heckeT_p_fun_eq_coset_sum k hp hpN g.toModularForm'
  rw [h_Tp_g, SlashAction.add_slash]
  rw [show heckeT_p_ut k p hp.pos вҮ‘g.toModularForm' =
      вҲ‘ b вҲҲ Finset.range p,
        вҮ‘g.toModularForm' вҲЈ[k]
          (T_p_upper p hp.pos b : GL (Fin 2) в„ҡ) from rfl]
  rw [SlashAction.sum_slash]
  simp_rw [slash_glQ_mapGLSL_to_combinedGL]
  rw [add_comm]
  set F : UpperHalfPlane вҶ’ в„Ӯ :=
    (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
      GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) with hF_def
  set G0 : UpperHalfPlane вҶ’ в„Ӯ :=
    вҮ‘g вҲЈ[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hG0_def
  set G : в„• вҶ’ UpperHalfPlane вҶ’ в„Ӯ := fun b =>
    вҮ‘g вҲЈ[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hG_def
  have h0 : IntegrableOn (fun П„ => petersson k F G0 П„) ModularGroup.fd Ој_hyp := by
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) g
      (M_infty N p hp.pos hpN) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
        GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘g вҲЈ[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show (вҮ‘g вҲЈ[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) =
      (вҮ‘g вҲЈ[k]
        ((M_infty N p hp.pos hpN).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k) вҮ‘g
        (M_infty N p hp.pos hpN) qвҒ»В№).symm]
    rw [вҶҗ coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
    exact h
  have hG_int : вҲҖ b вҲҲ Finset.range p,
      IntegrableOn (fun П„ => petersson k F (G b) П„) ModularGroup.fd Ој_hyp := by
    intro b _
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) g
      (T_p_upper p hp.pos b) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
        GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘g вҲЈ[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show (вҮ‘g вҲЈ[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) =
      (вҮ‘g вҲЈ[k]
        ((T_p_upper p hp.pos b).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k) вҮ‘g
        (T_p_upper p hp.pos b) qвҒ»В№).symm]
    rw [вҶҗ coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
    exact h
  exact peterssonInner_add_finset_sum_right (Finset.range p) F G0 G ModularGroup.fd h0 hG_int

open UpperHalfPlane ModularGroup in
/-- **T128 RHS branch normalization (upper family)**: rewrites
`вҮ‘(вҹЁuвҒ»В№вҹ©g) вҲЈ[k] (glMap T_p_upper(b) * mapGL qвҒ»В№)` in combined GL(2, в„қ) form
to `вҮ‘g вҲЈ[k] (glMap T_p_lower * mapGL Оҙ_b * mapGL qвҒ»В№)` via the diamond
coercion (`diamondOpCusp_eq` + `adjointGamma0Rep_units`) and the landed
p+1 coset-family factorization
`mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta` at `b`. -/
private lemma slash_diamond_inv_T_p_upper_eq_T_p_lower_delta
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•) (q : SL(2, в„Ө))
    (g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    вҮ‘g вҲЈ[k]
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) := by
  have h_diamond : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
      UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) := by
    show вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  rw [h_diamond, вҶҗ SlashAction.slash_mul, вҶҗ mul_assoc,
    mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta N p hp.pos hpN b]

open UpperHalfPlane ModularGroup in
/-- **T128 RHS branch normalization (M_вҲһ)**: rewrites
`вҮ‘(вҹЁuвҒ»В№вҹ©g) вҲЈ[k] (glMap M_вҲһ * mapGL qвҒ»В№)` in combined GL(2, в„қ) form
to `вҮ‘g вҲЈ[k] (glMap T_p_lower * mapGL Оө * mapGL qвҒ»В№)` via the diamond
coercion (`diamondOpCusp_eq` + `adjointGamma0Rep_units`) and the landed
M_вҲһ-branch factorization
`mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon`. -/
private lemma slash_diamond_inv_M_infty_eq_T_p_lower_epsilon
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (q : SL(2, в„Ө))
    (g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    вҮ‘g вҲЈ[k]
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
            M_infty_Gamma1_factor N p hpN 0)) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) := by
  have h_diamond : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
      UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) := by
    show вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  rw [h_diamond, вҶҗ SlashAction.slash_mul, вҶҗ mul_assoc,
    mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon N p hp.pos hpN]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 RHS per-q normalized consumer**: composes
`peterssonInner_heckeT_p_RHS_per_q_distribute` with branch normalization via
`slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` (M_вҲһ branch) and
`slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` (upper branches).

Rewrites the per-q summand
`peterssonInner fd (вҮ‘f вҲЈ mapGL qвҒ»В№) (вҮ‘(heckeT_p_cusp (вҹЁuвҒ»В№вҹ©g)) вҲЈ mapGL qвҒ»В№)`
into the normalized split form where each p+1 branch has its slot-2 in
`вҮ‘g вҲЈ[k] (glMap T_p_lower * mapGL Оҙ_i * mapGL qвҒ»В№)` form with explicit
О“вӮҒ(N)-correction factor `Оҙ_i`. -/
private lemma peterssonInner_heckeT_p_RHS_per_q_normalized
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘(heckeT_p_cusp k p hp hpN
            (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) +
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
                GL (Fin 2) в„қ))) := by
  rw [peterssonInner_heckeT_p_RHS_per_q_distribute p hp hpN q f g]
  congr 1
  В· rw [slash_diamond_inv_M_infty_eq_T_p_lower_epsilon p hp hpN q g]
  В· refine Finset.sum_congr rfl fun b _ => ?_
    rw [slash_diamond_inv_T_p_upper_eq_T_p_lower_delta p hp hpN b q g]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 SLвҶ”mapGL-в„қ slash coercion bridge**: `peterssonInner fd` of
`(qвҒ»В№ : SL(2, в„Ө))`-slashed arguments equals the `mapGL в„қ qвҒ»В№`-slashed form,
since the SL(2, в„Ө) slash action on `в„Қ вҶ’ в„Ӯ` is the `monoidHomSlashAction mapGL в„қ`
instance. Used to bridge `petN` summands (SL slash) to the `mapGL в„қ` form
required by the RHS normalized consumer. -/
private lemma peterssonInner_SL_inv_eq_mapGL_inv
    (F G : UpperHalfPlane вҶ’ в„Ӯ) (q : SL(2, в„Ө)) :
    peterssonInner k ModularGroup.fd
      (F вҲЈ[k] (qвҒ»В№ : SL(2, в„Ө)))
      (G вҲЈ[k] (qвҒ»В№ : SL(2, в„Ө))) =
    peterssonInner k ModularGroup.fd
      (F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
      (G вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) := by
  rfl

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 symmetric-form sum-level distributed aggregate**: lifts the
fixed-q symmetric distribute helper
`peterssonInner_heckeT_p_symm_RHS_per_q_distribute` to the `вҲ‘ q :
SL(2, в„Ө) в§ё Gamma1 N` aggregate level, applied at `q.out`.  The first
slot retains the `ОівӮҖвҒ»В№` residual
`(вҮ‘f вҲЈ[k] mapGL ОівӮҖвҒ»В№) вҲЈ[k] mapGL (q.out)вҒ»В№` as the correct symmetric
first-slot twist matching `вҮ‘(вҹЁuвҹ© f)`.

Directly usable as a `rw` target for the symmetric form
`petN_heckeT_p_diamond_shift_core` once the matching R2 shifted-tile
aggregate is landed. -/
private lemma petN_diamond_heckeT_p_symm_RHS_sum_distributed
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
        (heckeT_p_cusp k p hp hpN g) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k ModularGroup.fd
          ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k ModularGroup.fd
            ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
                GL (Fin 2) в„қ)) вҲЈ[k]
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№))
            (вҮ‘g вҲЈ[k]
              ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) := by
  show вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘(heckeT_p_cusp k p hp hpN g) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) = _
  refine Finset.sum_congr rfl fun q _ => ?_
  rw [peterssonInner_SL_inv_eq_mapGL_inv]
  exact peterssonInner_heckeT_p_symm_RHS_per_q_distribute p hp hpN
    (q.out : SL(2, в„Ө)) f g

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 RHS sum-level normalized aggregate**: rewrites
`petN f (heckeT_p_cusp k p hp hpN (diamondOp_cusp k uвҒ»В№ g))` at the `вҲ‘_q` level
into the normalized split form produced by
`peterssonInner_heckeT_p_RHS_per_q_normalized` applied per q, bridged from
