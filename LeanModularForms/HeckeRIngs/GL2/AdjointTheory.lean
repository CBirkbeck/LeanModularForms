    (diamondOp k (ZMod.unitOfCoprime p hpN) f)]
  -- Step 2: ⟨u⟩ f ∣ glMap T_p_lower = ⟨u⟩ f ∣ (T_p_lower : GL ℚ)  (rfl bridge via glMap)
