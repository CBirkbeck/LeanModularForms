    {╬╣ : SL(2, тДд) тз╕ Gamma1 N тЖТ Type*} [hFt : тИА q, Fintype (╬╣ q)]
    {T : SL(2, тДд) тз╕ Gamma1 N тЖТ Set UpperHalfPlane}
