      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) :
      CuspForm ((Gamma1 N).map (mapGL в„қ)) k) = f from by
    show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
      (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) = f
    rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) =
        ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)).comp
          (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№)) f from rfl,
      вҶҗ diamondOpCusp_mul, mul_inv_cancel, diamondOpCusp_one]
    rfl] at h
  exact h.symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d upper-`b` LHS-dist per-q tile-form**: upper-`b` analog of
`peterssonInner_LHS_M_infty_per_q_to_tile_form`.

```
pet fd (f вҲЈ (T_p_lower В· Оі_b В· qвҒ»В№)) (g вҲЈ ОівӮҖ В· qвҒ»В№)
  = pet (T_p_upper(b) вҖў qвҒ»В№ вҖў fd) (вҹЁuвҒ»В№вҹ©f) ((вҹЁuвҒ»В№вҹ©g вҲЈ T_p_upper(0)) вҲЈ mapGL ОівӮҖ)
```

**Proof.** Three steps (parallel to M_вҲһ branch):
1. f-slot master identity (`slash_T_p_lower_b_factor_eq_diamond_inv_slash_T_p_upper`).
2. g-slot diamond identification вҹЁuвҒ»В№вҹ©g = g вҲЈ ОівӮҖ.
3. `peterssonInner_slash_adj_T_p_upper_q_summand_eq` at `(f := вҹЁuвҒ»В№вҹ©f, g := вҹЁuвҒ»В№вҹ©g)`. -/
private lemma peterssonInner_LHS_upper_per_q_to_tile_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k]
          (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    peterssonInner k ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ) вҖў (ModularGroup.fd : Set UpperHalfPlane)))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f))
      ((вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
          (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  -- Step 1: f-slot master identity (T_p_lower factor вҶ’ вҹЁuвҒ»В№вҹ©f В· T_p_upper(b)).
  rw [slash_T_p_lower_b_factor_eq_diamond_inv_slash_T_p_upper p hp hpN b f q]
  -- Step 2: g-slot diamond identification (ОівӮҖ В· qвҒ»В№ вҶ’ вҹЁuвҒ»В№вҹ©g В· qвҒ»В№).
  have h_diamond_inv_g : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
        UpperHalfPlane вҶ’ в„Ӯ) = вҮ‘g вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) := by
    have h := coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)
    rw [show (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
        CuspForm ((Gamma1 N).map (mapGL в„қ)) k) = g from by
      show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) = g
      rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
          (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) =
          ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)).comp
            (diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№)) g from rfl,
        вҶҗ diamondOpCusp_mul, mul_inv_cancel, diamondOpCusp_one]
      rfl] at h
    have h2 := congr_arg (fun F : UpperHalfPlane вҶ’ в„Ӯ => F вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) h
    simp only at h2
    rw [вҶҗ SlashAction.slash_mul, вҶҗ map_mul, inv_mul_cancel, map_one,
      SlashAction.slash_one] at h2
    exact h2.symm
  rw [show (вҮ‘g вҲЈ[k]
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) from by
    rw [SlashAction.slash_mul, вҶҗ h_diamond_inv_g]]
  -- Step 3: apply T_p_upper(b)-slash-adjoint at (вҹЁuвҒ»В№вҹ©f, вҹЁuвҒ»В№вҹ©g).
  exact peterssonInner_slash_adj_T_p_upper_q_summand_eq p hp hpN b q
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f)
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d M_вҲһ LHS-dist sum to per-q tile-form sum** (Finset.sum_congr
of the per-q tile-form lemma): rewrites the entire LHS sum of
`SigmaQPermResidual_M_infty` into the per-q tile-form sum with q-independent
slot-2. -/
private lemma sum_peterssonInner_LHS_M_infty_to_tile_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k]
          (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
          ((mapGL в„қ ((q.out : SL(2, в„Ө))вҒ»В№) : GL (Fin 2) в„қ) вҖў
            (ModularGroup.fd : Set UpperHalfPlane)))
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f))
        ((вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
            (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  refine Finset.sum_congr rfl (fun q _ => ?_)
  exact peterssonInner_LHS_M_infty_per_q_to_tile_form p hp hpN
    ((q.out : SL(2, в„Ө)) : SL(2, в„Ө)) f g

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d upper-`b` LHS-dist sum to per-q,b tile-form sum**: upper-`b` analog
of `sum_peterssonInner_LHS_M_infty_to_tile_form`. Applies the per-q upper-`b`
tile-form lemma to each (q,b)-summand via `Finset.sum_congr`. -/
private lemma sum_peterssonInner_LHS_upper_to_tile_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k]
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
            ((mapGL в„қ ((q.out : SL(2, в„Ө))вҒ»В№) : GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f))
          ((вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
              (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  refine Finset.sum_congr rfl (fun q _ => Finset.sum_congr rfl (fun b _ => ?_))
  exact peterssonInner_LHS_upper_per_q_to_tile_form p hp hpN b
    ((q.out : SL(2, в„Ө)) : SL(2, в„Ө)) f g

