          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) : GL (Fin 2) тДЭ))тБ╗┬╣ =
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
