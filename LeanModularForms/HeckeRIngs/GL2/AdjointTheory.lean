the ╬У_p(╬▒) / `conjBy` infrastructure тАФ directly usable by integral
identities over ╬УтВБ(N)-FD where the integrand is a ╬У_p(╬▒)-invariant
╬▒-slashed cusp form. -/
lemma slash_╬▒_Gamma_p_╬▒_invariant_cuspForm
    (╬▒ : GL (Fin 2) тДЪ) (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    {╬│ : SL(2, тДд)} (h╬│ : ╬│ тИИ Gamma_p_╬▒ (N := N) ╬▒) :
    ((тЗСf) тИг[k] ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))) тИг[k]
      ((mapGL тДЭ ╬│ : GL (Fin 2) тДЭ)) =
    (тЗСf) тИг[k] ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) := by
  refine slash_╬▒_Gamma_p_╬▒_invariant ╬▒ (тЗСf) ?_ h╬│
  intro ╬┤ h╬┤
  rw [show ((mapGL тДЭ ╬┤ : GL (Fin 2) тДЭ)) =
        (((╬┤ : SL(2, тДд)) : GL (Fin 2) тДЭ)) from rfl, тЖР ModularForm.SL_slash]
