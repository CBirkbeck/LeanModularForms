Forms*, Prop. 5.5.2(b); Miyake ┬з4.5. -/
private theorem peterssonInner_M_infty_T_p_upper_tile_sum_matches_per_q_distribute
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд) тз╕ Gamma1 N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (g_const : UpperHalfPlane тЖТ тДВ)
    (tile : Fin (p + 1) тЖТ Set UpperHalfPlane)
    (h_tile_zero_match :
      peterssonInner k (tile 0) тЗСf g_const =
      peterssonInner k ModularGroup.fd
          ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣))
          (тЗСg тИг[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))))
    (h_tile_succ_match : тИА b : Fin p,
      peterssonInner k (tile b.succ) тЗСf g_const =
      peterssonInner k ModularGroup.fd
            ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
                GL (Fin 2) тДЭ)) тИг[k]
