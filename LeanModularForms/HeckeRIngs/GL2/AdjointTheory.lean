open CongruenceSubgroup UpperHalfPlane MeasureTheory in
/-- **Phase M (e) вҖ” fiber-invariance of the SL-tile integral at H = О“вӮҒ(N), О“_p(Оұ)-quotient.**

For a `О“вӮҒ(N)`-invariant integrand `h`, the SL-tile integral over `q.outвҒ»В№ вҖў fd`
(q вҲҲ SL в§ё О“_p(Оұ)) equals the SL-tile integral over `(slGamma_p_ОұToGamma1 q).outвҒ»В№ вҖў fd`
(at the SL в§ё О“вӮҒ(N) target).

Mirror of `setIntegral_SL_tile_eq_PSL_tile_Gamma_p_Оұ` (Phase M(b)) at the
SL/О“вӮҒ(N) target.  The proof uses the SL-equivariance of the quotient map and
`О“вӮҒ(N)`-invariance of `h` to identify the per-q tile with the corresponding
SL/О“вӮҒ(N) tile via a О“вӮҒ(N)-element shift. -/
theorem setIntegral_SL_tile_Gamma_p_Оұ_eq_SL_tile_Gamma1
    (Оұ : GL (Fin 2) в„ҡ) (h : в„Қ вҶ’ в„Ӯ)
    (h_inv : вҲҖ Оі вҲҲ Gamma1 N, вҲҖ П„ : в„Қ, h (Оі вҖў П„) = h П„)
    (q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ) :
    вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp =
      вҲ« П„ in ((slGamma_p_ОұToGamma1 (N := N) Оұ q).out : SL(2, в„Ө))вҒ»В№ вҖў
        (fd : Set в„Қ), h П„ вҲӮОј_hyp := by
  -- Step 1: extract Оі вҲҲ О“вӮҒ(N) realizing the difference between SL.mk q.out and
  -- (slGamma_p_ОұToGamma1 Оұ q).out as О“вӮҒ(N)-cosets.
  have h_quot_eq : (QuotientGroup.mk q.out : SL(2, в„Ө) в§ё Gamma1 N) =
      QuotientGroup.mk ((slGamma_p_ОұToGamma1 (N := N) Оұ q).out : SL(2, в„Ө)) := by
    have h1 : slGamma_p_ОұToGamma1 (N := N) Оұ q = QuotientGroup.mk q.out := by
      conv_lhs => rw [вҶҗ q.out_eq]
      rfl
    exact h1.symm.trans (slGamma_p_ОұToGamma1 (N := N) Оұ q).out_eq.symm
  rw [QuotientGroup.eq] at h_quot_eq
  -- h_quot_eq : (q.out)вҒ»В№ * (slGamma_p_ОұToGamma1 Оұ q).out вҲҲ Gamma1 N.
  set Оі := (q.out : SL(2, в„Ө))вҒ»В№ * (slGamma_p_ОұToGamma1 (N := N) Оұ q).out with hОі_def
  have hОі_mem : Оі вҲҲ Gamma1 N := h_quot_eq
  -- Step 2: rewrite the target tile as a Оі-shift of the source tile.
  have h_eq : ((slGamma_p_ОұToGamma1 (N := N) Оұ q).out : SL(2, в„Ө)) = q.out * Оі := by
    rw [hОі_def]; group
  rw [show ((slGamma_p_ОұToGamma1 (N := N) Оұ q).out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ) =
      ((q.out : SL(2, в„Ө)) * Оі)вҒ»В№ вҖў (fd : Set в„Қ) from by rw [h_eq]]
  rw [show (((q.out : SL(2, в„Ө)) * Оі)вҒ»В№ вҖў (fd : Set в„Қ) : Set в„Қ) =
      ((Оі : SL(2, в„Ө))вҒ»В№ вҖў ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ))) from by
    rw [mul_inv_rev, mul_smul]]
  -- Step 3: change of variables П„ вҶҰ Оі вҖў Пғ on the ОівҒ»В№-shifted set, then use О“вӮҒ-invariance.
  symm
  rw [show ((ОівҒ»В№ : SL(2, в„Ө)) вҖў ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ)) : Set в„Қ) =
      (fun П„ => (ОівҒ»В№ : SL(2, в„Ө)) вҖў П„) '' ((q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ)) from rfl,
    (measurePreserving_smul (ОівҒ»В№ : SL(2, в„Ө)) Ој_hyp).setIntegral_image_emb
      (measurableEmbedding_const_smul _)]
  congr 1; ext П„
  exact h_inv ОівҒ»В№ ((Gamma1 N).inv_mem hОі_mem) П„

open CongruenceSubgroup UpperHalfPlane MeasureTheory Classical in
/-- **Phase M (e) вҖ” SL/О“_p(Оұ) вҶ’ SL/О“вӮҒ(N) fiber-sum reindex.**

For a `О“вӮҒ(N)`-invariant integrand `h`, the SL outer-q sum over `SL в§ё О“_p(Оұ)`
reindexes via the natural quotient `slGamma_p_ОұToGamma1 : SL в§ё О“_p(Оұ) вҶ’
SL в§ё О“вӮҒ(N)` to a sum over `SL в§ё О“вӮҒ(N)` weighted by the uniform fiber count
`slGamma_p_ОұToGamma1_fiberCard Оұ = (Gamma_p_Оұ Оұ).relIndex (Gamma1 N)`.

Standard fiberwise reindex via `Finset.sum_fiberwise'` plus uniform fiber size. -/
theorem sum_SL_tile_Gamma_p_Оұ_eq_fiberCard_mul_SL_tile_Gamma1
    (Оұ : GL (Fin 2) в„ҡ) (h : в„Қ вҶ’ в„Ӯ)
    (h_inv : вҲҖ Оі вҲҲ Gamma1 N, вҲҖ П„ : в„Қ, h (Оі вҖў П„) = h П„) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
      вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp =
    (slGamma_p_ОұToGamma1_fiberCard (N := N) Оұ) вҖў
      вҲ‘ q' : SL(2, в„Ө) в§ё Gamma1 N,
        вҲ« П„ in (q'.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp := by
  calc вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
          вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp
      = вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
          вҲ« П„ in ((slGamma_p_ОұToGamma1 (N := N) Оұ q).out : SL(2, в„Ө))вҒ»В№ вҖў
            (fd : Set в„Қ), h П„ вҲӮОј_hyp :=
        Finset.sum_congr rfl fun q _ =>
          setIntegral_SL_tile_Gamma_p_Оұ_eq_SL_tile_Gamma1 (N := N) Оұ h h_inv q
    _ = вҲ‘ q' : SL(2, в„Ө) в§ё Gamma1 N,
          вҲ‘ q вҲҲ Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
            slGamma_p_ОұToGamma1 (N := N) Оұ q = q'),
            вҲ« П„ in (q'.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp :=
        (Finset.sum_fiberwise' Finset.univ
          (slGamma_p_ОұToGamma1 (N := N) Оұ)
          (fun q' => вҲ« П„ in (q'.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp)).symm
    _ = (slGamma_p_ОұToGamma1_fiberCard (N := N) Оұ) вҖў
          вҲ‘ q' : SL(2, в„Ө) в§ё Gamma1 N,
            вҲ« П„ in (q'.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp := by
        rw [Finset.smul_sum]
        refine Finset.sum_congr rfl fun q' _ => ?_
