    (F G : CuspForm ((Gamma1 N).map (mapGL ℝ)) k)
    (hm : ∀ q : SL(2, ℤ) ⧸ Gamma1 N,
      NullMeasurableSet
        (((mapGL ℝ : SL(2, ℤ) →* GL (Fin 2) ℝ) (q.out : SL(2, ℤ))⁻¹ :
          GL (Fin 2) ℝ) • (fd : Set ℍ)) μ_hyp)
    (hd : Pairwise (fun q₁ q₂ : SL(2, ℤ) ⧸ Gamma1 N =>
      AEDisjoint μ_hyp
        (((mapGL ℝ : SL(2, ℤ) →* GL (Fin 2) ℝ) (q₁.out : SL(2, ℤ))⁻¹ :
          GL (Fin 2) ℝ) • (fd : Set ℍ))
        (((mapGL ℝ : SL(2, ℤ) →* GL (Fin 2) ℝ) (q₂.out : SL(2, ℤ))⁻¹ :
          GL (Fin 2) ℝ) • (fd : Set ℍ))))
    (hint : IntegrableOn (fun τ => petersson k ⇑F ⇑G τ)
      (⋃ q : SL(2, ℤ) ⧸ Gamma1 N,
        ((mapGL ℝ : SL(2, ℤ) →* GL (Fin 2) ℝ) (q.out : SL(2, ℤ))⁻¹ :
          GL (Fin 2) ℝ) • (fd : Set ℍ)) μ_hyp) :
