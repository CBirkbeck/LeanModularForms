                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) := by
  -- Step 1: Normalize LHS to вҹЁuвҒ»В№вҹ©-shifted form.
  rw [M_infty_branch_LHS_normalize_to_diamond p hp hpN f g]
  -- Step 2: Per-q apply `peterssonInner_slash_adj_M_infty_q_summand_eq`.
  rw [show (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f)
          ((вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
            (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))))
    from Finset.sum_congr rfl fun q _ =>
      peterssonInner_slash_adj_M_infty_q_summand_eq p hp hpN
        (q.out : SL(2, в„Ө))
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f)
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)]
  -- Step 3: Apply the explicit Q-reindex absorption hypothesis.
  exact h_tile_shift_to_prefactored

