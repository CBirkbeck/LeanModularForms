      (D := fd) (╬▒ := ╬▓ * (mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ)) hdet_pos
      f (g тИг[k] (mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ))
  -- Step 3: Simplify peterssonAdj(╬▓ * qтБ╗┬╣) = q * peterssonAdj ╬▓
  have h_adj_prod : peterssonAdj (╬▓ * (mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
      (mapGL тДЭ q : GL (Fin 2) тДЭ) * peterssonAdj ╬▓ := by
