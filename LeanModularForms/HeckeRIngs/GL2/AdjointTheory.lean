* `peterssonInner_slash_adjoint` on slot-1: moves `T_p_lower` slash from
  slot-1 to slot-2 with domain shift `UNION тЖТ T_p_lower тАв UNION`;
* `slash_peterssonAdj_T_p_lower_eq_T_p_upper_0` (applied to `тЯиuтБ╗┬╣тЯйg`):
  converts `peterssonAdj T_p_lower` slash to `T_p_upper(0)` slash;
* `peterssonInner_slash_adjoint_right` on RHS slot-2: moves `T_p_lower`
  slash from slot-2 to slot-1 with domain shift `UNION тЖТ T_p_lower тАв UNION`;
* `slash_peterssonAdj_T_p_lower_eq_T_p_upper_0` (applied to `тЯиuтЯйf`):
  converts `peterssonAdj T_p_lower` slash to `T_p_upper(0)` slash. -/
private theorem TpUpperZeroShiftedFormBlocker_of_v2
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (h_v2 : TpUpperZeroShiftedFormBlocker_v2 p hp hpN f g) :
    TpUpperZeroShiftedFormBlocker p hp hpN f g := by
  have h_det_pos : 0 < (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).map
        (algebraMap тДЪ тДЭ)).det =
        (algebraMap тДЪ тДЭ) (((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_lower p hp.pos : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp.pos
  unfold TpUpperZeroShiftedFormBlocker_v2 at h_v2
  unfold TpUpperZeroShiftedFormBlocker
  rw [peterssonInner_slash_adjoint (k := k) _ _ h_det_pos тЗСf
      тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g),
    slash_peterssonAdj_T_p_lower_eq_T_p_upper_0 p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g),
    peterssonInner_slash_adjoint_right (k := k) _ _ h_det_pos
      тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
      тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g),
    slash_peterssonAdj_T_p_lower_eq_T_p_upper_0 p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)] at h_v2
  exact h_v2

