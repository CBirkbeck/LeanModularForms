**Proof**: (1) `change` outer SL slash to `mapGL в„қ qвҒ»В№` coercion (definitional
via the SL SlashAction instance); (2) unfold `heckeT_p_cusp` via
`heckeT_p_fun_eq_coset_sum` + `SlashAction.add_slash` + `SlashAction.sum_slash`;
(3) normalize each summand via `slash_glQ_mapGLSL_to_combinedGL`;
(4) apply `peterssonInner_add_finset_sum_left` with integrability from
`integrableOn_petersson_cuspform_mixed_slash_on_fd` (f, g swapped) +
`slash_glQ_then_mapGL_SL_eq_combinedGL` for target-integrand bridging. -/
private lemma peterssonInner_heckeT_p_LHS_per_q_distribute
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) +
      вҲ‘ b вҲҲ Finset.range p,
        peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) := by
  have h_Tpf : (вҮ‘(heckeT_p_cusp k p hp hpN f) : UpperHalfPlane вҶ’ в„Ӯ) =
      heckeT_p_ut k p hp.pos вҮ‘f.toModularForm' +
        вҮ‘f.toModularForm' вҲЈ[k] (M_infty N p hp.pos hpN : GL (Fin 2) в„ҡ) :=
    heckeT_p_fun_eq_coset_sum k hp hpN f.toModularForm'
  rw [h_Tpf, SlashAction.add_slash]
  rw [show heckeT_p_ut k p hp.pos вҮ‘f.toModularForm' =
      вҲ‘ b вҲҲ Finset.range p,
        вҮ‘f.toModularForm' вҲЈ[k] (T_p_upper p hp.pos b : GL (Fin 2) в„ҡ) from rfl]
  rw [SlashAction.sum_slash]
  simp_rw [slash_glQ_mapGLSL_to_combinedGL]
  rw [add_comm]
  set G : UpperHalfPlane вҶ’ в„Ӯ :=
    вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) with hG_def
  set F0 : UpperHalfPlane вҶ’ в„Ӯ :=
    вҮ‘f вҲЈ[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hF0_def
  set F : в„• вҶ’ UpperHalfPlane вҶ’ в„Ӯ := fun b =>
    вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) with hF_def
  have h0 : IntegrableOn (fun П„ => petersson k G F0 П„) ModularGroup.fd Ој_hyp := by
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) g f (M_infty N p hp.pos hpN) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘f вҲЈ[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show вҮ‘f вҲЈ[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) =
      (вҮ‘f вҲЈ[k] ((M_infty N p hp.pos hpN).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        вҮ‘f (M_infty N p hp.pos hpN) qвҒ»В№).symm]
    exact h
  have hF : вҲҖ b вҲҲ Finset.range p,
      IntegrableOn (fun П„ => petersson k G (F b) П„) ModularGroup.fd Ој_hyp := by
    intro b _
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) g f (T_p_upper p hp.pos b) qвҒ»В№
    show IntegrableOn (fun П„ => petersson k
      (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))
      (вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№))) П„) ModularGroup.fd Ој_hyp
    rw [show вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№)) =
      (вҮ‘f вҲЈ[k] ((T_p_upper p hp.pos b).map (Rat.castHom в„қ) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        вҮ‘f (T_p_upper p hp.pos b) qвҒ»В№).symm]
    exact h
  exact peterssonInner_add_finset_sum_left (Finset.range p) F0 F G ModularGroup.fd h0 hF

open UpperHalfPlane ModularGroup MeasureTheory ConjAct Pointwise in
/-- **T128 upper-family union integrability (uniform g-slot)**: integrability of
`petersson k вҮ‘f ((вҮ‘g вҲЈ[k] glMap T_p_upper(0)) вҲЈ[k] mapGL ОівӮҖ)` on the per-q
upper-family union tile `вӢғ_b (glMap T_p_upper(b) * mapGL qвҒ»В№) вҖў fd`. This
is the `hfi_upper` input needed by
`peterssonInner_M_infty_plus_upper_union_tile_per_q`.

**Proof**: merge the stacked `T_p_upper(0) В· ОівӮҖ` slash into a single GL(2,в„қ)
slash via `SlashAction.slash_mul`, translate `g` by this combined matrix via
`CuspForm.translate` (arithmeticity of the conjugate subgroup comes from
`Subgroup.IsArithmetic.conj` at the GL(2,в„ҡ) pre-image), apply AM-GM bound on
`вҖ–petersson k f (g_tr) П„вҖ–` using `petersson_bounded_left` for both `f f` and
`g_tr g_tr`, plus finite measure of the union tile
(`measure_biUnion_finset_le` + `measure_glPos_smul_eq` + `hyperbolicMeasure_fd_lt_top`).
Finish with `IntegrableOn.of_bound`. -/
private lemma integrableOn_petersson_upper_union_uniform_gslot_per_q
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    IntegrableOn
      (fun П„ => petersson k вҮ‘f
        ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) П„)
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)) Ој_hyp := by
  set A : GL (Fin 2) в„қ :=
    (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) with hA_def
  have h_integrand_eq :
      (fun П„ => petersson k вҮ‘f
        ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) П„) =
      (fun П„ => petersson k вҮ‘f (вҮ‘g вҲЈ[k] A) П„) := by
    funext П„; rw [hA_def, SlashAction.slash_mul]
  rw [h_integrand_eq]
  set Пғ : GL (Fin 2) в„ҡ :=
    T_p_upper p hp.pos 0 *
      ((mapGL в„ҡ : SL(2, в„Ө) вҶ’* _)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) with hПғ_def
  have h_Пғ_map :
      (((Пғ : GL (Fin 2) в„ҡ).map (Rat.castHom в„қ)) : GL (Fin 2) в„қ) = A := by
    show glMap Пғ = A
    rw [hПғ_def, map_mul, glMap_mapGL_Q_eq_mapGL_R, hA_def]
  haveI hArith :
      (toConjAct (A : GL (Fin 2) в„қ)вҒ»В№ вҖў
        ((Gamma1 N).map (mapGL в„қ))).IsArithmetic := by
    have h := Subgroup.IsArithmetic.conj ((Gamma1 N).map (mapGL в„қ)) ПғвҒ»В№
    have h_inv : (((ПғвҒ»В№ : GL (Fin 2) в„ҡ).map (Rat.castHom в„қ)) : GL (Fin 2) в„қ) =
        (A : GL (Fin 2) в„қ)вҒ»В№ := by
      rw [map_inv, h_Пғ_map]
    rw [h_inv] at h
    exact h
  let g_tr : CuspForm
      (toConjAct (A : GL (Fin 2) в„қ)вҒ»В№ вҖў ((Gamma1 N).map (mapGL в„қ))) k :=
    CuspForm.translate g A
  have h_gtr_coe : (вҮ‘g_tr : UpperHalfPlane вҶ’ в„Ӯ) = вҮ‘g вҲЈ[k] A := rfl
  obtain вҹЁC_f, hC_fвҹ© := CuspFormClass.petersson_bounded_left k
    ((Gamma1 N).map (mapGL в„қ)) f f
  obtain вҹЁC_gtr, hC_gtrвҹ© :=
    CuspFormClass.petersson_bounded_left k _ g_tr g_tr
  have h_AM_GM : вҲҖ П„,
      вҖ–petersson k вҮ‘f (вҮ‘g вҲЈ[k] A) П„вҖ– вүӨ (C_f + C_gtr) / 2 := by
    intro П„
    rw [вҶҗ h_gtr_coe]
    show вҖ–petersson k вҮ‘f вҮ‘g_tr П„вҖ– вүӨ (C_f + C_gtr) / 2
    have h_norm_ineq : вҖ–petersson k вҮ‘f вҮ‘g_tr П„вҖ– вүӨ
        (вҖ–petersson k вҮ‘f вҮ‘f П„вҖ– + вҖ–petersson k вҮ‘g_tr вҮ‘g_tr П„вҖ–) / 2 := by
      simp only [petersson, norm_mul, Complex.norm_conj]
      have h_im_nn : (0 : в„қ) вүӨ вҖ–((П„.im : в„Ӯ) ^ k)вҖ– := norm_nonneg _
      nlinarith [mul_nonneg (sq_nonneg (вҖ–(вҮ‘f) П„вҖ– - вҖ–(вҮ‘g_tr) П„вҖ–)) h_im_nn,
        sq_nonneg (вҖ–(вҮ‘f) П„вҖ– - вҖ–(вҮ‘g_tr) П„вҖ–), norm_nonneg (вҮ‘f П„),
        norm_nonneg (вҮ‘g_tr П„), h_im_nn]
    linarith [hC_f П„, hC_gtr П„]
  have h_fd_null : NullMeasurableSet (ModularGroup.fd : Set UpperHalfPlane) Ој_hyp :=
    ((isClosed_le continuous_const
        (Complex.continuous_normSq.comp UpperHalfPlane.continuous_coe)).inter
      (isClosed_le (continuous_abs.comp UpperHalfPlane.continuous_re)
        continuous_const)).measurableSet.nullMeasurableSet
  have h_mapGL_mat_det_eq_one :
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
    rw [show (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix (qвҒ»В№ : SL(2, в„Ө)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, (qвҒ»В№ : SL(2, в„Ө)).property]
    simp
  have h_Tp_det_pos : вҲҖ b,
      0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det.val := fun b => by
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  have h_Оұ_det_pos : вҲҖ b,
      0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)).det.val := fun b => by
    show 0 < (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) :
          Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) :
            Matrix (Fin 2) (Fin 2) в„қ) =
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) *
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact h_Tp_det_pos b
  have h_finite_measure :
      Ој_hyp (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)) < вҠӨ := by
    refine lt_of_le_of_lt (measure_biUnion_finset_le _ _) ?_
    refine ENNReal.sum_lt_top.mpr fun b _ => ?_
    rw [measure_glPos_smul_eq _ (h_Оұ_det_pos b) h_fd_null]
    exact hyperbolicMeasure_fd_lt_top
  refine IntegrableOn.of_bound h_finite_measure ?_ ((C_f + C_gtr) / 2) ?_
  В· rw [вҶҗ h_gtr_coe]
    exact (petersson_continuous k (ModularFormClass.continuous f.toModularForm')
      (ModularFormClass.continuous g_tr)).aestronglyMeasurable.restrict
  В· exact ae_of_all _ fun П„ => h_AM_GM П„

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 per-q union-tile consumer**: combines the fixed-q LHS distribute
helper with `peterssonInner_M_infty_plus_upper_union_tile_per_q` + the landed
upper-family integrability to produce the per-q union-tile form directly from
the pre-transfer petN summand. -/
private lemma peterssonInner_heckeT_p_LHS_per_q_to_union_tiles
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
      (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
      (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)))
      вҮ‘f
      ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) +
    peterssonInner k
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane))
      вҮ‘f
      ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  rw [peterssonInner_heckeT_p_LHS_per_q_distribute p hp hpN q f g]
  exact peterssonInner_M_infty_plus_upper_union_tile_per_q p hp hpN q f g
    (integrableOn_petersson_upper_union_uniform_gslot_per_q p hp hpN q f g)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 per-q LHS-to-union-tiles, T_p_lower form**: combines
`peterssonInner_heckeT_p_LHS_per_q_to_union_tiles` (per-q M_вҲһ + upper-union
tile form, slot-2 = `(g вҲЈ T_p_upper(0)) вҲЈ ОівӮҖ`) with the slot-2 collapse
`(g вҲЈ T_p_upper(0)) вҲЈ ОівӮҖ = g вҲЈ T_p_lower` via
`slash_T_p_lower_eq_T_p_upper_zero_slash_gamma0.symm`, plus the M_вҲһ-branch
domain combine `M_вҲһ вҖў (mapGL qвҒ»В№ вҖў fd) = (glMap M_вҲһ * mapGL qвҒ»В№) вҖў fd` via
`вҶҗ mul_smul`.

This is the canonical per-q form with **uniform slot-2 = `g вҲЈ T_p_lower`**
and **uniform combined-GL domain shape `(glMap Оұ * mapGL qвҒ»В№) вҖў fd`** for
both the M_вҲһ branch and each upper-`b` branch вҖ” directly consumable by
`peterssonInner_sum_slash_adjoint_coset_aggregate` per Оұ to aggregate
the q-sum into a single Petersson integral over the per-Оұ tile union. -/
private lemma peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
      (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
      (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k
      (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
        (ModularGroup.fd : Set UpperHalfPlane))
      вҮ‘f (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) +
    peterssonInner k
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane))
      вҮ‘f (вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ)) := by
  rw [peterssonInner_heckeT_p_LHS_per_q_to_union_tiles p hp hpN q f g,
    show (вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) =
      вҮ‘g вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) from
        (slash_T_p_lower_eq_T_p_upper_zero_slash_gamma0 p hp hpN g).symm,
    вҶҗ mul_smul]

