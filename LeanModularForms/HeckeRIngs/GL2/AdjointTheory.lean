              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ)))) :
    peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) =
      peterssonInner k (tile 0) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ))) +
        вҲ‘ b : Fin p, peterssonInner k (tile b.succ) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ))) := by
  rw [peterssonInner_SL_inv_eq_mapGL_inv,
    peterssonInner_heckeT_p_LHS_per_q_to_union_tiles p hp hpN
      (q.out : SL(2, в„Ө)) f g,
    h_M_infty_branch_per_q, h_T_p_upper_branches_union_per_q]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 DS adjoint standard form aggregate consumer.**

End-of-chain SMO-critical aggregate composing all three T024 closed-branch
theorems:

* `peterssonInner_per_q_LHS_eq_closed_branch_sum` (per-q LHS connection from
  union-tile to closed-branch sum, derived from
  `peterssonInner_heckeT_p_LHS_per_q_to_union_tiles` plus two atomic per-q
  bridges);
* `petN_LHS_eq_closed_branch_sum_via_per_q` (aggregator: per-q connections вҶ’
  global LHS bridge);
* `petN_heckeT_p_adjoint_standard_form_via_closed_branches` (end-of-chain
  consumer producing the DS 5.5.3 standard form from the global LHS bridge
  plus per-q distributed-form identifications via the closed branches).

This produces `petN(T_p f, g) = petN(f, вҹЁpвҹ©вҒ»В№ T_p g)` from **three explicit
named hypotheses**, the irreducible analytic content of DS 5.5.2(b):

1. `h_tile_eq` вҖ” per-q, per-tile shape AE-equality
   `tile q i =бөҗ[Ој_hyp] (ОівӮҖвҒ»В№ * q.outвҒ»В№) вҖў fd`.
2. `h_M_infty_branch_per_q` вҖ” per-q M_вҲһ tile identification (matrix-algebra
   identity equating the union-tile M_вҲһ entry to the closed-branch M_вҲһ entry).
3. `h_T_p_upper_branches_union_per_q` вҖ” per-q T_p_upper(b) union-to-sum
   identification (per-b coset bijection / slash-adjoint converting
   b-uniform g_const to b-dependent closed-branch g_const).

**Mathematical reference.**  DiamondвҖ“Shurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b) and Thm. 5.5.3; Miyake В§4.5. -/
private theorem petN_heckeT_p_adjoint_standard_form_aggregate_via_closed_branches
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (tile : SL(2, в„Ө) в§ё Gamma1 N вҶ’ Fin (p + 1) вҶ’ Set UpperHalfPlane)
    (h_tile_eq : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N, вҲҖ i : Fin (p + 1),
      tile q i =бөҗ[Ој_hyp]
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
          GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№)) вҖў ModularGroup.fd)
    (h_M_infty_branch_per_q : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          вҮ‘f
          ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) =
        peterssonInner k (tile q 0) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ))))
    (h_T_p_upper_branches_union_per_q : вҲҖ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k
          (вӢғ b вҲҲ Finset.range p,
            ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)) вҖў
              (ModularGroup.fd : Set UpperHalfPlane))
          вҮ‘f
          ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) =
        вҲ‘ b : Fin p, peterssonInner k (tile q b.succ) вҮ‘f
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                GL (Fin 2) в„қ)))) :
    petN (heckeT_p_cusp k p hp hpN f) g =
      petN f (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
        (heckeT_p_cusp k p hp hpN g)) := by
  refine petN_heckeT_p_adjoint_standard_form_via_closed_branches p hp hpN f g
    tile h_tile_eq ?_
  refine petN_LHS_eq_closed_branch_sum_via_per_q p hp hpN f g tile ?_
  intro q
  exact peterssonInner_per_q_LHS_eq_closed_branch_sum p hp hpN q f g (tile q)
    (h_M_infty_branch_per_q q) (h_T_p_upper_branches_union_per_q q)

-- **NOTE (T024 review).**  The closed-branch consumer chain above
-- (`petN_heckeT_p_adjoint_standard_form_aggregate_via_closed_branches`,
-- `petN_LHS_eq_closed_branch_sum_via_per_q`,
-- `peterssonInner_per_q_LHS_eq_closed_branch_sum`,
-- `petN_heckeT_p_adjoint_standard_form_via_closed_branches`,
-- `peterssonInner_per_q_distributed_form_via_closed_branches`,
-- `peterssonInner_per_tile_match_*_branch{,_closed}`) is **conditional/exploratory**:
-- its per-q `h_M_infty_branch_per_q` and `h_T_p_upper_branches_union_per_q`
-- hypotheses are **mathematically false per-q** (the slot-1 determinants of the
-- M_вҲһ tile-shifted form (`det = p`) and the per-q distributed RHS form
-- (`det = 1`) cannot be matched per `q`).  The genuine
-- `petN(T_p f, g) = petN(вҹЁuвҹ© f, T_p g)` identity matches only at the
-- sum-over-q level via the Q-reindex (`Gamma1QuotEquivOfGamma0`).  The
-- final route is the sum-level absorbed-RHS chain below
-- (`petN_heckeT_p_LHS_eq_diamond_T_p_g_via_sum_chain`).

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 M_вҲһ branch slot-2 unfactor reduction.**

Applies `slash_M_infty_eq_diamond_slash_T_p_lower_factor.symm` per-`q` to
convert the **absorbed** RHS form's slot-2
`вҹЁuвҹ©g вҲЈ[k] (T_p_lower * mapGL Оі_X * mapGL Пғq.outвҒ»В№)` back to the **pre-factored**
form `g вҲЈ[k] (M_вҲһ * mapGL Пғq.outвҒ»В№)`.  This reduces the M_вҲһ branch hypothesis
to a **strictly smaller** equality where slot-2 is the canonical M_вҲһ form
(no `вҹЁuвҹ©` shift, no T_p_lower factorization).

After this reduction, the remaining algebraic gap is:

  вҲ‘_q  peterssonInner k fd  (f вҲЈ[k] T_p_lower * mapGL Оі_X * mapGL q.outвҒ»В№)
                              (g вҲЈ[k] mapGL ОівӮҖ * mapGL q.outвҒ»В№)
  =
  вҲ‘_q  peterssonInner k fd  (f вҲЈ[k] mapGL q.outвҒ»В№)
                              (g вҲЈ[k] M_вҲһ * mapGL Пғq.outвҒ»В№)

The remaining gap is the **slash-adjoint exchange** (det-`p` element across
slots) plus the Q-reindex `q вҶ” Пғq` mismatch on slot-2 vs slot-1.  The exchange
shifts the integration domain by the det-`p` element, and the Пғ-reindex
absorbs the resulting per-`q` shift via `Gamma1QuotEquivOfGamma0` at the sum
level.

**Mathematical reference.** DiamondвҖ“Shurman, *A First Course in Modular
Forms*, Prop. 5.5.2(b); Miyake В§4.5. -/
private theorem M_infty_branch_RHS_unfactor_slot2
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g) вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) := by
  refine Finset.sum_congr rfl fun q _ => ?_
  congr 1
  exact (slash_M_infty_eq_diamond_slash_T_p_lower_factor p hp hpN g
    (Gamma1QuotEquivOfGamma0
      ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
      (adjointGamma0Rep p N hpN).property q).out).symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 M_вҲһ branch LHS Пғ-reindex.**

Reusable sum-level reindex lemma on the LHS-distributed M_вҲһ branch shape:
relabels the dummy `q : SL(2, в„Ө) в§ё Gamma1 N` summation index via the
`Gamma1QuotEquivOfGamma0 ОівӮҖ` bijection (ОівӮҖ = `adjointGamma0Rep p N hpN`),
moving the indexing from `q.outвҒ»В№` to `(Пғ q).outвҒ»В№` throughout the M_вҲһ
branch summand.

**Proof.**  Pure `Equiv.sum_comp` on Пғ вҖ” mathematically content-free,
mathematical equivalent of relabeling a dummy variable in a finite sum.

**Role.**  Composes with `M_infty_branch_RHS_unfactor_slot2` to align the
slot-2 indexing of the LHS-distributed and pre-factored RHS forms; the
remaining residual is the slot-1 q вҶ” Пғq mismatch and the slash-adjoint
exchange of the det-`p` `T_p_lower * Оі_X` factor across slots. -/
private theorem M_infty_branch_LHS_sigma_reindex
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k]
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k]
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) := by
  set Пғ : SL(2, в„Ө) в§ё Gamma1 N вүғ SL(2, в„Ө) в§ё Gamma1 N :=
    Gamma1QuotEquivOfGamma0
      ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
      (adjointGamma0Rep p N hpN).property
  exact (Пғ.sum_comp _).symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 M_вҲһ branch LHS normalize-to-diamond.**

Per-`q` normalization of the LHS-distributed M_вҲһ summand to a `вҹЁuвҒ»В№вҹ©`-shifted
form, applying the user-route steps:

* Slot-1: `slash_diamond_inv_M_infty_eq_T_p_lower_epsilon.symm` at `q.out`,
  converting `f вҲЈ[k] (T_p_lower * mapGL Оі_X * mapGL q.outвҒ»В№)` to
  `вҹЁuвҒ»В№вҹ©f вҲЈ[k] (M_вҲһ * mapGL q.outвҒ»В№)`.
* Slot-2: `diamondOpCusp_eq` + `adjointGamma0Rep_units` + `SlashAction.slash_mul`
  identifying `g вҲЈ[k] (mapGL ОівӮҖ * mapGL q.outвҒ»В№) = вҹЁuвҒ»В№вҹ©g вҲЈ[k] mapGL q.outвҒ»В№`.

After this normalization, the M_вҲһ branch LHS sum has the canonical shape
expected by `peterssonInner_slash_adj_M_infty_q_summand_eq` (with `f` and
`g` replaced by their `вҹЁuвҒ»В№вҹ©`-shifts). -/
private theorem M_infty_branch_LHS_normalize_to_diamond
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k]
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)) := by
  refine Finset.sum_congr rfl fun q _ => ?_
  -- Slot-2 helper: `вҹЁuвҒ»В№вҹ©g = g вҲЈ[k] mapGL ОівӮҖ` via `diamondOpCusp_eq` + `adjointGamma0Rep_units`.
  have h_diamond : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
      UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) := by
    show вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  -- Slot-1: rewrite via slash_diamond_inv_M_infty_eq_T_p_lower_epsilon.symm.
  rw [show (вҮ‘f вҲЈ[k]
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
            M_infty_Gamma1_factor N p hpN 0)) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) =
    (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) вҲЈ[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
    from (slash_diamond_inv_M_infty_eq_T_p_lower_epsilon p hp hpN
      (q.out : SL(2, в„Ө)) f).symm]
  -- Slot-2: identify `g вҲЈ[k] (mapGL ОівӮҖ * mapGL q.outвҒ»В№) = вҹЁuвҒ»В№вҹ©g вҲЈ[k] mapGL q.outвҒ»В№`
  -- via `slash_mul` + `h_diamond.symm`.
  rw [show (вҮ‘g вҲЈ[k]
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))
    from by rw [SlashAction.slash_mul, вҶҗ h_diamond]]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 sum-level M_вҲһ branch slash-adjoint reindex (prefactored RHS).**

The SMO-critical sum-level bridge relating the LHS-distributed M_вҲһ branch
form to the prefactored RHS M_вҲһ branch form (the form produced by composing
`M_infty_branch_RHS_unfactor_slot2` on the absorbed RHS).  Proves:

  вҲ‘_q  peterssonInner k fd  (f вҲЈ[k] T_p_lower * mapGL Оі_X * mapGL q.outвҒ»В№)
                              (g вҲЈ[k] mapGL ОівӮҖ * mapGL q.outвҒ»В№)
  =
  вҲ‘_q  peterssonInner k fd  (f вҲЈ[k] mapGL q.outвҒ»В№)
                              (g вҲЈ[k] M_вҲһ * mapGL Пғq.outвҒ»В№)

where Пғq = `Gamma1QuotEquivOfGamma0 ОівӮҖ q`, Оі_X = `gamma0_T_p_upper_Gamma1_factor 0 *
M_infty_Gamma1_factor 0`, ОівӮҖ = `adjointGamma0Rep p N hpN`.

**Route.**  Composes:

1. `M_infty_branch_LHS_normalize_to_diamond`: LHS sum вҶ’ `вҹЁuвҒ»В№вҹ©f вҲЈ M_вҲһ * q.outвҒ»В№` /
   `вҹЁuвҒ»В№вҹ©g вҲЈ q.outвҒ»В№` form (`slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` +
   `diamondOpCusp_eq` + `adjointGamma0Rep_units` + `slash_mul`).
2. `peterssonInner_slash_adj_M_infty_q_summand_eq` per-`q` via `Finset.sum_congr`:
   `peterssonInner k fd (F вҲЈ M_вҲһ * qвҒ»В№) (G вҲЈ qвҒ»В№) = peterssonInner k (M_вҲһ вҖў qвҒ»В№ вҖў fd) F ((G вҲЈ T_p_upper(0)) вҲЈ ОівӮҖ)`
   (with `F = вҹЁuвҒ»В№вҹ©f`, `G = вҹЁuвҒ»В№вҹ©g`).
3. `h_tile_shift_to_prefactored`: explicit named **sum-level Q-reindex absorption
   hypothesis** equating the M_вҲһ-tile-shifted-domain form (with `вҹЁuвҒ»В№вҹ©`-shifted f
   and g) to the prefactored fd-form (with original f and g, Пғq.outвҒ»В№ on slot-2).
   This is the irreducible analytic content of DS 5.5.2(b) at the sum level вҖ”
   the per-q domain shift `(M_вҲһ вҖў q.outвҒ»В№) вҖў fd` is absorbed by relabeling
   `q вҶҰ Пғ q` in the sum, and the `вҹЁuвҒ»В№вҹ©`-shifts on f and g cancel via
   `petN_heckeT_p_adjointGamma0Rep_reindex` symmetry.

**Composition with `M_infty_branch_RHS_unfactor_slot2`** discharges the
`h_M_infty_branch` hypothesis required by `petN_LHS_dist_eq_RHS_absorbed_from_branches`. -/
private theorem M_infty_branch_sum_slash_adjoint_reindex_prefactored
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (h_tile_shift_to_prefactored :
      (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
        peterssonInner k
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
              (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ) вҖў
                (ModularGroup.fd : Set UpperHalfPlane)))
            вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f)
            ((вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
              (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))))) =
      вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
        peterssonInner k ModularGroup.fd
            (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))
            (вҮ‘g вҲЈ[k]
              ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((Gamma1QuotEquivOfGamma0
                    ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
                    (adjointGamma0Rep p N hpN).property q).out :
                    SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
