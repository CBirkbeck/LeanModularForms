          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
          GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№)) вҖў ModularGroup.fd) :
    peterssonInner k (tile 0) F
      (вҮ‘g вҲЈ[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
            GL (Fin 2) в„қ))) +
      вҲ‘ b : Fin p, peterssonInner k (tile b.succ) F
        (вҮ‘g вҲЈ[k]
          ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
