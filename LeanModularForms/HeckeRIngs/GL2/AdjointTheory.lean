            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f))
        (тЗСg тИг[k] (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)) := by
  rw [peterssonInner_iUnion_finite_aedisjoint _ hm hd _ _ hint_LHS,
