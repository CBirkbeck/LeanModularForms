                (((q.out : SL(2, в„Ө))вҒ»В№ : SL(2, в„Ө)) вҖў (fd : Set в„Қ)))
              вҮ‘f
              ((вҮ‘g : в„Қ вҶ’ в„Ӯ) вҲЈ[k]
                peterssonAdj (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ))) := by
  rw [petN_T_p_heckeT_p_LHS_sum_distributed p hp hpN f g]
