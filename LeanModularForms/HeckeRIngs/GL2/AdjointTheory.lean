the `тИС_b`. -/
private lemma peterssonInner_M_infty_plus_upper_union_tile_per_q
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hfi_upper : IntegrableOn
      (fun ╧Д => petersson k тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) ╧Д)
      (тЛГ b тИИ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set UpperHalfPlane)) ╬╝_hyp) :
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) +
      тИС b тИИ Finset.range p,
        peterssonInner k ModularGroup.fd
          (тЗСf тИг[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)))
          (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) =
    peterssonInner k
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) тАв
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ) тАв
            (ModularGroup.fd : Set UpperHalfPlane)))
        тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) +
      peterssonInner k
        (тЛГ b тИИ Finset.range p,
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
              (ModularGroup.fd : Set UpperHalfPlane))
        тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) := by
  rw [peterssonInner_ds_p_plus_one_family_union_collapse_per_q_split p hp hpN q f g]; congr 1
  rw [show (тИС b тИИ Finset.range p,
        peterssonInner k ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) тАв
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ) тАв
            (ModularGroup.fd : Set UpperHalfPlane)))
          тЗСf
          ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))))) =
      тИС b тИИ Finset.range p,
        peterssonInner k (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane))
          тЗСf
          ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) from
    Finset.sum_congr rfl fun b _ => by rw [mul_smul]]
  exact peterssonInner_T_p_upper_family_union_collapse_per_q hp hpN q f g hfi_upper

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 slash-chain bridge** (pre-mapped form): the GL(2, тДЭ) тЖТ GL(2, тДЭ)
stacked slash chain combines into a single GL(2, тДЭ) slash product via
