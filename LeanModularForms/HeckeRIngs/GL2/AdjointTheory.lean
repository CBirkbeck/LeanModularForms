private theorem peterssonInner_T_p_lower_iUnion_tile_eq_sum
    (p : тДХ) [NeZero N] (hpN : Nat.Coprime p N) (S : Set тДН) (F G : тДН тЖТ тДВ)
    (hm : тИА i : Option (Fin p), NullMeasurableSet
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) ╬╝_hyp)
