  `вҮ‘f вҲЈ[k] mapGL ОівӮҖвҒ»В№ = вҮ‘(вҹЁuвҹ© f)`;
* `slash_Gamma1QuotEquiv_out_inv_eq_diamond_slash_out_inv_GL` to absorb
  `(Пғ q).outвҒ»В№ = mapGL q.outвҒ»В№` modulo a diamond shift;
* `adjointGamma0Rep_units` to identify `Gamma0MapUnits ОівӮҖ = uвҒ»В№`;
* `diamondOpCusp_mul`/`inv_mul_cancel`/`diamondOpCusp_one` to collapse
  `вҹЁuвҒ»В№вҹ©(вҹЁuвҹ© f) = f`. -/
private lemma slash_diamond_outAt_Gamma1QuotEquiv_eq_slash_outAt
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (q : SL(2, в„Ө) в§ё Gamma1 N) :
    (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
        GL (Fin 2) в„қ)) вҲЈ[k]
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((Gamma1QuotEquivOfGamma0
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))
          (adjointGamma0Rep p N hpN).property q).out : SL(2, в„Ө))вҒ»В№) =
    вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (q.out : SL(2, в„Ө))вҒ»В№) := by
  -- Identify `вҮ‘f вҲЈ[k] mapGL ОівӮҖвҒ»В№` as `вҮ‘(вҹЁuвҹ© f)`.
  rw [show (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
        GL (Fin 2) в„қ)) =
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) :
        UpperHalfPlane вҶ’ в„Ӯ) from
    (coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f).symm]
  -- Apply T126 (GL form) to absorb Пғ.
  rw [slash_Gamma1QuotEquiv_out_inv_eq_diamond_slash_out_inv_GL
    (adjointGamma0Rep p N hpN)
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) q]
  -- Replace `Gamma0MapUnits adjointGamma0Rep` with `uвҒ»В№`.
  rw [adjointGamma0Rep_units p N hpN]
  -- Collapse `вҹЁuвҒ»В№вҹ©(вҹЁuвҹ© f) = f`.
  congr 1
  show вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f)) = вҮ‘f
  rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f) =
      ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№).comp
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN))) f from rfl,
    вҶҗ diamondOpCusp_mul, inv_mul_cancel, diamondOpCusp_one]
  rfl

