private lemma peterssonInner_slash_adj_T_p_upper_q_summand_eq
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          (mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ)))
        (вҮ‘g вҲЈ[k] (mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ)) =
    peterssonInner k ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ) вҖў (ModularGroup.fd : Set UpperHalfPlane)))
      вҮ‘f
      ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  -- Positive det of glMap T_p_upper(p, b) in GL (Fin 2) в„қ.
  have hdet_pos : 0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det.val := by
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  -- Step 1: transfer the adjoint to the g-slot via `peterssonInner_slash_adjoint_coset`.
  rw [peterssonInner_slash_adjoint_coset (glMap (T_p_upper p hp.pos b))
        hdet_pos q вҮ‘f вҮ‘g]
  -- Step 2: apply the b-coset-bijection consumer to collapse b-dependence on
  -- the g-slot.  This transitively invokes
  -- `slash_peterssonAdj_T_p_upper_adjointGamma0Rep_inv_eq_T_p_upper_zero`
  -- through `slash_peterssonAdj_T_p_upper_eq_slash_T_p_upper_zero_slash_gamma0`.
  rw [slash_peterssonAdj_T_p_upper_eq_slash_T_p_upper_zero_slash_gamma0 p hp hpN b g]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205 finite-family upper b-collapse (per-`q`)**: for each
