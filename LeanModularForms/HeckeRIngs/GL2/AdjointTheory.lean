/-- **Phase M (e) вҖ” uniform fiber cardinality** of `slGamma_p_ОұToGamma1` at identity. -/
noncomputable def slGamma_p_ОұToGamma1_fiberCard (Оұ : GL (Fin 2) в„ҡ) : в„• :=
  haveI : DecidableEq (SL(2, в„Ө) в§ё Gamma1 N) := Classical.decEq _
  (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ =>
