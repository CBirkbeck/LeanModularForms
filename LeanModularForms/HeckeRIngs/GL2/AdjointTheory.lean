        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f))
        ((вҮ‘g) вҲЈ[k] (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)) П„)
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
