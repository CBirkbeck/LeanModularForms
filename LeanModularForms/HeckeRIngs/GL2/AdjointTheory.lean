    (h_upper_disj : вҲҖ b вҲҲ Finset.range p,
      Pairwise (fun (qвӮҒ qвӮӮ : SL(2, в„Ө) в§ё Gamma1 N) =>
        AEDisjoint Ој_hyp
          (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
