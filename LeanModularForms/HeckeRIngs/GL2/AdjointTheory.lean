/-- **T090 per-(╬▒, ╬│_╬▒) general slash factorization (per-q).**

Generalizes both `slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` (for ╬▒ = M_тИЮ,
╬│_╬▒ = ╬│_X┬╖╬│_Y) and `slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` (for
╬▒ = T_p_upper(b), ╬│_╬▒ = ╬│_b) under a single matrix-factorization hypothesis.

Given the per-╬▒ matrix identity `╬│тВА ┬╖ ╬▒ = T_p_lower ┬╖ mapGL ╬│_╬▒` in `GL(2, тДЭ)`
(satisfied by both DS Prop. 5.5.2(b) families per the existing
`mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon` /
`mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta`), the per-q slash
identity holds:

```
тЯиuтБ╗┬╣тЯйg тИг[k] (╬▒ ┬╖ mapGL qтБ╗┬╣) = g тИг[k] (T_p_lower ┬╖ mapGL ╬│_╬▒ ┬╖ mapGL qтБ╗┬╣)
```

This is the per-q "matrix factorization step" used by both the M_тИЮ and upper-b
chain Step 3 (slot-1 diamond unfactor). -/
private lemma slash_diamond_inv_╬▒_eq_T_p_lower_via_matrix_factor
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (╬▒ : GL (Fin 2) тДЭ) (╬│_╬▒ : SL(2, тДд))
    (h_factor : ((mapGL тДЭ : SL(2, тДд) тЖТ* _)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) : GL (Fin 2) тДЭ) * ╬▒ =
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│_╬▒ : GL (Fin 2) тДЭ))
    (q : SL(2, тДд)) (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
      (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тЗСg тИг[k]
      ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│_╬▒) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) := by
  have h_diamond : (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) :
      UpperHalfPlane тЖТ тДВ) =
      тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) := by
    show тЗС(diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  rw [h_diamond, тЖР SlashAction.slash_mul, тЖР mul_assoc, h_factor]

