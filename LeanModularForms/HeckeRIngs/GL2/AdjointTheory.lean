          | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ)) вҖў D)
      f (g вҲЈ[k] (glMap (T_p_lower p hp) : GL (Fin 2) в„қ)) =
    peterssonInner k
      (вӢғ i : Option (Fin p),
        (match i with
          | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)
          | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ)) вҖў D)
      (g' вҲЈ[k] (glMap (T_p_lower p hp) : GL (Fin 2) в„қ)) g вҶ”
    peterssonInner k
      ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) вҖў
        (вӢғ i : Option (Fin p),
          (match i with
            | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)
            | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ)) вҖў D))
      (f вҲЈ[k] (glMap (T_p_upper p hp 0) : GL (Fin 2) в„қ)) g =
    peterssonInner k
      ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) вҖў
        (вӢғ i : Option (Fin p),
          (match i with
            | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)
            | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ)) вҖў D))
      g' (g вҲЈ[k] (glMap (T_p_upper p hp 0) : GL (Fin 2) в„қ)) := by
  rw [peterssonInner_Hecke_FD_T_p_lower_slot2_slash_adjoint
        (N := N) p hp hpN D f g,
      peterssonInner_Hecke_FD_T_p_lower_slot1_slash_adjoint
        (N := N) p hp hpN D g' g]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM MГ¶bius scalar invariance**: for `Оұ, ОІ вҲҲ GL(2,в„қ)вҒә` with
`Оұ.val = c вҖў ОІ.val` for some real `c вү  0`, the MГ¶bius actions on `в„Қ` agree:
`Оұ вҖў П„ = ОІ вҖў П„`.

Mathematical content: scalars are in the kernel of `GL+(2,в„қ) вҶ’ PGL+(2,в„қ)`,
which is the group acting faithfully on `в„Қ`. -/
private lemma UpperHalfPlane_smul_eq_of_matrix_smul_eq
    (Оұ ОІ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val) (hОІ : 0 < ОІ.det.val)
    (c : в„қ) (hc : c вү  0)
    (hMat : (Оұ : Matrix (Fin 2) (Fin 2) в„қ) = c вҖў (ОІ : Matrix (Fin 2) (Fin 2) в„қ))
    (П„ : в„Қ) :
    Оұ вҖў П„ = ОІ вҖў П„ := by
  rw [UpperHalfPlane.ext_iff,
      UpperHalfPlane.coe_smul_of_det_pos hОұ,
      UpperHalfPlane.coe_smul_of_det_pos hОІ]
  simp only [UpperHalfPlane.num, UpperHalfPlane.denom]
  have h00 : (Оұ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 =
      c * (ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h01 : (Оұ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 =
      c * (ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h10 : (Оұ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 =
      c * (ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h11 : (Оұ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 =
      c * (ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  rw [show ((Оұ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 : в„Ӯ) =
        (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 : в„Ӯ) from by
    exact_mod_cast h00,
    show ((Оұ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 : в„Ӯ) =
        (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 : в„Ӯ) from by
      exact_mod_cast h01,
    show ((Оұ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 : в„Ӯ) =
        (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 : в„Ӯ) from by
      exact_mod_cast h10,
    show ((Оұ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 : в„Ӯ) =
        (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 : в„Ӯ) from by
      exact_mod_cast h11]
  have hc_ne_zero : (c : в„Ӯ) вү  0 := by exact_mod_cast hc
  -- num/denom both scale by c, ratio unchanged
  have h_num : (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 : в„Ӯ) * (П„ : в„Ӯ) +
      (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 : в„Ӯ) =
      (c : в„Ӯ) * (((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 0 : в„Ӯ) * (П„ : в„Ӯ) +
        ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 0 1 : в„Ӯ)) := by ring
  have h_den : (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 : в„Ӯ) * (П„ : в„Ӯ) +
      (c : в„Ӯ) * ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 : в„Ӯ) =
      (c : в„Ӯ) * (((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 0 : в„Ӯ) * (П„ : в„Ӯ) +
        ((ОІ : Matrix (Fin 2) (Fin 2) в„қ) 1 1 : в„Ӯ)) := by ring
  rw [h_num, h_den, mul_div_mul_left _ _ hc_ne_zero]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM upper-tile MГ¶bius equivalence**: `T_p_lower В· T_p_upper(b)`
acts on `в„Қ` the same as `shiftSL_loc(b) вҲҲ SL(2,в„Ө)`.

Composes `UpperHalfPlane_smul_eq_of_matrix_smul_eq` with the matrix identity
`(T_p_lower В· T_p_upper(b)).val = p вҖў shiftSL_loc(b).val` (entry-wise: both
sides equal `!![p, pb; 0, p]`). -/
private theorem T_p_lower_mul_T_p_upper_smul_eq_shift_smul
    (p : в„•) (hp : 0 < p) (b : в„•) (П„ : в„Қ) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
      (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ)) вҖў П„ =
    ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (shiftSL_loc (b : в„Ө)) : GL (Fin 2) в„қ) вҖў П„ := by
  have hp_real : (0 : в„қ) < (p : в„қ) := by exact_mod_cast hp
  have h_det_pos_LHS : 0 <
      ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
        (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ)).det.val := by
    show 0 < (((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
      (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show (((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
        (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) : Matrix _ _ в„қ) *
        ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) : Matrix _ _ в„қ) from rfl,
      Matrix.det_mul]
    have h_T_p_lower : ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = (p : в„қ) := by
      rw [show ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) =
          ((T_p_lower p hp : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
      rw [show (((T_p_lower p hp : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
          (algebraMap в„ҡ в„қ) (((T_p_lower p hp : GL (Fin 2) в„ҡ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_lower p hp : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
        simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = _
      rfl
    have h_T_p_upper : ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = (p : в„қ) := by
      rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) =
          ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
      rw [show (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
          (algebraMap в„ҡ в„қ) (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
        simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = _
      rfl
    rw [h_T_p_lower, h_T_p_upper]
    positivity
  have h_det_pos_RHS : 0 <
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b : в„Ө)) :
        GL (Fin 2) в„қ).det.val := by
    show 0 < (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b : в„Ө)) :
        GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc (b : в„Ө)) :
        GL (Fin 2) в„қ).val = ((Int.castRingHom в„қ).mapMatrix
        (shiftSL_loc (b : в„Ө)).val) from by rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, (shiftSL_loc (b : в„Ө)).property]
    norm_num
  refine UpperHalfPlane_smul_eq_of_matrix_smul_eq _ _ h_det_pos_LHS h_det_pos_RHS
    (p : в„қ) (by exact_mod_cast hp.ne') ?_ П„
  -- Matrix entry equality: (T_p_lower В· T_p_upper(b)).val = p вҖў shiftSL_loc(b).val
  ext i j
  fin_cases i <;> fin_cases j <;>
    simp [glMap, T_p_lower, T_p_upper, mapGL_coe_matrix, shiftSL_loc,
      Matrix.GeneralLinearGroup.mkOfDetNeZero, Matrix.GeneralLinearGroup.map,
      Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply, Units.val_mul,
      algebraMap_int_eq, Matrix.smul_apply] <;>
    ring

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM M_вҲһ-tile MГ¶bius equivalence**: `T_p_lower В· M_вҲһ`
acts on `в„Қ` the same as `mapGL в„қ (M_infty_Gamma1_factor) вҲҲ О“вӮҒ(N)`.

Composes the upper-tile MГ¶bius equivalence at `b = 0` with the
matrix factorization
`glMap M_вҲһ = glMap T_p_upper(0) В· mapGL M_infty_Gamma1_factor`. -/
private theorem T_p_lower_mul_M_infty_smul_eq_M_infty_Gamma1_factor_smul
    (p : в„•) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (П„ : в„Қ) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
      (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)) вҖў П„ =
    ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) в„қ) вҖў П„ := by
  -- glMap M_вҲһ = glMap T_p_upper(0) В· mapGL M_infty_Gamma1_factor
  have h_M_infty_eq : (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) =
      (glMap (T_p_upper p hp 0) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (M_infty_Gamma1_factor N p hpN 0)) := by
    rw [вҶҗ glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp hpN 0,
      mul_inv_cancel_left]
  rw [h_M_infty_eq, вҶҗ mul_assoc, mul_smul]
  -- (T_p_lower В· T_p_upper(0)) вҖў (mapGL M_infty_Gamma1_factor вҖў П„)
  -- = shift(0) вҖў (mapGL M_infty_Gamma1_factor вҖў П„) [by tile equivalence]
  rw [T_p_lower_mul_T_p_upper_smul_eq_shift_smul p hp 0]
  -- shift(0) = id on в„Қ
  show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (shiftSL_loc ((0 : в„•) : в„Ө))
    : GL (Fin 2) в„қ) вҖў _ = _
  rw [show shiftSL_loc ((0 : в„•) : в„Ө) = (1 : SL(2, в„Ө)) from by
    apply Subtype.ext; ext i j
    fin_cases i <;> fin_cases j <;>
      simp [shiftSL_loc, Matrix.of_apply, Nat.cast_zero]]
  simp [MonoidHom.map_one, one_smul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM MГ¶bius equivalence on sets**: scalar invariance lifts
to set-level smul equality. If `Оұ, ОІ вҲҲ GL(2,в„қ)вҒә` satisfy
`Оұ вҖў П„ = ОІ вҖў П„` for all П„ вҲҲ в„Қ, then `Оұ вҖў S = ОІ вҖў S` for any `S вҠҶ в„Қ`. -/
private lemma smul_set_eq_of_smul_eq
    {Оұ ОІ : GL (Fin 2) в„қ} (hsmul : вҲҖ П„ : в„Қ, Оұ вҖў П„ = ОІ вҖў П„) (S : Set в„Қ) :
    Оұ вҖў S = ОІ вҖў S := by
  ext П„
  constructor
  В· rintro вҹЁПғ, hПғ, rflвҹ©
    exact вҹЁПғ, hПғ, (hsmul Пғ).symmвҹ©
  В· rintro вҹЁПғ, hПғ, rflвҹ©
    exact вҹЁПғ, hПғ, hsmul Пғвҹ©

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM upper-tile set equivalence**:
`(T_p_lower В· T_p_upper(b)) вҖў S = shiftSL_loc(b) вҖў S` for any `S : Set в„Қ`. -/
private theorem T_p_lower_mul_T_p_upper_smul_set_eq_shift_smul
    (p : в„•) (hp : 0 < p) (b : в„•) (S : Set в„Қ) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
      (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ)) вҖў S =
    ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (shiftSL_loc (b : в„Ө)) : GL (Fin 2) в„қ) вҖў S :=
  smul_set_eq_of_smul_eq (T_p_lower_mul_T_p_upper_smul_eq_shift_smul p hp b) S

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM M_вҲһ-tile set equivalence**:
`(T_p_lower В· M_вҲһ) вҖў S = mapGL в„қ M_infty_Gamma1_factor вҖў S` for any `S : Set в„Қ`. -/
private theorem T_p_lower_mul_M_infty_smul_set_eq_M_infty_Gamma1_factor_smul
    (p : в„•) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (S : Set в„Қ) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) в„қ) *
      (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)) вҖў S =
    ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
      (M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) в„қ) вҖў S :=
  smul_set_eq_of_smul_eq
    (T_p_lower_mul_M_infty_smul_eq_M_infty_Gamma1_factor_smul (N := N) p hp hpN) S

/-- **T205-d-SYMM SL(2,в„Ө) tile family**: the (p+1) SL(2,в„Ө) elements
that index the per-tile decomposition of `T_p_lower вҖў Hecke_FD`. -/
private noncomputable def T_p_lower_tile_family
    (N p : в„•) [NeZero N] (hpN : Nat.Coprime p N) :
    Option (Fin p) вҶ’ SL(2, в„Ө)
  | none => M_infty_Gamma1_factor N p hpN 0
  | some b => shiftSL_loc (b.val : в„Ө)

/-- **T205-d-SYMM Hecke representative family** as a function. -/
private noncomputable def Hecke_rep_family
    (N p : в„•) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) :
    Option (Fin p) вҶ’ GL (Fin 2) в„қ
  | none => (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ)
  | some b => (glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM Hecke FD tile decomposition under T_p_lower**:
`T_p_lower вҖў (вӢғ_X Оұ_X вҖў S) = вӢғ_X (mapGL П„_X) вҖў S` where each П„_X is the
corresponding SL(2,в„Ө) element (`shiftSL_loc(b)` for the upper branches,
`M_infty_Gamma1_factor` for the M_вҲһ branch).

This is the geometric heart of the per-tile Пғ_p Q-permutation: the Hecke
FD shifted by T_p_lower decomposes as a union of (p+1) SL(2,в„Ө)-tiles. -/
private theorem T_p_lower_smul_Hecke_FD_eq_iUnion_tile
    (p : в„•) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (S : Set в„Қ) :
    (glMap (T_p_lower p hp) : GL (Fin 2) в„қ) вҖў
      (вӢғ i : Option (Fin p), Hecke_rep_family N p hp hpN i вҖў S) =
    вӢғ i : Option (Fin p),
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ) вҖў S := by
  rw [Set.smul_set_iUnion]
  refine Set.iUnion_congr fun i => ?_
  match i with
  | none =>
    show (glMap (T_p_lower p hp) : GL (Fin 2) в„қ) вҖў
      ((glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) вҖў S) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) в„қ) вҖў S
    rw [вҶҗ mul_smul]
    exact T_p_lower_mul_M_infty_smul_set_eq_M_infty_Gamma1_factor_smul
      (N := N) p hp hpN S
  | some b =>
    show (glMap (T_p_lower p hp) : GL (Fin 2) в„қ) вҖў
      ((glMap (T_p_upper p hp b.val) : GL (Fin 2) в„қ) вҖў S) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (shiftSL_loc (b.val : в„Ө)) : GL (Fin 2) в„қ) вҖў S
    rw [вҶҗ mul_smul]
    exact T_p_lower_mul_T_p_upper_smul_set_eq_shift_smul p hp b.val S

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM per-tile slash conversion**: applying
`peterssonInner_mapGL_smul_eq_slash` to each tile of the
`T_p_lower вҖў Hecke_FD` decomposition converts each tile integral on
`mapGL П„_X вҖў S` into a slash form on `S` with both slots slashed by `П„_X`. -/
private theorem peterssonInner_T_p_lower_tile_eq_slash
    (p : в„•) [NeZero N] (hpN : Nat.Coprime p N) (S : Set в„Қ) (F G : в„Қ вҶ’ в„Ӯ)
    (i : Option (Fin p)) :
    peterssonInner k
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) в„қ) вҖў S) F G =
    peterssonInner k S
