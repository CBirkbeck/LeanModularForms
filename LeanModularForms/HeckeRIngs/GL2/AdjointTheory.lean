      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S)
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN j) : GL (Fin 2) тДЭ) тАв S)))
    (hfi : IntegrableOn (fun ╧Д => petersson k F G ╧Д)
      (тЛГ i : Option (Fin p),
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) ╬╝_hyp) :
    peterssonInner k
      (тЛГ i : Option (Fin p),
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) F G =
    тИС i : Option (Fin p), peterssonInner k
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) F G :=
  peterssonInner_iUnion_finite_aedisjoint _ hm hd F G hfi

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM full chain: T_p_lowerтАвHecke_FD as ╬г ╧Д_X-slashed ╬УтВБ_FD integrals**.

Composes the entire chain:
* `T_p_lower_smul_Hecke_FD_eq_iUnion_tile` (set decomposition);
* `peterssonInner_T_p_lower_iUnion_tile_eq_sum` (iUnion to sum);
* `peterssonInner_T_p_lower_tile_eq_slash` (per-tile slash conversion).

Result: for `F G : тДН тЖТ тДВ` with appropriate measure-theoretic hypotheses,
```
pet (T_p_lower тАв Hecke_FD) F G = тИС_X pet ╬УтВБ_FD (F тИг ╧Д_X) (G тИг ╧Д_X)
```
where `╧Д_X` ranges over the SL(2,тДд) family
`{M_infty_Gamma1_factor} тИк {shiftSL_loc(b)}_{b<p}`.

This is the **final slash-form** of the T_p_lowerтАвHecke_FD integral тАФ
both sides of the symmetric form residual reduce to expressions of this
shape, exposing the ╧Г_p Q-permutation as a sum reindex on Option (Fin p). -/
private theorem peterssonInner_T_p_lower_Hecke_FD_eq_sum_tile_slash
    (p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N)
    (S : Set тДН) (F G : тДН тЖТ тДВ)
    (hm : тИА i : Option (Fin p), NullMeasurableSet
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) ╬╝_hyp)
    (hd : Pairwise (fun i j : Option (Fin p) => AEDisjoint ╬╝_hyp
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S)
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN j) : GL (Fin 2) тДЭ) тАв S)))
    (hfi : IntegrableOn (fun ╧Д => petersson k F G ╧Д)
      (тЛГ i : Option (Fin p),
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) тАв S) ╬╝_hyp) :
    peterssonInner k
      ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) тАв
        (тЛГ i : Option (Fin p), Hecke_rep_family N p hp hpN i тАв S)) F G =
    тИС i : Option (Fin p), peterssonInner k S
      (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))
      (G тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ)) := by
  rw [T_p_lower_smul_Hecke_FD_eq_iUnion_tile (N := N) p hp hpN S,
      peterssonInner_T_p_lower_iUnion_tile_eq_sum (N := N) p hpN S F G hm hd hfi]
  refine Finset.sum_congr rfl fun i _ => ?_
  exact peterssonInner_T_p_lower_tile_eq_slash (N := N) p hpN S F G i

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM uniform identity** `mapGL ╧Д_X ┬╖ peterssonAdj ╬▒_X = glMap T_p_lower`.

For each `X : Option (Fin p)`, the product `mapGL ╧Д_X ┬╖ peterssonAdj ╬▒_X`
collapses **uniformly** to `glMap T_p_lower`:

- `X = some b`: shift(b) ┬╖ peterssonAdj T_p_upper(b)
              = shift(b) ┬╖ (mapGL shift(-b) ┬╖ glMap T_p_lower)
              = mapGL (shift(b)┬╖shift(-b)) ┬╖ glMap T_p_lower = glMap T_p_lower тЬУ
- `X = none`: M_infty_Gamma1_factor ┬╖ peterssonAdj M_тИЮ
            = M_infty_Gamma1_factor ┬╖ (mapGL M_infty_Gamma1_factorтБ╗┬╣ ┬╖ glMap T_p_lower)
            = mapGL 1 ┬╖ glMap T_p_lower = glMap T_p_lower тЬУ

This is the key algebraic identity making the per-X slash-adjoint reduction
collapse to a single uniform target (analog of the `gтИгpeterssonAdj ╬▒_X = gтИгT_p_lower`
uniformity, but at the matrix level). -/
private theorem mapGL_tile_mul_peterssonAdj_Hecke_rep_eq_glMap_T_p_lower
    (p : тДХ) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (i : Option (Fin p)) :
    ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ) *
      peterssonAdj (Hecke_rep_family N p hp.pos hpN i) =
    (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) := by
  match i with
  | none =>
    show ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN 0)
      : GL (Fin 2) тДЭ) *
      peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)
    -- M_тИЮ = T_p_upper(0) ┬╖ M_infty_Gamma1_factor
    rw [show (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) =
        (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (M_infty_Gamma1_factor N p hpN 0)) from by
      rw [тЖР glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp.pos hpN 0,
        mul_inv_cancel_left]]
    rw [peterssonAdj_mul, peterssonAdj_mapGL_SL_eq_inv,
      peterssonAdj_glMap_T_p_upper_zero_eq_glMap_T_p_lower]
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (M_infty_Gamma1_factor N p hpN 0)) *
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (M_infty_Gamma1_factor N p hpN 0))тБ╗┬╣ *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) =
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (M_infty_Gamma1_factor N p hpN 0) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (M_infty_Gamma1_factor N p hpN 0))тБ╗┬╣) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) from by group]
    rw [mul_inv_cancel, one_mul]
  | some b =>
    show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b.val : тДд))
      : GL (Fin 2) тДЭ) *
      peterssonAdj (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) =
      (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)
    rw [peterssonAdj_T_p_upper_eq_shift_mul_lower p hp.pos b.val]
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b.val : тДд))) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b.val : тДд))) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) =
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b.val : тДд)) *
          (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b.val : тДд)))) *
          (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) from by group]
    rw [тЖР map_mul]
    rw [show shiftSL_loc (b.val : тДд) * shiftSL_loc (-(b.val : тДд)) =
        (1 : SL(2, тДд)) from by
      apply Subtype.ext; ext i j
      fin_cases i <;> fin_cases j <;>
        simp [shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply]]
    rw [map_one, one_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM per-X swap identity** via slot-2 slash-adjoint + uniformity.

For each `X : Option (Fin p)`, slot-2 slash-adjoint applied with `╬▒ = ╬▒_X`
plus the uniform identity `╧Д_X ┬╖ peterssonAdj ╬▒_X = T_p_lower` yields:

  pet ╬УтВБ_FD F (GтИг╬▒_X) = pet (╬▒_XтАв╬УтВБ_FD) (FтИгpeterssonAdj ╬▒_X) G

Specialized at F = "anything тИг ╧Д_X" form:
  pet ╬УтВБ_FD (F'тИг╧Д_X) (GтИг╬▒_X) = pet (╬▒_XтАв╬УтВБ_FD) (F'тИгT_p_lower) G

where the slash by `╧Д_X ┬╖ peterssonAdj ╬▒_X` simplifies to slash by T_p_lower
uniformly via the previous lemma. -/
private theorem peterssonInner_swap_via_uniform_adj
    (p : тДХ) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (F G : тДН тЖТ тДВ) (i : Option (Fin p)) :
    peterssonInner k (fd : Set тДН)
      (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))
      (G тИг[k] (Hecke_rep_family N p hp.pos hpN i)) =
    peterssonInner k (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
      (F тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) G := by
  have h╬▒ : 0 < (Hecke_rep_family N p hp.pos hpN i).det.val := by
    match i with
    | none =>
      exact glMap_M_infty_det_pos N p hp.pos hpN
    | some b =>
      show 0 < ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det
      rw [show ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) =
          ((T_p_upper p hp.pos b.val : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
      rw [show (((T_p_upper p hp.pos b.val : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
          (algebraMap тДЪ тДЭ) (((T_p_upper p hp.pos b.val : GL (Fin 2) тДЪ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_upper p hp.pos b.val : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
        simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
      rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
      exact_mod_cast hp.pos
  rw [peterssonInner_slash_adjoint_right _ _ h╬▒]
  rw [show (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ)) тИг[k]
        peterssonAdj (Hecke_rep_family N p hp.pos hpN i) =
        F тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) from by
    rw [тЖР SlashAction.slash_mul,
      mapGL_tile_mul_peterssonAdj_Hecke_rep_eq_glMap_T_p_lower (N := N) p hp hpN i]]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM LHS-side per-X swap identity** via slot-1 slash-adjoint
+ uniformity.

For each X, slot-1 slash-adjoint at ╬▒ = ╬▒_X combined with the uniform
identity yields:

  pet ╬УтВБ_FD (G тИг ╬▒_X) (F тИг ╧Д_X) = pet (╬▒_X тАв ╬УтВБ_FD) G (F тИг T_p_lower)

Summing over X (AE-disjoint): converts the slot-1 sum into pet Hecke_FD G (F тИг T_p_lower).

This is the LHS analog of `peterssonInner_swap_via_uniform_adj`. -/
private theorem peterssonInner_swap_via_uniform_adj_slot1
    (p : тДХ) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (F G : тДН тЖТ тДВ) (i : Option (Fin p)) :
    peterssonInner k (fd : Set тДН)
      (G тИг[k] (Hecke_rep_family N p hp.pos hpN i))
      (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ)) =
    peterssonInner k (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН)) G
      (F тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) := by
  -- Apply petersson_symm twice: pet (GтИг╬▒_X) (FтИг╧Д_X) = conj(pet (FтИг╧Д_X) (GтИг╬▒_X))
  -- Then use the slot-2 swap, then conj back.
  rw [тЖР peterssonInner_conj_symm,
      peterssonInner_swap_via_uniform_adj (N := N) p hp hpN F G i,
      peterssonInner_conj_symm]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM aggregate-form characterization**: combining the per-X
swap identities (slot-1 and slot-2) under AE-disjoint hypotheses converts the
╧Г_p Q-permutation aggregate residual

  `тИС_X pet ╬УтВБ_FD (fтИг╬▒_X) (gтИг╧Д_X) = тИС_X pet ╬УтВБ_FD ((тЯиuтЯйf)тИг╧Д_X) (gтИг╬▒_X)`

(itself equivalent to the symmetric form `petN(T_p f, g) = petN(тЯиuтЯйf, T_p g)`)
into a SINGLE integral equality on the Hecke FD:

  `pet Hecke_FD f (gтИгT_p_lower) = pet Hecke_FD ((тЯиuтЯйf)тИгT_p_lower) g`

This is the FINAL form of the residual at the integral level тАФ both sides
are integrals on the SAME Hecke FD with different (slot-1, slot-2) slash
structure. The remaining content is to prove this integral equality
directly via measure-theoretic change of variables.

The wrapper composes:
* `peterssonInner_swap_via_uniform_adj_slot1` (LHS per-X collapse)
* `peterssonInner_swap_via_uniform_adj` (RHS per-X collapse)
* `peterssonInner_iUnion_finite_aedisjoint` (sum-to-iUnion absorption,
  requires the AE-disjoint hypothesis). -/
private theorem peterssonInner_per_X_sum_iff_Hecke_FD_residual
    (p : тДХ) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : тДН тЖТ тДВ)
    (hm : тИА i : Option (Fin p), NullMeasurableSet
      (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН)) ╬╝_hyp)
    (hd : Pairwise (fun i j : Option (Fin p) => AEDisjoint ╬╝_hyp
      (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
      (Hecke_rep_family N p hp.pos hpN j тАв (fd : Set тДН))))
    (hfi_LHS : IntegrableOn (fun ╧Д => petersson k f
        (g тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН)) ╬╝_hyp)
    (hfi_RHS : IntegrableOn (fun ╧Д => petersson k
        (f тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) g ╧Д)
      (тЛГ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН)) ╬╝_hyp) :
    (тИС i : Option (Fin p), peterssonInner k (fd : Set тДН)
      (f тИг[k] (Hecke_rep_family N p hp.pos hpN i))
      (g тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))) =
      peterssonInner k
        (тЛГ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
        f (g тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) тИз
    (тИС i : Option (Fin p), peterssonInner k (fd : Set тДН)
      (f тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))
      (g тИг[k] (Hecke_rep_family N p hp.pos hpN i))) =
      peterssonInner k
        (тЛГ i : Option (Fin p), Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
        (f тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) g := by
  refine тЯи?_, ?_тЯй
  ┬╖ -- LHS aggregation: тИС_X pet ╬УтВБ_FD (fтИг╬▒_X) (gтИг╧Д_X) = pet Hecke_FD f (gтИгT_p_lower)
    have h_per_X : тИА i : Option (Fin p), peterssonInner k (fd : Set тДН)
        (f тИг[k] (Hecke_rep_family N p hp.pos hpN i))
        (g тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ)) =
        peterssonInner k (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
          f (g тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) := fun i =>
      peterssonInner_swap_via_uniform_adj_slot1 (N := N) p hp hpN g f i
    rw [Finset.sum_congr rfl (fun i _ => h_per_X i)]
    exact (peterssonInner_iUnion_finite_aedisjoint
      (fun i : Option (Fin p) => Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
      hm hd f (g тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) hfi_LHS).symm
  ┬╖ -- RHS aggregation: тИС_X pet ╬УтВБ_FD (fтИг╧Д_X) (gтИг╬▒_X) = pet Hecke_FD (fтИгT_p_lower) g
    have h_per_X : тИА i : Option (Fin p), peterssonInner k (fd : Set тДН)
        (f тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (T_p_lower_tile_family N p hpN i) : GL (Fin 2) тДЭ))
        (g тИг[k] (Hecke_rep_family N p hp.pos hpN i)) =
        peterssonInner k (Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
          (f тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) g := fun i =>
      peterssonInner_swap_via_uniform_adj (N := N) p hp hpN f g i
    rw [Finset.sum_congr rfl (fun i _ => h_per_X i)]
    exact (peterssonInner_iUnion_finite_aedisjoint
      (fun i : Option (Fin p) => Hecke_rep_family N p hp.pos hpN i тАв (fd : Set тДН))
      hm hd (f тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) g hfi_RHS).symm

