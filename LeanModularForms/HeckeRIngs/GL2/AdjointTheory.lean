open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 slash-chain bridge** (post-expansion form): matches the actual
post-`heckeT_p_fun_eq_coset_sum` stacked form `F тИг[k] (╬▒ : GL(2,тДЪ)) тИг[k] (mapGL тДЭ ╬┤)`
with the GL(2,тДЪ) slash via the `monoidHomSlashAction glMap` instance, and
combines into `F тИг[k] (glMap ╬▒ * mapGL тДЭ ╬┤ : GL(2,тДЭ))`. The `change` step
is the GL(2,тДЪ)тЖТGL(2,тДЭ) coercion bridge (both are definitionally equal by the
`monoidHomSlashAction glMap` instance). -/
private lemma slash_glQ_mapGLSL_to_combinedGL
    (F : UpperHalfPlane тЖТ тДВ) (╬▒ : GL (Fin 2) тДЪ) (╬┤ : SL(2, тДд)) :
    ((F тИг[k] (╬▒ : GL (Fin 2) тДЪ)) тИг[k]
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬┤)) =
    F тИг[k] ((glMap ╬▒ : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬┤)) := by
  change ((F тИг[k] (glMap ╬▒ : GL (Fin 2) тДЭ)) тИг[k]
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬┤)) =
    F тИг[k] ((glMap ╬▒ : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬┤))
  rw [тЖР SlashAction.slash_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 fixed-q LHS distribution helper**: rewrites the pre-transfer
`peterssonInner fd (тЗС(heckeT_p_cusp f) тИг[k] qтБ╗┬╣) (тЗСg тИг[k] qтБ╗┬╣)` (SL slash)
into the split post-coset-sum form `M_тИЮ summand + тИС_b upper summand` with
slashes normalized to combined GL(2, тДЭ) form (`glMap ╬▒ * mapGL тДЭ qтБ╗┬╣`),
directly consumable by `peterssonInner_M_infty_plus_upper_union_tile_per_q`.

**Proof**: (1) `change` outer SL slash to `mapGL тДЭ qтБ╗┬╣` coercion (definitional
via the SL SlashAction instance); (2) unfold `heckeT_p_cusp` via
`heckeT_p_fun_eq_coset_sum` + `SlashAction.add_slash` + `SlashAction.sum_slash`;
(3) normalize each summand via `slash_glQ_mapGLSL_to_combinedGL`;
(4) apply `peterssonInner_add_finset_sum_left` with integrability from
`integrableOn_petersson_cuspform_mixed_slash_on_fd` (f, g swapped) +
`slash_glQ_then_mapGL_SL_eq_combinedGL` for target-integrand bridging. -/
private lemma peterssonInner_heckeT_p_LHS_per_q_distribute
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗС(heckeT_p_cusp k p hp hpN f) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) +
      тИС b тИИ Finset.range p,
        peterssonInner k ModularGroup.fd
          (тЗСf тИг[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)))
          (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) := by
  have h_Tpf : (тЗС(heckeT_p_cusp k p hp hpN f) : UpperHalfPlane тЖТ тДВ) =
      heckeT_p_ut k p hp.pos тЗСf.toModularForm' +
        тЗСf.toModularForm' тИг[k] (M_infty N p hp.pos hpN : GL (Fin 2) тДЪ) :=
    heckeT_p_fun_eq_coset_sum k hp hpN f.toModularForm'
  rw [h_Tpf, SlashAction.add_slash]
  rw [show heckeT_p_ut k p hp.pos тЗСf.toModularForm' =
      тИС b тИИ Finset.range p,
        тЗСf.toModularForm' тИг[k] (T_p_upper p hp.pos b : GL (Fin 2) тДЪ) from rfl]
  rw [SlashAction.sum_slash]
  simp_rw [slash_glQ_mapGLSL_to_combinedGL]
  rw [add_comm]
  set G : UpperHalfPlane тЖТ тДВ :=
    тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) with hG_def
  set F0 : UpperHalfPlane тЖТ тДВ :=
    тЗСf тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) with hF0_def
  set F : тДХ тЖТ UpperHalfPlane тЖТ тДВ := fun b =>
    тЗСf тИг[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) with hF_def
  have h0 : IntegrableOn (fun ╧Д => petersson k G F0 ╧Д) ModularGroup.fd ╬╝_hyp := by
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) g f (M_infty N p hp.pos hpN) qтБ╗┬╣
    show IntegrableOn (fun ╧Д => petersson k
      (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
      (тЗСf тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) ╧Д) ModularGroup.fd ╬╝_hyp
    rw [show тЗСf тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) =
      (тЗСf тИг[k] ((M_infty N p hp.pos hpN).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        тЗСf (M_infty N p hp.pos hpN) qтБ╗┬╣).symm]
    exact h
  have hF : тИА b тИИ Finset.range p,
      IntegrableOn (fun ╧Д => petersson k G (F b) ╧Д) ModularGroup.fd ╬╝_hyp := by
    intro b _
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) g f (T_p_upper p hp.pos b) qтБ╗┬╣
    show IntegrableOn (fun ╧Д => petersson k
      (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
      (тЗСf тИг[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) ╧Д) ModularGroup.fd ╬╝_hyp
    rw [show тЗСf тИг[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) =
      (тЗСf тИг[k] ((T_p_upper p hp.pos b).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k)
        тЗСf (T_p_upper p hp.pos b) qтБ╗┬╣).symm]
    exact h
  exact peterssonInner_add_finset_sum_left (Finset.range p) F0 F G ModularGroup.fd h0 hF

open UpperHalfPlane ModularGroup MeasureTheory ConjAct Pointwise in
/-- **T128 upper-family union integrability (uniform g-slot)**: integrability of
`petersson k тЗСf ((тЗСg тИг[k] glMap T_p_upper(0)) тИг[k] mapGL ╬│тВА)` on the per-q
upper-family union tile `тЛГ_b (glMap T_p_upper(b) * mapGL qтБ╗┬╣) тАв fd`. This
is the `hfi_upper` input needed by
`peterssonInner_M_infty_plus_upper_union_tile_per_q`.

**Proof**: merge the stacked `T_p_upper(0) ┬╖ ╬│тВА` slash into a single GL(2,тДЭ)
slash via `SlashAction.slash_mul`, translate `g` by this combined matrix via
`CuspForm.translate` (arithmeticity of the conjugate subgroup comes from
`Subgroup.IsArithmetic.conj` at the GL(2,тДЪ) pre-image), apply AM-GM bound on
`тАЦpetersson k f (g_tr) ╧ДтАЦ` using `petersson_bounded_left` for both `f f` and
`g_tr g_tr`, plus finite measure of the union tile
(`measure_biUnion_finset_le` + `measure_glPos_smul_eq` + `hyperbolicMeasure_fd_lt_top`).
Finish with `IntegrableOn.of_bound`. -/
private lemma integrableOn_petersson_upper_union_uniform_gslot_per_q
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    IntegrableOn
      (fun ╧Д => petersson k тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
