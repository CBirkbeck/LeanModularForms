      тЖР diamondOpCusp_mul, mul_inv_cancel, diamondOpCusp_one]
    rfl] at h
  exact h.symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d M_тИЮ LHS-dist per-q tile-form**: rewrites the per-q M_тИЮ-branch
LHS-distributed summand into the tile-shifted form on `M_тИЮ тАв qтБ╗┬╣ тАв fd`,
with q-independent slot-2 carrying the diamond/T_p_upper(0) factor.

```
pet fd (f тИг (T_p_lower ┬╖ ╬│_T ┬╖ ╬│_M ┬╖ qтБ╗┬╣)) (g тИг ╬│тВА ┬╖ qтБ╗┬╣)
  = pet (M_тИЮ тАв qтБ╗┬╣ тАв fd) (тЯиuтБ╗┬╣тЯйf) ((тЯиuтБ╗┬╣тЯйg тИг T_p_upper(0)) тИг mapGL ╬│тВА)
```

**Proof.** Three steps:
1. f-slot master identity (`slash_T_p_lower_factor_eq_diamond_inv_slash_M_infty`):
   `f тИг T_p_lower ┬╖ ╬│ ┬╖ qтБ╗┬╣ = тЯиuтБ╗┬╣тЯйf тИг M_тИЮ ┬╖ qтБ╗┬╣`.
2. g-slot diamond identification (`coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv`):
   `g тИг ╬│тВА ┬╖ qтБ╗┬╣ = тЯиuтБ╗┬╣тЯйg тИг qтБ╗┬╣`.
3. `peterssonInner_slash_adj_M_infty_q_summand_eq` at `(f := тЯиuтБ╗┬╣тЯйf, g := тЯиuтБ╗┬╣тЯйg)`. -/
private lemma peterssonInner_LHS_M_infty_per_q_to_tile_form
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k]
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) =
    peterssonInner k ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) тАв
        ((mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ) тАв (ModularGroup.fd : Set UpperHalfPlane)))
      (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f))
      ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
          (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) := by
  -- Step 1: f-slot master identity (T_p_lower factor тЖТ тЯиuтБ╗┬╣тЯйf ┬╖ M_тИЮ).
  rw [slash_T_p_lower_factor_eq_diamond_inv_slash_M_infty p hp hpN f q]
  -- Step 2: g-slot diamond identification (╬│тВА ┬╖ qтБ╗┬╣ тЖТ тЯиuтБ╗┬╣тЯйg ┬╖ qтБ╗┬╣).
  -- Bridge: тЯиuтБ╗┬╣тЯйg = g тИг ╬│тВА (derived from existing тЯиuтЯйh = h тИг ╬│тВАтБ╗┬╣).
  have h_diamond_inv_g : (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) :
        UpperHalfPlane тЖТ тДВ) = тЗСg тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) := by
    -- Apply lemma to тЯиuтБ╗┬╣тЯйg and cancel тЯиuтЯйтЯиuтБ╗┬╣тЯй = id.
    have h := coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)
    rw [show (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) :
        CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) = g from by
      show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) = g
      rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)
          (diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) =
          ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)).comp
            (diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣)) g from rfl,
        тЖР diamondOpCusp_mul, mul_inv_cancel, diamondOpCusp_one]
      rfl] at h
    -- Now h: тЗСg = (тЗС(тЯиuтБ╗┬╣тЯйg)) тИг[k] mapGL ╬│тВАтБ╗┬╣.
    -- Slash both sides by mapGL ╬│тВА to cancel ╬│тВАтБ╗┬╣.
    have h2 := congr_arg (fun F : UpperHalfPlane тЖТ тДВ => F тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) h
    simp only at h2
    rw [тЖР SlashAction.slash_mul, тЖР map_mul, inv_mul_cancel, map_one,
      SlashAction.slash_one] at h2
    exact h2.symm
  rw [show (тЗСg тИг[k]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) =
      тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ) from by
    rw [SlashAction.slash_mul, тЖР h_diamond_inv_g]]
  -- Step 3: apply M_тИЮ-slash-adjoint at (тЯиuтБ╗┬╣тЯйf, тЯиuтБ╗┬╣тЯйg).
  exact peterssonInner_slash_adj_M_infty_q_summand_eq p hp hpN q
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)

