      (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) ╧Д) ModularGroup.fd ╬╝_hyp
    rw [show (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
