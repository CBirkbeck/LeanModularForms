/-- **T092 helper: `petersson` is linear in its second argument over finite sums.** -/
theorem petersson_sum_right {╬╣ : Type*} (s : Finset ╬╣) (f : тДН тЖТ тДВ)
    (g : ╬╣ тЖТ тДН тЖТ тДВ) (╧Д : тДН) :
    petersson k f (тИС i тИИ s, g i) ╧Д = тИС i тИИ s, petersson k f (g i) ╧Д := by
