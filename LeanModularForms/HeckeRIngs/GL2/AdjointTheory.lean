open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **Phase D step 4 вҖ” projective FD-shift adapter for `О“_p(Оұ)` at PSL(2, в„қ)**.

Specialization of `isFundamentalDomain_PSL_R_smul_conjAct` at
`HвӮҒ := (Gamma_p_Оұ Оұ).map SL2Z_to_PSL2R` and `Оұ := GLPos_to_PSL_R_term Оұ'`.

Given a fundamental domain `s` for the projective image of `О“_p(Оұ)` in
`PSL(2, в„қ)` (via the direct `SL2Z_to_PSL2R` map, equivalent to
`(О“_p(Оұ)).map (PSL2Z_to_PSL2R вҲҳ mk') = (imageGamma1_PSL вӢӮ ...)`'s image
in `PSL(2, в„қ)`), produce a fundamental domain for the
`GLPos_to_PSL_R_term Оұ'`-translate `GLPos_to_PSL_R_term Оұ' вҖў s` and the
projective conjugate `ConjAct.toConjAct (GLPos_to_PSL_R_term Оұ') вҖў HвӮҒ`.

The conjugate subgroup is the projective image of `Оұ' В· О“_p(Оұ) В· Оұ'вҒ»В№`
(the matrix-coset bijection of `Gamma_p_Оұ_conjBy_spec`).

This is the projective replacement for the conditional
`Gamma_p_Оұ_GLPos_lift_FD_smul_conjAct` (no `ВұI`-kernel obstruction;
unconditional in `[NeZero N]`). -/
theorem Gamma_p_Оұ_PSL_R_lift_FD_smul_conjAct
    (Оұ : GL (Fin 2) в„ҡ) (Оұ' : GL(2, в„қ)вҒә) {s : Set в„Қ}
    (hs : IsFundamentalDomain
      ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R) s Ој_hyp) :
    IsFundamentalDomain
      ((ConjAct.toConjAct (GLPos_to_PSL_R_term Оұ') вҖў
        ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R)) :
          Subgroup (PSL(2, в„қ)))
      (GLPos_to_PSL_R_term Оұ' вҖў s) Ој_hyp :=
  isFundamentalDomain_PSL_R_smul_conjAct (GLPos_to_PSL_R_term Оұ') hs

open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **Phase G вҖ” projective shifted FD-decomposition (general Оұ/Оұ').**

Composes `Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_auto` (the unshifted
finite-index FD on the explicit `q.out`-translate union) with
`Gamma_p_Оұ_PSL_R_lift_FD_smul_conjAct` (the `Оұ'`-shift via
`GLPos_to_PSL_R_term Оұ'`).

The composition uses two ingredients:
* `Subgroup.subgroupOfEquivOfLe` (mathlib) reinterprets the `subgroupOf`
  FD output of `_decomp_auto` as an FD on the ambient
  `(О“_p(Оұ)).map SL2Z_to_PSL2R : Subgroup PSL(2, в„қ)` (the input shape required
  by `Gamma_p_Оұ_PSL_R_lift_FD_smul_conjAct`).  Both subgroup types act on `в„Қ`
  via the same matrix-MГ¶bius action, so the bridge through
  `MeasureTheory.IsFundamentalDomain.image_of_equiv` at the identity equiv
  on `в„Қ` is purely a type cast.

* The shifted set
  `Оұ' вҖў (вӢғ q, q.outвҒ»В№ вҖў Gamma1_fundDomain_PSL N)`
  is rewritten via `Set.smul_set_iUnion` + `mul_smul` into the explicit
  `вӢғ q, (Оұ' * q.outвҒ»В№) вҖў Gamma1_fundDomain_PSL N`.

**Use site (DS Prop. 5.5.2(b) tile-decomposition).**  This produces the
`Оұ'`-shifted О“_p(Оұ)-FD whose Petersson integral hosts the per-Оұ slash-adjoint
shift: the integration domain is decomposed into `[О“вӮҒ(N) : О“_p(Оұ)]` translates
of the О“вӮҒ(N)-FD, each shifted by `Оұ' * q.outвҒ»В№` for `q вҲҲ ((О“вӮҒ(N)).map П•) в§ё
((О“_p(Оұ).map П•).subgroupOf ((О“вӮҒ(N).map П•)))`.  The acting group is the
projective conjugate `ConjAct.toConjAct (GLPos_to_PSL_R_term Оұ') вҖў О“_p(Оұ)`. -/
theorem Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_shifted
    (Оұ : GL (Fin 2) в„ҡ) (Оұ' : GL(2, в„қ)вҒә) :
    IsFundamentalDomain
      ((ConjAct.toConjAct (GLPos_to_PSL_R_term Оұ') вҖў
        ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R)) :
          Subgroup PSL(2, в„қ))
      (вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
              (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
                ((Gamma1 N).map SL2Z_to_PSL2R)),
        (GLPos_to_PSL_R_term Оұ' *
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№) вҖў
            (Gamma1_fundDomain_PSL N : Set в„Қ))
      Ој_hyp := by
  -- Step 1: subgroupOf FD from auto-decomp.
  have h_subgroupOf := Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_auto (N := N) Оұ
  -- Step 2: subgroupOf вҶ” ambient subgroup bridge via subgroupOfEquivOfLe.
  have h_le : ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R) вүӨ
              ((Gamma1 N).map SL2Z_to_PSL2R) :=
    Subgroup.map_mono (Gamma_p_Оұ_le_Gamma1 Оұ)
  have h_ambient :
      IsFundamentalDomain ((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R)
        (вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
                (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
                  ((Gamma1 N).map SL2Z_to_PSL2R)),
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№ вҖў
            (Gamma1_fundDomain_PSL N : Set в„Қ))
        Ој_hyp := by
    have h_image := h_subgroupOf.image_of_equiv (Equiv.refl в„Қ)
      (MeasureTheory.Measure.QuasiMeasurePreserving.id _)
      ((Subgroup.subgroupOfEquivOfLe h_le).symm.toEquiv)
      (fun _ _ => rfl)
    simp only [Equiv.coe_refl, Set.image_id] at h_image
    exact h_image
  -- Step 3: Оұ'-shift.
  have h_shifted := Gamma_p_Оұ_PSL_R_lift_FD_smul_conjAct Оұ Оұ' h_ambient
  -- Step 4: rewrite the shifted set into the explicit `вӢғ q, (Оұ' * q.outвҒ»В№) вҖў S` form.
  have h_set_eq :
      (вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
              (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
                ((Gamma1 N).map SL2Z_to_PSL2R)),
        (GLPos_to_PSL_R_term Оұ' *
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№) вҖў
            (Gamma1_fundDomain_PSL N : Set в„Қ)) =
      GLPos_to_PSL_R_term Оұ' вҖў
        (вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
                (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
                  ((Gamma1 N).map SL2Z_to_PSL2R)),
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№ вҖў
            (Gamma1_fundDomain_PSL N : Set в„Қ)) := by
    rw [Set.smul_set_iUnion]
    refine Set.iUnion_congr ?_
    intro q
    exact mul_smul _ _ _
  rw [h_set_eq]
  exact h_shifted

open CongruenceSubgroup Pointwise UpperHalfPlane MeasureTheory in
/-- **Phase H вҖ” packaged per-Оұ `О“_p(Оұ)`-fundamental-domain set.**

Set-level packaging of the unshifted О“_p(Оұ)-fundamental domain at the
projective ambient: the `[О“вӮҒ(N) : О“_p(Оұ)]`-tile union over the right-coset
space `((О“вӮҒ(N).map П•) в§ё ((О“_p(Оұ).map П•).subgroupOf ((О“вӮҒ(N).map П•)))`,
where each tile is a translate `q.outвҒ»В№ вҖў Gamma1_fundDomain_PSL N`.

Together with the `Оұ'`-shift identity below, this gives a clean readable
form for the Phase G shifted FD set: `Оұ' вҖў Gamma_p_Оұ_fundDomain_PSL N Оұ`. -/
noncomputable def Gamma_p_Оұ_fundDomain_PSL (Оұ : GL (Fin 2) в„ҡ) : Set в„Қ :=
  вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
          (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
            ((Gamma1 N).map SL2Z_to_PSL2R)),
    ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№ вҖў
      (Gamma1_fundDomain_PSL N : Set в„Қ)

open CongruenceSubgroup Pointwise UpperHalfPlane MeasureTheory in
/-- **Phase H вҖ” Phase G shifted FD set as `Оұ' вҖў О“_p(Оұ)-FD` (generic).**

Set-level identity packaging the explicit shifted-union shape from
`Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_shifted` as the `Оұ'`-shift of
`Gamma_p_Оұ_fundDomain_PSL N Оұ`.  Direct application of `Set.smul_set_iUnion`
and `mul_smul`. -/
theorem Gamma_p_Оұ_PSL_R_FD_finite_index_decomp_shifted_eq_smul
    (Оұ : GL (Fin 2) в„ҡ) (Оұ' : GL(2, в„қ)вҒә) :
    (вӢғ q : ((Gamma1 N).map SL2Z_to_PSL2R) в§ё
            (((Gamma_p_Оұ (N := N) Оұ).map SL2Z_to_PSL2R).subgroupOf
              ((Gamma1 N).map SL2Z_to_PSL2R)),
      (GLPos_to_PSL_R_term Оұ' *
        ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, в„қ))вҒ»В№) вҖў
          (Gamma1_fundDomain_PSL N : Set в„Қ)) =
    GLPos_to_PSL_R_term Оұ' вҖў Gamma_p_Оұ_fundDomain_PSL (N := N) Оұ := by
  unfold Gamma_p_Оұ_fundDomain_PSL
  rw [Set.smul_set_iUnion]
  exact Set.iUnion_congr fun q => mul_smul _ _ _

open CongruenceSubgroup UpperHalfPlane ModularGroup MeasureTheory in
/-- **Phase J вҖ” generic SL outer-quotient вҶ” scaled `Gamma1_fundDomain_PSL`
integral bridge.**

For any `О“вӮҒ(N)`-invariant `h : в„Қ вҶ’ в„Ӯ` integrable on `Gamma1_fundDomain_PSL N`:
```
вҲ‘ q : SL(2, в„Ө) в§ё О“вӮҒ(N), вҲ«_{q.outвҒ»В№ вҖў fd} h dОј_hyp =
    (slToPslQuot_fiberCard N) вҖў вҲ«_{Gamma1_fundDomain_PSL N} h dОј_hyp.
```

**Composition of existing PSL machinery (no new measure-theoretic content):**
* `setIntegral_SL_tile_fd_eq_fdo` вҖ” converts the SL-tile integral over `fd`
  (closed) to the integral over `fdo` (open); the boundary has measure zero.
* `sum_SL_tile_eq_fiberwise_PSL_tile` вҖ” reindexes the SL outer-q sum as a
  PSL inner-q sum weighted by per-fiber cardinalities.
* `slToPslQuot_fiberCard_eq` вҖ” the fibers all have cardinality
  `slToPslQuot_fiberCard N` (= 1 for `N вүӨ 2`, = 2 for `N вүҘ 3`).
* `setIntegral_Gamma1_fundDomain_PSL_eq_sum` вҖ” packages the PSL-tile sum
  back into the single integral over `Gamma1_fundDomain_PSL N`.

**Use site (Phase J/DSDoubleCosetTileBridge orientation bridge).**  Provides
the missing `Gamma1_fundDomain_PSL` вҶ” outer-quotient SL/О“вӮҒ(N) bridge in the
generic form: lifts the `petN_eq_setIntegral_Gamma1_fundDomain_PSL`
identity (currently stated for `petersson f g` only) to any `О“вӮҒ(N)`-invariant
integrand `h`, with the universal `slToPslQuot_fiberCard N` factor.

This lemma extracts the inline `gen_SL_fd_sum_eq` block from the proof of
`sum_setIntegral_GL2_shift` (line 1920) into a reusable top-level
identity.  The `(slToPslQuot_fiberCard N)` weight on the RHS is **not
optional**: for `N вүҘ 3` the SL coset space is a 2-fold cover of the
PSL/imageGamma1_PSL coset space (since `-I вҲү О“вӮҒ(N)` distinguishes
SL-cosets `[q]` and `[-q]` that project to the same PSL-coset), so the
SL outer sum genuinely overcounts the PSL fundamental-domain integral
by exactly `slToPslQuot_fiberCard N`. -/
theorem setIntegral_Gamma1_fundDomain_PSL_eq_SL_outer_q_sum
    (h : в„Қ вҶ’ в„Ӯ)
    (h_inv : вҲҖ Оі вҲҲ Gamma1 N, вҲҖ П„ : в„Қ, h (Оі вҖў П„) = h П„)
    (h_int : IntegrableOn h (Gamma1_fundDomain_PSL N) Ој_hyp) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp =
    (slToPslQuot_fiberCard N) вҖў вҲ« П„ in Gamma1_fundDomain_PSL N, h П„ вҲӮОј_hyp := by
  classical
  calc вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
          вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ), h П„ вҲӮОј_hyp
      = вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
          вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp :=
        Finset.sum_congr rfl fun q _ => setIntegral_SL_tile_fd_eq_fdo h q
    _ = вҲ‘ q' : PSL(2, в„Ө) в§ё imageGamma1_PSL N,
          (Finset.univ.filter (fun q : SL(2, в„Ө) в§ё Gamma1 N =>
            slToPslQuot q = q')).card вҖў
            вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp :=
        sum_SL_tile_eq_fiberwise_PSL_tile h h_inv
    _ = (slToPslQuot_fiberCard N) вҖў вҲ‘ q' : PSL(2, в„Ө) в§ё imageGamma1_PSL N,
          вҲ« П„ in ((q'.out : PSL(2, в„Ө)))вҒ»В№ вҖў (fdo : Set в„Қ), h П„ вҲӮОј_hyp := by
        rw [Finset.smul_sum]
        refine Finset.sum_congr rfl fun q' _ => ?_
        congr 1
        convert slToPslQuot_fiberCard_eq q' using 2
        congr
    _ = (slToPslQuot_fiberCard N) вҖў вҲ« П„ in Gamma1_fundDomain_PSL N, h П„ вҲӮОј_hyp := by
        rw [вҶҗ setIntegral_Gamma1_fundDomain_PSL_eq_sum h h_int]

open CongruenceSubgroup UpperHalfPlane ModularGroup MeasureTheory in
/-- **Phase K вҖ” Petersson-integrand specialization of the Phase J generic
SL outer-quotient bridge.**

For two `О“вӮҒ(N)`-cusp forms `f, g`, the SL outer-quotient sum of integrals
of the Petersson integrand `petersson k f g` over the per-`q.outвҒ»В№`-translates
of `ModularGroup.fd` equals `(slToPslQuot_fiberCard N)`-many copies of the
single integral over `Gamma1_fundDomain_PSL N`:
```
вҲ‘ q : SL(2, в„Ө) в§ё О“вӮҒ(N), вҲ«_{q.outвҒ»В№ вҖў fd} petersson k f g dОј_hyp =
    (slToPslQuot_fiberCard N) вҖў вҲ«_{Gamma1_fundDomain_PSL N} petersson k f g dОј_hyp.
```

**Direct consumer of `setIntegral_Gamma1_fundDomain_PSL_eq_SL_outer_q_sum`** at
`h := petersson k вҮ‘f вҮ‘g`, with the two ambient hypotheses discharged once and
for all from existing infrastructure:
* `О“вӮҒ(N)`-invariance: `petersson_Gamma1_invariant`.
* Integrability on the О“вӮҒ(N)-FD: `integrableOn_petersson_Gamma1_fundDomain_PSL`.

**Use site (Phase K orientation bridge).**  Provides the cleanest typed form
of the SL/О“вӮҒ(N) outer-q вҶ” scaled `Gamma1_fundDomain_PSL` integral identity for
the Petersson integrand actually consumed downstream by `petN` and the
DS LHS sum chain (`petN_LHS_dist_eq_RHS_absorbed_from_branches`).  This
equals `petN_eq_setIntegral_Gamma1_fundDomain_PSL` rearranged:
the LHS is the unfolded `petN f g` (with `petN_summand_eq_setIntegral` and
`setIntegral_SL_tile_fd_eq_fdo` already absorbed), the RHS is the fiber-scaled
single integral. -/
theorem peterssonInner_Gamma1_fundDomain_PSL_eq_SL_outer_q_sum
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ),
        petersson k вҮ‘f вҮ‘g П„ вҲӮОј_hyp =
    (slToPslQuot_fiberCard N) вҖў
      вҲ« П„ in Gamma1_fundDomain_PSL N, petersson k вҮ‘f вҮ‘g П„ вҲӮОј_hyp :=
  setIntegral_Gamma1_fundDomain_PSL_eq_SL_outer_q_sum
    (petersson k вҮ‘f вҮ‘g)
    (fun Оі hОі П„ => petersson_Gamma1_invariant f g Оі hОі П„)
    (integrableOn_petersson_Gamma1_fundDomain_PSL f g)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **Phase L (a) вҖ” generic per-`q` SL slash-domain reducer.**

For arbitrary `F G : в„Қ вҶ’ в„Ӯ` and `q : SL(2, в„Ө) в§ё О“вӮҒ(N)`,
```
peterssonInner k fd (F вҲЈ[k] q.outвҒ»В№) (G вҲЈ[k] q.outвҒ»В№) =
    вҲ«_{q.outвҒ»В№ вҖў fd} petersson k F G dОј_hyp.
```
Generic-in-`F, G` version of the existing `petN_summand_eq_setIntegral`
(specialized to `f, g` cusp-form coercions).  Same proof structure: unfold
`peterssonInner`, rewrite via `petersson_slash_SL` (since `q.outвҒ»В№ вҲҲ SL(2, в„Ө)`
has det 1, the integrand becomes `petersson k F G ((q.out)вҒ»В№ вҖў П„)`), then
apply change of variables `П„ вҶҰ q.out вҖў Пғ` on the closed `fd`. -/
theorem peterssonInner_fd_slash_q_eq_setIntegral_shifted_fd
    (F G : в„Қ вҶ’ в„Ӯ) (q : SL(2, в„Ө) в§ё Gamma1 N) :
    peterssonInner k fd (F вҲЈ[k] (q.out : SL(2, в„Ө))вҒ»В№) (G вҲЈ[k] (q.out : SL(2, в„Ө))вҒ»В№) =
    вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ),
      petersson k F G П„ вҲӮОј_hyp := by
  simp only [peterssonInner]
  simp_rw [petersson_slash_SL]
  rw [вҶҗ Set.image_smul,
    вҶҗ (measurePreserving_smul (q.out : SL(2, в„Ө))вҒ»В№ Ој_hyp).setIntegral_image_emb
      (measurableEmbedding_const_smul _)]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **Phase L (b) вҖ” DS-LHS branch per-`q` slash-compose + slash-domain reducer.**

For per-branch `GL (Fin 2) в„қ` slash prefixes `A B` and arbitrary `F G : в„Қ вҶ’ в„Ӯ`,
the per-`q` DS-LHS-shaped summand
`peterssonInner k fd (F вҲЈ[k] (A * mapGL q.outвҒ»В№)) (G вҲЈ[k] (B * mapGL q.outвҒ»В№))`
factors via `SlashAction.slash_mul` into
`peterssonInner k fd ((F вҲЈ A) вҲЈ mapGL q.outвҒ»В№) ((G вҲЈ B) вҲЈ mapGL q.outвҒ»В№)`,
and then by Phase L(a) (`peterssonInner_fd_slash_q_eq_setIntegral_shifted_fd`)
collapses to a single integral over the `q.outвҒ»В№`-shifted SL fundamental
domain `q.outвҒ»В№ вҖў fd` of the unshifted-in-`q` integrand `petersson k (F вҲЈ A) (G вҲЈ B)`.

**The `mapGL в„қ q.outвҒ»В№` slash equals the SL slash by `q.outвҒ»В№` definitionally**
(`ModularForm.SL_slash` is `rfl`), so the bridge from the GL-typed slash in
the DS-LHS form to the SL-typed slash expected by `petersson_slash_SL` is
purely syntactic.

**Use site (Phase L DS reducer).**  Applies per-`q` to each summand of the
DS-LHS chain (e.g., M_вҲһ branch line `AdjointTheory.lean:9229`), converting
the per-`q` slash-prefixed `fd` form into a `q`-shifted-domain integral with
a `q`-independent integrand.  This is the strict reducer manager step: it
exposes the **integrand's invariance under what subgroup** as the next
question (in DS LHS, that subgroup is `О“_p(Оұ_i)`, NOT `О“вӮҒ(N)`, which is why
the Phase K Petersson О“вӮҒ(N)-version does not directly apply at the slashed
integrand).  Subsequent Phase J/K-style outer-q sum identities for the
shifted integrand require the corresponding `О“_p(Оұ_i)`-FD analog. -/
theorem peterssonInner_slash_compose_q_eq_setIntegral_shifted_fd
    (A B : GL (Fin 2) в„қ) (q : SL(2, в„Ө) в§ё Gamma1 N) (F G : в„Қ вҶ’ в„Ӯ) :
    peterssonInner k fd
      (F вҲЈ[k] (A * ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (q.out : SL(2, в„Ө))вҒ»В№)))
      (G вҲЈ[k] (B * ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (q.out : SL(2, в„Ө))вҒ»В№))) =
    вҲ« П„ in (q.out : SL(2, в„Ө))вҒ»В№ вҖў (fd : Set в„Қ),
      petersson k (F вҲЈ[k] A) (G вҲЈ[k] B) П„ вҲӮОј_hyp := by
  rw [SlashAction.slash_mul, SlashAction.slash_mul]
  exact peterssonInner_fd_slash_q_eq_setIntegral_shifted_fd
    (F вҲЈ[k] A) (G вҲЈ[k] B) q

