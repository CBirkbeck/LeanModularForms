        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)) := by
    rw [вҶҗ map_mul (mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ),
