private def TpPerQSigmaAlignedBlocker
    (p : тДХ) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (M : GL (Fin 2) тДЭ) (q : SL(2, тДд) тз╕ Gamma1 N) : Prop :=
  peterssonInner k
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
        GL (Fin 2) тДЭ) тАв (fd : Set тДН))
      (тЗСf тИг[k] M)
      (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) =
    peterssonInner k
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((Gamma1QuotEquivOfGamma0
