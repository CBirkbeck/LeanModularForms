        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) =
    вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) вҲЈ[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) := by
  have h := slash_T_p_upper_eq_diamond_slash_T_p_lower_factor p hp hpN b
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f) q
