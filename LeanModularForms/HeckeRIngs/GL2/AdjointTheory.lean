open UpperHalfPlane ModularGroup MeasureTheory in
/-- **Fundamental domain tiling identity** for `GLтВВтБ║(тДЭ)` shifts.

For `╬▒ тИИ GLтВВтБ║(тДЭ)` that normalizes `╬УтВБ(N)` (so that `╬▒ тАв D_N^PSL` is again a
`╬УтВБ(N)`-fundamental domain) and a `╬УтВБ(N)`-invariant integrand `h`, the sum of
integrals over the shifted tiles `{╬▒ тАв (qтБ╗┬╣ тАв fd)}_{q тИИ SLтВВ/╬УтВБ}` equals the sum
over the standard tiles `{qтБ╗┬╣ тАв fd}`:

```
  ╬г_q тИл_{╬▒ тАв (qтБ╗┬╣ тАв fd)} h d╬╝ = ╬г_q тИл_{qтБ╗┬╣ тАв fd} h d╬╝
```

**Proof outline**: Both sums reduce to `fiber_count ┬╖ тИл_{D_N^PSL} h d╬╝` where
`D_N^PSL = тЛГ_{q' : PSL/imageGamma1_PSL} q'.outтБ╗┬╣ тАв fdo` is the PSL-level
fundamental domain and `fiber_count` is the uniform cardinality of the
`SL/╬УтВБ тЖТ PSL/imageGamma1_PSL` fibers. For the ╬▒-shifted sum, change of variables
(via measure-preservation of `╬▒`) converts each summand to an integral of
`h тИШ ╬▒` over the unshifted tile; the hypothesis `h╬▒_h_inv` ensures that `h тИШ ╬▒`
is also `╬УтВБ(N)`-invariant, so the same PSL-sum template applies. The resulting
integral `тИл_{D_N^PSL} (h тИШ ╬▒) d╬╝ = тИл_{╬▒ тАв D_N^PSL} h d╬╝` (another change of
variables), which equals `тИл_{D_N^PSL} h d╬╝` by `IsFundamentalDomain.setIntegral_eq`
applied with `h╬▒_fd`, `isFundamentalDomain_Gamma1_PSL`, and the `imageGamma1_PSL`
invariance derived from `h_inv`. -/
theorem sum_setIntegral_GL2_shift
    (╬▒ : GL(2, тДЭ)тБ║) (h : UpperHalfPlane тЖТ тДВ)
    (h_inv : тИА (╬│ : SL(2, тДд)), ╬│ тИИ Gamma1 N тЖТ
      тИА ╧Д : UpperHalfPlane, h (╬│ тАв ╧Д) = h ╧Д)
    (h╬▒_h_inv : тИА (╬│ : SL(2, тДд)), ╬│ тИИ Gamma1 N тЖТ
      тИА ╧Д : UpperHalfPlane,
        h ((╬▒ : GL (Fin 2) тДЭ) тАв ((╬│ : SL(2, тДд)) тАв ╧Д)) =
        h ((╬▒ : GL (Fin 2) тДЭ) тАв ╧Д))
    (h╬▒_fd : IsFundamentalDomain (imageGamma1_PSL N)
      ((╬▒ : GL (Fin 2) тДЭ) тАв (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp)
    (h_int : IntegrableOn h (Gamma1_fundDomain_PSL N) ╬╝_hyp)
    (h_╬▒_int : IntegrableOn (fun ╧Д => h ((╬▒ : GL (Fin 2) тДЭ) тАв ╧Д))
      (Gamma1_fundDomain_PSL N) ╬╝_hyp) :
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      тИл ╧Д in (тЖС╬▒ : GL (Fin 2) тДЭ) тАв
          ((q.out : SL(2, тДд))тБ╗┬╣ тАв (ModularGroup.fd : Set UpperHalfPlane)),
        h ╧Д тИВhyperbolicMeasure =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (ModularGroup.fd : Set UpperHalfPlane),
        h ╧Д тИВhyperbolicMeasure := by
  -- Strategy: LHS = fiber_count ┬╖ тИл_{╬▒тАвD_N^PSL} h d╬╝
  --          RHS = fiber_count ┬╖ тИл_{D_N^PSL} h d╬╝
  -- and the two integrals are equal by IsFundamentalDomain.setIntegral_eq.
  set h_╬▒ : тДН тЖТ тДВ := fun ╧Д => h ((╬▒ : GL (Fin 2) тДЭ) тАв ╧Д) with h_╬▒_def
  have h_╬▒_inv : тИА (╬│ : SL(2, тДд)), ╬│ тИИ Gamma1 N тЖТ
      тИА ╧Д : UpperHalfPlane, h_╬▒ (╬│ тАв ╧Д) = h_╬▒ ╧Д := h╬▒_h_inv
  -- Step 1: Change of variables on each LHS summand.
  have h_LHS_cov : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      тИл ╧Д in (тЖС╬▒ : GL (Fin 2) тДЭ) тАв
          ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)),
        h ╧Д тИВ╬╝_hyp =
      тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane), h_╬▒ ╧Д тИВ╬╝_hyp := by
    intro q
    rw [show ((тЖС╬▒ : GL (Fin 2) тДЭ) тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)) :
          Set UpperHalfPlane) =
        (fun ╧Д => (╬▒ : GL(2, тДЭ)тБ║) тАв ╧Д) ''
          ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)) from by
        rw [Set.image_smul]; rfl]
    exact (measurePreserving_smul ╬▒ ╬╝_hyp).setIntegral_image_emb
      (measurableEmbedding_const_smul ╬▒) _ _
  simp_rw [h_LHS_cov]
  -- Step 2: Both sums (for h and h_╬▒) reduce to fiber_count ┬╖ тИл_{D_N^PSL} (┬╖) d╬╝
  -- via fd тЖТ fdo тЖТ PSL-fiberwise sum + uniform fiber count + PSL fundamental domain integral.
  classical
  have gen_SL_fd_sum_eq : тИА (╧Ж : тДН тЖТ тДВ)
      (_ : тИА (╬│ : SL(2, тДд)), ╬│ тИИ Gamma1 N тЖТ тИА ╧Д : UpperHalfPlane, ╧Ж (╬│ тАв ╧Д) = ╧Ж ╧Д)
      (_ : IntegrableOn ╧Ж (Gamma1_fundDomain_PSL N) ╬╝_hyp),
      тИС q : SL(2, тДд) тз╕ Gamma1 N,
        тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane), ╧Ж ╧Д тИВ╬╝_hyp =
      (slToPslQuot_fiberCard N) тАв тИл ╧Д in Gamma1_fundDomain_PSL N, ╧Ж ╧Д тИВ╬╝_hyp := by
    intro ╧Ж ╧Ж_inv ╧Ж_int
    calc тИС q : SL(2, тДд) тз╕ Gamma1 N,
            тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane), ╧Ж ╧Д тИВ╬╝_hyp
        = тИС q : SL(2, тДд) тз╕ Gamma1 N,
            тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fdo : Set UpperHalfPlane), ╧Ж ╧Д тИВ╬╝_hyp :=
          Finset.sum_congr rfl fun q _ => setIntegral_SL_tile_fd_eq_fdo ╧Ж q
      _ = тИС q' : PSL(2, тДд) тз╕ imageGamma1_PSL N,
            (Finset.univ.filter (fun q : SL(2, тДд) тз╕ Gamma1 N =>
              slToPslQuot q = q')).card тАв
              тИл ╧Д in ((q'.out : PSL(2, тДд)))тБ╗┬╣ тАв (fdo : Set UpperHalfPlane), ╧Ж ╧Д тИВ╬╝_hyp :=
          sum_SL_tile_eq_fiberwise_PSL_tile ╧Ж ╧Ж_inv
      _ = (slToPslQuot_fiberCard N) тАв тИС q' : PSL(2, тДд) тз╕ imageGamma1_PSL N,
            тИл ╧Д in ((q'.out : PSL(2, тДд)))тБ╗┬╣ тАв (fdo : Set UpperHalfPlane), ╧Ж ╧Д тИВ╬╝_hyp := by
          rw [Finset.smul_sum]
          refine Finset.sum_congr rfl fun q' _ => ?_
          congr 1
          convert slToPslQuot_fiberCard_eq q' using 2
          congr
      _ = (slToPslQuot_fiberCard N) тАв тИл ╧Д in Gamma1_fundDomain_PSL N, ╧Ж ╧Д тИВ╬╝_hyp := by
          rw [тЖР setIntegral_Gamma1_fundDomain_PSL_eq_sum ╧Ж ╧Ж_int]
  rw [gen_SL_fd_sum_eq h_╬▒ h_╬▒_inv h_╬▒_int,
      gen_SL_fd_sum_eq h h_inv h_int]
  congr 1
  -- Goal: тИл_{D_N^PSL} h_╬▒ d╬╝ = тИл_{D_N^PSL} h d╬╝
  -- Step 3a: change of vars shifts h_╬▒ back: тИл_{D_N^PSL} h_╬▒ = тИл_{╬▒ тАв D_N^PSL} h
  rw [show тИл ╧Д in Gamma1_fundDomain_PSL N, h_╬▒ ╧Д тИВ╬╝_hyp =
        тИл ╧Д in ((тЖС╬▒ : GL (Fin 2) тДЭ) тАв (Gamma1_fundDomain_PSL N : Set тДН) : Set тДН),
          h ╧Д тИВ╬╝_hyp from by
    rw [show ((тЖС╬▒ : GL (Fin 2) тДЭ) тАв (Gamma1_fundDomain_PSL N : Set тДН) : Set тДН) =
        (fun ╧Д => (╬▒ : GL(2, тДЭ)тБ║) тАв ╧Д) '' (Gamma1_fundDomain_PSL N : Set тДН) from by
        rw [Set.image_smul]; rfl]
    exact ((measurePreserving_smul ╬▒ ╬╝_hyp).setIntegral_image_emb
      (measurableEmbedding_const_smul ╬▒) _ _).symm]
  -- Step 3b: Both D_N^PSL and ╬▒ тАв D_N^PSL are imageGamma1_PSL-fundamental domains,
  -- and h is imageGamma1_PSL-invariant (derived from h_inv via PSL_smul_coe).
  refine h╬▒_fd.setIntegral_eq isFundamentalDomain_Gamma1_PSL ?_
  intro g ╧Д
  obtain тЯи╬│, h╬│_mem, h╬│_eqтЯй := Subgroup.mem_map.mp g.property
  have h_act_eq : ((g : imageGamma1_PSL N) : PSL(2, тДд)) тАв ╧Д = ╬│ тАв ╧Д := by
    rw [тЖР h╬│_eq]; exact PSL_smul_coe ╬│ ╧Д
  show h (((g : imageGamma1_PSL N) : PSL(2, тДд)) тАв ╧Д) = h ╧Д
  rw [h_act_eq]
  exact h_inv ╬│ h╬│_mem ╧Д

open UpperHalfPlane ModularGroup MeasureTheory in
theorem petN_slash_adjoint_GL2
    (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (f_╬▒ : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hf_╬▒ : тЗСf_╬▒ = тЗСf тИг[k] ╬▒)
    (g_adj : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hg_adj : тЗСg_adj = тЗСg тИг[k] peterssonAdj ╬▒)
    (h╬▒_norm : тИА (╬│ : SL(2, тДд)), ╬│ тИИ Gamma1 N тЖТ
      тИА ╧Д : тДН, petersson k тЗСf тЗСg_adj (╬▒ тАв ((╬│ : SL(2, тДд)) тАв ╧Д)) =
        petersson k тЗСf тЗСg_adj (╬▒ тАв ╧Д))
    (h╬▒_fd : IsFundamentalDomain (imageGamma1_PSL N)
      (╬▒ тАв (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp)
    (h_int : IntegrableOn (petersson k тЗСf тЗСg_adj) (Gamma1_fundDomain_PSL N) ╬╝_hyp)
    (h_╬▒_int : IntegrableOn (fun ╧Д => petersson k тЗСf тЗСg_adj (╬▒ тАв ╧Д))
      (Gamma1_fundDomain_PSL N) ╬╝_hyp) :
    petN f_╬▒ g = petN f g_adj := by
  -- Strategy: transform each petN summand via peterssonInner_slash_adjoint,
  -- then invoke sum_setIntegral_GL2_shift for the domain tiling identity.
  --
  -- Step 1: Convert each petN summand to a set integral, apply hf_╬▒/hg_adj,
  -- then use peterssonInner_slash_adjoint to shift the domain.
  -- Step 2: The shifted-domain sum equals the standard-domain sum by the
  -- fundamental domain tiling identity (sum_setIntegral_GL2_shift).
  --
  -- Proof chain per summand q:
  --   peterssonInner k fd (тЗСf_╬▒ тИг qтБ╗┬╣) (тЗСg тИг qтБ╗┬╣)
  --   = тИл_{qтБ╗┬╣тАвfd} petersson k тЗСf_╬▒ тЗСg d╬╝           [petN_summand_eq_setIntegral]
  --   = тИл_{qтБ╗┬╣тАвfd} petersson k (тЗСfтИг╬▒) тЗСg d╬╝          [hf_╬▒]
  --   = peterssonInner k (qтБ╗┬╣тАвfd) (тЗСfтИг╬▒) тЗСg           [def peterssonInner]
  --   = peterssonInner k (╬▒тАв(qтБ╗┬╣тАвfd)) тЗСf (тЗСgтИгadj(╬▒))  [peterssonInner_slash_adjoint]
  --   = тИл_{╬▒тАв(qтБ╗┬╣тАвfd)} petersson k тЗСf (тЗСgтИгadj(╬▒)) d╬╝  [def peterssonInner]
  --   = тИл_{╬▒тАв(qтБ╗┬╣тАвfd)} petersson k тЗСf тЗСg_adj d╬╝        [hg_adj]
  -- Then for the RHS:
  --   peterssonInner k fd (тЗСf тИг qтБ╗┬╣) (тЗСg_adj тИг qтБ╗┬╣)
  --   = тИл_{qтБ╗┬╣тАвfd} petersson k тЗСf тЗСg_adj d╬╝            [petN_summand_eq_setIntegral]
  -- So: LHS = ╬г_q тИл_{╬▒тАв(qтБ╗┬╣тАвfd)} h d╬╝, RHS = ╬г_q тИл_{qтБ╗┬╣тАвfd} h d╬╝
  -- where h = petersson k тЗСf тЗСg_adj is ╬УтВБ(N)-invariant.
  -- These are equal by sum_setIntegral_GL2_shift.
  show тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k fd (тЗСf_╬▒ тИг[k] (q.out)тБ╗┬╣) (тЗСg тИг[k] (q.out)тБ╗┬╣) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k fd (тЗСf тИг[k] (q.out)тБ╗┬╣) (тЗСg_adj тИг[k] (q.out)тБ╗┬╣)
  -- Rewrite each LHS summand through the chain above.
  have h_lhs : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k fd (тЗСf_╬▒ тИг[k] (q.out)тБ╗┬╣) (тЗСg тИг[k] (q.out)тБ╗┬╣) =
      тИл ╧Д in ╬▒ тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)),
        petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д тИВ╬╝_hyp := fun q => by
    calc peterssonInner k fd (тЗСf_╬▒ тИг[k] (q.out)тБ╗┬╣) (тЗСg тИг[k] (q.out)тБ╗┬╣)
        = тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane),
            petersson k тЗСf_╬▒ тЗСg ╧Д тИВ╬╝_hyp := petN_summand_eq_setIntegral f_╬▒ g q
      _ = тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane),
            petersson k (тЗСf тИг[k] ╬▒) тЗСg ╧Д тИВ╬╝_hyp := by rw [hf_╬▒]
      _ = peterssonInner k ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane))
            (тЗСf тИг[k] ╬▒) тЗСg := rfl
      _ = peterssonInner k (╬▒ тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)))
            тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) :=
          peterssonInner_slash_adjoint _ ╬▒ h╬▒ тЗСf тЗСg
      _ = тИл ╧Д in ╬▒ тАв ((q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane)),
            petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д тИВ╬╝_hyp := rfl
  -- Rewrite each RHS summand.
  have h_rhs : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k fd (тЗСf тИг[k] (q.out)тБ╗┬╣) (тЗСg_adj тИг[k] (q.out)тБ╗┬╣) =
      тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane),
        petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д тИВ╬╝_hyp := fun q => by
    calc peterssonInner k fd (тЗСf тИг[k] (q.out)тБ╗┬╣) (тЗСg_adj тИг[k] (q.out)тБ╗┬╣)
        = тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane),
            petersson k тЗСf тЗСg_adj ╧Д тИВ╬╝_hyp := petN_summand_eq_setIntegral f g_adj q
      _ = тИл ╧Д in (q.out : SL(2, тДд))тБ╗┬╣ тАв (fd : Set UpperHalfPlane),
            petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д тИВ╬╝_hyp := by rw [hg_adj]
  simp_rw [h_lhs, h_rhs]
  -- Goal: ╬г_q тИл_{╬▒тАв(qтБ╗┬╣тАвfd)} h d╬╝ = ╬г_q тИл_{qтБ╗┬╣тАвfd} h d╬╝
  -- where h = petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) is ╬УтВБ(N)-invariant.
  -- The integrand petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) is ╬УтВБ(N)-invariant:
  -- since тЗСg тИг[k] peterssonAdj ╬▒ = тЗСg_adj (by hg_adj), and f, g_adj are ╬УтВБ(N)-cusp forms,
  -- petersson_Gamma1_invariant gives petersson k тЗСf тЗСg_adj (╬│ тАв ╧Д) = petersson k тЗСf тЗСg_adj ╧Д.
  refine sum_setIntegral_GL2_shift тЯи╬▒, h╬▒тЯй
    (fun ╧Д => petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д)
    (fun ╬│ h╬│ ╧Д => by
      show petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) (╬│ тАв ╧Д) =
        petersson k тЗСf (тЗСg тИг[k] peterssonAdj ╬▒) ╧Д
      rw [тЖР hg_adj]; exact petersson_Gamma1_invariant f g_adj ╬│ h╬│ ╧Д)
    (fun ╬│ h╬│ ╧Д => by rw [тЖР hg_adj]; exact h╬▒_norm ╬│ h╬│ ╧Д) h╬▒_fd ?_ ?_
  ┬╖ -- IntegrableOn h (Gamma1_fundDomain_PSL N) ╬╝_hyp
    simpa [hg_adj] using h_int
  ┬╖ -- IntegrableOn (h тИШ ╬▒тАв) (Gamma1_fundDomain_PSL N) ╬╝_hyp
    simpa [hg_adj] using h_╬▒_int

/-! ### Summand-level adjoint identity

The proof of `petN(T_p f, g) = petN(тЯиpтЯйf, T_p g)` works at the `peterssonInner` summand
level. For each coset `[q]` in `SLтВВ(тДд)/╬УтВБ(N)`, the `petN` summand decomposes:

```
peterssonInner k fd ((T_p f)тИгqтБ╗┬╣) (gтИгqтБ╗┬╣)
= ╬г_b peterssonInner k fd (fтИг╬▒_bтИгqтБ╗┬╣) (gтИгqтБ╗┬╣) + peterssonInner k fd ((тЯиpтЯйf)тИг╬▒_тИЮтИгqтБ╗┬╣) (gтИгqтБ╗┬╣)
```

by linearity of `peterssonInner` in the first argument. Then `peterssonInner_slash_adjoint`
(fully proved, no sorry) gives for each term:

```
peterssonInner k fd (fтИг(╬▒_b * qтБ╗┬╣)) (gтИгqтБ╗┬╣)
= peterssonInner k ((╬▒_b * qтБ╗┬╣) тАв fd) f ((gтИгqтБ╗┬╣)тИгadj(╬▒_b * qтБ╗┬╣))
```

The key algebraic identities:
* `adj(T_p_upper(b)) = [[p,-b],[0,1]] = [[1,-b],[0,1]] ┬╖ [[p,0],[0,1]]`
  where `[[1,-b],[0,1]] тИИ ╬УтВБ(N)`, so for `g тИИ S_k(╬УтВБ(N))`:
  `gтИгadj(T_p_upper(b)) = gтИгT_p_lower` (b-independent).
* `adj(T_p_lower) = [[1,0],[0,p]] = T_p_upper(0)`.
* From `adjointGamma0Rep`: `T_p_lower = ╬│тВБтБ╗┬╣ ┬╖ T_p_upper(0) ┬╖ ╬│тВА`
  where `╬│тВБ тИИ ╬УтВБ(N)` and `Gamma0MapUnits(╬│тВА) = тЯиpтЯйтБ╗┬╣`.

The domain tiling after change of variables reassembles the integrals into `petN` for
the RHS. This tiling step requires `╬УтВБ(N)` fundamental domain infrastructure. -/

/-- The adjugate of `T_p_upper(b)` as a GLтВВ(тДЭ) element has matrix `[[p,-b],[0,1]]`. -/
private lemma peterssonAdj_glMap_T_p_upper (p : тДХ) (hp : 0 < p) (b : тДХ) :
    (peterssonAdj (glMap (T_p_upper p hp b)) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(p : тДЭ), -(b : тДЭ); 0, 1] := by
  rw [peterssonAdj_coe]
  -- glMap embeds Q тЖТ R entrywise; T_p_upper_coe gives the Q-matrix
  have hcoe : (glMap (T_p_upper p hp b) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(1 : тДЭ), (b : тДЭ); 0, (p : тДЭ)] := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [glMap, T_p_upper]
  rw [hcoe, Matrix.adjugate_fin_two]
  ext i j; fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]

/-- The adjugate of `T_p_lower` as a GLтВВ(тДЭ) element has matrix `[[1,0],[0,p]]`. -/
private lemma peterssonAdj_glMap_T_p_lower (p : тДХ) (hp : 0 < p) :
    (peterssonAdj (glMap (T_p_lower p hp)) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(1 : тДЭ), 0; 0, (p : тДЭ)] := by
  rw [peterssonAdj_coe]
  have hcoe : (glMap (T_p_lower p hp) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(p : тДЭ), 0; 0, (1 : тДЭ)] := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [glMap, T_p_lower]
  rw [hcoe, Matrix.adjugate_fin_two]
  ext i j; fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]

/-- **T106 helper (GLтВВ(тДЭ)-level)**: `peterssonAdj (glMap T_p_lower) = glMap T_p_upper(0)`.

Both are `GL (Fin 2) тДЭ` elements with matrix `[[1, 0], [0, p]]`. Provides the
GL-level identity needed downstream when `adj(T_p_lower)` must be compared to
`T_p_upper(0)` as group elements (not just as matrices). -/
theorem peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero
    (p : тДХ) (hp : 0 < p) :
    peterssonAdj (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) =
      (glMap (T_p_upper p hp 0) : GL (Fin 2) тДЭ) := by
  apply Units.ext
  ext i j
  have h_L := peterssonAdj_glMap_T_p_lower p hp
  have h_R : ((glMap (T_p_upper p hp 0) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ) = !![(1 : тДЭ), 0; 0, (p : тДЭ)] := by
    ext i' j'; fin_cases i' <;> fin_cases j' <;>
      simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.GeneralLinearGroup.map, Matrix.of_apply]
  show (peterssonAdj (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) :
      Matrix _ _ тДЭ) i j =
    ((glMap (T_p_upper p hp 0) : GL (Fin 2) тДЭ) : Matrix _ _ тДЭ) i j
  rw [h_L, h_R]

/-- **T106 helper**: `glMap (mapGL тДЪ ╬│) = mapGL тДЭ ╬│` for `╬│ : SL(2, тДд)`.

Composition of `SL(2, тДд) тЖТ GL(2, тДЪ) тЖТ GL(2, тДЭ)` via `glMap тИШ mapGL тДЪ` equals
the direct `SL(2, тДд) тЖТ GL(2, тДЭ)` map `mapGL тДЭ`. Follows from Mathlib's
`map_mapGL` for `SpecialLinearGroup`. -/
theorem glMap_mapGL_Q_eq_mapGL_R (╬│ : SL(2, тДд)) :
    (glMap ((mapGL тДЪ : SL(2, тДд) тЖТ* GL (Fin 2) тДЪ) ╬│) : GL (Fin 2) тДЭ) =
      (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ := by
  apply Units.ext
  -- Both sides are `SpecialLinearGroup.map (algebraMap тДд тДЭ) ╬│` (as matrices).
  -- LHS = `(mapGL тДЪ ╬│).map (algebraMap тДЪ тДЭ) = mapGL тДЭ ╬│` via `map_mapGL`.
  ext i j
  show ((glMap ((mapGL тДЪ : SL(2, тДд) тЖТ* GL (Fin 2) тДЪ) ╬│) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ) i j =
    (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│) : Matrix (Fin 2) (Fin 2) тДЭ) i j
  simp [glMap, Matrix.GeneralLinearGroup.map, mapGL_coe_matrix,
    Matrix.SpecialLinearGroup.map, algebraMap_int_eq,
    IsScalarTower.algebraMap_apply тДд тДЪ тДЭ, Matrix.map_apply]

/-- **T106 M_тИЮ adjoint helper**: `peterssonAdj (glMap M_тИЮ) =
glMap T_p_upper(0) * mapGL тДЭ ╧Г_pтБ╗┬╣`.

Uses `M_тИЮ = mapGL тДЪ ╧Г_p ┬╖ T_p_lower` (from `M_infty_eq_sigma_mul_T_p_lower`)
combined with:
* `peterssonAdj_mul` (anti-multiplicativity of `peterssonAdj`),
* `peterssonAdj_mapGL_SL_eq_inv` (for the SL-element `╧Г_p`),
* `peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero`,
* `glMap_mapGL_Q_eq_mapGL_R` (bridging тДЪтЖФтДЭ glMap compositions),
* `map_inv` on `mapGL тДЭ` (MonoidHom preserves inverses).

This is the single missing M_тИЮ adjoint ingredient needed by
`petN_heckeT_p_diamond_shift_core` for the M_тИЮ term: after slashing `g` by
this adjoint, `╧Г_pтБ╗┬╣ тИИ ╬УтВА(N)` acts as the diamond operator `тЯиpтЯйтБ╗┬╣` on `g`. -/
theorem peterssonAdj_glMap_M_infty_eq
    (N p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) :
    peterssonAdj (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) =
      (glMap (T_p_upper p hp 0) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (sigma_p_specific N p hp hpN)тБ╗┬╣) := by
  -- Step 1: `M_тИЮ = mapGL тДЪ ╧Г_p ┬╖ T_p_lower` in GL(Fin 2) тДЪ.
  rw [show (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) =
      (glMap ((mapGL тДЪ : SL(2, тДд) тЖТ* _) (sigma_p_specific N p hp hpN)) *
        glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) from by
    rw [тЖР map_mul]; exact congr_arg _
      (M_infty_eq_sigma_mul_T_p_lower N p hp hpN)]
  -- Step 2: adj anti-multiplicativity.
  rw [peterssonAdj_mul]
  -- Step 3: adj(glMap T_p_lower) = glMap T_p_upper(0).
  rw [peterssonAdj_glMap_T_p_lower_eq_glMap_T_p_upper_zero]
  -- Step 4: glMap (mapGL тДЪ ╧Г_p) = mapGL тДЭ ╧Г_p.
  rw [glMap_mapGL_Q_eq_mapGL_R]
  -- Step 5: adj(mapGL тДЭ ╧Г_p) = (mapGL тДЭ ╧Г_p)тБ╗┬╣.
  rw [peterssonAdj_mapGL_SL_eq_inv]
  -- Step 6: (mapGL тДЭ ╧Г_p)тБ╗┬╣ = mapGL тДЭ (╧Г_pтБ╗┬╣) via MonoidHom.map_inv.
  rw [тЖР map_inv]

/-- The shift matrix `[[1, m; 0, 1]]` as an SLтВВ(тДд) element. -/
private def shiftSL_loc (m : тДд) : SL(2, тДд) :=
  тЯи!![1, m; 0, 1], by simp [Matrix.det_fin_two]тЯй

/-- `shiftSL_loc m тИИ ╬УтВБ(N)` for any level `N`. -/
private lemma shiftSL_loc_mem_Gamma1 (m : тДд) : shiftSL_loc m тИИ Gamma1 N := by
  rw [Gamma1_mem]; refine тЯи?_, ?_, ?_тЯй <;> simp [shiftSL_loc]

/-- Matrix factorization: `peterssonAdj(glMap(T_p_upper(b))) = mapGL тДЭ (shift(-b)) * glMap(T_p_lower)`.

Both sides have matrix `[[p, -b], [0, 1]]` over тДЭ. -/
private lemma peterssonAdj_T_p_upper_eq_shift_mul_lower
    (p : тДХ) (hp : 0 < p) (b : тДХ) :
    peterssonAdj (glMap (T_p_upper p hp b)) =
      (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b : тДд))) *
        glMap (T_p_lower p hp) := by
  -- Both sides have matrix [[p, -b], [0, 1]] over тДЭ.
  -- Prove by showing their matrix coercions agree.
  apply Units.ext; ext i j
  -- LHS matrix from peterssonAdj_glMap_T_p_upper
  have h_lhs : (peterssonAdj (glMap (T_p_upper p hp b)) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(p : тДЭ), -(b : тДЭ); 0, 1] := peterssonAdj_glMap_T_p_upper p hp b
  -- RHS matrix: product of shift and lower
  have h_rhs : ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b : тДд))) *
      glMap (T_p_lower p hp) : GL (Fin 2) тДЭ).val =
      (!![(p : тДЭ), -(b : тДЭ); 0, 1] : Matrix (Fin 2) (Fin 2) тДЭ) := by
    ext i' j'; fin_cases i' <;> fin_cases j' <;>
      simp [shiftSL_loc, glMap, T_p_lower, mapGL, Matrix.SpecialLinearGroup.map,
        Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply, Units.val_mul]
  show (peterssonAdj (glMap (T_p_upper p hp b)) : Matrix _ _ тДЭ) i j =
    ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b : тДд))) *
      glMap (T_p_lower p hp) : GL (Fin 2) тДЭ).val i j
  rw [h_lhs, h_rhs]

/-- **b-independence** for the Petersson adjoint of T_p coset reps (DS Theorem 5.5.3):
`g тИг[k] adj(glMap(T_p_upper(b))) = g тИг[k] glMap(T_p_lower)` for all `b`.

The adjugate `adj([[1,b],[0,p]]) = [[p,-b],[0,1]] = [[1,-b],[0,1]] ┬╖ [[p,0],[0,1]]`,
and `[[1,-b],[0,1]] тИИ ╬УтВБ(N)` acts trivially on `g тИИ S_k(╬УтВБ(N))`. -/
private lemma slash_peterssonAdj_T_p_upper_eq_T_p_lower
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : тДХ)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    тЗСg тИг[k] peterssonAdj (glMap (T_p_upper p hp.pos b)) =
      тЗСg тИг[k] glMap (T_p_lower p hp.pos) := by
  -- Factor: adj(T_p_upper(b)) = mapGL тДЭ (shift(-b)) * glMap(T_p_lower)
  rw [peterssonAdj_T_p_upper_eq_shift_mul_lower p hp.pos b,
      SlashAction.slash_mul]
  -- Now: (g тИг[k] mapGL тДЭ (shift(-b))) тИг[k] glMap(T_p_lower) = g тИг[k] glMap(T_p_lower)
  -- The shift is in ╬УтВБ(N), so g тИг[k] shift(-b) = g.
  -- SL_slash: g тИг[k] (╬│ : SL(2,тДд)) = g тИг[k] (mapGL тДЭ ╬│ : GL(Fin 2) тДЭ)
  -- slash_Gamma1_eq: g тИг[k] ╬│ = g for ╬│ тИИ ╬УтВБ(N)
  congr 1
  -- Goal: тЗСg тИг[k] (mapGL тДЭ ...) (shiftSL_loc ...) = тЗСg
  -- The (mapGL тДЭ)(shiftSL_loc(-b)) is the coercion of shiftSL_loc(-b) : SL(2,тДд) to GL(Fin 2) тДЭ.
  -- By SL_slash, g тИг[k] (mapGL тДЭ ╬│) = g тИг[k] ╬│ for ╬│ : SL(2,тДд).
  -- By slash_Gamma1_eq, g тИг[k] ╬│ = g for ╬│ тИИ ╬УтВБ(N).
  change тЗСg тИг[k] (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b : тДд))) = тЗСg
  have : (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (-(b : тДд))) =
      (shiftSL_loc (-(b : тДд)) : GL (Fin 2) тДЭ) := rfl
  rw [this, тЖР ModularForm.SL_slash]
  exact slash_Gamma1_eq g _ (shiftSL_loc_mem_Gamma1 _)

/-- The adjugate of `glMap(T_p_lower)` equals `glMap(T_p_upper 0)` as GLтВВ(тДЭ) matrices.

`adj([[p,0],[0,1]]) = [[1,0],[0,p]] = T_p_upper(0)`. -/
private lemma slash_peterssonAdj_T_p_lower_eq_T_p_upper_0
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    тЗСg тИг[k] peterssonAdj (glMap (T_p_lower p hp.pos)) =
      тЗСg тИг[k] glMap (T_p_upper p hp.pos 0) := by
  -- adj(T_p_lower) has matrix [[1,0],[0,p]] = glMap(T_p_upper(0)).
  -- Two GLтВВ(тДЭ) elements with the same matrix give the same slash.
  congr 1
  apply Units.ext; ext i j
  have h1 := peterssonAdj_glMap_T_p_lower p hp.pos
  have h2 : (glMap (T_p_upper p hp.pos 0) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(1 : тДЭ), 0; 0, (p : тДЭ)] := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [glMap, T_p_upper]
  rw [show (peterssonAdj (glMap (T_p_lower p hp.pos)) : Matrix _ _ тДЭ) i j =
      (!![(1 : тДЭ), 0; 0, (p : тДЭ)]) i j from by rw [h1]]
  rw [show (glMap (T_p_upper p hp.pos 0) : Matrix _ _ тДЭ) i j =
      (!![(1 : тДЭ), 0; 0, (p : тДЭ)]) i j from by rw [h2]]

/-- **T_p_lower triple product identity** (DS Theorem 5.5.3, matrix level):
`T_p_lower = ╬│тВБ_inv ┬╖ T_p_upper(0) ┬╖ ╬│тВА` where `╬│тВБ_inv тИИ ╬УтВБ(N)` and
`╬│тВА = adjointGamma0Rep тИИ ╬УтВА(N)`. Verified by direct matrix multiplication
using Bezout `p┬╖gcdA + gcdB┬╖N = 1`. -/
private lemma T_p_lower_triple_product_matrix (p N : тДХ) [NeZero N] (hp : 0 < p)
    (hpN : Nat.Coprime p N) :
    (glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (adjointGamma1Rep p N hpN)) *
      (glMap (T_p_upper p hp 0)) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) := by
  -- Verify as matrices over тДЭ
  apply Units.ext; ext i j
  -- LHS matrix: T_p_lower has entries [[p,0],[0,1]] over тДЭ
  have h_lhs : (glMap (T_p_lower p hp) : Matrix (Fin 2) (Fin 2) тДЭ) =
      !![(p : тДЭ), 0; 0, 1] := by
    ext i' j'; fin_cases i' <;> fin_cases j' <;> simp [glMap, T_p_lower]
  -- Bezout relation in тДд
  have hbez : (p : тДд) * Int.gcdA p N + Int.gcdB p N * N = 1 := by
    have h := Int.gcd_eq_gcd_ab p N
    rw [show (Int.gcd (тЖСp) (тЖСN) : тДд) = 1 from by exact_mod_cast hpN] at h
    linarith
  -- Bezout in тДЭ
  have hbezтДЭ : (p : тДЭ) * (Int.gcdA p N : тДЭ) + (Int.gcdB p N : тДЭ) * (N : тДЭ) = 1 := by
    have := congr_arg (Int.cast : тДд тЖТ тДЭ) hbez
    push_cast at this; linarith
  -- RHS matrix: ╬│тВБ_inv ┬╖ T_p_upper(0) ┬╖ ╬│тВА
  have h_rhs : ((((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (adjointGamma1Rep p N hpN)) *
      (glMap (T_p_upper p hp 0))) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) :
      GL (Fin 2) тДЭ).val =
      (!![(p : тДЭ), 0; 0, 1] : Matrix (Fin 2) (Fin 2) тДЭ) := by
    ext i' j'
    -- ╬│тВБ_inv = [[p*gcdA, gcdB],[-N, 1]]
    -- T_p_upper(0) = [[1, 0],[0, p]]
    -- ╬│тВА = [[p, -gcdB],[N, gcdA]]
    -- Product = [[p, 0],[0, 1]] by Bezout
    fin_cases i' <;> fin_cases j' <;>
      simp [adjointGamma1Rep, adjointGamma0Rep, glMap, T_p_upper,
        mapGL, Matrix.SpecialLinearGroup.map,
        Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply, Units.val_mul] <;>
      nlinarith [hbezтДЭ]
  show (glMap (T_p_lower p hp) : Matrix _ _ тДЭ) i j =
    ((((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (adjointGamma1Rep p N hpN)) *
        (glMap (T_p_upper p hp 0))) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) : GL (Fin 2) тДЭ).val i j
  rw [h_lhs, h_rhs]

/-- **Slash identity for T_p_lower via triple product** (T205-d Step 2, ModularForm version):
For `f тИИ M_k(╬УтВБ(N))`, slashing by `T_p_lower` equals slashing by
`T_p_upper(0)` then by `╬│тВА = adjointGamma0Rep`. This uses the triple-product
matrix identity plus the fact that `╬│тВБ_inv тИИ ╬УтВБ(N)` acts trivially on `f`. -/
private lemma slash_T_p_lower_eq_T_p_upper_zero_slash_gamma0_ModularForm
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : ModularForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    тЗСf тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) =
      (тЗСf тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) := by
  -- Use the triple product identity: T_p_lower = ╬│тВБ_inv ┬╖ T_p_upper(0) ┬╖ ╬│тВА
  rw [show (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (adjointGamma1Rep p N hpN)) *
      (glMap (T_p_upper p hp.pos 0)) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) from
    T_p_lower_triple_product_matrix p N hp.pos hpN]
  -- Distribute the slash: (╬│тВБ_inv ┬╖ T_p_upper(0) ┬╖ ╬│тВА) -> ╬│тВБ_inv, then T_p_upper(0), then ╬│тВА
  rw [SlashAction.slash_mul, SlashAction.slash_mul]
  -- Now: ((f тИг ╬│тВБ_inv) тИг T_p_upper(0)) тИг ╬│тВА = (f тИг T_p_upper(0)) тИг ╬│тВА
  -- ╬│тВБ_inv тИИ ╬УтВБ(N), so f тИг ╬│тВБ_inv = f by slash_action_eq
  congr 2
  -- Goal: f тИг (mapGL тДЭ ╬│тВБ_inv) = f
  have hmem : (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (adjointGamma1Rep p N hpN) тИИ
      (Gamma1 N).map (mapGL тДЭ) :=
    тЯиadjointGamma1Rep p N hpN, adjointGamma1Rep_mem_Gamma1 p N hpN, rflтЯй
  exact SlashInvariantFormClass.slash_action_eq f _ hmem

/-- **Slash identity for T_p_lower via triple product** (T205-d Step 2, CuspForm version):
The CuspForm version, derived from the ModularForm version. -/
private lemma slash_T_p_lower_eq_T_p_upper_zero_slash_gamma0
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    тЗСf тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) =
      (тЗСf тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))) :=
  slash_T_p_lower_eq_T_p_upper_zero_slash_gamma0_ModularForm p hp hpN f.toModularForm'

/-- **T205 b-coset bijection (slash form)**: for every `b : тДХ`, slashing a
╬УтВБ(N)-cusp form `f` by `peterssonAdj(glMap T_p_upper(p, b)) * (mapGL тДЭ ╬│тВА)тБ╗┬╣`
(`╬│тВА = adjointGamma0Rep p N hpN`) collapses to slashing by
`glMap T_p_upper(p, 0)`.

**Matrix identity (with explicit ╬УтВБ(N) witness).** Combining
`peterssonAdj_T_p_upper_eq_shift_mul_lower`
(`adj(T_p_upper(p, b)) = mapGL(shift(-b)) * glMap T_p_lower`) with
`T_p_lower_triple_product_matrix`
(`glMap T_p_lower = mapGL(╬│тВБ_inv) * glMap T_p_upper(p, 0) * mapGL(╬│тВА)`)
gives the exact 2├Ч2 matrix equality
```
peterssonAdj (glMap T_p_upper(p, b)) ┬╖ (mapGL ╬│тВА)тБ╗┬╣
  = mapGL (shift(-b) * ╬│тВБ_inv) ┬╖ glMap T_p_upper(p, 0)
```
where `╧Г_b := shiftSL_loc(-b) * adjointGamma1Rep p N hpN` is the explicit
╬УтВБ(N) witness (both `shiftSL_loc(-b)` and `adjointGamma1Rep` lie in ╬УтВБ(N)
by `shiftSL_loc_mem_Gamma1` and `adjointGamma1Rep_mem_Gamma1`).

**Why this is the correct b-coset identity.** The naive T_p_upper-family
conjugation `T_p_upper(p, b) * ╬│тВА = ╧Г * T_p_upper(p, b')` fails: the
(0,0) entry `p + bN тЙб p mod N` requires `p тЙб 1 mod N` for `╧Г тИИ ╬УтВБ(N)`.
Reversing to the adjoint side (slashing by `adj(T_p_upper(p, b)) * ╬│тВАтБ╗┬╣`)
fixes the mod-N obstruction because the (0,0) entry becomes
`pm + bN = 1 + (n+b)N тЙб 1 mod N` (using the Bezout identity
`p┬╖m - n┬╖N = 1` in `adjointGamma0Rep`'s definition).

**Role in T205 closure.** Consumed per-summand in the T_p-adjoint
decomposition to collapse all `p` upper-triangular `b тИИ Fin p` adjoint
contributions into a single `T_p_upper(p, 0)` term after the ╬│тВА-slash.
Pairs with `peterssonInner_sum_slash_adjoint_constantRHS` and the T094
`aedisjoint_pairwise_T_p_family` at the line-2365 residual. -/
private lemma slash_peterssonAdj_T_p_upper_adjointGamma0Rep_inv_eq_T_p_upper_zero
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : тДХ)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    (тЗСf тИг[k] peterssonAdj (glMap (T_p_upper p hp.pos b))) тИг[k]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))тБ╗┬╣ :
          GL (Fin 2) тДЭ) =
    тЗСf тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ) := by
  -- Step 1: substitute the matrix factorization `adj = mapGL(shift) * T_p_lower`.
  rw [peterssonAdj_T_p_upper_eq_shift_mul_lower p hp.pos b]
  -- Step 2: substitute `T_p_lower = mapGL(╬│тВБ_inv) * T_p_upper(0) * mapGL(╬│тВА)`.
  rw [T_p_lower_triple_product_matrix p N hp.pos hpN]
  -- Step 3: split the slash by the product into successive slashes.
  rw [SlashAction.slash_mul, SlashAction.slash_mul, SlashAction.slash_mul]
  -- Step 4: collapse `... тИг[k] mapGL(╬│тВА) тИг[k] (mapGL ╬│тВА)тБ╗┬╣ = ...` via
  -- `mul_inv_cancel` + `slash_one`.
  rw [тЖР SlashAction.slash_mul, mul_inv_cancel, SlashAction.slash_one]
  -- Step 5: absorb slash by `mapGL(shift(-b))` (тИИ ╬УтВБ(N)-image) on cusp form `f`.
  rw [show (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (shiftSL_loc (-(b : тДд)))) : UpperHalfPlane тЖТ тДВ) = тЗСf from
      SlashInvariantFormClass.slash_action_eq f _
        (Subgroup.mem_map.mpr тЯи_, shiftSL_loc_mem_Gamma1 _, rflтЯй)]
  -- Step 6: absorb slash by `mapGL(╬│тВБ_inv)` (= `adjointGamma1Rep`, тИИ ╬УтВБ(N)-image).
  rw [show (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (adjointGamma1Rep p N hpN)) : UpperHalfPlane тЖТ тДВ) = тЗСf from
      SlashInvariantFormClass.slash_action_eq f _
        (Subgroup.mem_map.mpr
          тЯи_, adjointGamma1Rep_mem_Gamma1 p N hpN, rflтЯй)]

/-- **T205 adjoint b-collapse (q-summand form, b-independent RHS)**: for any
`b : тДХ` and ╬УтВБ(N)-cusp form `g`, slashing `g` by
`peterssonAdj(glMap T_p_upper(p, b))` equals slashing by
`glMap T_p_upper(p, 0)` then by `mapGL ╬│тВА`.

