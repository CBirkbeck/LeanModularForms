/-- **T090 / T205 specialization to the T_p Hecke double-coset family.**

Concrete consumer of `peterssonInner_T_p_family_sum_slashes_eq_aggregate_of_integrable`
specialized to the `Option (Fin p) тЖТ GL (Fin 2) тДЭ` family:
* `none тЖж glMap (M_infty p)`
* `some b тЖж glMap (T_p_upper p b.val)`

with common adjoint RHS `тЗСg тИг[k] (glMap (T_p_lower p))`.

**Hypotheses (all dischargeable from existing helpers at the call site):**
* `hm` (per-tile null-measurable): `тИА i, NullMeasurableSet (...) ╬╝_hyp`.
* `h_int_per` (per-tile integrability): `тИА i, IntegrableOn ...`.
* `hfi` (RHS biUnion integrability): `IntegrableOn (fun ╧Д => petersson k тЗСf
  (тЗСg тИг[k] glMap T_p_lower) ╧Д) (тЛГ i тИИ Finset.univ, ...)`.

**Discharged automatically:**
* `h╬▒` (positive determinant): `glMap_M_infty_det_pos` + `glMap_T_p_upper_det_pos`.
* `hadj` (common adjoint = T_p_lower slash):
  `slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_lower` (M_тИЮ branch) +
  `slash_peterssonAdj_glMap_T_p_upper_eq_slash_T_p_lower` (upper-b branch).
* `hd` (pairwise AE-disjoint): `aedisjoint_pairwise_T_p_family`.

**Output.** The aggregate Hecke-FD form
```
peterssonInner k ╬УтВБ_FD (тИС_{i тИИ Finset.univ} f тИг[k] ╬▒_i) g =
  peterssonInner k (тЛГ_{i тИИ Finset.univ} ╬▒_i тАв ╬УтВБ_FD) f (g тИг[k] T_p_lower)
```
where ╬▒_i ranges over the T_p Hecke double-coset family. -/
private theorem peterssonInner_T_p_reps_sum_slashes_eq_aggregate_HeckeFD
    {N : тДХ} [NeZero N] (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hm : тИА i тИИ (Finset.univ : Finset (Option (Fin p))),
      NullMeasurableSet ((match i with
        | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
        | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
        (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp)
    (h_int_per : тИА i тИИ (Finset.univ : Finset (Option (Fin p))),
      IntegrableOn (fun ╧Д => petersson k тЗСg
        (тЗСf тИг[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ))) ╧Д)
        (Gamma1_fundDomain_PSL N) ╬╝_hyp)
    (hfi : IntegrableOn (fun ╧Д => petersson k тЗСf
        (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
          (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N)
      (тИС i тИИ (Finset.univ : Finset (Option (Fin p))),
        тЗСf тИг[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ))) тЗСg =
    peterssonInner k
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
          (Gamma1_fundDomain_PSL N : Set тДН))
      тЗСf
      (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) := by
  -- Factor the Hecke family once so the apply target uses a clean `╬▒ i` shape.
  let ╬▒ : Option (Fin p) тЖТ GL (Fin 2) тДЭ := fun i => match i with
    | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
    | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)
  -- Establish the set equality between the dependent-union shape and the
  -- compact `тЛГ i тИИ s, ╬▒ i тАв ...` shape via per-index case analysis.
  have hset_eq : (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        ╬▒ i тАв (Gamma1_fundDomain_PSL N : Set тДН)) =
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
          (Gamma1_fundDomain_PSL N : Set тДН)) := by
    refine Set.iUnion_congr ?_
    intro i
    refine Set.iUnion_congr ?_
    intro _
    cases i <;> rfl
  -- Re-cast `hfi` into the compact `тЛГ i тИИ s, ╬▒ i тАв ...` shape.
  have hfi_compact : IntegrableOn (fun ╧Д => petersson k тЗСf
        (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        ╬▒ i тАв (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp := by
    rw [hset_eq]; exact hfi
  -- Local statement in compact form so the helper applies cleanly.
  have hmain : peterssonInner k (Gamma1_fundDomain_PSL N)
      (тИС i тИИ (Finset.univ : Finset (Option (Fin p))), тЗСf тИг[k] ╬▒ i) тЗСg =
    peterssonInner k
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        ╬▒ i тАв (Gamma1_fundDomain_PSL N : Set тДН))
      тЗСf
      (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) := by
    apply peterssonInner_T_p_family_sum_slashes_eq_aggregate_of_integrable
      (s := Finset.univ) (╬▒ := ╬▒) (f := f) (g := g)
      (g' := тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ))
    ┬╖ -- positive determinant
      intro i _
      cases i with
      | none => exact glMap_M_infty_det_pos N p hp.pos hpN
      | some b => exact glMap_T_p_upper_det_pos p hp.pos b.val
    ┬╖ -- common adjoint = T_p_lower slash
      intro i _
      cases i with
      | none => exact slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_lower p hp hpN g
      | some b => exact slash_peterssonAdj_glMap_T_p_upper_eq_slash_T_p_lower p hp.pos b.val g
    ┬╖ -- per-tile null-measurable
      exact hm
    ┬╖ -- pairwise AE-disjoint
      exact aedisjoint_pairwise_T_p_family p hp hpN
    ┬╖ -- per-tile integrability
      exact h_int_per
    ┬╖ -- biUnion integrability
      exact hfi_compact
  -- Close the original goal: rewrite the RHS union into the compact `╬▒ i` form
  -- (via `hset_eq.symm`) and close by `hmain`.  The sum on the LHS aligns
  -- definitionally because `╬▒ i` ╬▓-reduces to the original `match i` form.
  rw [тЖР hset_eq]
  exact hmain

