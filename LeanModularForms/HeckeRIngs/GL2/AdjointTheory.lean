open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: `M_infty_Gamma1_factor` lies in `╬УтВБ(N)`.** -/
theorem M_infty_Gamma1_factor_mem_Gamma1
    (N p : тДХ) [NeZero N] (hpN : Nat.Coprime p N) (b : тДХ) :
    M_infty_Gamma1_factor N p hpN b тИИ Gamma1 N := by
  rw [Gamma1_mem]
