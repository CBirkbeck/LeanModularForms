open CongruenceSubgroup Pointwise ConjAct UpperHalfPlane MeasureTheory in
/-- **Phase G тАФ projective shifted FD-decomposition (general ╬▒/╬▒').**

Composes `Gamma_p_╬▒_PSL_R_FD_finite_index_decomp_auto` (the unshifted
finite-index FD on the explicit `q.out`-translate union) with
`Gamma_p_╬▒_PSL_R_lift_FD_smul_conjAct` (the `╬▒'`-shift via
`GLPos_to_PSL_R_term ╬▒'`).

The composition uses two ingredients:
* `Subgroup.subgroupOfEquivOfLe` (mathlib) reinterprets the `subgroupOf`
  FD output of `_decomp_auto` as an FD on the ambient
  `(╬У_p(╬▒)).map SL2Z_to_PSL2R : Subgroup PSL(2, тДЭ)` (the input shape required
  by `Gamma_p_╬▒_PSL_R_lift_FD_smul_conjAct`).  Both subgroup types act on `тДН`
  via the same matrix-M├╢bius action, so the bridge through
  `MeasureTheory.IsFundamentalDomain.image_of_equiv` at the identity equiv
  on `тДН` is purely a type cast.

* The shifted set
  `╬▒' тАв (тЛГ q, q.outтБ╗┬╣ тАв Gamma1_fundDomain_PSL N)`
  is rewritten via `Set.smul_set_iUnion` + `mul_smul` into the explicit
  `тЛГ q, (╬▒' * q.outтБ╗┬╣) тАв Gamma1_fundDomain_PSL N`.

**Use site (DS Prop. 5.5.2(b) tile-decomposition).**  This produces the
`╬▒'`-shifted ╬У_p(╬▒)-FD whose Petersson integral hosts the per-╬▒ slash-adjoint
shift: the integration domain is decomposed into `[╬УтВБ(N) : ╬У_p(╬▒)]` translates
of the ╬УтВБ(N)-FD, each shifted by `╬▒' * q.outтБ╗┬╣` for `q тИИ ((╬УтВБ(N)).map ╧Х) тз╕
((╬У_p(╬▒).map ╧Х).subgroupOf ((╬УтВБ(N).map ╧Х)))`.  The acting group is the
projective conjugate `ConjAct.toConjAct (GLPos_to_PSL_R_term ╬▒') тАв ╬У_p(╬▒)`. -/
theorem Gamma_p_╬▒_PSL_R_FD_finite_index_decomp_shifted
    (╬▒ : GL (Fin 2) тДЪ) (╬▒' : GL(2, тДЭ)тБ║) :
    IsFundamentalDomain
      ((ConjAct.toConjAct (GLPos_to_PSL_R_term ╬▒') тАв
        ((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R)) :
          Subgroup PSL(2, тДЭ))
      (тЛГ q : ((Gamma1 N).map SL2Z_to_PSL2R) тз╕
              (((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R).subgroupOf
                ((Gamma1 N).map SL2Z_to_PSL2R)),
        (GLPos_to_PSL_R_term ╬▒' *
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣) тАв
            (Gamma1_fundDomain_PSL N : Set тДН))
      ╬╝_hyp := by
  -- Step 1: subgroupOf FD from auto-decomp.
  have h_subgroupOf := Gamma_p_╬▒_PSL_R_FD_finite_index_decomp_auto (N := N) ╬▒
  -- Step 2: subgroupOf тЖФ ambient subgroup bridge via subgroupOfEquivOfLe.
  have h_le : ((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R) тЙд
              ((Gamma1 N).map SL2Z_to_PSL2R) :=
    Subgroup.map_mono (Gamma_p_╬▒_le_Gamma1 ╬▒)
  have h_ambient :
      IsFundamentalDomain ((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R)
        (тЛГ q : ((Gamma1 N).map SL2Z_to_PSL2R) тз╕
                (((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R).subgroupOf
                  ((Gamma1 N).map SL2Z_to_PSL2R)),
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣ тАв
            (Gamma1_fundDomain_PSL N : Set тДН))
        ╬╝_hyp := by
    have h_image := h_subgroupOf.image_of_equiv (Equiv.refl тДН)
      (MeasureTheory.Measure.QuasiMeasurePreserving.id _)
      ((Subgroup.subgroupOfEquivOfLe h_le).symm.toEquiv)
      (fun _ _ => rfl)
    simp only [Equiv.coe_refl, Set.image_id] at h_image
    exact h_image
  -- Step 3: ╬▒'-shift.
  have h_shifted := Gamma_p_╬▒_PSL_R_lift_FD_smul_conjAct ╬▒ ╬▒' h_ambient
  -- Step 4: rewrite the shifted set into the explicit `тЛГ q, (╬▒' * q.outтБ╗┬╣) тАв S` form.
  have h_set_eq :
      (тЛГ q : ((Gamma1 N).map SL2Z_to_PSL2R) тз╕
              (((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R).subgroupOf
                ((Gamma1 N).map SL2Z_to_PSL2R)),
        (GLPos_to_PSL_R_term ╬▒' *
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣) тАв
            (Gamma1_fundDomain_PSL N : Set тДН)) =
      GLPos_to_PSL_R_term ╬▒' тАв
        (тЛГ q : ((Gamma1 N).map SL2Z_to_PSL2R) тз╕
                (((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R).subgroupOf
                  ((Gamma1 N).map SL2Z_to_PSL2R)),
          ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣ тАв
            (Gamma1_fundDomain_PSL N : Set тДН)) := by
    rw [Set.smul_set_iUnion]
    refine Set.iUnion_congr ?_
    intro q
    exact mul_smul _ _ _
  rw [h_set_eq]
  exact h_shifted

open CongruenceSubgroup Pointwise UpperHalfPlane MeasureTheory in
/-- **Phase H тАФ packaged per-╬▒ `╬У_p(╬▒)`-fundamental-domain set.**

Set-level packaging of the unshifted ╬У_p(╬▒)-fundamental domain at the
