open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205/T128 integrability bridge**: integrability of
`petersson k g (f вҲЈ[k] Оұ)` on `D` follows from integrability of
`petersson k f g'` on `Оұ вҖў D` + the adjoint identity
`g вҲЈ[k] peterssonAdj Оұ = g'`.

This is the `h_int` shape needed by
`peterssonInner_sum_slash_adjoint_constantRHS`: it transports
integrability from the RHS union-domain form (where T094's
`integrableOn_petersson_biUnion_glMap_smul` applies for cusp forms)
back to the per-summand fd form needed for `peterssonInner_add_left`
distribution of `+` across a ОЈ_b sum.

**Proof pattern** (mirrors `peterssonInner_slash_adjoint`):
1. Decompose `g = (g вҲЈ ОұвҒ»В№) вҲЈ Оұ`, apply `petersson_slash` (with
   `Пғ Оұ = id` for positive det) to get pointwise
   `petersson k (f вҲЈ Оұ) g П„ = |Оұ.det|^(k-2) В· petersson k f (g вҲЈ ОұвҒ»В№) (Оұ вҖў П„)`.
2. Use `slash_peterssonAdj_eq` + `hadj` to identify
   `|Оұ.det|^(k-2) вҖў (g вҲЈ ОұвҒ»В№) = g'`, yielding
   `|Оұ.det|^(k-2) В· petersson k f (g вҲЈ ОұвҒ»В№) = petersson k f g'` (petersson
   linearity in 2nd arg).
3. Conjugate via `petersson_symm`: `petersson k g (f вҲЈ Оұ) П„ =
   conj(petersson k f g' (Оұ вҖў П„)) = petersson k g' f (Оұ вҖў П„)`.
4. Transfer integrability via `MeasurePreserving.integrableOn_image`
   (setIntegral pattern) + `petersson_symm` (norm-preserving conjugate). -/
private lemma integrableOn_petersson_slash_of_adj_image
    (D : Set в„Қ) (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val)
    (f g g' : в„Қ вҶ’ в„Ӯ)
    (hadj : g вҲЈ[k] peterssonAdj Оұ = g')
    (hfi : IntegrableOn (fun П„ => petersson k f g' П„) (Оұ вҖў D) Ој_hyp) :
    IntegrableOn (fun П„ => petersson k g (f вҲЈ[k] Оұ) П„) D Ој_hyp := by
  -- Step 1: establish pointwise identity.
  -- `petersson k g (f вҲЈ Оұ) П„ = petersson k g' f (Оұ вҖў П„)`.
  have hg_decomp : g = (g вҲЈ[k] ОұвҒ»В№) вҲЈ[k] Оұ := by
    rw [вҶҗ SlashAction.slash_mul, inv_mul_cancel, SlashAction.slash_one]
  set g_inv := g вҲЈ[k] ОұвҒ»В№ with hg_inv_def
  have h_pointwise : вҲҖ П„, petersson k g (f вҲЈ[k] Оұ) П„ =
      petersson k g' f (Оұ вҖў П„) := by
    intro П„
    -- `petersson k g (f вҲЈ Оұ) П„ = conj (petersson k (f вҲЈ Оұ) g П„)`.
    rw [petersson_symm k (f вҲЈ[k] Оұ) g]
    -- `petersson k (f вҲЈ Оұ) g П„ = petersson k (f вҲЈ Оұ) (g_inv вҲЈ Оұ) П„`.
    conv_lhs => rw [show g = g_inv вҲЈ[k] Оұ from hg_decomp]
    -- Apply `petersson_slash` + `Пғ Оұ = id`.
    rw [petersson_slash, show Пғ Оұ = RingHom.id в„Ӯ from if_pos hОұ, RingHom.id_apply]
    -- Goal: `conj (|Оұ.det|^(k-2) * petersson k f g_inv (Оұ вҖў П„)) = petersson k g' f (Оұ вҖў П„)`.
    -- First: `|Оұ.det|^(k-2) * petersson k f g_inv = petersson k f (|Оұ.det|^(k-2) вҖў g_inv)`.
    have h_scalar : (вҶ‘|Оұ.det.val| ^ (k - 2) : в„Ӯ) * petersson k f g_inv (Оұ вҖў П„) =
        petersson k f ((вҶ‘(|Оұ.det.val| ^ (k - 2)) : в„Ӯ) вҖў g_inv) (Оұ вҖў П„) := by
      simp [petersson, Pi.smul_apply, smul_eq_mul]; ring
    rw [h_scalar]
    -- `|Оұ.det|^(k-2) вҖў g_inv = g вҲЈ peterssonAdj Оұ = g'` (by slash_peterssonAdj_eq + hadj).
    rw [show ((вҶ‘(|Оұ.det.val| ^ (k - 2)) : в„Ӯ) вҖў g_inv) = g' from by
      rw [вҶҗ hadj, hg_inv_def, slash_peterssonAdj_eq Оұ hОұ]]
    -- Goal: `conj (petersson k f g' (Оұ вҖў П„)) = petersson k g' f (Оұ вҖў П„)`.
    exact (petersson_symm k f g' (Оұ вҖў П„)).symm
  -- Step 2: transfer integrability via change of variables + petersson_symm.
  have h_fn_eq : (fun П„ => petersson k g (f вҲЈ[k] Оұ) П„) =
      fun П„ => petersson k g' f (Оұ вҖў П„) := funext h_pointwise
  rw [h_fn_eq]
  -- Use `MeasurePreserving.integrableOn_image` (reverse): from
  -- `IntegrableOn h (Оұ вҖў D)` to `IntegrableOn (h вҲҳ (Оұ вҖў В·)) D`.
  set Оұ' : GL(2, в„қ)вҒә := вҹЁОұ, hОұвҹ©
  have h_Оұ_eq : (Оұ : GL (Fin 2) в„қ) вҖў D = (fun П„ => Оұ' вҖў П„) '' D := by
    rw [Set.image_smul]; rfl
  rw [show (fun П„ => petersson k g' f (Оұ вҖў П„)) =
      petersson k g' f вҲҳ (fun П„ => Оұ' вҖў П„) from rfl]
  rw [вҶҗ (measurePreserving_smul Оұ' Ој_hyp).integrableOn_image
      (measurableEmbedding_const_smul Оұ')]
  -- Goal: `IntegrableOn (petersson k g' f) (Оұ вҖў D) Ој_hyp`.
  rw [h_Оұ_eq] at hfi
  -- Use `petersson_symm`: `petersson k g' f П„ = conj (petersson k f g' П„)`.
  -- Rewrite the goal's integrand via pointwise-equality.
  have h_symm_fn : (petersson k g' f : в„Қ вҶ’ в„Ӯ) =
      fun П„ => starRingEnd в„Ӯ (petersson k f g' П„) :=
    funext fun П„ => petersson_symm k f g' П„
  rw [h_symm_fn]
  -- Use that `starRingEnd в„Ӯ` is a continuous linear map with norm 1, so integrability transfers.
  -- Actually `IntegrableOn h S Ој` for `h = star вҲҳ f` follows from `IntegrableOn f S Ој`
  -- since `вҖ–star zвҖ– = вҖ–zвҖ–` (norm preservation) + `star` continuous (measurability preservation).
  refine вҹЁ?_, ?_вҹ©
  В· -- AEStronglyMeasurable: continuous conj composed with a measurable function.
    exact Complex.continuous_conj.comp_aestronglyMeasurable hfi.aestronglyMeasurable
  В· -- HasFiniteIntegral: вҲ« вҖ–conj вҲҳ hвҖ–вӮ‘ = вҲ« вҖ–hвҖ–вӮ‘ since `вҖ–conj zвҖ– = вҖ–zвҖ–`.
    have h_finite := hfi.2
    show HasFiniteIntegral _ _
    unfold HasFiniteIntegral at h_finite вҠў
    refine lt_of_le_of_lt (le_of_eq ?_) h_finite
    apply lintegral_congr_ae
    filter_upwards with П„
    show вҖ–(starRingEnd в„Ӯ) (petersson k f g' П„)вҖ–вӮ‘ = вҖ–petersson k f g' П„вҖ–вӮ‘
    rw [enorm_eq_nnnorm, enorm_eq_nnnorm]
    congr 1
    exact Subtype.ext (Complex.norm_conj _)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205/T128 bridge: GL-pair AE-disjoint on the SL(2, в„Ө)-fundamental
domain `ModularGroup.fd` via `mapGL в„қ Пғ`-factored inverse product**.

For `ОұвӮҒ, ОұвӮӮ : GL (Fin 2) в„қ` with `ОұвӮҒвҒ»В№` measure-preserving on `в„Қ`, if
`ОұвӮҒвҒ»В№ * ОұвӮӮ = mapGL в„қ Пғ` for some `Пғ : SL(2, в„Ө)` with non-trivial image
in `PSL(2, в„Ө)`, then `ОұвӮҒ вҖў fd` and `ОұвӮӮ вҖў fd` are AE-disjoint.

This is the `fd`-version of
`aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1` (which works for
`Gamma1_fundDomain_PSL N`).  It is the specific AE-disjointness needed
for the T205 upper-family union collapse on the per-`q` tile
`(mapGL qвҒ»В№) вҖў fd`, where the `Пғ = q В· shift(bвӮӮ-bвӮҒ) В· qвҒ»В№` conjugate
product lands in `SL(2, в„Ө) \ О“вӮҒ(N)` in general (О“вӮҒ(N) is not normal
in SL(2, в„Ө)), so the О“вӮҒ-version cannot be invoked directly.

**Proof route** (per manager guidance):
1. Start from `isFundamentalDomain_fdo_PSL.aedisjoint` (gives
   `AEDisjoint fdo (q вҖў fdo)` for `q = вҹЁПғвҹ© вү  1 вҲҲ PSL(2, в„Ө)`).
2. Transfer from `fdo` to `fd` via `fd_ae_eq_fdo` + `AEDisjoint.congr`,
   using that `q`-smul preserves a.e. equality of sets (as `q` acts by
   a measure-preserving map on `в„Қ`).
3. Pull back by `ОұвӮҒвҒ»В№` following the pattern of
   `aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1`. -/
theorem aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne
    (ОұвӮҒ ОұвӮӮ : GL (Fin 2) в„қ)
    (h_mp_inv : MeasurePreserving ((ОұвӮҒвҒ»В№ вҖў В·) : в„Қ вҶ’ в„Қ) Ој_hyp Ој_hyp)
    (Пғ : SL(2, в„Ө)) (hПғ_ne : (QuotientGroup.mk Пғ : PSL(2, в„Ө)) вү  1)
    (h_inv_mul : ОұвӮҒвҒ»В№ * ОұвӮӮ =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) Пғ : GL (Fin 2) в„қ)) :
    AEDisjoint Ој_hyp (ОұвӮҒ вҖў (ModularGroup.fd : Set UpperHalfPlane))
      (ОұвӮӮ вҖў (ModularGroup.fd : Set UpperHalfPlane)) := by
  set q : PSL(2, в„Ө) := QuotientGroup.mk Пғ with hq_def
  -- Step 1: `AEDisjoint fdo (q вҖў fdo)` from `isFundamentalDomain_fdo_PSL`.
  have h_fdo_aedisjoint : AEDisjoint Ој_hyp (fdo : Set в„Қ) (q вҖў (fdo : Set в„Қ)) := by
    have h_ne : (1 : PSL(2, в„Ө)) вү  q := fun h => hПғ_ne h.symm
    have h_gen := isFundamentalDomain_fdo_PSL.aedisjoint h_ne
    -- Unfold `Function.onFun` and simplify `1 вҖў fdo = fdo`.
    simp only [Function.onFun, one_smul] at h_gen
    exact h_gen
  -- Step 2: `q`-smul of `fd` and `fdo` agree a.e. (since `fd =бөҗ fdo` and
  -- `q`-smul is measure-preserving on `в„Қ` via `instSMulInvMeasure_PSL`).
  have h_q_smul_aeeq :
      (q вҖў (ModularGroup.fd : Set UpperHalfPlane) : Set в„Қ) =бөҗ[Ој_hyp] (q вҖў (fdo : Set в„Қ)) := by
    refine ae_eq_set.mpr вҹЁ?_, ?_вҹ©
    В· -- Ој (q вҖў fd \ q вҖў fdo) = Ој (q вҖў (fd \ fdo)) = Ој (fd \ fdo) = 0
      -- (using `measure_smul` via `instSMulInvMeasure_PSL`).
      have h_sdiff : (q вҖў (ModularGroup.fd : Set UpperHalfPlane) \ q вҖў (fdo : Set в„Қ) : Set в„Қ) =
          q вҖў ((ModularGroup.fd : Set UpperHalfPlane) \ fdo) := by
        ext x
        simp only [Set.mem_diff, Set.mem_smul_set_iff_inv_smul_mem]
      rw [h_sdiff, measure_smul]
      exact hyperbolicMeasure_fd_boundary
    В· -- Ој (q вҖў fdo \ q вҖў fd) = 0 because `fdo вҠҶ fd` makes this set empty.
      have h_fdo_sub_fd : q вҖў (fdo : Set в„Қ) вҠҶ q вҖў (ModularGroup.fd : Set UpperHalfPlane) := by
        intro x hx
        rcases hx with вҹЁy, hy, rflвҹ©
        exact вҹЁy, fdo_subset_fd hy, rflвҹ©
      rw [Set.diff_eq_empty.mpr h_fdo_sub_fd]
      exact measure_empty
  -- Step 3: `AEDisjoint fd (q вҖў fd)` by transferring from Step 1 via Step 2.
  have h_inner : AEDisjoint Ој_hyp (ModularGroup.fd : Set UpperHalfPlane)
      (q вҖў (ModularGroup.fd : Set UpperHalfPlane)) :=
    h_fdo_aedisjoint.congr fd_ae_eq_fdo h_q_smul_aeeq
  -- Step 4: Preimage identifications (same as Gamma1 version).
  have h_pre_ОұвӮҒ : ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (ModularGroup.fd : Set UpperHalfPlane) : Set в„Қ) =
      ОұвӮҒ вҖў (ModularGroup.fd : Set UpperHalfPlane) := by
    ext П„; simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  have h_pre_ОұвӮӮ : ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (q вҖў (ModularGroup.fd : Set UpperHalfPlane)) : Set в„Қ) =
      ОұвӮӮ вҖў (ModularGroup.fd : Set UpperHalfPlane) := by
    ext П„
    simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    have hq_smul : вҲҖ z : в„Қ, (qвҒ»В№ вҖў z : в„Қ) =
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Пғ)вҒ»В№ : GL (Fin 2) в„қ) вҖў z := by
      intro z
      rw [hq_def, вҶҗ QuotientGroup.mk_inv, PSL_smul_coe]
      rw [sl_moeb, show ((ПғвҒ»В№ : SL(2, в„Ө)) : GL (Fin 2) в„қ) =
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Пғ)вҒ»В№ from by
        rw [вҶҗ map_inv]; rfl]
    rw [hq_smul (ОұвӮҒвҒ»В№ вҖў П„)]
    have h_eq : ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Пғ)вҒ»В№ = ОұвӮӮвҒ»В№ * ОұвӮҒ := by
      rw [вҶҗ h_inv_mul, mul_inv_rev, inv_inv]
    rw [h_eq, mul_smul]
    rw [show (ОұвӮҒ вҖў ОұвӮҒвҒ»В№ вҖў П„ : в„Қ) = П„ from by
      rw [вҶҗ mul_smul, mul_inv_cancel, one_smul]]
  -- Step 5: AE-disjointness of preimages via quasi-measure-preserving.
  have h_QMP : MeasureTheory.Measure.QuasiMeasurePreserving
      ((ОұвӮҒвҒ»В№ вҖў В·) : в„Қ вҶ’ в„Қ) Ој_hyp Ој_hyp :=
    h_mp_inv.quasiMeasurePreserving
  have h_pre_aedisjoint : AEDisjoint Ој_hyp
      ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (ModularGroup.fd : Set UpperHalfPlane))
      ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (q вҖў (ModularGroup.fd : Set UpperHalfPlane))) :=
    h_inner.preimage h_QMP
  rw [h_pre_ОұвӮҒ, h_pre_ОұвӮӮ] at h_pre_aedisjoint
  exact h_pre_aedisjoint

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094 bridge: GL-pair AE-disjoint via `mapGL в„қ Оі`-factored inverse product.**

For `ОұвӮҒ, ОұвӮӮ : GL (Fin 2) в„қ` with `ОұвӮҒвҒ»В№` measure-preserving on в„Қ, if
`ОұвӮҒвҒ»В№ * ОұвӮӮ = mapGL в„қ Оі` for some `Оі вҲҲ О“вӮҒ(N)` non-trivial in `PSL(2,в„Ө)`,
then `ОұвӮҒ вҖў D_N^PSL` and `ОұвӮӮ вҖў D_N^PSL` are AE-disjoint. -/
theorem aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    {N : в„•} [NeZero N] (ОұвӮҒ ОұвӮӮ : GL (Fin 2) в„қ)
    (h_mp_inv : MeasurePreserving ((ОұвӮҒвҒ»В№ вҖў В·) : в„Қ вҶ’ в„Қ) Ој_hyp Ој_hyp)
    (Оі : SL(2, в„Ө)) (hОі_О“1 : Оі вҲҲ Gamma1 N)
    (hОі_ne : (QuotientGroup.mk Оі : PSL(2, в„Ө)) вү  1)
    (h_inv_mul : ОұвӮҒвҒ»В№ * ОұвӮӮ = ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Оі : GL (Fin 2) в„қ)) :
    AEDisjoint Ој_hyp (ОұвӮҒ вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
      (ОұвӮӮ вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) := by
  set D : Set в„Қ := Gamma1_fundDomain_PSL N
  set q : PSL(2, в„Ө) := QuotientGroup.mk Оі with hq_def
  have h_inner : AEDisjoint Ој_hyp D (q вҖў D) := by
    have h_mem : (1 : PSL(2, в„Ө))вҒ»В№ * q вҲҲ imageGamma1_PSL N := by
      rw [inv_one, one_mul, hq_def]
      exact Subgroup.mem_map.mpr вҹЁОі, hОі_О“1, rflвҹ©
    have h_ne : (1 : PSL(2, в„Ө))вҒ»В№ * q вү  1 := by
      rw [inv_one, one_mul]; exact hОі_ne
    have h_gen := isFundamentalDomain_Gamma1_coset_tiling (N := N)
      |>.aedisjoint_smul_of_mul_inv_mem h_mem h_ne
    rwa [one_smul] at h_gen
  have h_pre_ОұвӮҒ : ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' D : Set в„Қ) = ОұвӮҒ вҖў D := by
    ext П„; simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  have h_pre_ОұвӮӮ : ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (q вҖў D) : Set в„Қ) = ОұвӮӮ вҖў D := by
    ext П„
    simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    have hq_smul : вҲҖ Пғ : в„Қ, (qвҒ»В№ вҖў Пғ : в„Қ) =
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Оі)вҒ»В№ : GL (Fin 2) в„қ) вҖў Пғ := by
      intro Пғ
      rw [hq_def, вҶҗ QuotientGroup.mk_inv, PSL_smul_coe]
      rw [sl_moeb, show ((ОівҒ»В№ : SL(2, в„Ө)) : GL (Fin 2) в„қ) =
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Оі)вҒ»В№ from by
        rw [вҶҗ map_inv]; rfl]
    rw [hq_smul (ОұвӮҒвҒ»В№ вҖў П„)]
    have h_eq : ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) Оі)вҒ»В№ = ОұвӮӮвҒ»В№ * ОұвӮҒ := by
      rw [вҶҗ h_inv_mul, mul_inv_rev, inv_inv]
    rw [h_eq, mul_smul]
    rw [show (ОұвӮҒ вҖў ОұвӮҒвҒ»В№ вҖў П„ : в„Қ) = П„ from by
      rw [вҶҗ mul_smul, mul_inv_cancel, one_smul]]
  have h_QMP : MeasureTheory.Measure.QuasiMeasurePreserving
      ((ОұвӮҒвҒ»В№ вҖў В·) : в„Қ вҶ’ в„Қ) Ој_hyp Ој_hyp :=
    h_mp_inv.quasiMeasurePreserving
  have h_pre_aedisjoint : AEDisjoint Ој_hyp
      ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' D) ((ОұвӮҒвҒ»В№ вҖў В·) вҒ»В№' (q вҖў D)) :=
    h_inner.preimage h_QMP
  rw [h_pre_ОұвӮҒ, h_pre_ОұвӮӮ] at h_pre_aedisjoint
  exact h_pre_aedisjoint

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094 matrix identity M1: `T_p_upper` inverse-product factors through
`shiftSL_loc`.**

`(glMap T_p_upper(bвӮҒ))вҒ»В№ * (glMap T_p_upper(bвӮӮ)) = mapGL в„қ (shiftSL_loc (bвӮӮ - bвӮҒ))`
in `GL (Fin 2) в„қ`. Proved via `A * (shift) = B` computation, inverted. -/
theorem glMap_T_p_upper_inv_mul_eq_mapGL_shift
    {p : в„•} (hp : 0 < p) (bвӮҒ bвӮӮ : в„•) :
    (glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№ *
        (glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)))) := by
  -- Strategy: show `glMap T_p_upper(bвӮӮ) = glMap T_p_upper(bвӮҒ) * mapGL в„қ (shift)`.
  have h_mul : (glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) =
      (glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)))) := by
    apply Units.ext
    ext i j
    have h_L : ((glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) = !![(1 : в„қ), (bвӮӮ : в„қ); 0, (p : в„қ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R1 : ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) = !![(1 : в„қ), (bвӮҒ : в„қ); 0, (p : в„қ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R2 : (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)))) :
        Matrix (Fin 2) (Fin 2) в„қ) = !![(1 : в„қ), (bвӮӮ : в„қ) - (bвӮҒ : в„қ); 0, 1] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [mapGL_coe_matrix, shiftSL_loc, algebraMap_int_eq, Matrix.of_apply]
    show ((glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) : Matrix _ _ в„қ) i j =
      ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) *
       ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)))) :
       GL (Fin 2) в„қ).val i j
    rw [h_L, Units.val_mul, h_R1, h_R2]
    fin_cases i <;> fin_cases j <;>
      simp [Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply] <;> ring
  rw [h_mul, вҶҗ mul_assoc, inv_mul_cancel, one_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: AE-disjoint for two `T_p_upper`-translates.** -/
theorem aedisjoint_glMap_T_p_upper_pair
    {N : в„•} [NeZero N] {p : в„•} (hp : 0 < p) {bвӮҒ bвӮӮ : в„•}
    (hne : (bвӮӮ : в„Ө) - (bвӮҒ : в„Ө) вү  0) :
    AEDisjoint Ој_hyp
      ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) вҖў
        (Gamma1_fundDomain_PSL N : Set в„Қ))
      ((glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) вҖў
        (Gamma1_fundDomain_PSL N : Set в„Қ)) := by
  have h_det_pos : вҲҖ b, 0 < (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
      (algebraMap в„ҡ в„қ) (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det) from
        (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp
  have h_inv_det_pos : 0 <
      ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№).det.val := by
    have hОұ_pos := h_det_pos bвӮҒ
    show 0 < ((((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№).det : в„қЛЈ) : в„қ)
    rw [show (((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№).det : в„қЛЈ) =
        ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ).det : в„қЛЈ)вҒ»В№ from map_inv _ _]
    show 0 < (((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ).det : в„қЛЈ))вҒ»В№.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr hОұ_pos
  have h_psl_ne : (QuotientGroup.mk (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө))) :
      PSL(2, в„Ө)) вү  1 := by
    intro heq
    rw [QuotientGroup.eq_one_iff] at heq
    have hS : (!![(0 : в„Ө), -1; 1, 0] : Matrix (Fin 2) (Fin 2) в„Ө).det = 1 := by
      simp [Matrix.det_fin_two]
    set S_mat : SL(2, в„Ө) := вҹЁ!![0, -1; 1, 0], hSвҹ©
    have hcomm : shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) * S_mat =
        S_mat * shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) := heq.comm S_mat
    have hcomm_val :
        (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) : SL(2, в„Ө)).val * S_mat.val =
        S_mat.val * (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) : SL(2, в„Ө)).val :=
      congr_arg Subtype.val hcomm
    have h_00 := congr_fun (congr_fun hcomm_val 0) 0
    simp only [S_mat, shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two,
      Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
      Matrix.head_cons, Matrix.head_fin_const] at h_00
    apply hne; linarith
  exact aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    (glMap (T_p_upper p hp bвӮҒ)) (glMap (T_p_upper p hp bвӮӮ))
    (measurePreserving_glPos_smul _ h_inv_det_pos)
    (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө))) (shiftSL_loc_mem_Gamma1 _) h_psl_ne
    (glMap_T_p_upper_inv_mul_eq_mapGL_shift hp bвӮҒ bвӮӮ)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205 per-`q` upper-family pairwise AE-disjoint on `fd`-tiles**:
for fixed `q : SL(2, в„Ө)` and `bвӮҒ вү  bвӮӮ`, the tiles
`(glMap T_p_upper(p, b) * mapGL qвҒ»В№) вҖў fd` are pairwise AE-disjoint.

This is the `hd` input for `peterssonInner_biUnion_finset_ae` / the
`peterssonInner_sum_slash_adjoint_constantRHS` finite-family collapse on
the T205 upper family at each `q : SL(2, в„Ө) в§ё О“вӮҒ(N)`.

**Uses**: `aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne` (fd-level
bridge) with `Пғ = q В· shiftSL_loc(bвӮӮ-bвӮҒ) В· qвҒ»В№`, `h_inv_mul` from
`glMap_T_p_upper_inv_mul_eq_mapGL_shift` combined with conjugation by
`mapGL qвҒ»В№`, and PSL nontriviality of the conjugate from the existing
shift-commutation argument (transported through conjugation: a group
element is trivial in a quotient iff its conjugate is).

**Why not the О“вӮҒ-version**: `(ОұвӮҒ)вҒ»В№ В· ОұвӮӮ = mapGL(q В· shift(bвӮӮ-bвӮҒ) В· qвҒ»В№)`
lands in `SL(2, в„Ө) \ О“вӮҒ(N)` in general (О“вӮҒ(N) is not normal in SL(2, в„Ө)),
so `aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1` does not apply. -/
theorem aedisjoint_glMap_T_p_upper_pair_fd_per_q
    {p : в„•} (hp : 0 < p) (q : SL(2, в„Ө)) {bвӮҒ bвӮӮ : в„•}
    (hne : (bвӮӮ : в„Ө) - (bвӮҒ : в„Ө) вү  0) :
    AEDisjoint Ој_hyp
      (((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane))
      (((glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)) := by
  set ОұвӮҒ : GL (Fin 2) в„қ :=
    (glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)
  set ОұвӮӮ : GL (Fin 2) в„қ :=
    (glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)
  -- Positive det of `glMap T_p_upper(p, b)` (= p > 0).
  have h_Tp_det_pos :
      вҲҖ b, 0 < (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp
  -- Det of matrix of `mapGL qвҒ»В№` is 1 (since `qвҒ»В№ вҲҲ SL(2, в„Ө)`).
  have h_mapGL_mat_det_eq_one :
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
    rw [show (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix (qвҒ»В№ : SL(2, в„Ө)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, (qвҒ»В№ : SL(2, в„Ө)).property]
    simp
  -- Positive det of ОұвӮҒ = glMap T_p_upper(p, bвӮҒ) * mapGL qвҒ»В№.
  have h_ОұвӮҒ_det_pos : 0 < (ОұвӮҒ : GL (Fin 2) в„қ).det.val := by
    show 0 < ((ОұвӮҒ : GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((ОұвӮҒ : GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ) =
        ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) : Matrix (Fin 2) (Fin 2) в„қ) *
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact h_Tp_det_pos bвӮҒ
  -- Positive det of ОұвӮҒвҒ»В№ = 1/det(ОұвӮҒ) > 0.
  have h_ОұвӮҒ_inv_det_pos : 0 < (ОұвӮҒвҒ»В№ : GL (Fin 2) в„қ).det.val := by
    show 0 < (((ОұвӮҒвҒ»В№).det : в„қЛЈ) : в„қ)
    rw [show ((ОұвӮҒвҒ»В№ : GL (Fin 2) в„қ)).det = ОұвӮҒ.detвҒ»В№ from map_inv _ _,
      Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h_ОұвӮҒ_det_pos
  -- Matrix identity: ОұвӮҒвҒ»В№ * ОұвӮӮ = mapGL (q * shift(bвӮӮ-bвӮҒ) * qвҒ»В№).
  have h_inv_mul : ОұвӮҒвҒ»В№ * ОұвӮӮ =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        (q * shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) * qвҒ»В№) : GL (Fin 2) в„қ) := by
    show (((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№ *
        ((glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))) = _
    rw [mul_inv_rev]
    -- `((mapGL qвҒ»В№))вҒ»В№ = mapGL q`.
    rw [show (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№ =
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) q : GL (Fin 2) в„қ) from by
        rw [вҶҗ map_inv]; simp]
    -- Re-associate: (mapGL q * (glMap T_p_upper(bвӮҒ))вҒ»В№) * (glMap T_p_upper(bвӮӮ) * mapGL qвҒ»В№)
    --             = mapGL q * ((glMap T_p_upper(bвӮҒ))вҒ»В№ * glMap T_p_upper(bвӮӮ)) * mapGL qвҒ»В№
    rw [mul_assoc ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) q : GL (Fin 2) в„қ)
          (glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№,
      вҶҗ mul_assoc ((glMap (T_p_upper p hp bвӮҒ) : GL (Fin 2) в„қ)вҒ»В№)
          (glMap (T_p_upper p hp bвӮӮ) : GL (Fin 2) в„қ)
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ),
      glMap_T_p_upper_inv_mul_eq_mapGL_shift hp bвӮҒ bвӮӮ,
      вҶҗ mul_assoc]
    -- Now: mapGL q * mapGL shift * mapGL qвҒ»В№ = mapGL (q * shift * qвҒ»В№).
    rw [вҶҗ map_mul, вҶҗ map_mul]
  -- PSL nontriviality of the conjugate `q В· shift(bвӮӮ-bвӮҒ) В· qвҒ»В№`.
  -- Reduce to nontriviality of `shift(bвӮӮ-bвӮҒ)` by conjugation invariance in
  -- the group quotient.
  have h_psl_shift_ne :
      (QuotientGroup.mk (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө))) :
        PSL(2, в„Ө)) вү  1 := by
    intro heq
    rw [QuotientGroup.eq_one_iff] at heq
    have hS : (!![(0 : в„Ө), -1; 1, 0] : Matrix (Fin 2) (Fin 2) в„Ө).det = 1 := by
      simp [Matrix.det_fin_two]
    set S_mat : SL(2, в„Ө) := вҹЁ!![0, -1; 1, 0], hSвҹ©
    have hcomm : shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) * S_mat =
        S_mat * shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) := heq.comm S_mat
    have hcomm_val :
        (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) : SL(2, в„Ө)).val * S_mat.val =
        S_mat.val * (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) : SL(2, в„Ө)).val :=
      congr_arg Subtype.val hcomm
    have h_00 := congr_fun (congr_fun hcomm_val 0) 0
    simp only [S_mat, shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two,
      Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
      Matrix.head_cons, Matrix.head_fin_const] at h_00
    apply hne; linarith
  have h_psl_conj_ne :
      (QuotientGroup.mk (q * shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) * qвҒ»В№) :
        PSL(2, в„Ө)) вү  1 := by
    intro heq
    apply h_psl_shift_ne
    have hconj : (QuotientGroup.mk q : PSL(2, в„Ө)) *
            (QuotientGroup.mk (shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө))) : PSL(2, в„Ө)) *
            (QuotientGroup.mk q : PSL(2, в„Ө))вҒ»В№ = 1 := by
      rw [вҶҗ QuotientGroup.mk_inv, вҶҗ QuotientGroup.mk_mul, вҶҗ QuotientGroup.mk_mul]
      exact heq
    -- Solve for shift from the conjugate equation.
    rw [mul_inv_eq_one] at hconj
    -- hconj : вҹЁqвҹ© * вҹЁshiftвҹ© = вҹЁqвҹ©; conclude вҹЁshiftвҹ© = 1 via `mul_left_cancel` on
    -- `вҹЁqвҹ© * вҹЁshiftвҹ© = вҹЁqвҹ© * 1`.
    exact mul_left_cancel (hconj.trans (mul_one _).symm)
  -- Apply the fd-level helper.
  exact aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne ОұвӮҒ ОұвӮӮ
    (measurePreserving_glPos_smul _ h_ОұвӮҒ_inv_det_pos)
    (q * shiftSL_loc ((bвӮӮ : в„Ө) - (bвӮҒ : в„Ө)) * qвҒ»В№)
    h_psl_conj_ne h_inv_mul

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205 per-`q` upper-family union-collapse (peterssonInner form)**.

For fixed `q : SL(2, в„Ө)` and О“вӮҒ(N)-cusp forms `f, g`, the sum of
`peterssonInner` over per-`b` upper-family fd-tiles collapses to a single
`peterssonInner` on the union-domain with the b-INDEPENDENT `g`-slot
`G := (вҮ‘g вҲЈ[k] glMap T_p_upper(p, 0)) вҲЈ[k] mapGL ОівӮҖ`.

Directly invokes `peterssonInner_biUnion_finset_ae`, with:
- `hd` supplied by `aedisjoint_glMap_T_p_upper_pair_fd_per_q`;
- `hm` by a pointwise preimage identification
  `Оұ_b вҖў fd = (Оұ_bвҒ»В№ вҖў В·) вҒ»В№' fd` + `NullMeasurableSet.preimage` via
  `QuasiMeasurePreserving` (from `measurePreserving_glPos_smul` on positive
  determinant `Оұ_bвҒ»В№`) + `MeasurableSet fd` (fd as closed intersection of
  `|z| вүҘ 1 вҲ© |Re(z)| вүӨ 1/2`);
- `hfi` (integrability of `petersson k вҮ‘f G` over the union) is taken as a
  hypothesis, to be supplied by a separate integrability helper (the second
  blocker identified in the obstruction report).

**Role in T205 closure.** This is the finite-family collapse that turns the
upper `вҲ‘_b peterssonInner` into a single union-domain integral, the final
step before `peterssonInner_sum_slash_adjoint_constantRHS`-style assembly. -/
theorem peterssonInner_T_p_upper_family_union_collapse_per_q
    {p : в„•} [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (hfi : IntegrableOn
      (fun П„ => petersson k вҮ‘f
        ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) П„)
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane)) Ој_hyp) :
    вҲ‘ b вҲҲ Finset.range p,
      peterssonInner k
        (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane))
        вҮ‘f
        ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) =
    peterssonInner k
      (вӢғ b вҲҲ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane))
      вҮ‘f
      ((вҮ‘g вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)))) := by
  -- `fd` is measurable (closed intersection of two half-planes).
  have h_fd_mset : MeasurableSet (ModularGroup.fd : Set UpperHalfPlane) :=
    ((isClosed_le continuous_const
        (Complex.continuous_normSq.comp UpperHalfPlane.continuous_coe)).inter
      (isClosed_le (continuous_abs.comp UpperHalfPlane.continuous_re)
        continuous_const)).measurableSet
  have h_fd_null : NullMeasurableSet (ModularGroup.fd : Set UpperHalfPlane) Ој_hyp :=
    h_fd_mset.nullMeasurableSet
  -- Positive determinants of Оұ_b and Оұ_bвҒ»В№.
  have h_Tp_det_pos :
      вҲҖ b, 0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  have h_mapGL_mat_det_eq_one :
      (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
    rw [show (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((Int.castRingHom в„қ).mapMatrix (qвҒ»В№ : SL(2, в„Ө)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [вҶҗ RingHom.map_det, (qвҒ»В№ : SL(2, в„Ө)).property]
    simp
  have h_Оұ_det_pos : вҲҖ b, 0 <
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)).det.val := fun b => by
    show 0 < (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) :
          Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) :
            Matrix (Fin 2) (Fin 2) в„қ) =
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) *
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ) :
          Matrix (Fin 2) (Fin 2) в„қ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact h_Tp_det_pos b
  have h_Оұ_inv_det_pos : вҲҖ b, 0 <
      (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№ :
          GL (Fin 2) в„қ).det.val := fun b => by
    have hОұ_pos := h_Оұ_det_pos b
    show 0 < (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№).det : в„қЛЈ) : в„қ)
    rw [show (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№).det : в„қЛЈ)) =
        ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)).det : в„қЛЈ))вҒ»В№ from
          map_inv _ _]
    show 0 < ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)).det : в„қЛЈ))вҒ»В№.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr hОұ_pos
  -- `hm`: NullMeasurableSet for each per-b tile via Оұ_bвҒ»В№-smul preimage.
  have hm : вҲҖ b вҲҲ Finset.range p, NullMeasurableSet
      (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
          (ModularGroup.fd : Set UpperHalfPlane)) Ој_hyp := fun b _ => by
    have h_eq : (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane)) =
        (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ))вҒ»В№ вҖў В·) :
              в„Қ вҶ’ в„Қ) вҒ»В№' (ModularGroup.fd : Set UpperHalfPlane)) := by
      ext П„; simp [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    rw [h_eq]
    exact h_fd_null.preimage
      (measurePreserving_glPos_smul _ (h_Оұ_inv_det_pos b)).quasiMeasurePreserving
  -- `hd`: pairwise AE-disjointness from `aedisjoint_glMap_T_p_upper_pair_fd_per_q`.
  have hd : (вҶ‘(Finset.range p) : Set в„•).Pairwise fun bвӮҒ bвӮӮ =>
      AEDisjoint Ој_hyp
        (((glMap (T_p_upper p hp.pos bвӮҒ) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane))
        (((glMap (T_p_upper p hp.pos bвӮӮ) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
            (ModularGroup.fd : Set UpperHalfPlane)) := fun bвӮҒ _ bвӮӮ _ hne => by
    apply aedisjoint_glMap_T_p_upper_pair_fd_per_q hp.pos q
    intro h
    apply hne
    exact_mod_cast (sub_eq_zero.mp h).symm
  -- Invoke `peterssonInner_biUnion_finset_ae` in reverse (union вҶ’ sum direction)
  -- to obtain `вҲ‘_b = peterssonInner (вӢғ_b В·)`.
  exact (peterssonInner_biUnion_finset_ae (Finset.range p) hm hd вҮ‘f _ hfi).symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: `Ој_hyp` is invariant under positive-det `GL (Fin 2) в„қ` translates.**

Uses the `(ОұвҒ»В№ вҖў В·)` preimage formula and `MeasurePreserving.measure_preimage` on
the GL(2, в„қ)вҒә lift. -/
theorem measure_glPos_smul_eq (Оұ : GL (Fin 2) в„қ) (hОұ : 0 < Оұ.det.val)
    {S : Set в„Қ} (hS : NullMeasurableSet S Ој_hyp) :
    Ој_hyp (Оұ вҖў S) = Ој_hyp S := by
  -- Positive det of ОұвҒ»В№.
  have hОұ_inv : 0 < (ОұвҒ»В№ : GL (Fin 2) в„қ).det.val := by
    show 0 < (((ОұвҒ»В№).det : в„қЛЈ) : в„қ)
    rw [show ((ОұвҒ»В№ : GL (Fin 2) в„қ)).det = Оұ.detвҒ»В№ from map_inv _ _,
      Units.val_inv_eq_inv_val]
    exact inv_pos.mpr hОұ
  have h_mp_inv := measurePreserving_glPos_smul ОұвҒ»В№ hОұ_inv
  -- (ОұвҒ»В№ вҖў В·) вҒ»В№' S = Оұ вҖў S.
  have h_eq : ((ОұвҒ»В№ вҖў В·) : в„Қ вҶ’ в„Қ) вҒ»В№' S = Оұ вҖў S := by
    ext П„; simp [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  rw [вҶҗ h_eq]
  exact h_mp_inv.measure_preimage hS

