  have hsum : IntegrableOn (fun П„ => petersson k f (вҲ‘ i вҲҲ s, G i) П„) D Ој_hyp := by
    rw [show (fun П„ => petersson k f (вҲ‘ i вҲҲ s, G i) П„) =
        (fun П„ => вҲ‘ i вҲҲ s, petersson k f (G i) П„) from by
      funext П„; exact petersson_sum_right s f G П„]
    exact MeasureTheory.integrable_finset_sum _ hG
  rw [peterssonInner_add_right k D f g0 (вҲ‘ i вҲҲ s, G i) h0 hsum,
