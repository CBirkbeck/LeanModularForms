/-- **T128 sum-level comparison: symmetric residual aggregate vs.
standard shifted-tile aggregate**.  The two `вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N`
sums coincide via the quotient-reindex consumer
`petN_f_heckeT_p_adjointGamma0Rep_reindex` applied at `(вҹЁuвҹ© f, g)`,
followed by the `вҹЁuвҒ»В№вҹ©вҹЁuвҹ© f = f` collapse via `diamondOpCusp_mul`. -/
private lemma petN_symm_residual_sum_eq_standard_shifted_tiles
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((q.out : SL(2, в„Ө)) *
                  (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                    M_infty_Gamma1_factor N p hpN 0)вҒ»В№)вҒ»В№ :
                GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)) вҲЈ[k]
            (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
          (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
            GL (Fin 2) в„қ)) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
              (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((q.out : SL(2, в„Ө)) *
                    (gamma0_T_p_upper_Gamma1_factor N p hpN b)вҒ»В№)вҒ»В№ :
                  GL (Fin 2) в„қ) вҖў
                (ModularGroup.fd : Set UpperHalfPlane)))
            ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
                GL (Fin 2) в„қ)) вҲЈ[k]
              (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
            (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)))) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((q.out : SL(2, в„Ө)) *
                  (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                    M_infty_Gamma1_factor N p hpN 0)вҒ»В№)вҒ»В№ :
                GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          (вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
          вҮ‘g +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
              (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((q.out : SL(2, в„Ө)) *
                    (gamma0_T_p_upper_Gamma1_factor N p hpN b)вҒ»В№)вҒ»В№ :
                  GL (Fin 2) в„қ) вҖў
                (ModularGroup.fd : Set UpperHalfPlane)))
            (вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
            вҮ‘g) := by
  rw [вҶҗ petN_diamond_heckeT_p_symm_RHS_sum_shifted_tile_residual p hp hpN f g,
      вҶҗ petN_f_heckeT_p_RHS_sum_shifted_tiles p hp hpN f g]
  -- Goal: petN (вҹЁuвҹ© f) (T_p g) = petN f (T_p (вҹЁuвҒ»В№вҹ© g))
  have h := petN_f_heckeT_p_adjointGamma0Rep_reindex p hp hpN
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) g
  -- h: petN (вҹЁuвҹ© f) (T_p g) = petN (вҹЁuвҒ»В№вҹ© (вҹЁuвҹ© f)) (T_p (вҹЁuвҒ»В№вҹ© g))
  -- Collapse `вҹЁuвҒ»В№вҹ© (вҹЁuвҹ© f) = f` via `diamondOpCusp_mul` + `inv_mul_cancel` + `diamondOpCusp_one`.
  rw [show (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) :
      CuspForm ((Gamma1 N).map (mapGL в„қ)) k) = f from by
    show diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f) = f
    rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f) =
        ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№).comp
          (diamondOpCusp k (ZMod.unitOfCoprime p hpN))) f from rfl,
      вҶҗ diamondOpCusp_mul, inv_mul_cancel, diamondOpCusp_one]
    rfl] at h
  exact h

/-- **T128 RHS-side bridge: `petN(вҹЁuвҹ© f, T_p g) = petN(f, T_p(вҹЁuвҒ»В№вҹ© g))`**.
Three aggregate rewrites: expand the LHS via the symmetric residual
shifted-tile aggregate, equate it to the standard shifted-tile sum via
the comparison lemma, then collapse the standard sum back to the
unsymmetric `petN f (T_p (вҹЁuвҒ»В№вҹ© g))` form.  This is the **RHS-side**
half of DS 5.5.3; the LHS-side bridge `petN(T_p f, g) = petN(вҹЁuвҹ© f, T_p g)`
remains the open obligation toward the canonical adjoint residual. -/
private lemma petN_diamond_heckeT_p_eq_canonical_RHS
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
        (heckeT_p_cusp k p hp hpN g) =
      petN f (heckeT_p_cusp k p hp hpN
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) := by
  rw [petN_diamond_heckeT_p_symm_RHS_sum_shifted_tile_residual p hp hpN f g,
      petN_symm_residual_sum_eq_standard_shifted_tiles p hp hpN f g,
      вҶҗ petN_f_heckeT_p_RHS_sum_shifted_tiles p hp hpN f g]

/-- **T128 cusp-level T_p/diamond commutation** (private helper): CuspForm
analog of `heckeT_p_comm_diamondOp` (which is a `LinearMap` equality at the
ModularForm level). Proof: apply `CuspForm.ext`, pull coercions through
`toModularForm'`, invoke `heckeT_p_comm_diamondOp` via `LinearMap.congr_fun`. -/
private lemma heckeT_p_cusp_comm_diamondOp_private
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (d : (ZMod N)ЛЈ)
    (g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    heckeT_p_cusp k p hp hpN (diamondOp_cusp k d g) =
      diamondOp_cusp k d (heckeT_p_cusp k p hp hpN g) := by
  apply CuspForm.ext; intro П„
  show ((heckeT_p k p hp hpN) (diamondOp k d g.toModularForm')).toFun П„ =
    ((diamondOp k d) (heckeT_p k p hp hpN g.toModularForm')).toFun П„
  have h := LinearMap.congr_fun
    (heckeT_p_comm_diamondOp (N := N) k p hp hpN d) g.toModularForm'
  simp only [LinearMap.comp_apply] at h
  exact congr_arg (fun m : ModularForm ((Gamma1 N).map (mapGL в„қ)) k => m.toFun П„)
    h.symm

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 LHS-side sum-level distribute**: lifts `peterssonInner_heckeT_p_LHS_per_q_distribute`
to the `вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N` aggregate, applied at `q.out`.

This is the LHS analog of `petN_diamond_heckeT_p_symm_RHS_sum_distributed`:
the `T_p` slash on slot-1 of `petN(T_p f, g)` is distributed via
`heckeT_p_fun_eq_coset_sum` into M_вҲһ + `вҲ‘_b T_p_upper(b)` summands, with
slot-2 left as plain `вҮ‘g вҲЈ q.outвҒ»В№`. -/
private lemma petN_T_p_heckeT_p_LHS_sum_distributed
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№)) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k ModularGroup.fd
            (вҮ‘f вҲЈ[k] ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
            (вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))) := by
  show вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
        (вҮ‘(heckeT_p_cusp k p hp hpN f) вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k]
          ((q.out : SL(2, в„Ө))вҒ»В№)) = _
  refine Finset.sum_congr rfl fun q _ => ?_
  rw [peterssonInner_SL_inv_eq_mapGL_inv]
  exact peterssonInner_heckeT_p_LHS_per_q_distribute p hp hpN
    (q.out : SL(2, в„Ө)) f g

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T024 LHS-side diamond-exposed sum-level distribute**: composes
`petN_heckeT_p_adjointGamma0Rep_reindex` (LHS Q-reindex
`petN(T_p f, g) = petN(T_p (вҹЁuвҒ»В№вҹ© f), вҹЁuвҒ»В№вҹ© g)`) with
`petN_T_p_heckeT_p_LHS_sum_distributed` instantiated at `(вҹЁuвҒ»В№вҹ© f, вҹЁuвҒ»В№вҹ© g)`,
then per-q applies `slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` to the
M_вҲһ summand-1 slash (with `f` as the inner cusp form),
`slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per `b` to the upper-b
summand-1 slashes, and the diamond expansion `вҮ‘(вҹЁuвҒ»В№вҹ© g) = вҮ‘g вҲЈ mapGL ОівӮҖ`
on the slot-2 slash via `slash_mul`.

Result: `petN(T_p f, g) = вҲ‘_q [diamond-exposed shifted-tile residual at q.out]`
with f-slot in `вҮ‘f вҲЈ (T_p_lower * mapGL Оі_X * mapGL qвҒ»В№)` form (Оі_X is the
ds_p_plus_one О“вӮҒ(N) factor for branch X) and g-slot in
`вҮ‘g вҲЈ (mapGL ОівӮҖ * mapGL qвҒ»В№)` form.

**Role in T024 closure.**  This is the LHS-side mirror of
`petN_diamond_heckeT_p_symm_RHS_sum_distributed` (RHS analog at line 4516).
Together with a sum-level Пғ_p / ОівӮҖ-coset Q-reindex bridging this to the
existing RHS-side distributed sum, it yields the LHS double-coset bridge
`petN(T_p f, g) = petN(вҹЁuвҹ© f, T_p g)` consumable by
`petN_heckeT_p_adjoint_standard_form_of_LHS_bridge`. -/
private lemma petN_T_p_heckeT_p_LHS_sum_diamond_distributed
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                  M_infty_Gamma1_factor N p hpN 0)) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
          (вҮ‘g вҲЈ[k]
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k ModularGroup.fd
            (вҮ‘f вҲЈ[k]
              ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
            (вҮ‘g вҲЈ[k]
              (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))) := by
  -- Q-reindex first: `petN(T_p f, g) = petN(T_p(вҹЁuвҒ»В№вҹ© f), вҹЁuвҒ»В№вҹ© g)`.
  rw [petN_heckeT_p_adjointGamma0Rep_reindex p hp hpN f g]
  -- Sum-level distribute on the reindexed form.
  rw [petN_T_p_heckeT_p_LHS_sum_distributed p hp hpN
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ f)
    (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)]
  -- Per-q: rewrite each branch via the diamond/T_p_lower factorization
  -- helpers (`slash_diamond_inv_M_infty_eq_T_p_lower_epsilon` for the M_вҲһ
  -- branch slot-1, `slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per b
  -- for the upper-family summands), and expose `вҮ‘(вҹЁuвҒ»В№вҹ© g) вҲЈ mapGL qвҒ»В№` as
  -- `вҮ‘g вҲЈ mapGL ОівӮҖ * mapGL qвҒ»В№` via `diamondOpCusp_eq` + `slash_mul`.
  refine Finset.sum_congr rfl fun q _ => ?_
  -- Diamond expansion of slot-2 g side: `вҮ‘(вҹЁuвҒ»В№вҹ© g) = вҮ‘g вҲЈ mapGL ОівӮҖ`.
  have h_diamond_g : (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
      UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘g вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) := by
    show вҮ‘(diamondOpCusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) = _
    rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)вҒ»В№
      (adjointGamma0Rep p N hpN) (adjointGamma0Rep_units p N hpN)]
    rfl
  congr 1
  В· -- M_вҲһ branch.  Slot 1 via `slash_diamond_inv_M_infty_eq_T_p_lower_epsilon`
    -- applied to `f`.  Slot 2 via `h_diamond_g` + `slash_mul`.
    rw [slash_diamond_inv_M_infty_eq_T_p_lower_epsilon p hp hpN
      (q.out : SL(2, в„Ө)) f]
    rw [show (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№)) =
      вҮ‘g вҲЈ[k]
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)) from by
      rw [h_diamond_g, вҶҗ SlashAction.slash_mul]]
  В· -- Upper branches `вҲ‘_b`.  Slot 1 via
    -- `slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` per b, slot 2 same as
    -- M_вҲһ branch.
    refine Finset.sum_congr rfl fun b _ => ?_
    rw [slash_diamond_inv_T_p_upper_eq_T_p_lower_delta p hp hpN b
      (q.out : SL(2, в„Ө)) f]
    rw [show (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) вҲЈ[k]
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
          (q.out : SL(2, в„Ө))вҒ»В№)) =
      вҮ‘g вҲЈ[k]
        (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
