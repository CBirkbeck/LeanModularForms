      ((Finset.range p : Finset тДХ) : Set тДХ).Pairwise (fun bтВБ bтВВ =>
        AEDisjoint ╬╝_hyp
          (((glMap (T_p_upper p hp.pos bтВБ) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
