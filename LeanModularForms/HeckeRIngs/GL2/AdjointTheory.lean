open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: `M_infty_Gamma1_factor` is non-trivial in `PSL(2, тДд)` for `p` prime.**

If `╬│ = M_infty_Gamma1_factor` were central in `SL(2, тДд)`, commutation with the
rotation `S = !![0, -1; 1, 0]` would force both `╬│ 0 0 = ╬│ 1 1` and `╬│ 0 1 =
-╬│ 1 0`.  Using `╬│ 1 1 = 1` and `╬│ 0 0 = ap тИТ bNm`, we'd get `ap тИТ bNm = 1`.
Separately, `╬│ 0 1 = 1 тИТ b = -Nm`.  Combined with the Bezout `ap тИТ Nm = 1`,
this leaves a contradiction whenever `p тЙе 2` (i.e., `p` prime). -/
theorem M_infty_Gamma1_factor_psl_ne_one
    (N p : тДХ) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : тДХ) :
    (QuotientGroup.mk (M_infty_Gamma1_factor N p hpN b) : PSL(2, тДд)) тЙа 1 := by
  -- Commutation with `S = !![0, -1; 1, 0]` + entry (1,0) gives `ap - bNm = 1`.
  -- Combined with Bezout `ap - Nm = 1`, we get `(b-1)┬╖Nm = 0`.  Via
  -- entry (0,1) giving `1 - b = -Nm`, both cases collapse to `Nm = 0` and
  -- `ap = 1`, which contradicts `p` prime тЙе 2.
  intro heq
  rw [QuotientGroup.eq_one_iff] at heq
  have hS : (!![(0 : тДд), -1; 1, 0] : Matrix (Fin 2) (Fin 2) тДд).det = 1 := by
    simp [Matrix.det_fin_two]
  set S_mat : SL(2, тДд) := тЯи!![0, -1; 1, 0], hSтЯй
  have hcomm : M_infty_Gamma1_factor N p hpN b * S_mat =
      S_mat * M_infty_Gamma1_factor N p hpN b := heq.comm S_mat
  have hcomm_val : (M_infty_Gamma1_factor N p hpN b : SL(2, тДд)).val * S_mat.val =
      S_mat.val * (M_infty_Gamma1_factor N p hpN b : SL(2, тДд)).val :=
    congr_arg Subtype.val hcomm
  -- Entry (1,0) of commutation: ╬│ 1 1 = ╬│ 0 0, i.e., 1 = ap - bNm.
  have h_10 := congr_fun (congr_fun hcomm_val 1) 0
  simp only [S_mat, M_infty_Gamma1_factor, Matrix.mul_apply, Fin.sum_univ_two,
    Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
    Matrix.head_cons, Matrix.head_fin_const] at h_10
  -- Entry (0,0) of commutation: ╬│ 0 1 = -╬│ 1 0, i.e., 1 - b = -Nm.
  have h_00 := congr_fun (congr_fun hcomm_val 0) 0
  simp only [S_mat, M_infty_Gamma1_factor, Matrix.mul_apply, Fin.sum_univ_two,
    Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
    Matrix.head_cons, Matrix.head_fin_const] at h_00
  -- h_10: `ap - bNm = 1`; Bezout `ap - Nm = 1`.  Subtract: `(1-b) Nm = 0`.
  -- h_00: `1 - b = -Nm`.
  have h_bezout := N_mul_mIdx_eq N p hpN
  -- From h_10, h_bezout: `ap - bNm - (ap - Nm) = 0`, i.e., `(1-b) * Nm = 0`.
  -- From h_00: `(1 - b) = -Nm`.  Substitute: `(-Nm) * Nm = 0`, so `Nm^2 = 0`, `Nm = 0`.
  have h_Nm_zero : (N : тДд) * mIdxOfCoprime N p hpN = 0 := by
    have h_sub : (1 - (b : тДд)) * ((N : тДд) * mIdxOfCoprime N p hpN) = 0 := by
      linarith
    have h_subst : -((N : тДд) * mIdxOfCoprime N p hpN) *
        ((N : тДд) * mIdxOfCoprime N p hpN) = 0 := by
      have : (1 - (b : тДд)) = -((N : тДд) * mIdxOfCoprime N p hpN) := by linarith
      rw [this] at h_sub; exact h_sub
    have h_sq : ((N : тДд) * mIdxOfCoprime N p hpN)^2 = 0 := by
      have := h_subst; nlinarith
    exact pow_eq_zero_iff (by norm_num : (2 : тДХ) тЙа 0) |>.mp h_sq
  -- Then ap = 1 from Bezout.
  have h_ap : (aInvOfCoprime N p hpN : тДд) * p = 1 := by linarith
  -- ap = 1 with p prime тЙе 2: impossible.
  have hp_div : (p : тДд) тИг 1 := тЯиaInvOfCoprime N p hpN, by linarithтЯй
  have hp_ge : (p : тДд) тЙе 2 := by exact_mod_cast hp.two_le
  have hp_unit := Int.isUnit_iff.mp (isUnit_of_dvd_one hp_div)
  rcases hp_unit with h | h <;> omega

