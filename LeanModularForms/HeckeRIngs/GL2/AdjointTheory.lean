    {╬╣ : Type*} [DecidableEq ╬╣] (s : Finset ╬╣)
    (╬▒ : ╬╣ тЖТ GL (Fin 2) тДЭ) (h╬▒ : тИА i тИИ s, 0 < (╬▒ i).det.val)
