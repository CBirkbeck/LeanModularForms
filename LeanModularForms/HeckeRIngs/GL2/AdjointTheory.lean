            ((Gamma1 N).map SL2Z_to_PSL2R)),
    ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣ тАв
      (Gamma1_fundDomain_PSL N : Set тДН)

open CongruenceSubgroup Pointwise UpperHalfPlane MeasureTheory in
/-- **Phase H тАФ Phase G shifted FD set as `╬▒' тАв ╬У_p(╬▒)-FD` (generic).**

Set-level identity packaging the explicit shifted-union shape from
`Gamma_p_╬▒_PSL_R_FD_finite_index_decomp_shifted` as the `╬▒'`-shift of
`Gamma_p_╬▒_fundDomain_PSL N ╬▒`.  Direct application of `Set.smul_set_iUnion`
and `mul_smul`. -/
theorem Gamma_p_╬▒_PSL_R_FD_finite_index_decomp_shifted_eq_smul
    (╬▒ : GL (Fin 2) тДЪ) (╬▒' : GL(2, тДЭ)тБ║) :
    (тЛГ q : ((Gamma1 N).map SL2Z_to_PSL2R) тз╕
            (((Gamma_p_╬▒ (N := N) ╬▒).map SL2Z_to_PSL2R).subgroupOf
              ((Gamma1 N).map SL2Z_to_PSL2R)),
      (GLPos_to_PSL_R_term ╬▒' *
        ((q.out : ((Gamma1 N).map SL2Z_to_PSL2R)) : PSL(2, тДЭ))тБ╗┬╣) тАв
          (Gamma1_fundDomain_PSL N : Set тДН)) =
    GLPos_to_PSL_R_term ╬▒' тАв Gamma_p_╬▒_fundDomain_PSL (N := N) ╬▒ := by
  unfold Gamma_p_╬▒_fundDomain_PSL
  rw [Set.smul_set_iUnion]
