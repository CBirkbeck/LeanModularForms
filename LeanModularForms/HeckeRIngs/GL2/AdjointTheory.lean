open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d M_вҲһ RHS-absorbed per-q tile-form**: rewrites the per-q M_вҲһ-branch
RHS-absorbed summand of `SigmaQPermResidual_M_infty` (with `(Пғq)вҒ»В№` on the g-slot
T_p_lower factor) into a tile-shifted form via:
1. g-slot reverse master identity: `вҹЁuвҹ©g вҲЈ T_p_lower В· Оі В· (Пғq)вҒ»В№ = g вҲЈ M_вҲһ В· (Пғq)вҒ»В№`
   (this is `slash_M_infty_eq_diamond_slash_T_p_lower_factor.symm` applied at g, (Пғq)).
2. right-slash-adjoint at `Оұ = M_вҲһ` on slot-2, using
   `slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_upper_zero_slash_gamma0` to
   convert `f вҲЈ peterssonAdj M_вҲһ` to `(f вҲЈ T_p_upper(0)) вҲЈ mapGL ОівӮҖ`. -/
private lemma peterssonInner_RHS_M_infty_per_q_to_tile_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g) вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    peterssonInner k ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ) вҖў (ModularGroup.fd : Set UpperHalfPlane)))
      ((вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))))
      (вҮ‘g) := by
  -- Step 1: reverse master identity on g-slot.
  rw [вҶҗ slash_M_infty_eq_diamond_slash_T_p_lower_factor p hp hpN g q]
  -- Step 2: apply right-slash-adjoint via the slash-adjoint-coset analog.
  -- Use right version: pet fd (F вҲЈ qвҒ»В№) (G вҲЈ (ОІ * qвҒ»В№)) =
  --     pet (ОІ вҖў qвҒ»В№ вҖў fd) ((F вҲЈ qвҒ»В№) вҲЈ peterssonAdj(ОІ * qвҒ»В№)) G
  -- Then simplify via slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_upper_zero_slash_gamma0.
  have hОІ : 0 < ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)).det.val := by
    show 0 < ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) :
      GL (Fin 2) в„қ).val.det
    rw [Units.val_mul, Matrix.det_mul]
    have h2 : ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
      rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
          Matrix (Fin 2) (Fin 2) в„қ) =
          ((Int.castRingHom в„қ).mapMatrix (qвҒ»В№).val) from by
        rw [mapGL_coe_matrix]; rfl]
      rw [вҶҗ RingHom.map_det, (qвҒ»В№).property]; simp
    rw [h2, mul_one]
    exact glMap_M_infty_det_pos N p hp.pos hpN
  have hslash := peterssonInner_slash_adjoint_right (k := k)
    (D := (fd : Set в„Қ))
    (Оұ := (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
    hОІ
    ((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
    (вҮ‘g)
  -- hslash : pet fd (f вҲЈ qвҒ»В№) (g вҲЈ (M_вҲһ * qвҒ»В№)) =
  --   pet ((M_вҲһ * qвҒ»В№) вҖў fd) ((f вҲЈ qвҒ»В№) вҲЈ peterssonAdj(M_вҲһ * qвҒ»В№)) g
  rw [hslash]
  -- Simplify domain: (M_вҲһ * qвҒ»В№) вҖў fd = M_вҲһ вҖў qвҒ»В№ вҖў fd.
  rw [show ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
        (fd : Set в„Қ) =
      (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) вҖў fd from
    mul_smul _ _ _]
  -- Simplify slot-1: peterssonAdj(M_вҲһ * qвҒ»В№) = q * peterssonAdj M_вҲһ.
  rw [peterssonAdj_mul, peterssonAdj_mapGL_SL_eq_inv,
    show (mapGL в„қ qвҒ»В№)вҒ»В№ = (mapGL в„қ q : GL (Fin 2) в„қ) from by
      rw [вҶҗ map_inv, inv_inv]]
  -- slot-1: (f вҲЈ qвҒ»В№) вҲЈ (q * peterssonAdj M_вҲһ) = (f вҲЈ (qвҒ»В№ * q)) вҲЈ peterssonAdj M_вҲһ = f вҲЈ peterssonAdj M_вҲһ.
  rw [show ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
        GL (Fin 2) в„қ)) вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) q *
        peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ))) =
      вҮ‘f вҲЈ[k] peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) from by
    rw [вҶҗ SlashAction.slash_mul, вҶҗ mul_assoc,
      show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) q) = 1 from by
        rw [вҶҗ map_mul, inv_mul_cancel, map_one], one_mul]]
  -- f вҲЈ peterssonAdj M_вҲһ = (f вҲЈ T_p_upper(0)) вҲЈ mapGL ОівӮҖ.
  rw [slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_upper_zero_slash_gamma0 p hp hpN f]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d upper-`b` RHS-absorbed per-q tile-form**: upper-`b` analog of
`peterssonInner_RHS_M_infty_per_q_to_tile_form`. -/
private lemma peterssonInner_RHS_upper_per_q_to_tile_form
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•)
    (q : SL(2, в„Ө)) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    peterssonInner k ModularGroup.fd
        (вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
        (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g) вҲЈ[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))) =
    peterssonInner k ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ qвҒ»В№ : GL (Fin 2) в„қ) вҖў (ModularGroup.fd : Set UpperHalfPlane)))
      ((вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))))
      (вҮ‘g) := by
  -- Step 1: reverse master identity on g-slot.
  rw [вҶҗ slash_T_p_upper_eq_diamond_slash_T_p_lower_factor p hp hpN b g q]
  -- Step 2: prepare det positivity for T_p_upper(b) * qвҒ»В№.
  have hОІ : 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)).det.val := by
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) :
      GL (Fin 2) в„қ).val.det
    rw [Units.val_mul, Matrix.det_mul]
    have h2 : ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
        Matrix (Fin 2) (Fin 2) в„қ).det = 1 := by
      rw [show ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
          Matrix (Fin 2) (Fin 2) в„қ) =
          ((Int.castRingHom в„қ).mapMatrix (qвҒ»В№).val) from by
        rw [mapGL_coe_matrix]; rfl]
      rw [вҶҗ RingHom.map_det, (qвҒ»В№).property]; simp
    rw [h2, mul_one]
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  -- Step 3: apply right-slash-adjoint.
  have hslash := peterssonInner_slash_adjoint_right (k := k)
    (D := (fd : Set в„Қ))
    (Оұ := (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
    hОІ
    ((вҮ‘f : в„Қ вҶ’ в„Ӯ) вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ))
    (вҮ‘g)
  rw [hslash]
  -- Step 4: Simplify domain.
  rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ)) вҖў
        (fd : Set в„Қ) =
      (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ : GL (Fin 2) в„қ) вҖў fd from
    mul_smul _ _ _]
  -- Step 5: Simplify slot-1: peterssonAdj(T_p_upper(b) * qвҒ»В№) = q * peterssonAdj T_p_upper(b).
  rw [peterssonAdj_mul, peterssonAdj_mapGL_SL_eq_inv,
    show (mapGL в„қ qвҒ»В№)вҒ»В№ = (mapGL в„қ q : GL (Fin 2) в„қ) from by
      rw [вҶҗ map_inv, inv_inv]]
  -- slot-1: (f вҲЈ qвҒ»В№) вҲЈ (q * peterssonAdj T_p_upper(b)) = f вҲЈ peterssonAdj T_p_upper(b).
  rw [show ((вҮ‘f вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) qвҒ»В№ :
        GL (Fin 2) в„қ)) вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) q *
        peterssonAdj (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ))) =
