          GL (Fin 2) тДЭ) from (map_inv _ _).symm,
      show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q * (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
              M_infty_Gamma1_factor N p hpN 0)тБ╗┬╣)тБ╗┬╣ : GL (Fin 2) тДЭ)) =
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
