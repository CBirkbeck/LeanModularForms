            M_infty_Gamma1_factor N p hpN 0)) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
    тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) := by
  have h := slash_M_infty_eq_diamond_slash_T_p_lower_factor p hp hpN
