              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k ModularGroup.fd
            ((F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
                GL (Fin 2) в„қ)) вҲЈ[k]
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№))
            (вҮ‘g вҲЈ[k]
              ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ))) := by
  congr 1
  В· exact peterssonInner_per_tile_match_M_infty_branch_closed p hp hpN q g F
      (h_tile_eq 0)
  В· -- вҲ‘ b : Fin p, ... = вҲ‘ b вҲҲ range p, ...
    rw [show (вҲ‘ b : Fin p, peterssonInner k (tile b.succ) F
            (вҮ‘g вҲЈ[k]
              ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
                ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө)) :
                  GL (Fin 2) в„қ)))) =
        вҲ‘ b : Fin p, peterssonInner k ModularGroup.fd
          ((F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
              GL (Fin 2) в„қ)) вҲЈ[k]
            ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
              (q.out : SL(2, в„Ө))вҒ»В№))
          (вҮ‘g вҲЈ[k]
            ((glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                (q.out : SL(2, в„Ө))вҒ»В№ : GL (Fin 2) в„қ)))
      from Finset.sum_congr rfl fun b _ =>
        peterssonInner_per_tile_match_T_p_upper_branch_closed p hp hpN b.val q g F
          (h_tile_eq b.succ)]
    exact Fin.sum_univ_eq_sum_range
      (fun n : в„• => peterssonInner k ModularGroup.fd
        ((F вҲЈ[k] ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, в„Ө))вҒ»В№) :
            GL (Fin 2) в„қ)) вҲЈ[k]
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
            (q.out : SL(2, в„Ө))вҒ»В№))
        (вҮ‘g вҲЈ[k]
