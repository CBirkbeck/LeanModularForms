    (вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      peterssonInner k ModularGroup.fd
          (вҮ‘f вҲЈ[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) *
              ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
