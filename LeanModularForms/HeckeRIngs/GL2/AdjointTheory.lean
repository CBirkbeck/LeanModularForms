/-- **T094: AE-disjoint for `T_p_upper(b)` vs `M_тИЮ` (p prime).** -/
theorem aedisjoint_glMap_M_infty_T_p_upper
    {N : тДХ} [NeZero N] {p : тДХ} (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : тДХ) :
    AEDisjoint ╬╝_hyp
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) тАв
        (Gamma1_fundDomain_PSL N : Set тДН))
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) тАв
        (Gamma1_fundDomain_PSL N : Set тДН)) := by
  have h_det_pos : 0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ).det.val := by
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
      (algebraMap тДЪ тДЭ) (((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).det) from
        (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp.pos
  have h_inv_det_pos : 0 <
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ)тБ╗┬╣).det.val := by
    show 0 < ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ)тБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ)тБ╗┬╣).det : тДЭ╦г) =
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ).det : тДЭ╦г)тБ╗┬╣ from
      map_inv _ _]
    show 0 < (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ).det : тДЭ╦г))тБ╗┬╣.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h_det_pos
  exact aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    (glMap (T_p_upper p hp.pos b)) (glMap (M_infty N p hp.pos hpN))
    (measurePreserving_glPos_smul _ h_inv_det_pos)
    (M_infty_Gamma1_factor N p hpN b)
    (M_infty_Gamma1_factor_mem_Gamma1 N p hpN b)
    (M_infty_Gamma1_factor_psl_ne_one N p hp hpN b)
    (glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp.pos hpN b)

