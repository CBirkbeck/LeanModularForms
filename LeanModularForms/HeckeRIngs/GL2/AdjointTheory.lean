theorem aedisjoint_PSL_coset_tiles_Gamma_p_Оұ (Оұ : GL (Fin 2) в„ҡ) :
    Pairwise (fun qвӮҒ qвӮӮ : PSL(2, в„Ө) в§ё image_Gamma_p_Оұ_PSL (N := N) Оұ =>
      MeasureTheory.AEDisjoint Ој_hyp
        ((qвӮҒ.out : PSL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ))
        ((qвӮӮ.out : PSL(2, в„Ө))вҒ»В№ вҖў (fdo : Set в„Қ))) := by
