/-- **T094: AE-disjoint for `T_p_upper(b)` vs `M_вҲһ` (p prime).** -/
theorem aedisjoint_glMap_M_infty_T_p_upper
    {N : в„•} [NeZero N] {p : в„•} (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•) :
    AEDisjoint Ој_hyp
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) вҖў
        (Gamma1_fundDomain_PSL N : Set в„Қ))
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ) вҖў
        (Gamma1_fundDomain_PSL N : Set в„Қ)) := by
  have h_det_pos : 0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det.val := by
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
      (algebraMap в„ҡ в„қ) (((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det) from
        (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  have h_inv_det_pos : 0 <
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ)вҒ»В№).det.val := by
    show 0 < ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ)вҒ»В№).det : в„қЛЈ) : в„қ)
    rw [show (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ)вҒ»В№).det : в„қЛЈ) =
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det : в„қЛЈ)вҒ»В№ from
      map_inv _ _]
    show 0 < (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ).det : в„қЛЈ))вҒ»В№.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h_det_pos
  exact aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    (glMap (T_p_upper p hp.pos b)) (glMap (M_infty N p hp.pos hpN))
    (measurePreserving_glPos_smul _ h_inv_det_pos)
    (M_infty_Gamma1_factor N p hpN b)
    (M_infty_Gamma1_factor_mem_Gamma1 N p hpN b)
    (M_infty_Gamma1_factor_psl_ne_one N p hp hpN b)
    (glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp.pos hpN b)

