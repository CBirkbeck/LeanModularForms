        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) в„қ) *
          ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
            GL (Fin 2) в„қ)) вҖў (ModularGroup.fd : Set в„Қ))
