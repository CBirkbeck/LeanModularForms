    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp.pos
  have h_gamma_M_det_one : (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
        M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = 1 := by
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
          M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix
          (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
