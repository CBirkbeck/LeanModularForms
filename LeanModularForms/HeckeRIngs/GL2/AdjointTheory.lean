to discharge `h_M_infty_tile_shift_to_prefactored`. -/
private theorem M_infty_slot_swap_LHS_via_slash_adjoint_coset
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (F G : UpperHalfPlane тЖТ тДВ) :
    (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
          (F тИг[k] ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
          (G тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) тАв
          (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ) тАв
            (ModularGroup.fd : Set UpperHalfPlane)))
        F
        (G тИг[k] peterssonAdj (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)) := by
  refine Finset.sum_congr rfl fun q _ => ?_
  exact peterssonInner_slash_adjoint_coset
    (glMap (M_infty N p hp.pos hpN))
    (glMap_M_infty_det_pos N p hp.pos hpN) (q.out : SL(2, тДд)) F G

