`slash_diamond_inv_T_p_upper_eq_T_p_lower_delta` (upper branches).

Rewrites the per-q summand
`peterssonInner fd (тЗСf тИг mapGL qтБ╗┬╣) (тЗС(heckeT_p_cusp (тЯиuтБ╗┬╣тЯйg)) тИг mapGL qтБ╗┬╣)`
into the normalized split form where each p+1 branch has its slot-2 in
`тЗСg тИг[k] (glMap T_p_lower * mapGL ╬┤_i * mapGL qтБ╗┬╣)` form with explicit
╬УтВБ(N)-correction factor `╬┤_i`. -/
private lemma peterssonInner_heckeT_p_RHS_per_q_normalized
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗС(heckeT_p_cusp k p hp hpN
            (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                M_infty_Gamma1_factor N p hpN 0)) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) +
      тИС b тИИ Finset.range p,
        peterssonInner k ModularGroup.fd
          (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
          (тЗСg тИг[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (gamma0_T_p_upper_Gamma1_factor N p hpN b)) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ :
                GL (Fin 2) тДЭ))) := by
  rw [peterssonInner_heckeT_p_RHS_per_q_distribute p hp hpN q f g]
  congr 1
  ┬╖ rw [slash_diamond_inv_M_infty_eq_T_p_lower_epsilon p hp hpN q g]
  ┬╖ refine Finset.sum_congr rfl fun b _ => ?_
    rw [slash_diamond_inv_T_p_upper_eq_T_p_lower_delta p hp hpN b q g]

