open UpperHalfPlane ModularGroup MeasureTheory ConjAct Pointwise in
/-- **T205 integrability helper (mixed SL/GL slash bridge).**
For `╬УтВБ(N)` cusp forms `f, g`, a rational matrix `╬▒ : GL (Fin 2) тДЪ`, and an
`SL(2, тДд)` element `╬┤`, the petersson integrand
`petersson k (тЗСf тИг[k] ╬┤) ((тЗСg тИг[k] ╬▒) тИг[k] ╬┤)` is integrable on the
`SL(2, тДд)`-fundamental domain `fd`.

**Proof.** After rewriting via `petersson_slash_SL k _ _ ╬┤` (since `╬┤` is SL,
the outer slash pulls out as a change of variables `╬┤ тАв ╧Д`), the integrand
equals `petersson k тЗСf (тЗСg тИг[k] ╬▒) (╬┤ тАв ╧Д)`. The inner `тЗСg тИг[k] ╬▒` is the
coercion of the translated cusp form `CuspForm.translate g ╬▒` of the
arithmetic conjugate subgroup `toConjAct ╬▒тБ╗┬╣ тАв ╬УтВБ(N)` (arithmeticity via
`Subgroup.IsArithmetic.conj`). Applying `CuspFormClass.petersson_bounded_left`
separately to `f` with itself and to the translated `g` with itself yields
global bounds `тАЦpetersson k f f ╧ДтАЦ тЙд C_f` and `тАЦpetersson k (g тИг ╬▒) (g тИг ╬▒)
╧ДтАЦ тЙд C_g`. AM-GM (`2|ab| тЙд a┬▓ + b┬▓`) combines these into a global bound
`тАЦpetersson k f (g тИг ╬▒) ╧ДтАЦ тЙд (C_f + C_g) / 2`, invariant under the `╬┤ тАв ╧Д`
shift. Combined with `hyperbolicMeasure_fd_lt_top`, `IntegrableOn.of_bound`
closes.

**Role in T205.** This is the single theorem-local bridge consumed to
discharge the four inline integrability witnesses in
`petN_heckeT_p_diamond_shift_core`, which land in the mixed-slash shape
`petersson k (cuspform тИг SL) (cuspform тИг GL тДЪ тИг SL)` that does not
match the existing T094 `integrableOn_petersson_slash` /
`integrableOn_petersson_glMap_smul_Gamma1_fundDomain` shapes. -/
theorem integrableOn_petersson_cuspform_mixed_slash_on_fd
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (╬▒ : GL (Fin 2) тДЪ) (╬┤ : SL(2, тДд)) :
    IntegrableOn (fun ╧Д => UpperHalfPlane.petersson k (тЗСf тИг[k] ╬┤)
        ((тЗСg тИг[k] ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ)) тИг[k] ╬┤) ╧Д)
      (ModularGroup.fd : Set UpperHalfPlane) ╬╝_hyp := by
  -- Step 1: Rewrite integrand using `petersson_slash_SL` (SL slash pulls out).
  rw [show (fun ╧Д => UpperHalfPlane.petersson k (тЗСf тИг[k] ╬┤)
        ((тЗСg тИг[k] ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ)) тИг[k] ╬┤) ╧Д) =
      (fun ╧Д => UpperHalfPlane.petersson k тЗСf
        (тЗСg тИг[k] ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ)) (╬┤ тАв ╧Д)) from
      funext fun ╧Д => petersson_slash_SL k _ _ ╬┤ ╧Д]
  -- Step 2: Arithmeticity of the conjugate subgroup.
  haveI hArith :
      ((toConjAct ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣) тАв
        ((Gamma1 N).map (mapGL тДЭ))).IsArithmetic := by
    have h := Subgroup.IsArithmetic.conj ((Gamma1 N).map (mapGL тДЭ)) ╬▒тБ╗┬╣
    have h_inv : ((╬▒тБ╗┬╣ : GL (Fin 2) тДЪ).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) =
        ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣ := map_inv _ _
    rwa [h_inv] at h
  -- Step 3: The translated cusp form.
  let g_tr : CuspForm
      ((toConjAct ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣) тАв
        ((Gamma1 N).map (mapGL тДЭ))) k :=
    CuspForm.translate g ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ)
  have h_gtr_coe : (тЗСg_tr : UpperHalfPlane тЖТ тДВ) =
      тЗСg тИг[k] ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ) := rfl
  -- Step 4: Global bounds via `petersson_bounded_left` on each form with itself.
  obtain тЯиC_f, hC_fтЯй := CuspFormClass.petersson_bounded_left k
    ((Gamma1 N).map (mapGL тДЭ)) f f
  obtain тЯиC_g, hC_gтЯй := CuspFormClass.petersson_bounded_left k _ g_tr g_tr
  -- Step 5: AM-GM combines the two bounds globally.
  have h_AM_GM : тИА ╧Д,
      тАЦUpperHalfPlane.petersson k тЗСf
          (тЗСg тИг[k] ((╬▒.map (Rat.castHom тДЭ)) : GL (Fin 2) тДЭ)) ╧ДтАЦ тЙд
        (C_f + C_g) / 2 := by
    intro ╧Д
    rw [тЖР h_gtr_coe]
    -- AM-GM at the integrand level: тАЦpetersson k f g_tr ╧ДтАЦ тЙд
    -- (тАЦpetersson k f f ╧ДтАЦ + тАЦpetersson k g_tr g_tr ╧ДтАЦ) / 2.
    have h_norm_ineq : тАЦUpperHalfPlane.petersson k тЗСf тЗСg_tr ╧ДтАЦ тЙд
        (тАЦUpperHalfPlane.petersson k тЗСf тЗСf ╧ДтАЦ +
         тАЦUpperHalfPlane.petersson k тЗСg_tr тЗСg_tr ╧ДтАЦ) / 2 := by
      -- Expand all three `petersson` expressions as norm products.
      simp only [UpperHalfPlane.petersson, norm_mul, Complex.norm_conj]
      -- Goal now: тАЦf ╧ДтАЦ * тАЦg_tr ╧ДтАЦ * c тЙд (тАЦf ╧ДтАЦ * тАЦf ╧ДтАЦ * c + тАЦg_tr ╧ДтАЦ * тАЦg_tr ╧ДтАЦ * c) / 2
      -- where c is some complex norm тЙе 0.  Use AM-GM `(a - b)┬▓ ┬╖ c тЙе 0`.
      have h_im_nn : (0 : тДЭ) тЙд тАЦ((╧Д.im : тДВ) ^ k)тАЦ := norm_nonneg _
      nlinarith [mul_nonneg (sq_nonneg (тАЦ(тЗСf) ╧ДтАЦ - тАЦ(тЗСg_tr) ╧ДтАЦ)) h_im_nn,
        sq_nonneg (тАЦ(тЗСf) ╧ДтАЦ - тАЦ(тЗСg_tr) ╧ДтАЦ), norm_nonneg (тЗСf ╧Д),
        norm_nonneg (тЗСg_tr ╧Д), h_im_nn]
    linarith [hC_f ╧Д, hC_g ╧Д]
  -- Step 6: Apply `IntegrableOn.of_bound` with the composed bound.
  refine IntegrableOn.of_bound hyperbolicMeasure_fd_lt_top ?_ ((C_f + C_g) / 2) ?_
  ┬╖ -- AEStronglyMeasurable: the composed function is continuous.
    refine ((petersson_continuous k (ModularFormClass.continuous f)
      ?_).comp (continuous_const_smul ╬┤)).aestronglyMeasurable.restrict
    rw [тЖР h_gtr_coe]
    exact ModularFormClass.continuous g_tr
  ┬╖ exact ae_of_all _ fun ╧Д => h_AM_GM (╬┤ тАв ╧Д)

