  setIntegral_Gamma1_fundDomain_PSL_eq_SL_outer_q_sum
    (petersson k тЗСf тЗСg)
    (fun ╬│ h╬│ ╧Д => petersson_Gamma1_invariant f g ╬│ h╬│ ╧Д)
