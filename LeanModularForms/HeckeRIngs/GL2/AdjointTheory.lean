    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN f (heckeT_p_cusp k p hp hpN
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) =
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma1 N,
      (peterssonInner k
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
            (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                ((q.out : SL(2, в„Ө)) *
                  (gamma0_T_p_upper_Gamma1_factor N p hpN 0 *
                    M_infty_Gamma1_factor N p hpN 0)вҒ»В№)вҒ»В№ :
                GL (Fin 2) в„қ) вҖў
              (ModularGroup.fd : Set UpperHalfPlane)))
          (вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
          вҮ‘g +
        вҲ‘ b вҲҲ Finset.range p,
          peterssonInner k
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) вҖў
              (((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ)
                  ((q.out : SL(2, в„Ө)) *
                    (gamma0_T_p_upper_Gamma1_factor N p hpN b)вҒ»В№)вҒ»В№ :
                  GL (Fin 2) в„қ) вҖў
                (ModularGroup.fd : Set UpperHalfPlane)))
            (вҮ‘f вҲЈ[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) в„қ))
            вҮ‘g) := by
  rw [petN_f_heckeT_p_RHS_sum_normalized p hp hpN f g]
  refine Finset.sum_congr rfl fun q _ => ?_
  exact peterssonInner_heckeT_p_RHS_per_q_normalized_shifted_tile p hp hpN
    (q.out : SL(2, в„Ө)) f g

