    (h_slash_slot2 :
      g_const тИг[k] (peterssonAdj
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣)))тБ╗┬╣ =
      тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) :
    peterssonInner k tile_zero F g_const =
      peterssonInner k ModularGroup.fd
        ((F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  refine peterssonInner_per_tile_match_via_slash_adjoint _ h_╬▓_pos F g_const _ _
    h_tile_eq ?_ h_slash_slot2
  exact SlashAction.slash_mul _ _ _ F

