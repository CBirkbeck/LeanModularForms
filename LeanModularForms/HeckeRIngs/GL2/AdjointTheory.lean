private theorem peterssonInner_per_tile_match_M_infty_branch
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд) тз╕ Gamma1 N)
    (g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (F g_const : UpperHalfPlane тЖТ тДВ)
    {tile_zero : Set UpperHalfPlane}
    (h_╬▓_pos : 0 < (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
        GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (q.out : SL(2, тДд))тБ╗┬╣)).det.val)
    (h_tile_eq : tile_zero =с╡Р[╬╝_hyp]
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
