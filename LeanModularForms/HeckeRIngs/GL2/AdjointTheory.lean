  -- h_quot_eq : (q.out)тБ╗┬╣ * (slGamma_p_╬▒ToGamma1 ╬▒ q).out тИИ Gamma1 N.
  set ╬│ := (q.out : SL(2, тДд))тБ╗┬╣ * (slGamma_p_╬▒ToGamma1 (N := N) ╬▒ q).out with h╬│_def
