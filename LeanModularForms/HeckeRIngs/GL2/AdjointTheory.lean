  В· change ((1 : в„Ө) : ZMod N) = 1
    push_cast; rfl
  В· change ((((N : в„Ө) * mIdxOfCoprime N p hpN) : в„Ө) : ZMod N) = 0
    push_cast
    rw [show (((N : в„•) : ZMod N)) = 0 from ZMod.natCast_self N]; ring

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: `M_infty_Gamma1_factor` is non-trivial in `PSL(2, в„Ө)` for `p` prime.**

If `Оі = M_infty_Gamma1_factor` were central in `SL(2, в„Ө)`, commutation with the
rotation `S = !![0, -1; 1, 0]` would force both `Оі 0 0 = Оі 1 1` and `Оі 0 1 =
-Оі 1 0`.  Using `Оі 1 1 = 1` and `Оі 0 0 = ap вҲ’ bNm`, we'd get `ap вҲ’ bNm = 1`.
Separately, `Оі 0 1 = 1 вҲ’ b = -Nm`.  Combined with the Bezout `ap вҲ’ Nm = 1`,
this leaves a contradiction whenever `p вүҘ 2` (i.e., `p` prime). -/
theorem M_infty_Gamma1_factor_psl_ne_one
    (N p : в„•) [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N) (b : в„•) :
    (QuotientGroup.mk (M_infty_Gamma1_factor N p hpN b) : PSL(2, в„Ө)) вү  1 := by
  -- Commutation with `S = !![0, -1; 1, 0]` + entry (1,0) gives `ap - bNm = 1`.
  -- Combined with Bezout `ap - Nm = 1`, we get `(b-1)В·Nm = 0`.  Via
  -- entry (0,1) giving `1 - b = -Nm`, both cases collapse to `Nm = 0` and
  -- `ap = 1`, which contradicts `p` prime вүҘ 2.
  intro heq
  rw [QuotientGroup.eq_one_iff] at heq
  have hS : (!![(0 : в„Ө), -1; 1, 0] : Matrix (Fin 2) (Fin 2) в„Ө).det = 1 := by
    simp [Matrix.det_fin_two]
  set S_mat : SL(2, в„Ө) := вҹЁ!![0, -1; 1, 0], hSвҹ©
  have hcomm : M_infty_Gamma1_factor N p hpN b * S_mat =
      S_mat * M_infty_Gamma1_factor N p hpN b := heq.comm S_mat
  have hcomm_val : (M_infty_Gamma1_factor N p hpN b : SL(2, в„Ө)).val * S_mat.val =
      S_mat.val * (M_infty_Gamma1_factor N p hpN b : SL(2, в„Ө)).val :=
    congr_arg Subtype.val hcomm
  -- Entry (1,0) of commutation: Оі 1 1 = Оі 0 0, i.e., 1 = ap - bNm.
  have h_10 := congr_fun (congr_fun hcomm_val 1) 0
  simp only [S_mat, M_infty_Gamma1_factor, Matrix.mul_apply, Fin.sum_univ_two,
    Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
    Matrix.head_cons, Matrix.head_fin_const] at h_10
  -- Entry (0,0) of commutation: Оі 0 1 = -Оі 1 0, i.e., 1 - b = -Nm.
  have h_00 := congr_fun (congr_fun hcomm_val 0) 0
  simp only [S_mat, M_infty_Gamma1_factor, Matrix.mul_apply, Fin.sum_univ_two,
    Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
    Matrix.head_cons, Matrix.head_fin_const] at h_00
  -- h_10: `ap - bNm = 1`; Bezout `ap - Nm = 1`.  Subtract: `(1-b) Nm = 0`.
  -- h_00: `1 - b = -Nm`.
  have h_bezout := N_mul_mIdx_eq N p hpN
  -- From h_10, h_bezout: `ap - bNm - (ap - Nm) = 0`, i.e., `(1-b) * Nm = 0`.
  -- From h_00: `(1 - b) = -Nm`.  Substitute: `(-Nm) * Nm = 0`, so `Nm^2 = 0`, `Nm = 0`.
  have h_Nm_zero : (N : в„Ө) * mIdxOfCoprime N p hpN = 0 := by
    have h_sub : (1 - (b : в„Ө)) * ((N : в„Ө) * mIdxOfCoprime N p hpN) = 0 := by
      linarith
    have h_subst : -((N : в„Ө) * mIdxOfCoprime N p hpN) *
        ((N : в„Ө) * mIdxOfCoprime N p hpN) = 0 := by
      have : (1 - (b : в„Ө)) = -((N : в„Ө) * mIdxOfCoprime N p hpN) := by linarith
      rw [this] at h_sub; exact h_sub
    have h_sq : ((N : в„Ө) * mIdxOfCoprime N p hpN)^2 = 0 := by
      have := h_subst; nlinarith
    exact pow_eq_zero_iff (by norm_num : (2 : в„•) вү  0) |>.mp h_sq
  -- Then ap = 1 from Bezout.
  have h_ap : (aInvOfCoprime N p hpN : в„Ө) * p = 1 := by linarith
  -- ap = 1 with p prime вүҘ 2: impossible.
  have hp_div : (p : в„Ө) вҲЈ 1 := вҹЁaInvOfCoprime N p hpN, by linarithвҹ©
  have hp_ge : (p : в„Ө) вүҘ 2 := by exact_mod_cast hp.two_le
  have hp_unit := Int.isUnit_iff.mp (isUnit_of_dvd_one hp_div)
  rcases hp_unit with h | h <;> omega

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094 matrix identity M2: `(T_p_upper(b))вҒ»В№ В· M_вҲһ = mapGL в„қ
(M_infty_Gamma1_factor)`.**  Verified via `M_вҲһ = T_p_upper(b) В· Оі'` computation. -/
theorem glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1
    (N p : в„•) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (b : в„•) :
    (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ)вҒ»В№ *
        (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) =
      ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (M_infty_Gamma1_factor N p hpN b)) := by
  have h_mul : (glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) =
      (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) *
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (M_infty_Gamma1_factor N p hpN b)) := by
    apply Units.ext
    ext i j
    have h_L : ((glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        !![((aInvOfCoprime N p hpN : в„Ө) : в„қ) * (p : в„қ), 1;
           (((N : в„Ө) * mIdxOfCoprime N p hpN : в„Ө) : в„қ) * (p : в„қ), (p : в„қ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, M_infty, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R1 : ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) = !![(1 : в„қ), (b : в„қ); 0, (p : в„қ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R2 : (((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (M_infty_Gamma1_factor N p hpN b)) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        !![((aInvOfCoprime N p hpN : в„Ө) : в„қ) * (p : в„қ) -
             (b : в„қ) * (((N : в„Ө) * mIdxOfCoprime N p hpN : в„Ө) : в„қ),
           (1 : в„қ) - (b : в„қ);
           (((N : в„Ө) * mIdxOfCoprime N p hpN : в„Ө) : в„қ), 1] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [mapGL_coe_matrix, M_infty_Gamma1_factor, algebraMap_int_eq,
          Matrix.of_apply]
    show ((glMap (M_infty N p hp hpN) : GL (Fin 2) в„қ) : Matrix _ _ в„қ) i j =
      ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) *
       ((mapGL в„қ : SL(2, в„Ө) вҶ’* _) (M_infty_Gamma1_factor N p hpN b)) :
       GL (Fin 2) в„қ).val i j
    rw [h_L, Units.val_mul, h_R1, h_R2]
    fin_cases i <;> fin_cases j <;>
      simp [Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply] <;> ring
  rw [h_mul, вҶҗ mul_assoc, inv_mul_cancel, one_mul]

