/-- **T024 petN T_p-side, per-q T_p_lower form**: applies the per-q
union-tile T_p_lower form
(`peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form`) to each
summand of `petN(T_p f, g) = тИС_q peterssonInner k fd (T_p f тИг qтБ╗┬╣) (g тИг qтБ╗┬╣)`,
producing the per-q union-tile decomposition with **uniform slot-2
= `g тИг T_p_lower`** and **uniform combined-GL domain shape
`(glMap ╬▒ * mapGL qтБ╗┬╣) тАв fd`**.

This is the entry point for the per-╬▒ aggregate reduction: each per-q
summand has an M_тИЮ-tile `peterssonInner` plus a `Finset.range p`-union
tile `peterssonInner` (over the `T_p_upper` family), ready for q-aggregation
via `peterssonInner_iUnion_finite_aedisjoint`.

**Composes**:
1. `Finset.sum_congr` over `q : SL(2, тДд) тз╕ ╬УтВБ(N)` to apply the per-q lemma.
2. Per-q lemma `peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form`,
   which itself composes the per-q distribution + union-tile collapse +
   slot-2 collapse to `g тИг T_p_lower`. -/
private theorem petN_heckeT_p_eq_per_q_T_p_lower_form
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      (peterssonInner k
        (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
              GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set UpperHalfPlane))
        тЗСf (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) +
       peterssonInner k
        (тЛГ b тИИ Finset.range p,
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
              GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane))
        тЗСf (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ))) := by
  show тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(heckeT_p_cusp k p hp hpN f) тИг[k] ((q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k] ((q.out : SL(2, тДд))тБ╗┬╣)) = _
  refine Finset.sum_congr rfl fun q _ => ?_
  change peterssonInner k ModularGroup.fd
      (тЗС(heckeT_p_cusp k p hp hpN f) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
          GL (Fin 2) тДЭ))
      (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
        GL (Fin 2) тДЭ)) = _
  exact peterssonInner_heckeT_p_LHS_per_q_to_union_tiles_T_p_lower_form
    p hp hpN (q.out : SL(2, тДд)) f g

