open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 symmetric-form fixed-q distribution helper**: symmetric
counterpart of `peterssonInner_heckeT_p_RHS_per_q_distribute`, for the
aggregate
`petN (diamondOp_cusp k u f) (heckeT_p_cusp k p hp hpN g)`
with `u := ZMod.unitOfCoprime p hpN`.  Slot-1 is the **diamond-twisted**
`тЗС(тЯиuтЯй f) тИг[k] mapGL qтБ╗┬╣` identified with
`(тЗСf тИг[k] mapGL ╬│тВАтБ╗┬╣) тИг[k] mapGL qтБ╗┬╣` via
`coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv`; slot-2 is
`тЗС(heckeT_p_cusp k p hp hpN g) тИг[k] mapGL qтБ╗┬╣` distributed over the
`M_тИЮ + тИС_b T_p_upper(b)` decomposition of `heckeT_p_cusp` via
`heckeT_p_fun_eq_coset_sum` + `SlashAction.add_slash` +
`SlashAction.sum_slash`.  The `╬│тВАтБ╗┬╣` residual on slot-1 is preserved
intentionally; it matches the correct symmetric DS 5.5.3 first-slot twist. -/
private lemma peterssonInner_heckeT_p_symm_RHS_per_q_distribute
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗС(heckeT_p_cusp k p hp hpN g) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) =
    peterssonInner k ModularGroup.fd
        ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
            GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
        (тЗСg тИг[k]
          ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) +
      тИС b тИИ Finset.range p,
        peterssonInner k ModularGroup.fd
          ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
              GL (Fin 2) тДЭ)) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
          (тЗСg тИг[k]
            ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- Rewrite slot-1 using the new diamond-vs-adjointGamma0Rep-inverse identity.
  rw [coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
  -- Distribute slot-2 via the T_p coset sum on plain g.
  have h_Tp_g : (тЗС(heckeT_p_cusp k p hp hpN g) : UpperHalfPlane тЖТ тДВ) =
      heckeT_p_ut k p hp.pos тЗСg.toModularForm' +
      тЗСg.toModularForm' тИг[k]
        (M_infty N p hp.pos hpN : GL (Fin 2) тДЪ) :=
    heckeT_p_fun_eq_coset_sum k hp hpN g.toModularForm'
  rw [h_Tp_g, SlashAction.add_slash]
  rw [show heckeT_p_ut k p hp.pos тЗСg.toModularForm' =
      тИС b тИИ Finset.range p,
        тЗСg.toModularForm' тИг[k]
          (T_p_upper p hp.pos b : GL (Fin 2) тДЪ) from rfl]
  rw [SlashAction.sum_slash]
  simp_rw [slash_glQ_mapGLSL_to_combinedGL]
  rw [add_comm]
  set F : UpperHalfPlane тЖТ тДВ :=
    (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
      GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) with hF_def
  set G0 : UpperHalfPlane тЖТ тДВ :=
    тЗСg тИг[k]
      ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) with hG0_def
  set G : тДХ тЖТ UpperHalfPlane тЖТ тДВ := fun b =>
    тЗСg тИг[k]
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣)) with hG_def
  have h0 : IntegrableOn (fun ╧Д => petersson k F G0 ╧Д) ModularGroup.fd ╬╝_hyp := by
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) g
      (M_infty N p hp.pos hpN) qтБ╗┬╣
    show IntegrableOn (fun ╧Д => petersson k
      ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
        GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
      (тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) ╧Д) ModularGroup.fd ╬╝_hyp
    rw [show (тЗСg тИг[k]
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) =
      (тЗСg тИг[k]
        ((M_infty N p hp.pos hpN).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k) тЗСg
        (M_infty N p hp.pos hpN) qтБ╗┬╣).symm]
    rw [тЖР coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
    exact h
  have hG_int : тИА b тИИ Finset.range p,
      IntegrableOn (fun ╧Д => petersson k F (G b) ╧Д) ModularGroup.fd ╬╝_hyp := by
    intro b _
    have h := integrableOn_petersson_cuspform_mixed_slash_on_fd
      (N := N) (k := k) (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) g
      (T_p_upper p hp.pos b) qтБ╗┬╣
    show IntegrableOn (fun ╧Д => petersson k
      ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
        GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
      (тЗСg тИг[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) ╧Д) ModularGroup.fd ╬╝_hyp
    rw [show (тЗСg тИг[k]
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))) =
      (тЗСg тИг[k]
        ((T_p_upper p hp.pos b).map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣) from
      (slash_glQ_then_mapGL_SL_eq_combinedGL (k := k) тЗСg
        (T_p_upper p hp.pos b) qтБ╗┬╣).symm]
    rw [тЖР coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv p hp hpN f]
    exact h
  exact peterssonInner_add_finset_sum_right (Finset.range p) F G0 G ModularGroup.fd h0 hG_int

