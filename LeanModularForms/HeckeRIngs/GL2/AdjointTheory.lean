private lemma peterssonInner_heckeT_p_RHS_per_q_normalized_shifted_tile
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣))
        (тЗСg тИг[k]
