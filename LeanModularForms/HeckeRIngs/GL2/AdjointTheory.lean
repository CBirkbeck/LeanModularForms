/-- **T205-d ADJ-CORR step 10* (M_вҲһ branch, v2 cleaner form)**: cleaner
equivalent of `TpUpperZeroShiftedFormBlocker` operating on iUnion (instead
of `T_p_lower вҖў UNION`) with `T_p_lower`-slashed slots instead of
`T_p_upper(0)`-slashed slots.

This form matches the per-b `TpUpperBranchDiamondFormBlocker` structure
(slot-symmetric `f вҲЈ T_p_lower` vs `(вҹЁuвҹ©g) вҲЈ T_p_lower`), exposing the
same shape across both branches.  It is reduced from the original
blocker via slash-adjoint applied twice with Оұ = T_p_lower (det = p > 0)
+ `slash_peterssonAdj_T_p_lower_eq_T_p_upper_0`.

**Mathematical role.** Lets a future worker target a single uniformly-
shaped identity across the M_вҲһ branch (special case Оі_M = id) and the
T_p_upper(b) branch (per-b factor Оі_b). -/
private def TpUpperZeroShiftedFormBlocker_v2
    (p : в„•) (hp : Nat.Prime p) (_hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) : Prop :=
  peterssonInner k
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
          GL (Fin 2) в„қ) вҖў (fd : Set в„Қ))
      (вҮ‘f вҲЈ[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p _hpN)вҒ»В№ g)) =
    peterssonInner k
      (вӢғ q : SL(2, в„Ө) в§ё Gamma1 N,
        ((mapGL в„қ : SL(2, в„Ө) вҶ’* GL (Fin 2) в„қ) (q.out : SL(2, в„Ө))вҒ»В№ :
          GL (Fin 2) в„қ) вҖў (fd : Set в„Қ))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p _hpN) f))
      (вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p _hpN) g) вҲЈ[k]
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ))

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d ADJ-CORR step 10** alias: `TpUpperZeroShiftedFormBlocker` from
the cleaner v2 form, via slash-adjoint applied twice (Оұ = T_p_lower, det > 0).

Composition:
* `peterssonInner_slash_adjoint` on slot-1: moves `T_p_lower` slash from
  slot-1 to slot-2 with domain shift `UNION вҶ’ T_p_lower вҖў UNION`;
* `slash_peterssonAdj_T_p_lower_eq_T_p_upper_0` (applied to `вҹЁuвҒ»В№вҹ©g`):
  converts `peterssonAdj T_p_lower` slash to `T_p_upper(0)` slash;
* `peterssonInner_slash_adjoint_right` on RHS slot-2: moves `T_p_lower`
  slash from slot-2 to slot-1 with domain shift `UNION вҶ’ T_p_lower вҖў UNION`;
* `slash_peterssonAdj_T_p_lower_eq_T_p_upper_0` (applied to `вҹЁuвҹ©f`):
  converts `peterssonAdj T_p_lower` slash to `T_p_upper(0)` slash. -/
private theorem TpUpperZeroShiftedFormBlocker_of_v2
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (h_v2 : TpUpperZeroShiftedFormBlocker_v2 p hp hpN f g) :
    TpUpperZeroShiftedFormBlocker p hp hpN f g := by
  have h_det_pos : 0 < (glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ).det.val := by
    show 0 < ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ).det
    rw [show ((glMap (T_p_lower p hp.pos) : GL (Fin 2) в„қ) :
        Matrix (Fin 2) (Fin 2) в„қ) =
        ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
    rw [show (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).map
        (algebraMap в„ҡ в„қ)).det =
        (algebraMap в„ҡ в„қ) (((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_lower p hp.pos : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
      simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
    rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
    exact_mod_cast hp.pos
  unfold TpUpperZeroShiftedFormBlocker_v2 at h_v2
  unfold TpUpperZeroShiftedFormBlocker
  rw [peterssonInner_slash_adjoint (k := k) _ _ h_det_pos вҮ‘f
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g),
    slash_peterssonAdj_T_p_lower_eq_T_p_upper_0 p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g),
    peterssonInner_slash_adjoint_right (k := k) _ _ h_det_pos
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
      вҮ‘(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g),
    slash_peterssonAdj_T_p_lower_eq_T_p_upper_0 p hp hpN
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)] at h_v2
  exact h_v2

