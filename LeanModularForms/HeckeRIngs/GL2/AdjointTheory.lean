/-- **T090 per-╬▒ common FD slash-exchange reduction.**

Unifies the M_тИЮ and upper-b FD slash-exchange residuals under a single
per-╬▒ reduction theorem. Given the per-╬▒ matrix factorization
`╬│тВА ┬╖ ╬▒ = T_p_lower ┬╖ mapGL ╬│_╬▒` (with ╬│_╬▒ : SL(2, тДд)), the FD slash-exchange
residual in `T_p_lower ┬╖ ╬│_╬▒ ┬╖ q.outтБ╗┬╣` form is logically equivalent (via a
per-q `Finset.sum_congr` consumer of
`slash_diamond_inv_╬▒_eq_T_p_lower_via_matrix_factor.symm`) to the canonical
`╬▒ ┬╖ q.outтБ╗┬╣` form:

```
тИС_q peterssonInner k fd (тЯиuтБ╗┬╣тЯйf тИг ╬▒ ┬╖ q.outтБ╗┬╣) (g тИг (╧Г q).outтБ╗┬╣)
  = тИС_q peterssonInner k fd (f тИг q.outтБ╗┬╣) (g тИг ╬▒ ┬╖ (╧Г q).outтБ╗┬╣)
```

For both branches, the matrix factorization is provided by existing lemmas:
* M_тИЮ branch: `mapGL_gamma0_mul_M_infty_eq_T_p_lower_mul_mapGL_epsilon`,
  with ╬▒ = `glMap M_тИЮ`, ╬│_╬▒ = `gamma0_T_p_upper_Gamma1_factor 0 *
  M_infty_Gamma1_factor 0`.
* upper-b branch (per b): `mapGL_gamma0_mul_T_p_upper_eq_T_p_lower_mul_mapGL_delta`,
  with ╬▒ = `glMap T_p_upper(b)`, ╬│_╬▒ = `gamma0_T_p_upper_Gamma1_factor b`.

**Role.** Common reduction lemma: discharging the **same canonical-form
hypothesis at every ╬▒** (M_тИЮ and T_p_upper(b) for b тИИ range p) suffices to
close all FD slash-exchange residuals via this single reduction. -/
private theorem h_╬▒_FD_slash_exchange_T_p_lower_form_of_canonical
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (╬▒ : GL (Fin 2) тДЭ) (╬│_╬▒ : SL(2, тДд))
    (h_factor : ((mapGL тДЭ : SL(2, тДд) тЖТ* _)
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)) : GL (Fin 2) тДЭ) * ╬▒ =
        (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│_╬▒ : GL (Fin 2) тДЭ))
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (h_canonical_╬▒ :
      (тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
            (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
              (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
            (тЗСg тИг[k]
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
      тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
            (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣))
            (тЗСg тИг[k]
              (╬▒ *
                ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                  ((Gamma1QuotEquivOfGamma0
                    ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                    (adjointGamma0Rep p N hpN).property q).out :
                    SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) :
    (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
          (тЗСf тИг[k]
            ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│_╬▒) *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
          (тЗСg тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((Gamma1QuotEquivOfGamma0
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                (adjointGamma0Rep p N hpN).property q).out :
                SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
          (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
          (тЗСg тИг[k]
            (╬▒ *
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                ((Gamma1QuotEquivOfGamma0
                  ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                  (adjointGamma0Rep p N hpN).property q).out :
                  SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- Per-q apply matrix factorization (`slash_diamond_inv_╬▒_eq_T_p_lower_via_matrix_factor.symm`)
  -- to LHS slot 1, converting `f тИг T_p_lower┬╖╬│_╬▒┬╖q.outтБ╗┬╣` to `тЯиuтБ╗┬╣тЯйf тИг ╬▒┬╖q.outтБ╗┬╣`.
  rw [show (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗСf тИг[k]
          ((glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│_╬▒) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((Gamma1QuotEquivOfGamma0
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
              (adjointGamma0Rep p N hpN).property q).out :
              SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((Gamma1QuotEquivOfGamma0
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
              (adjointGamma0Rep p N hpN).property q).out :
              SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
    from Finset.sum_congr rfl fun q _ => by
      congr 1
      exact (slash_diamond_inv_╬▒_eq_T_p_lower_via_matrix_factor p hp hpN ╬▒ ╬│_╬▒
        h_factor (q.out : SL(2, тДд)) f).symm]
  exact h_canonical_╬▒

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 per-╬▒ canonical-from-balanced reduction (╧Г-absorption).**

Reduces the per-╬▒ canonical sum-level ╧Г-absorption identity to the
**balanced** form (with no `╧Г q` on either side, only `q.outтБ╗┬╣`):

```
тИС_q peterssonInner k fd (тЯиuтБ╗┬╣тЯйf тИг ╬▒ ┬╖ q.outтБ╗┬╣) (тЯиuтБ╗┬╣тЯйg тИг q.outтБ╗┬╣)
  = тИС_q peterssonInner k fd (тЯиuтЯйf тИг q.outтБ╗┬╣) (g тИг ╬▒ ┬╖ q.outтБ╗┬╣)
```

This is the **structurally simplest form** of the per-╬▒ slash-exchange
content: no ╧Г-permutation, no shifted-tile domains, just FD-level
slash chains with explicit diamond shifts on either f or g.

**Proof.** Composes two existing per-q rewrites:
* LHS canonical тЖТ LHS balanced via slot-2 ╧Г-correction
  (`slash_Gamma1QuotEquiv_out_inv_eq_diamond_slash_out_inv_GL` applied to g).
* RHS balanced тЖТ RHS canonical via `Equiv.sum_comp` over ╧Г + slot-1
  ╧Г-correction on `тЯиuтЯйf` (giving `тЯиuтЯйf тИг (╧Г q).outтБ╗┬╣ = тЯиuтБ╗┬╣тЯй(тЯиuтЯйf) тИг q.outтБ╗┬╣ = f тИг q.outтБ╗┬╣`).

**Role.** Generic per-╬▒ reduction: discharging the **same balanced identity
at every ╬▒** (M_тИЮ and T_p_upper(b) for b тИИ range p) suffices to close all
canonical FD slash-exchange identities (and hence, via the existing
matrix-factorization reduction `h_╬▒_FD_slash_exchange_T_p_lower_form_of_canonical`,
the per-╬▒ tile-shift residual).

**Combined with the matrix-factorization reduction**, both M_тИЮ and upper-b
FD slash-exchange residuals reduce to ONE explicit balanced sum-level identity
per ╬▒ тАФ the maximally simplified form of the genuine analytic content. -/
private theorem h_╬▒_canonical_form_of_balanced
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (╬▒ : GL (Fin 2) тДЭ)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (h_balanced :
      (тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
            (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
              (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
            (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
      тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
            (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
              ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
            (тЗСg тИг[k]
              (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
                (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) :
    (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
          (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
            (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
          (тЗСg тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((Gamma1QuotEquivOfGamma0
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                (adjointGamma0Rep p N hpN).property q).out :
                SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
          (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣))
          (тЗСg тИг[k]
            (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              ((Gamma1QuotEquivOfGamma0
                ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
                (adjointGamma0Rep p N hpN).property q).out :
                SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- Step A: LHS canonical тЖТ LHS balanced via per-q slot-2 ╧Г-correction.
  have h_LHS : (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((Gamma1QuotEquivOfGamma0
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
              (adjointGamma0Rep p N hpN).property q).out :
              SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) := by
    refine Finset.sum_congr rfl fun q _ => ?_
    congr 1
    have h := slash_Gamma1QuotEquiv_out_inv_eq_diamond_slash_out_inv_GL
      (adjointGamma0Rep p N hpN) g q
    rw [adjointGamma0Rep_units p N hpN] at h
    exact h
  -- Step B: RHS balanced тЖТ RHS canonical via Equiv.sum_comp ╧Г + per-q slot-1
  -- ╧Г-correction on тЯиuтЯйf (using тЯиuтБ╗┬╣тЯй(тЯиuтЯйf) = f).
  have h_RHS : (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗСg тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣))
        (тЗСg тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((Gamma1QuotEquivOfGamma0
              ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
              (adjointGamma0Rep p N hpN).property q).out :
              SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
    -- Set ╧Г = Gamma1QuotEquivOfGamma0 (adjointGamma0Rep) and apply ╧Г.sum_comp
    -- to LHS of h_RHS (= balanced_RHS).
    -- ╧Г.sum_comp F : ╬г_q F(╧Г q) = ╬г_q F(q). So balanced_RHS = ╬г_q F(╧Г q) where
    -- F(q) = peterssonInner k fd (тЯиuтЯйf тИг q.outтБ╗┬╣) (g тИг ╬▒ ┬╖ q.outтБ╗┬╣).
    -- Then per-q, F(╧Г q) = peterssonInner k fd (тЯиuтЯйf тИг (╧Г q).outтБ╗┬╣)
    --                                        (g тИг ╬▒ ┬╖ (╧Г q).outтБ╗┬╣)
    -- and the slot-1 ╧Г-correction `тЯиuтЯйf тИг (╧Г q).outтБ╗┬╣ = f тИг q.outтБ╗┬╣` matches
    -- canonical_RHS_q.
    set ╧Г : SL(2, тДд) тз╕ Gamma1 N тЙГ SL(2, тДд) тз╕ Gamma1 N :=
      Gamma1QuotEquivOfGamma0
        ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))
        (adjointGamma0Rep p N hpN).property
    rw [тЖР ╧Г.sum_comp (fun q : SL(2, тДд) тз╕ Gamma1 N =>
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗСg тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))))]
    -- Goal: тИС_q F(╧Г q) = canonical_RHS where
    -- F(╧Г q) = peterssonInner k fd (тЯиuтЯйf тИг (╧Г q).outтБ╗┬╣) (g тИг ╬▒ ┬╖ (╧Г q).outтБ╗┬╣)
    refine Finset.sum_congr rfl fun q _ => ?_
    -- Per-q goal: F(╧Г q) = canonical_RHS_q.
    -- Slot 2 matches: g тИг ╬▒ ┬╖ (╧Г q).outтБ╗┬╣.
    -- Slot 1: тЯиuтЯйf тИг (╧Г q).outтБ╗┬╣ = f тИг q.outтБ╗┬╣.
    congr 1
    have h := slash_Gamma1QuotEquiv_out_inv_eq_diamond_slash_out_inv_GL
      (adjointGamma0Rep p N hpN)
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) q
    rw [adjointGamma0Rep_units p N hpN] at h
    -- h : тЗС(тЯиuтЯйf) тИг mapGL (╧Г q).outтБ╗┬╣ = тЗС(тЯиuтБ╗┬╣тЯй(тЯиuтЯйf)) тИг mapGL q.outтБ╗┬╣
    rw [h]
    -- Goal: тЗС(тЯиuтБ╗┬╣тЯй(тЯиuтЯйf)) тИг mapGL q.outтБ╗┬╣ = тЗСf тИг mapGL q.outтБ╗┬╣
    congr 1
    -- Goal: тЗС(тЯиuтБ╗┬╣тЯй(тЯиuтЯйf)) = тЗСf
    show тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
      (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) = тЗСf
    have h_cancel : diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) = f := by
      show diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
        (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f) = f
      rw [show diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣
          (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f) =
          ((diamondOpCusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣).comp
            (diamondOpCusp k (ZMod.unitOfCoprime p hpN))) f from rfl,
        тЖР diamondOpCusp_mul, inv_mul_cancel, diamondOpCusp_one]
      rfl
    rw [h_cancel]
  -- Combine: canonical_LHS = balanced_LHS = balanced_RHS = canonical_RHS.
  rw [h_LHS, h_balanced, h_RHS]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 per-╬▒ aggregate-FD-balance reduction.**

Reduces the per-╬▒ balanced sum identity (the irreducible content of both M_тИЮ
and upper-b FD slash-exchange residuals) to a single Petersson integral
balance at the **union of ╬▒-shifted ╬УтВБ(N) tiles**:

```
peterssonInner k (тЛГ_q (╬▒ ┬╖ q.outтБ╗┬╣) тАв fd) (тЯиuтБ╗┬╣тЯйf) (тЯиuтБ╗┬╣тЯйg тИг peterssonAdj ╬▒)
  = peterssonInner k (тЛГ_q (╬▒ ┬╖ q.outтБ╗┬╣) тАв fd) (тЯиuтЯйf тИг peterssonAdj ╬▒) g
```

**Composition.** Applies `peterssonInner_sum_slash_adjoint_coset_aggregate`
(LHS, slash-on-slot-1) and `peterssonInner_slash_adjoint_coset_right` +
`peterssonInner_iUnion_finite_aedisjoint` (RHS, slash-on-slot-2)
symmetrically, then uses the FD-balance hypothesis to equate the resulting
single Petersson integrals over the same union domain.

**Hypotheses.** Standard tile-family hypotheses for the ╬▒-shifted tiles
`{(╬▒ ┬╖ q.outтБ╗┬╣) тАв fd : q тИИ SL(2,тДд) тз╕ ╬УтВБ(N)}`:
* `h╬▒`: positivity of `╬▒.det.val`;
* `hd`: pairwise AE-disjointness;
* `hm`: NullMeasurableSet of each tile;
* `hint_LHS`/`hint_RHS`: integrability of the LHS/RHS petersson integrands
  on the union (with `peterssonAdj ╬▒` applied).

**For both DS Prop. 5.5.2(b) families** (M_тИЮ and T_p_upper(b)), the
positivity is provided by `glMap_M_infty_det_pos` /
`glMap_T_p_upper_det_pos`, AE-disjointness/measurability/integrability are
provided by existing helpers.

**Single irreducible blocker.** The remaining hypothesis `h_FD_balance` is
the genuine analytic content: a Petersson integral identity at the level
of the ╬▒-shifted ╬УтВБ(N) tile union. Closing this for `╬▒ тИИ {glMap M_тИЮ} тИк
{glMap T_p_upper(b) : b тИИ range p}` discharges all FD slash-exchange
residuals via composition with the prior T090 reductions
(`h_╬▒_canonical_form_of_balanced`,
`h_╬▒_FD_slash_exchange_T_p_lower_form_of_canonical`,
`h_╬▒_tile_shift_to_prefactored_of_FD_slash_exchange` /
`h_upper_tile_shift_to_prefactored_of_FD_slash_exchange`,
`petN_heckeT_p_adjoint_standard_form_from_two_FD_slash_exchanges`,
`petN_heckeT_p_diamond_shift_core_of_unsymm`). -/
private theorem balanced_╬▒_of_aggregate_FD_balance
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hd : Pairwise (fun (qтВБ qтВВ : SL(2, тДд) тз╕ Gamma1 N) =>
      AEDisjoint ╬╝_hyp
        ((╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (qтВБ.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        ((╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (qтВВ.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв fd)))
    (hm : тИА q : SL(2, тДд) тз╕ Gamma1 N,
      NullMeasurableSet
        ((╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН)) ╬╝_hyp)
    (hint_LHS : IntegrableOn
      (fun ╧Д => petersson k
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) тИг[k]
          peterssonAdj ╬▒) ╧Д)
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН)) ╬╝_hyp)
    (hint_RHS : IntegrableOn
      (fun ╧Д => petersson k
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k]
          peterssonAdj ╬▒) тЗСg ╧Д)
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН)) ╬╝_hyp)
    (h_FD_balance :
      peterssonInner k
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) тИг[k]
          peterssonAdj ╬▒) =
      peterssonInner k
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k]
          peterssonAdj ╬▒) тЗСg) :
    (тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f) тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) =
    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      peterssonInner k ModularGroup.fd
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
        (тЗСg тИг[k]
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))) := by
  -- Step 1: LHS aggregate via peterssonInner_sum_slash_adjoint_coset_aggregate.
  have h_LHS_agg := peterssonInner_sum_slash_adjoint_coset_aggregate
    (k := k) ╬▒ h╬▒
    (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f))
    (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g))
    hd hm hint_LHS
  -- Step 2: RHS aggregate via per-q `peterssonInner_slash_adjoint_coset_right`
  -- + `peterssonInner_iUnion_finite_aedisjoint`.
  have h_RHS_agg :
      (тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
          (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
          (тЗСg тИг[k]
            (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) =
      peterssonInner k
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k]
          peterssonAdj ╬▒) тЗСg := by
    rw [show (тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k ModularGroup.fd
          (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тИг[k]
            ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ))
          (тЗСg тИг[k]
            (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))) =
      тИС q : SL(2, тДд) тз╕ Gamma1 N,
        peterssonInner k
          ((╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
          ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k]
            peterssonAdj ╬▒) тЗСg from by
      refine Finset.sum_congr rfl fun q _ => ?_
      rw [peterssonInner_slash_adjoint_coset_right (k := k) ╬▒ h╬▒
        (q.out : SL(2, тДд))
        тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тЗСg, тЖР mul_smul]]
    exact (peterssonInner_iUnion_finite_aedisjoint
      (fun q : SL(2, тДд) тз╕ Gamma1 N =>
        (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
      hm hd
      ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k] peterssonAdj ╬▒)
      тЗСg hint_RHS).symm
  -- Combine: balanced_LHS = LHS_agg = (h_FD_balance) = RHS_agg = balanced_RHS.
  rw [h_LHS_agg, h_FD_balance, тЖР h_RHS_agg]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 slash-adjoint sub-reduction of `h_FD_balance`.**

Reduces the aggregate-FD-balance hypothesis (consumed by
`balanced_╬▒_of_aggregate_FD_balance`) to a **post-swap** form on
the same union domain `U_╬▒ := тЛГ_q (╬▒ ┬╖ q.outтБ╗┬╣) тАв fd`, with the
`peterssonAdj ╬▒` factor moved off the slot-2/slot-1 g-side via two
applications of slash-adjoint (`peterssonInner_slash_adjoint_right`
on the LHS, `peterssonInner_slash_adjoint` on the RHS), with positivity
of `(peterssonAdj ╬▒).det` from `peterssonAdj_det`, and the
double-adjoint collapse `peterssonAdj_peterssonAdj`:

```
peterssonInner k (peterssonAdj ╬▒ тАв U_╬▒) ((тЯиuтБ╗┬╣тЯйf) тИг ╬▒) (тЯиuтБ╗┬╣тЯйg)
  = peterssonInner k (peterssonAdj ╬▒ тАв U_╬▒) (тЯиuтЯйf) (g тИг ╬▒)
```

This is the **post-swap form**: integrals over `peterssonAdj ╬▒ тАв U_╬▒`
of petersson kernels with ╬▒ applied directly (not via `peterssonAdj`).

**Use site.** Discharging this post-swap balance hypothesis discharges the
original `h_FD_balance` consumed by `balanced_╬▒_of_aggregate_FD_balance`,
hence the entire FD slash-exchange / tile-shift residual chain.

**Next step toward closure.** The domain `peterssonAdj ╬▒ тАв U_╬▒` further
simplifies via `peterssonAdj ╬▒ ┬╖ ╬▒ = (det ╬▒) ┬╖ 1` (matrix algebra:
`Matrix.adjugate_mul`) and the trivial action of scalar matrices on
`UpperHalfPlane` тАФ collapsing to the standard SL-tile union
`тЛГ_q (mapGL q.outтБ╗┬╣) тАв fd` (= the ╬УтВБ(N) fundamental domain at SL level).
The remaining identity is then a Petersson-integral balance over the
canonical ╬УтВБ(N) fundamental domain, eligible for discharge via
`petN_slash_invariant` / `diamondOp_petersson_unitary`. -/
private theorem h_FD_balance_of_post_swap_balance
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (h_post_swap_balance :
      peterssonInner k
        (peterssonAdj ╬▒ тАв тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)) тИг[k] ╬▒)
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) =
      peterssonInner k
        (peterssonAdj ╬▒ тАв тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f))
        (тЗСg тИг[k] ╬▒)) :
    peterssonInner k
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
      (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f))
      ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g)) тИг[k]
        peterssonAdj ╬▒) =
    peterssonInner k
      (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
        (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
      ((тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)) тИг[k]
        peterssonAdj ╬▒) тЗСg := by
  -- positive determinant of peterssonAdj ╬▒ (= ╬▒.det)
  have h╬▒_adj : 0 < (peterssonAdj ╬▒).det.val := by
    show 0 < ((peterssonAdj ╬▒).det : тДЭ╦г).val
    rw [peterssonAdj_det]
    exact h╬▒
  -- Apply peterssonInner_slash_adjoint_right to LHS.
  rw [peterssonInner_slash_adjoint_right
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        (peterssonAdj ╬▒) h╬▒_adj
        тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ f)
        тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN)тБ╗┬╣ g),
      peterssonAdj_peterssonAdj]
  -- Apply peterssonInner_slash_adjoint to RHS.
  rw [peterssonInner_slash_adjoint
        (тЛГ q : SL(2, тДд) тз╕ Gamma1 N,
          (╬▒ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) тАв (fd : Set тДН))
        (peterssonAdj ╬▒) h╬▒_adj
        тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) тЗСg,
      peterssonAdj_peterssonAdj]
  exact h_post_swap_balance

open UpperHalfPlane in
/-- **T090 trivial action of `peterssonAdj ╬▓ ┬╖ ╬▓` on a point of `тДН`.**

The matrix product `peterssonAdj ╬▓ ┬╖ ╬▓` equals the scalar matrix `(det ╬▓) ┬╖ 1`
(by `Matrix.adjugate_mul`), and positive scalar matrices act trivially on
`UpperHalfPlane` via M├╢bius. Proof here is via the GL group structure:
`peterssonAdj ╬▓ тАв ╧Д = ╬▓тБ╗┬╣ тАв ╧Д` (by `peterssonAdj_smul_eq`, the `peterssonAdj`
acts as the inverse on `тДН`), so
`(peterssonAdj ╬▓ * ╬▓) тАв ╧Д = peterssonAdj ╬▓ тАв ╬▓ тАв ╧Д = ╬▓тБ╗┬╣ тАв ╬▓ тАв ╧Д = ╧Д`. -/
private lemma peterssonAdj_mul_self_smul
    (╬▓ : GL (Fin 2) тДЭ) (╧Д : тДН) :
    ((peterssonAdj ╬▓ * ╬▓ : GL (Fin 2) тДЭ) тАв ╧Д : тДН) = ╧Д := by
  rw [mul_smul, peterssonAdj_smul_eq, inv_smul_smul]

open UpperHalfPlane in
/-- **T090 trivial action of `peterssonAdj ╬▓ ┬╖ ╬▓` on sets of `тДН`.**

Set-level extension of `peterssonAdj_mul_self_smul`: pointwise triviality
implies `(peterssonAdj ╬▓ ┬╖ ╬▓) тАв S = S` for any `S : Set тДН`. -/
lemma peterssonAdj_mul_self_smul_set
    (╬▓ : GL (Fin 2) тДЭ) (S : Set тДН) :
    ((peterssonAdj ╬▓ * ╬▓ : GL (Fin 2) тДЭ) тАв S : Set тДН) = S := by
  ext ╧Д
  refine тЯи?_, ?_тЯй
  ┬╖ rintro тЯиs, hs, h╧ДтЯй
    -- h╧Д has the form (fun x => _ тАв x) s = ╧Д; cast to action form
