            GL (Fin 2) ℝ) • (fd : Set ℍ))
        ⇑F ⇑G =
      petN F G := by
  rw [peterssonInner_iUnion_finite_aedisjoint _ hm hd _ _ hint]
  simp_rw [peterssonInner_mapGL_smul_eq_slash]
  rfl

