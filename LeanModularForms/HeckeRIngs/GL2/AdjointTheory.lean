  -- Re-cast biUnion integrability into GL match-form.
  have hfi_GL : IntegrableOn (fun ╧Д => petersson k тЗСf
        (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
