    have h_gтВВ : (QuotientGroup.mk gтВВ : SL(2, тДд) тз╕ Gamma1 N) = qтВВ' := hqтВВ
    have h_g : (QuotientGroup.mk g : SL(2, тДд) тз╕ Gamma1 N) = qтВБ' := hq
    have h_gтВБ : (QuotientGroup.mk gтВБ : SL(2, тДд) тз╕ Gamma1 N) = qтВБ' := hqтВБ
