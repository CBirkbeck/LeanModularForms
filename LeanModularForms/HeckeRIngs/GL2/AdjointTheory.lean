        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
          GL (Fin 2) тДЭ) тАв (fd : Set тДН)) ╬╝_hyp)
