    (╬▒ ╬▓ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val) (h╬▓ : 0 < ╬▓.det.val)
    (c : тДЭ) (hc : c тЙа 0)
    (hMat : (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) = c тАв (╬▓ : Matrix (Fin 2) (Fin 2) тДЭ))
    (╧Д : тДН) :
    ╬▒ тАв ╧Д = ╬▓ тАв ╧Д := by
  rw [UpperHalfPlane.ext_iff,
      UpperHalfPlane.coe_smul_of_det_pos h╬▒,
      UpperHalfPlane.coe_smul_of_det_pos h╬▓]
  simp only [UpperHalfPlane.num, UpperHalfPlane.denom]
  have h00 : (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 =
      c * (╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h01 : (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 =
      c * (╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h10 : (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 =
      c * (╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  have h11 : (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 =
      c * (╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 := by
    rw [hMat, Matrix.smul_apply, smul_eq_mul]
  rw [show ((╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 : тДВ) =
        (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 : тДВ) from by
    exact_mod_cast h00,
    show ((╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 : тДВ) =
        (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 : тДВ) from by
      exact_mod_cast h01,
    show ((╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 : тДВ) =
        (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 : тДВ) from by
      exact_mod_cast h10,
    show ((╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 : тДВ) =
        (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 : тДВ) from by
      exact_mod_cast h11]
  have hc_ne_zero : (c : тДВ) тЙа 0 := by exact_mod_cast hc
  -- num/denom both scale by c, ratio unchanged
  have h_num : (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 : тДВ) * (╧Д : тДВ) +
      (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 : тДВ) =
      (c : тДВ) * (((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 0 : тДВ) * (╧Д : тДВ) +
        ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 0 1 : тДВ)) := by ring
  have h_den : (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 : тДВ) * (╧Д : тДВ) +
      (c : тДВ) * ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 : тДВ) =
      (c : тДВ) * (((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 0 : тДВ) * (╧Д : тДВ) +
        ((╬▓ : Matrix (Fin 2) (Fin 2) тДЭ) 1 1 : тДВ)) := by ring
  rw [h_num, h_den, mul_div_mul_left _ _ hc_ne_zero]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM upper-tile M├╢bius equivalence**: `T_p_lower ┬╖ T_p_upper(b)`
acts on `тДН` the same as `shiftSL_loc(b) тИИ SL(2,тДд)`.

Composes `UpperHalfPlane_smul_eq_of_matrix_smul_eq` with the matrix identity
`(T_p_lower ┬╖ T_p_upper(b)).val = p тАв shiftSL_loc(b).val` (entry-wise: both
sides equal `!![p, pb; 0, p]`). -/
private theorem T_p_lower_mul_T_p_upper_smul_eq_shift_smul
    (p : тДХ) (hp : 0 < p) (b : тДХ) (╧Д : тДН) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) *
      (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ)) тАв ╧Д =
    ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      (shiftSL_loc (b : тДд)) : GL (Fin 2) тДЭ) тАв ╧Д := by
  have hp_real : (0 : тДЭ) < (p : тДЭ) := by exact_mod_cast hp
  have h_det_pos_LHS : 0 <
      ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) *
        (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ)).det.val := by
    show 0 < (((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) *
      (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show (((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) *
        (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) : Matrix _ _ тДЭ) *
        ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) : Matrix _ _ тДЭ) from rfl,
      Matrix.det_mul]
    have h_T_p_lower : ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = (p : тДЭ) := by
      rw [show ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) =
          ((T_p_lower p hp : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
      rw [show (((T_p_lower p hp : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
          (algebraMap тДЪ тДЭ) (((T_p_lower p hp : GL (Fin 2) тДЪ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_lower p hp : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
        simp [T_p_lower, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = _
      rfl
    have h_T_p_upper : ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = (p : тДЭ) := by
      rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) =
          ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
      rw [show (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
          (algebraMap тДЪ тДЭ) (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det) from
            (RingHom.map_det _ _).symm]
      rw [show ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
        simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.det_fin_two, Matrix.of_apply]]
      show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = _
      rfl
    rw [h_T_p_lower, h_T_p_upper]
    positivity
  have h_det_pos_RHS : 0 <
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b : тДд)) :
        GL (Fin 2) тДЭ).det.val := by
    show 0 < (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b : тДд)) :
        GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc (b : тДд)) :
        GL (Fin 2) тДЭ).val = ((Int.castRingHom тДЭ).mapMatrix
        (shiftSL_loc (b : тДд)).val) from by rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, (shiftSL_loc (b : тДд)).property]
    norm_num
  refine UpperHalfPlane_smul_eq_of_matrix_smul_eq _ _ h_det_pos_LHS h_det_pos_RHS
    (p : тДЭ) (by exact_mod_cast hp.ne') ?_ ╧Д
  -- Matrix entry equality: (T_p_lower ┬╖ T_p_upper(b)).val = p тАв shiftSL_loc(b).val
  ext i j
  fin_cases i <;> fin_cases j <;>
    simp [glMap, T_p_lower, T_p_upper, mapGL_coe_matrix, shiftSL_loc,
      Matrix.GeneralLinearGroup.mkOfDetNeZero, Matrix.GeneralLinearGroup.map,
      Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply, Units.val_mul,
      algebraMap_int_eq, Matrix.smul_apply] <;>
    ring

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM M_тИЮ-tile M├╢bius equivalence**: `T_p_lower ┬╖ M_тИЮ`
acts on `тДН` the same as `mapGL тДЭ (M_infty_Gamma1_factor) тИИ ╬УтВБ(N)`.

Composes the upper-tile M├╢bius equivalence at `b = 0` with the
matrix factorization
`glMap M_тИЮ = glMap T_p_upper(0) ┬╖ mapGL M_infty_Gamma1_factor`. -/
private theorem T_p_lower_mul_M_infty_smul_eq_M_infty_Gamma1_factor_smul
    (p : тДХ) [NeZero N] (hp : 0 < p) (hpN : Nat.Coprime p N) (╧Д : тДН) :
    ((glMap (T_p_lower p hp) : GL (Fin 2) тДЭ) *
      (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ)) тАв ╧Д =
    ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
      (M_infty_Gamma1_factor N p hpN 0) : GL (Fin 2) тДЭ) тАв ╧Д := by
  -- glMap M_тИЮ = glMap T_p_upper(0) ┬╖ mapGL M_infty_Gamma1_factor
  have h_M_infty_eq : (glMap (M_infty N p hp hpN) : GL (Fin 2) тДЭ) =
      (glMap (T_p_upper p hp 0) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (M_infty_Gamma1_factor N p hpN 0)) := by
    rw [тЖР glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp hpN 0,
      mul_inv_cancel_left]
  rw [h_M_infty_eq, тЖР mul_assoc, mul_smul]
  -- (T_p_lower ┬╖ T_p_upper(0)) тАв (mapGL M_infty_Gamma1_factor тАв ╧Д)
  -- = shift(0) тАв (mapGL M_infty_Gamma1_factor тАв ╧Д) [by tile equivalence]
  rw [T_p_lower_mul_T_p_upper_smul_eq_shift_smul p hp 0]
  -- shift(0) = id on тДН
  show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (shiftSL_loc ((0 : тДХ) : тДд))
    : GL (Fin 2) тДЭ) тАв _ = _
  rw [show shiftSL_loc ((0 : тДХ) : тДд) = (1 : SL(2, тДд)) from by
    apply Subtype.ext; ext i j
    fin_cases i <;> fin_cases j <;>
      simp [shiftSL_loc, Matrix.of_apply, Nat.cast_zero]]
  simp [MonoidHom.map_one, one_smul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205-d-SYMM M├╢bius equivalence on sets**: scalar invariance lifts
to set-level smul equality. If `╬▒, ╬▓ тИИ GL(2,тДЭ)тБ║` satisfy
`╬▒ тАв ╧Д = ╬▓ тАв ╧Д` for all ╧Д тИИ тДН, then `╬▒ тАв S = ╬▓ тАв S` for any `S тКЖ тДН`. -/
private lemma smul_set_eq_of_smul_eq
    {╬▒ ╬▓ : GL (Fin 2) тДЭ} (hsmul : тИА ╧Д : тДН, ╬▒ тАв ╧Д = ╬▓ тАв ╧Д) (S : Set тДН) :
    ╬▒ тАв S = ╬▓ тАв S := by
  ext ╧Д
  constructor
  ┬╖ rintro тЯи╧Г, h╧Г, rflтЯй
    exact тЯи╧Г, h╧Г, (hsmul ╧Г).symmтЯй
  ┬╖ rintro тЯи╧Г, h╧Г, rflтЯй
    exact тЯи╧Г, h╧Г, hsmul ╧ГтЯй

