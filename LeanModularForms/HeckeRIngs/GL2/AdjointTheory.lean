              SL(2, ℤ))⁻¹ : GL (Fin 2) ℝ))) := by
  rw [slash_diamond_outAt_Gamma1QuotEquiv_eq_slash_outAt p hp hpN f q]
  rw [slash_T_p_upper_eq_diamond_slash_T_p_lower_factor p hp hpN b g
