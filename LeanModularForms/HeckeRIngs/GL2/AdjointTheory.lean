        (тЗСf тИг[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ))) ╧Д)
        (Gamma1_fundDomain_PSL N) ╬╝_hyp)
    (hfi : IntegrableOn (fun ╧Д => petersson k тЗСf
        (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) ╧Д)
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        ╬▒_T_p_PSL_R p hp hpN i тАв (Gamma1_fundDomain_PSL N : Set тДН)) ╬╝_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N)
      (тИС i тИИ (Finset.univ : Finset (Option (Fin p))),
        тЗСf тИг[k] (match i with
          | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
          | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ))) тЗСg =
    peterssonInner k
      (тЛГ i тИИ (Finset.univ : Finset (Option (Fin p))),
        ╬▒_T_p_PSL_R p hp hpN i тАв (Gamma1_fundDomain_PSL N : Set тДН))
      тЗСf
      (тЗСg тИг[k] (glMap (T_p_lower p hp.pos) : GL (Fin 2) тДЭ)) := by
  -- biUnion bridge: projective тЖФ GL match form.
