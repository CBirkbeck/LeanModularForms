    тИС q : SL(2, тДд) тз╕ Gamma1 N,
      (peterssonInner k ModularGroup.fd
          ((тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
              (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
