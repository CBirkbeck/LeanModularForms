theorem sum_SL_Gamma_p_Оұ_petN_summand_eq_relIndex_mul_petN
    (Оұ : GL (Fin 2) в„ҡ) (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    вҲ‘ q : SL(2, в„Ө) в§ё Gamma_p_Оұ (N := N) Оұ,
      peterssonInner k (ModularGroup.fd : Set в„Қ)
        (вҮ‘f вҲЈ[k] (q.out : SL(2, в„Ө))вҒ»В№)
        (вҮ‘g вҲЈ[k] (q.out : SL(2, в„Ө))вҒ»В№) =
    (slGamma_p_ОұToGamma1_fiberCard (N := N) Оұ) вҖў petN f g := by
