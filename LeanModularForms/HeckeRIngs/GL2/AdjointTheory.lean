private theorem petN_heckeT_p_canonical_adjoint_residual
    (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k) :
    petN (heckeT_p_cusp k p hp hpN f) g =
      petN f (heckeT_p_cusp k p hp hpN
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g)) := by
  rw [show (heckeT_p_cusp k p hp hpN
        (diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g) :
        CuspForm ((Gamma1 N).map (mapGL в„қ)) k) =
      diamondOp_cusp k (ZMod.unitOfCoprime p hpN)вҒ»В№
        (heckeT_p_cusp k p hp hpN g) from by
    apply CuspForm.ext; intro П„
    show ((heckeT_p k p hp hpN)
        (diamondOp k (ZMod.unitOfCoprime p hpN)вҒ»В№ g.toModularForm')).toFun П„ =
