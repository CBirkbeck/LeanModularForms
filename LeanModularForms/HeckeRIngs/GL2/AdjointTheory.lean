open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205/T128 integrability bridge**: integrability of
`petersson k g (f тИг[k] ╬▒)` on `D` follows from integrability of
`petersson k f g'` on `╬▒ тАв D` + the adjoint identity
`g тИг[k] peterssonAdj ╬▒ = g'`.

This is the `h_int` shape needed by
`peterssonInner_sum_slash_adjoint_constantRHS`: it transports
integrability from the RHS union-domain form (where T094's
`integrableOn_petersson_biUnion_glMap_smul` applies for cusp forms)
back to the per-summand fd form needed for `peterssonInner_add_left`
distribution of `+` across a ╬г_b sum.

**Proof pattern** (mirrors `peterssonInner_slash_adjoint`):
1. Decompose `g = (g тИг ╬▒тБ╗┬╣) тИг ╬▒`, apply `petersson_slash` (with
   `╧Г ╬▒ = id` for positive det) to get pointwise
   `petersson k (f тИг ╬▒) g ╧Д = |╬▒.det|^(k-2) ┬╖ petersson k f (g тИг ╬▒тБ╗┬╣) (╬▒ тАв ╧Д)`.
2. Use `slash_peterssonAdj_eq` + `hadj` to identify
   `|╬▒.det|^(k-2) тАв (g тИг ╬▒тБ╗┬╣) = g'`, yielding
   `|╬▒.det|^(k-2) ┬╖ petersson k f (g тИг ╬▒тБ╗┬╣) = petersson k f g'` (petersson
   linearity in 2nd arg).
3. Conjugate via `petersson_symm`: `petersson k g (f тИг ╬▒) ╧Д =
   conj(petersson k f g' (╬▒ тАв ╧Д)) = petersson k g' f (╬▒ тАв ╧Д)`.
4. Transfer integrability via `MeasurePreserving.integrableOn_image`
   (setIntegral pattern) + `petersson_symm` (norm-preserving conjugate). -/
private lemma integrableOn_petersson_slash_of_adj_image
    (D : Set тДН) (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (f g g' : тДН тЖТ тДВ)
    (hadj : g тИг[k] peterssonAdj ╬▒ = g')
    (hfi : IntegrableOn (fun ╧Д => petersson k f g' ╧Д) (╬▒ тАв D) ╬╝_hyp) :
    IntegrableOn (fun ╧Д => petersson k g (f тИг[k] ╬▒) ╧Д) D ╬╝_hyp := by
  -- Step 1: establish pointwise identity.
  -- `petersson k g (f тИг ╬▒) ╧Д = petersson k g' f (╬▒ тАв ╧Д)`.
  have hg_decomp : g = (g тИг[k] ╬▒тБ╗┬╣) тИг[k] ╬▒ := by
    rw [тЖР SlashAction.slash_mul, inv_mul_cancel, SlashAction.slash_one]
  set g_inv := g тИг[k] ╬▒тБ╗┬╣ with hg_inv_def
  have h_pointwise : тИА ╧Д, petersson k g (f тИг[k] ╬▒) ╧Д =
      petersson k g' f (╬▒ тАв ╧Д) := by
    intro ╧Д
    -- `petersson k g (f тИг ╬▒) ╧Д = conj (petersson k (f тИг ╬▒) g ╧Д)`.
    rw [petersson_symm k (f тИг[k] ╬▒) g]
    -- `petersson k (f тИг ╬▒) g ╧Д = petersson k (f тИг ╬▒) (g_inv тИг ╬▒) ╧Д`.
    conv_lhs => rw [show g = g_inv тИг[k] ╬▒ from hg_decomp]
    -- Apply `petersson_slash` + `╧Г ╬▒ = id`.
    rw [petersson_slash, show ╧Г ╬▒ = RingHom.id тДВ from if_pos h╬▒, RingHom.id_apply]
    -- Goal: `conj (|╬▒.det|^(k-2) * petersson k f g_inv (╬▒ тАв ╧Д)) = petersson k g' f (╬▒ тАв ╧Д)`.
    -- First: `|╬▒.det|^(k-2) * petersson k f g_inv = petersson k f (|╬▒.det|^(k-2) тАв g_inv)`.
    have h_scalar : (тЖС|╬▒.det.val| ^ (k - 2) : тДВ) * petersson k f g_inv (╬▒ тАв ╧Д) =
        petersson k f ((тЖС(|╬▒.det.val| ^ (k - 2)) : тДВ) тАв g_inv) (╬▒ тАв ╧Д) := by
      simp [petersson, Pi.smul_apply, smul_eq_mul]; ring
    rw [h_scalar]
    -- `|╬▒.det|^(k-2) тАв g_inv = g тИг peterssonAdj ╬▒ = g'` (by slash_peterssonAdj_eq + hadj).
    rw [show ((тЖС(|╬▒.det.val| ^ (k - 2)) : тДВ) тАв g_inv) = g' from by
      rw [тЖР hadj, hg_inv_def, slash_peterssonAdj_eq ╬▒ h╬▒]]
    -- Goal: `conj (petersson k f g' (╬▒ тАв ╧Д)) = petersson k g' f (╬▒ тАв ╧Д)`.
    exact (petersson_symm k f g' (╬▒ тАв ╧Д)).symm
  -- Step 2: transfer integrability via change of variables + petersson_symm.
  have h_fn_eq : (fun ╧Д => petersson k g (f тИг[k] ╬▒) ╧Д) =
      fun ╧Д => petersson k g' f (╬▒ тАв ╧Д) := funext h_pointwise
  rw [h_fn_eq]
  -- Use `MeasurePreserving.integrableOn_image` (reverse): from
  -- `IntegrableOn h (╬▒ тАв D)` to `IntegrableOn (h тИШ (╬▒ тАв ┬╖)) D`.
  set ╬▒' : GL(2, тДЭ)тБ║ := тЯи╬▒, h╬▒тЯй
  have h_╬▒_eq : (╬▒ : GL (Fin 2) тДЭ) тАв D = (fun ╧Д => ╬▒' тАв ╧Д) '' D := by
    rw [Set.image_smul]; rfl
  rw [show (fun ╧Д => petersson k g' f (╬▒ тАв ╧Д)) =
      petersson k g' f тИШ (fun ╧Д => ╬▒' тАв ╧Д) from rfl]
  rw [тЖР (measurePreserving_smul ╬▒' ╬╝_hyp).integrableOn_image
      (measurableEmbedding_const_smul ╬▒')]
  -- Goal: `IntegrableOn (petersson k g' f) (╬▒ тАв D) ╬╝_hyp`.
  rw [h_╬▒_eq] at hfi
  -- Use `petersson_symm`: `petersson k g' f ╧Д = conj (petersson k f g' ╧Д)`.
  -- Rewrite the goal's integrand via pointwise-equality.
  have h_symm_fn : (petersson k g' f : тДН тЖТ тДВ) =
      fun ╧Д => starRingEnd тДВ (petersson k f g' ╧Д) :=
    funext fun ╧Д => petersson_symm k f g' ╧Д
  rw [h_symm_fn]
  -- Use that `starRingEnd тДВ` is a continuous linear map with norm 1, so integrability transfers.
  -- Actually `IntegrableOn h S ╬╝` for `h = star тИШ f` follows from `IntegrableOn f S ╬╝`
  -- since `тАЦstar zтАЦ = тАЦzтАЦ` (norm preservation) + `star` continuous (measurability preservation).
  refine тЯи?_, ?_тЯй
  ┬╖ -- AEStronglyMeasurable: continuous conj composed with a measurable function.
    exact Complex.continuous_conj.comp_aestronglyMeasurable hfi.aestronglyMeasurable
  ┬╖ -- HasFiniteIntegral: тИл тАЦconj тИШ hтАЦтВС = тИл тАЦhтАЦтВС since `тАЦconj zтАЦ = тАЦzтАЦ`.
    have h_finite := hfi.2
    show HasFiniteIntegral _ _
    unfold HasFiniteIntegral at h_finite тКв
    refine lt_of_le_of_lt (le_of_eq ?_) h_finite
    apply lintegral_congr_ae
    filter_upwards with ╧Д
    show тАЦ(starRingEnd тДВ) (petersson k f g' ╧Д)тАЦтВС = тАЦpetersson k f g' ╧ДтАЦтВС
    rw [enorm_eq_nnnorm, enorm_eq_nnnorm]
    congr 1
    exact Subtype.ext (Complex.norm_conj _)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205/T128 bridge: GL-pair AE-disjoint on the SL(2, тДд)-fundamental
domain `ModularGroup.fd` via `mapGL тДЭ ╧Г`-factored inverse product**.

For `╬▒тВБ, ╬▒тВВ : GL (Fin 2) тДЭ` with `╬▒тВБтБ╗┬╣` measure-preserving on `тДН`, if
`╬▒тВБтБ╗┬╣ * ╬▒тВВ = mapGL тДЭ ╧Г` for some `╧Г : SL(2, тДд)` with non-trivial image
in `PSL(2, тДд)`, then `╬▒тВБ тАв fd` and `╬▒тВВ тАв fd` are AE-disjoint.

This is the `fd`-version of
`aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1` (which works for
`Gamma1_fundDomain_PSL N`).  It is the specific AE-disjointness needed
for the T205 upper-family union collapse on the per-`q` tile
`(mapGL qтБ╗┬╣) тАв fd`, where the `╧Г = q ┬╖ shift(bтВВ-bтВБ) ┬╖ qтБ╗┬╣` conjugate
product lands in `SL(2, тДд) \ ╬УтВБ(N)` in general (╬УтВБ(N) is not normal
in SL(2, тДд)), so the ╬УтВБ-version cannot be invoked directly.

**Proof route** (per manager guidance):
1. Start from `isFundamentalDomain_fdo_PSL.aedisjoint` (gives
   `AEDisjoint fdo (q тАв fdo)` for `q = тЯи╧ГтЯй тЙа 1 тИИ PSL(2, тДд)`).
2. Transfer from `fdo` to `fd` via `fd_ae_eq_fdo` + `AEDisjoint.congr`,
   using that `q`-smul preserves a.e. equality of sets (as `q` acts by
   a measure-preserving map on `тДН`).
3. Pull back by `╬▒тВБтБ╗┬╣` following the pattern of
   `aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1`. -/
theorem aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne
    (╬▒тВБ ╬▒тВВ : GL (Fin 2) тДЭ)
    (h_mp_inv : MeasurePreserving ((╬▒тВБтБ╗┬╣ тАв ┬╖) : тДН тЖТ тДН) ╬╝_hyp ╬╝_hyp)
    (╧Г : SL(2, тДд)) (h╧Г_ne : (QuotientGroup.mk ╧Г : PSL(2, тДд)) тЙа 1)
    (h_inv_mul : ╬▒тВБтБ╗┬╣ * ╬▒тВВ =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╧Г : GL (Fin 2) тДЭ)) :
    AEDisjoint ╬╝_hyp (╬▒тВБ тАв (ModularGroup.fd : Set UpperHalfPlane))
      (╬▒тВВ тАв (ModularGroup.fd : Set UpperHalfPlane)) := by
  set q : PSL(2, тДд) := QuotientGroup.mk ╧Г with hq_def
  -- Step 1: `AEDisjoint fdo (q тАв fdo)` from `isFundamentalDomain_fdo_PSL`.
  have h_fdo_aedisjoint : AEDisjoint ╬╝_hyp (fdo : Set тДН) (q тАв (fdo : Set тДН)) := by
    have h_ne : (1 : PSL(2, тДд)) тЙа q := fun h => h╧Г_ne h.symm
    have h_gen := isFundamentalDomain_fdo_PSL.aedisjoint h_ne
    -- Unfold `Function.onFun` and simplify `1 тАв fdo = fdo`.
    simp only [Function.onFun, one_smul] at h_gen
    exact h_gen
  -- Step 2: `q`-smul of `fd` and `fdo` agree a.e. (since `fd =с╡Р fdo` and
  -- `q`-smul is measure-preserving on `тДН` via `instSMulInvMeasure_PSL`).
  have h_q_smul_aeeq :
      (q тАв (ModularGroup.fd : Set UpperHalfPlane) : Set тДН) =с╡Р[╬╝_hyp] (q тАв (fdo : Set тДН)) := by
    refine ae_eq_set.mpr тЯи?_, ?_тЯй
    ┬╖ -- ╬╝ (q тАв fd \ q тАв fdo) = ╬╝ (q тАв (fd \ fdo)) = ╬╝ (fd \ fdo) = 0
      -- (using `measure_smul` via `instSMulInvMeasure_PSL`).
      have h_sdiff : (q тАв (ModularGroup.fd : Set UpperHalfPlane) \ q тАв (fdo : Set тДН) : Set тДН) =
          q тАв ((ModularGroup.fd : Set UpperHalfPlane) \ fdo) := by
        ext x
        simp only [Set.mem_diff, Set.mem_smul_set_iff_inv_smul_mem]
      rw [h_sdiff, measure_smul]
      exact hyperbolicMeasure_fd_boundary
    ┬╖ -- ╬╝ (q тАв fdo \ q тАв fd) = 0 because `fdo тКЖ fd` makes this set empty.
      have h_fdo_sub_fd : q тАв (fdo : Set тДН) тКЖ q тАв (ModularGroup.fd : Set UpperHalfPlane) := by
        intro x hx
        rcases hx with тЯиy, hy, rflтЯй
        exact тЯиy, fdo_subset_fd hy, rflтЯй
      rw [Set.diff_eq_empty.mpr h_fdo_sub_fd]
      exact measure_empty
  -- Step 3: `AEDisjoint fd (q тАв fd)` by transferring from Step 1 via Step 2.
  have h_inner : AEDisjoint ╬╝_hyp (ModularGroup.fd : Set UpperHalfPlane)
      (q тАв (ModularGroup.fd : Set UpperHalfPlane)) :=
    h_fdo_aedisjoint.congr fd_ae_eq_fdo h_q_smul_aeeq
  -- Step 4: Preimage identifications (same as Gamma1 version).
  have h_pre_╬▒тВБ : ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (ModularGroup.fd : Set UpperHalfPlane) : Set тДН) =
      ╬▒тВБ тАв (ModularGroup.fd : Set UpperHalfPlane) := by
    ext ╧Д; simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  have h_pre_╬▒тВВ : ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (q тАв (ModularGroup.fd : Set UpperHalfPlane)) : Set тДН) =
      ╬▒тВВ тАв (ModularGroup.fd : Set UpperHalfPlane) := by
    ext ╧Д
    simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    have hq_smul : тИА z : тДН, (qтБ╗┬╣ тАв z : тДН) =
        (((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╧Г)тБ╗┬╣ : GL (Fin 2) тДЭ) тАв z := by
      intro z
      rw [hq_def, тЖР QuotientGroup.mk_inv, PSL_smul_coe]
      rw [sl_moeb, show ((╧ГтБ╗┬╣ : SL(2, тДд)) : GL (Fin 2) тДЭ) =
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╧Г)тБ╗┬╣ from by
        rw [тЖР map_inv]; rfl]
    rw [hq_smul (╬▒тВБтБ╗┬╣ тАв ╧Д)]
    have h_eq : ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╧Г)тБ╗┬╣ = ╬▒тВВтБ╗┬╣ * ╬▒тВБ := by
      rw [тЖР h_inv_mul, mul_inv_rev, inv_inv]
    rw [h_eq, mul_smul]
    rw [show (╬▒тВБ тАв ╬▒тВБтБ╗┬╣ тАв ╧Д : тДН) = ╧Д from by
      rw [тЖР mul_smul, mul_inv_cancel, one_smul]]
  -- Step 5: AE-disjointness of preimages via quasi-measure-preserving.
  have h_QMP : MeasureTheory.Measure.QuasiMeasurePreserving
      ((╬▒тВБтБ╗┬╣ тАв ┬╖) : тДН тЖТ тДН) ╬╝_hyp ╬╝_hyp :=
    h_mp_inv.quasiMeasurePreserving
  have h_pre_aedisjoint : AEDisjoint ╬╝_hyp
      ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (ModularGroup.fd : Set UpperHalfPlane))
      ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (q тАв (ModularGroup.fd : Set UpperHalfPlane))) :=
    h_inner.preimage h_QMP
  rw [h_pre_╬▒тВБ, h_pre_╬▒тВВ] at h_pre_aedisjoint
  exact h_pre_aedisjoint

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094 bridge: GL-pair AE-disjoint via `mapGL тДЭ ╬│`-factored inverse product.**

For `╬▒тВБ, ╬▒тВВ : GL (Fin 2) тДЭ` with `╬▒тВБтБ╗┬╣` measure-preserving on тДН, if
`╬▒тВБтБ╗┬╣ * ╬▒тВВ = mapGL тДЭ ╬│` for some `╬│ тИИ ╬УтВБ(N)` non-trivial in `PSL(2,тДд)`,
then `╬▒тВБ тАв D_N^PSL` and `╬▒тВВ тАв D_N^PSL` are AE-disjoint. -/
theorem aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    {N : тДХ} [NeZero N] (╬▒тВБ ╬▒тВВ : GL (Fin 2) тДЭ)
    (h_mp_inv : MeasurePreserving ((╬▒тВБтБ╗┬╣ тАв ┬╖) : тДН тЖТ тДН) ╬╝_hyp ╬╝_hyp)
    (╬│ : SL(2, тДд)) (h╬│_╬У1 : ╬│ тИИ Gamma1 N)
    (h╬│_ne : (QuotientGroup.mk ╬│ : PSL(2, тДд)) тЙа 1)
    (h_inv_mul : ╬▒тВБтБ╗┬╣ * ╬▒тВВ = ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│ : GL (Fin 2) тДЭ)) :
    AEDisjoint ╬╝_hyp (╬▒тВБ тАв (Gamma1_fundDomain_PSL N : Set тДН))
      (╬▒тВВ тАв (Gamma1_fundDomain_PSL N : Set тДН)) := by
  set D : Set тДН := Gamma1_fundDomain_PSL N
  set q : PSL(2, тДд) := QuotientGroup.mk ╬│ with hq_def
  have h_inner : AEDisjoint ╬╝_hyp D (q тАв D) := by
    have h_mem : (1 : PSL(2, тДд))тБ╗┬╣ * q тИИ imageGamma1_PSL N := by
      rw [inv_one, one_mul, hq_def]
      exact Subgroup.mem_map.mpr тЯи╬│, h╬│_╬У1, rflтЯй
    have h_ne : (1 : PSL(2, тДд))тБ╗┬╣ * q тЙа 1 := by
      rw [inv_one, one_mul]; exact h╬│_ne
    have h_gen := isFundamentalDomain_Gamma1_coset_tiling (N := N)
      |>.aedisjoint_smul_of_mul_inv_mem h_mem h_ne
    rwa [one_smul] at h_gen
  have h_pre_╬▒тВБ : ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' D : Set тДН) = ╬▒тВБ тАв D := by
    ext ╧Д; simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
  have h_pre_╬▒тВВ : ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (q тАв D) : Set тДН) = ╬▒тВВ тАв D := by
    ext ╧Д
    simp only [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    have hq_smul : тИА ╧Г : тДН, (qтБ╗┬╣ тАв ╧Г : тДН) =
        (((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│)тБ╗┬╣ : GL (Fin 2) тДЭ) тАв ╧Г := by
      intro ╧Г
      rw [hq_def, тЖР QuotientGroup.mk_inv, PSL_smul_coe]
      rw [sl_moeb, show ((╬│тБ╗┬╣ : SL(2, тДд)) : GL (Fin 2) тДЭ) =
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│)тБ╗┬╣ from by
        rw [тЖР map_inv]; rfl]
    rw [hq_smul (╬▒тВБтБ╗┬╣ тАв ╧Д)]
    have h_eq : ((mapGL тДЭ : SL(2, тДд) тЖТ* _) ╬│)тБ╗┬╣ = ╬▒тВВтБ╗┬╣ * ╬▒тВБ := by
      rw [тЖР h_inv_mul, mul_inv_rev, inv_inv]
    rw [h_eq, mul_smul]
    rw [show (╬▒тВБ тАв ╬▒тВБтБ╗┬╣ тАв ╧Д : тДН) = ╧Д from by
      rw [тЖР mul_smul, mul_inv_cancel, one_smul]]
  have h_QMP : MeasureTheory.Measure.QuasiMeasurePreserving
      ((╬▒тВБтБ╗┬╣ тАв ┬╖) : тДН тЖТ тДН) ╬╝_hyp ╬╝_hyp :=
    h_mp_inv.quasiMeasurePreserving
  have h_pre_aedisjoint : AEDisjoint ╬╝_hyp
      ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' D) ((╬▒тВБтБ╗┬╣ тАв ┬╖) тБ╗┬╣' (q тАв D)) :=
    h_inner.preimage h_QMP
  rw [h_pre_╬▒тВБ, h_pre_╬▒тВВ] at h_pre_aedisjoint
  exact h_pre_aedisjoint

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094 matrix identity M1: `T_p_upper` inverse-product factors through
`shiftSL_loc`.**

`(glMap T_p_upper(bтВБ))тБ╗┬╣ * (glMap T_p_upper(bтВВ)) = mapGL тДЭ (shiftSL_loc (bтВВ - bтВБ))`
in `GL (Fin 2) тДЭ`. Proved via `A * (shift) = B` computation, inverted. -/
theorem glMap_T_p_upper_inv_mul_eq_mapGL_shift
    {p : тДХ} (hp : 0 < p) (bтВБ bтВВ : тДХ) :
    (glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣ *
        (glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)))) := by
  -- Strategy: show `glMap T_p_upper(bтВВ) = glMap T_p_upper(bтВБ) * mapGL тДЭ (shift)`.
  have h_mul : (glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) =
      (glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)))) := by
    apply Units.ext
    ext i j
    have h_L : ((glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) = !![(1 : тДЭ), (bтВВ : тДЭ); 0, (p : тДЭ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R1 : ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) = !![(1 : тДЭ), (bтВБ : тДЭ); 0, (p : тДЭ)] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [glMap, T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
          Matrix.GeneralLinearGroup.map, Matrix.of_apply]
    have h_R2 : (((mapGL тДЭ : SL(2, тДд) тЖТ* _) (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)))) :
        Matrix (Fin 2) (Fin 2) тДЭ) = !![(1 : тДЭ), (bтВВ : тДЭ) - (bтВБ : тДЭ); 0, 1] := by
      ext i' j'; fin_cases i' <;> fin_cases j' <;>
        simp [mapGL_coe_matrix, shiftSL_loc, algebraMap_int_eq, Matrix.of_apply]
    show ((glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) : Matrix _ _ тДЭ) i j =
      ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) *
       ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)))) :
       GL (Fin 2) тДЭ).val i j
    rw [h_L, Units.val_mul, h_R1, h_R2]
    fin_cases i <;> fin_cases j <;>
      simp [Matrix.mul_apply, Fin.sum_univ_two, Matrix.of_apply] <;> ring
  rw [h_mul, тЖР mul_assoc, inv_mul_cancel, one_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T094: AE-disjoint for two `T_p_upper`-translates.** -/
theorem aedisjoint_glMap_T_p_upper_pair
    {N : тДХ} [NeZero N] {p : тДХ} (hp : 0 < p) {bтВБ bтВВ : тДХ}
    (hne : (bтВВ : тДд) - (bтВБ : тДд) тЙа 0) :
    AEDisjoint ╬╝_hyp
      ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) тАв
        (Gamma1_fundDomain_PSL N : Set тДН))
      ((glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) тАв
        (Gamma1_fundDomain_PSL N : Set тДН)) := by
  have h_det_pos : тИА b, 0 < (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
      (algebraMap тДЪ тДЭ) (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det) from
        (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp
  have h_inv_det_pos : 0 <
      ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣).det.val := by
    have h╬▒_pos := h_det_pos bтВБ
    show 0 < ((((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show (((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣).det : тДЭ╦г) =
        ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ).det : тДЭ╦г)тБ╗┬╣ from map_inv _ _]
    show 0 < (((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ).det : тДЭ╦г))тБ╗┬╣.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h╬▒_pos
  have h_psl_ne : (QuotientGroup.mk (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд))) :
      PSL(2, тДд)) тЙа 1 := by
    intro heq
    rw [QuotientGroup.eq_one_iff] at heq
    have hS : (!![(0 : тДд), -1; 1, 0] : Matrix (Fin 2) (Fin 2) тДд).det = 1 := by
      simp [Matrix.det_fin_two]
    set S_mat : SL(2, тДд) := тЯи!![0, -1; 1, 0], hSтЯй
    have hcomm : shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) * S_mat =
        S_mat * shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) := heq.comm S_mat
    have hcomm_val :
        (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) : SL(2, тДд)).val * S_mat.val =
        S_mat.val * (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) : SL(2, тДд)).val :=
      congr_arg Subtype.val hcomm
    have h_00 := congr_fun (congr_fun hcomm_val 0) 0
    simp only [S_mat, shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two,
      Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
      Matrix.head_cons, Matrix.head_fin_const] at h_00
    apply hne; linarith
  exact aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1
    (glMap (T_p_upper p hp bтВБ)) (glMap (T_p_upper p hp bтВВ))
    (measurePreserving_glPos_smul _ h_inv_det_pos)
    (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд))) (shiftSL_loc_mem_Gamma1 _) h_psl_ne
    (glMap_T_p_upper_inv_mul_eq_mapGL_shift hp bтВБ bтВВ)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205 per-`q` upper-family pairwise AE-disjoint on `fd`-tiles**:
for fixed `q : SL(2, тДд)` and `bтВБ тЙа bтВВ`, the tiles
`(glMap T_p_upper(p, b) * mapGL qтБ╗┬╣) тАв fd` are pairwise AE-disjoint.

This is the `hd` input for `peterssonInner_biUnion_finset_ae` / the
`peterssonInner_sum_slash_adjoint_constantRHS` finite-family collapse on
the T205 upper family at each `q : SL(2, тДд) тз╕ ╬УтВБ(N)`.

**Uses**: `aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne` (fd-level
bridge) with `╧Г = q ┬╖ shiftSL_loc(bтВВ-bтВБ) ┬╖ qтБ╗┬╣`, `h_inv_mul` from
`glMap_T_p_upper_inv_mul_eq_mapGL_shift` combined with conjugation by
`mapGL qтБ╗┬╣`, and PSL nontriviality of the conjugate from the existing
shift-commutation argument (transported through conjugation: a group
element is trivial in a quotient iff its conjugate is).

**Why not the ╬УтВБ-version**: `(╬▒тВБ)тБ╗┬╣ ┬╖ ╬▒тВВ = mapGL(q ┬╖ shift(bтВВ-bтВБ) ┬╖ qтБ╗┬╣)`
lands in `SL(2, тДд) \ ╬УтВБ(N)` in general (╬УтВБ(N) is not normal in SL(2, тДд)),
so `aedisjoint_glMap_smul_of_mul_inv_eq_mapGL_Gamma1` does not apply. -/
theorem aedisjoint_glMap_T_p_upper_pair_fd_per_q
    {p : тДХ} (hp : 0 < p) (q : SL(2, тДд)) {bтВБ bтВВ : тДХ}
    (hne : (bтВВ : тДд) - (bтВБ : тДд) тЙа 0) :
    AEDisjoint ╬╝_hyp
      (((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set UpperHalfPlane))
      (((glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set UpperHalfPlane)) := by
  set ╬▒тВБ : GL (Fin 2) тДЭ :=
    (glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)
  set ╬▒тВВ : GL (Fin 2) тДЭ :=
    (glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)
  -- Positive det of `glMap T_p_upper(p, b)` (= p > 0).
  have h_Tp_det_pos :
      тИА b, 0 < (glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
        (algebraMap тДЪ тДЭ) (((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp b : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp
  -- Det of matrix of `mapGL qтБ╗┬╣` is 1 (since `qтБ╗┬╣ тИИ SL(2, тДд)`).
  have h_mapGL_mat_det_eq_one :
      (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = 1 := by
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix (qтБ╗┬╣ : SL(2, тДд)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, (qтБ╗┬╣ : SL(2, тДд)).property]
    simp
  -- Positive det of ╬▒тВБ = glMap T_p_upper(p, bтВБ) * mapGL qтБ╗┬╣.
  have h_╬▒тВБ_det_pos : 0 < (╬▒тВБ : GL (Fin 2) тДЭ).det.val := by
    show 0 < ((╬▒тВБ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((╬▒тВБ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ) =
        ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ) *
        (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact h_Tp_det_pos bтВБ
  -- Positive det of ╬▒тВБтБ╗┬╣ = 1/det(╬▒тВБ) > 0.
  have h_╬▒тВБ_inv_det_pos : 0 < (╬▒тВБтБ╗┬╣ : GL (Fin 2) тДЭ).det.val := by
    show 0 < (((╬▒тВБтБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show ((╬▒тВБтБ╗┬╣ : GL (Fin 2) тДЭ)).det = ╬▒тВБ.detтБ╗┬╣ from map_inv _ _,
      Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h_╬▒тВБ_det_pos
  -- Matrix identity: ╬▒тВБтБ╗┬╣ * ╬▒тВВ = mapGL (q * shift(bтВВ-bтВБ) * qтБ╗┬╣).
  have h_inv_mul : ╬▒тВБтБ╗┬╣ * ╬▒тВВ =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (q * shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) * qтБ╗┬╣) : GL (Fin 2) тДЭ) := by
    show (((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ *
        ((glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))) = _
    rw [mul_inv_rev]
    -- `((mapGL qтБ╗┬╣))тБ╗┬╣ = mapGL q`.
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ =
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) q : GL (Fin 2) тДЭ) from by
        rw [тЖР map_inv]; simp]
    -- Re-associate: (mapGL q * (glMap T_p_upper(bтВБ))тБ╗┬╣) * (glMap T_p_upper(bтВВ) * mapGL qтБ╗┬╣)
    --             = mapGL q * ((glMap T_p_upper(bтВБ))тБ╗┬╣ * glMap T_p_upper(bтВВ)) * mapGL qтБ╗┬╣
    rw [mul_assoc ((mapGL тДЭ : SL(2, тДд) тЖТ* _) q : GL (Fin 2) тДЭ)
          (glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣,
      тЖР mul_assoc ((glMap (T_p_upper p hp bтВБ) : GL (Fin 2) тДЭ)тБ╗┬╣)
          (glMap (T_p_upper p hp bтВВ) : GL (Fin 2) тДЭ)
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ),
      glMap_T_p_upper_inv_mul_eq_mapGL_shift hp bтВБ bтВВ,
      тЖР mul_assoc]
    -- Now: mapGL q * mapGL shift * mapGL qтБ╗┬╣ = mapGL (q * shift * qтБ╗┬╣).
    rw [тЖР map_mul, тЖР map_mul]
  -- PSL nontriviality of the conjugate `q ┬╖ shift(bтВВ-bтВБ) ┬╖ qтБ╗┬╣`.
  -- Reduce to nontriviality of `shift(bтВВ-bтВБ)` by conjugation invariance in
  -- the group quotient.
  have h_psl_shift_ne :
      (QuotientGroup.mk (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд))) :
        PSL(2, тДд)) тЙа 1 := by
    intro heq
    rw [QuotientGroup.eq_one_iff] at heq
    have hS : (!![(0 : тДд), -1; 1, 0] : Matrix (Fin 2) (Fin 2) тДд).det = 1 := by
      simp [Matrix.det_fin_two]
    set S_mat : SL(2, тДд) := тЯи!![0, -1; 1, 0], hSтЯй
    have hcomm : shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) * S_mat =
        S_mat * shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) := heq.comm S_mat
    have hcomm_val :
        (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) : SL(2, тДд)).val * S_mat.val =
        S_mat.val * (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) : SL(2, тДд)).val :=
      congr_arg Subtype.val hcomm
    have h_00 := congr_fun (congr_fun hcomm_val 0) 0
    simp only [S_mat, shiftSL_loc, Matrix.mul_apply, Fin.sum_univ_two,
      Matrix.of_apply, Matrix.cons_val_zero, Matrix.cons_val_one,
      Matrix.head_cons, Matrix.head_fin_const] at h_00
    apply hne; linarith
  have h_psl_conj_ne :
      (QuotientGroup.mk (q * shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) * qтБ╗┬╣) :
        PSL(2, тДд)) тЙа 1 := by
    intro heq
    apply h_psl_shift_ne
    have hconj : (QuotientGroup.mk q : PSL(2, тДд)) *
            (QuotientGroup.mk (shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд))) : PSL(2, тДд)) *
            (QuotientGroup.mk q : PSL(2, тДд))тБ╗┬╣ = 1 := by
      rw [тЖР QuotientGroup.mk_inv, тЖР QuotientGroup.mk_mul, тЖР QuotientGroup.mk_mul]
      exact heq
    -- Solve for shift from the conjugate equation.
    rw [mul_inv_eq_one] at hconj
    -- hconj : тЯиqтЯй * тЯиshiftтЯй = тЯиqтЯй; conclude тЯиshiftтЯй = 1 via `mul_left_cancel` on
    -- `тЯиqтЯй * тЯиshiftтЯй = тЯиqтЯй * 1`.
    exact mul_left_cancel (hconj.trans (mul_one _).symm)
  -- Apply the fd-level helper.
  exact aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne ╬▒тВБ ╬▒тВВ
    (measurePreserving_glPos_smul _ h_╬▒тВБ_inv_det_pos)
    (q * shiftSL_loc ((bтВВ : тДд) - (bтВБ : тДд)) * qтБ╗┬╣)
    h_psl_conj_ne h_inv_mul

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T205 per-`q` upper-family union-collapse (peterssonInner form)**.

For fixed `q : SL(2, тДд)` and ╬УтВБ(N)-cusp forms `f, g`, the sum of
`peterssonInner` over per-`b` upper-family fd-tiles collapses to a single
`peterssonInner` on the union-domain with the b-INDEPENDENT `g`-slot
`G := (тЗСg тИг[k] glMap T_p_upper(p, 0)) тИг[k] mapGL ╬│тВА`.

Directly invokes `peterssonInner_biUnion_finset_ae`, with:
- `hd` supplied by `aedisjoint_glMap_T_p_upper_pair_fd_per_q`;
- `hm` by a pointwise preimage identification
  `╬▒_b тАв fd = (╬▒_bтБ╗┬╣ тАв ┬╖) тБ╗┬╣' fd` + `NullMeasurableSet.preimage` via
  `QuasiMeasurePreserving` (from `measurePreserving_glPos_smul` on positive
  determinant `╬▒_bтБ╗┬╣`) + `MeasurableSet fd` (fd as closed intersection of
  `|z| тЙе 1 тИй |Re(z)| тЙд 1/2`);
- `hfi` (integrability of `petersson k тЗСf G` over the union) is taken as a
  hypothesis, to be supplied by a separate integrability helper (the second
  blocker identified in the obstruction report).

**Role in T205 closure.** This is the finite-family collapse that turns the
upper `тИС_b peterssonInner` into a single union-domain integral, the final
step before `peterssonInner_sum_slash_adjoint_constantRHS`-style assembly. -/
theorem peterssonInner_T_p_upper_family_union_collapse_per_q
    {p : тДХ} [NeZero N] (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (hfi : IntegrableOn
      (fun ╧Д => petersson k тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) ╧Д)
      (тЛГ b тИИ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane)) ╬╝_hyp) :
    тИС b тИИ Finset.range p,
      peterssonInner k
        (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane))
        тЗСf
        ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
            ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) =
    peterssonInner k
      (тЛГ b тИИ Finset.range p,
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane))
      тЗСf
      ((тЗСg тИг[k] (glMap (T_p_upper p hp.pos 0) : GL (Fin 2) тДЭ)) тИг[k]
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          ((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд)))) := by
  -- `fd` is measurable (closed intersection of two half-planes).
  have h_fd_mset : MeasurableSet (ModularGroup.fd : Set UpperHalfPlane) :=
    ((isClosed_le continuous_const
        (Complex.continuous_normSq.comp UpperHalfPlane.continuous_coe)).inter
      (isClosed_le (continuous_abs.comp UpperHalfPlane.continuous_re)
        continuous_const)).measurableSet
  have h_fd_null : NullMeasurableSet (ModularGroup.fd : Set UpperHalfPlane) ╬╝_hyp :=
    h_fd_mset.nullMeasurableSet
  -- Positive determinants of ╬▒_b and ╬▒_bтБ╗┬╣.
  have h_Tp_det_pos :
      тИА b, 0 < (glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ).det.val := by
    intro b
    show 0 < ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) :
      Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ) from rfl]
    rw [show (((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).map (algebraMap тДЪ тДЭ)).det =
        (algebraMap тДЪ тДЭ) (((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).det) from
          (RingHom.map_det _ _).symm]
    rw [show ((T_p_upper p hp.pos b : GL (Fin 2) тДЪ).val).det = (p : тДЪ) from by
      simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
        Matrix.det_fin_two, Matrix.of_apply]]
    show 0 < (algebraMap тДЪ тДЭ) ((p : тДЪ))
    rw [show (algebraMap тДЪ тДЭ) ((p : тДЪ)) = ((p : тДЪ) : тДЭ) from rfl]
    exact_mod_cast hp.pos
  have h_mapGL_mat_det_eq_one :
      (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = 1 := by
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix (qтБ╗┬╣ : SL(2, тДд)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, (qтБ╗┬╣ : SL(2, тДд)).property]
    simp
  have h_╬▒_det_pos : тИА b, 0 <
      ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)).det.val := fun b => by
    show 0 < (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) :
          Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) :
            Matrix (Fin 2) (Fin 2) тДЭ) =
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) *
        (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact h_Tp_det_pos b
  have h_╬▒_inv_det_pos : тИА b, 0 <
      (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ :
          GL (Fin 2) тДЭ).det.val := fun b => by
    have h╬▒_pos := h_╬▒_det_pos b
    show 0 < (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣).det : тДЭ╦г)) =
        ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)).det : тДЭ╦г))тБ╗┬╣ from
          map_inv _ _]
    show 0 < ((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)).det : тДЭ╦г))тБ╗┬╣.val
    rw [Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h╬▒_pos
  -- `hm`: NullMeasurableSet for each per-b tile via ╬▒_bтБ╗┬╣-smul preimage.
  have hm : тИА b тИИ Finset.range p, NullMeasurableSet
      (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set UpperHalfPlane)) ╬╝_hyp := fun b _ => by
    have h_eq : (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane)) =
        (((((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
            ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ тАв ┬╖) :
              тДН тЖТ тДН) тБ╗┬╣' (ModularGroup.fd : Set UpperHalfPlane)) := by
      ext ╧Д; simp [Set.mem_preimage, Set.mem_smul_set_iff_inv_smul_mem]
    rw [h_eq]
    exact h_fd_null.preimage
      (measurePreserving_glPos_smul _ (h_╬▒_inv_det_pos b)).quasiMeasurePreserving
  -- `hd`: pairwise AE-disjointness from `aedisjoint_glMap_T_p_upper_pair_fd_per_q`.
  have hd : (тЖС(Finset.range p) : Set тДХ).Pairwise fun bтВБ bтВВ =>
      AEDisjoint ╬╝_hyp
        (((glMap (T_p_upper p hp.pos bтВБ) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane))
        (((glMap (T_p_upper p hp.pos bтВВ) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
            (ModularGroup.fd : Set UpperHalfPlane)) := fun bтВБ _ bтВВ _ hne => by
    apply aedisjoint_glMap_T_p_upper_pair_fd_per_q hp.pos q
    intro h
    apply hne
    exact_mod_cast (sub_eq_zero.mp h).symm
  -- Invoke `peterssonInner_biUnion_finset_ae` in reverse (union тЖТ sum direction)
  -- to obtain `тИС_b = peterssonInner (тЛГ_b ┬╖)`.
  exact (peterssonInner_biUnion_finset_ae (Finset.range p) hm hd тЗСf _ hfi).symm

