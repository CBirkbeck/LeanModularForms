/-- **T094: T_p-double-coset family `{T_p_upper(b)}_{b<p} тИк {M_тИЮ}` тАФ pairwise
AE-disjoint translates of `Gamma1_fundDomain_PSL N`.**

The `p + 1` elements of the `T_p` double coset, indexed by `Option (Fin p)`
with `none = M_тИЮ` and `some b = T_p_upper(b)`, translate the ╬УтВБ(N)-fundamental
domain into `p + 1` pairwise AE-disjoint translates. Composes directly with
`peterssonInner_sum_slash_adjoint_constantRHS` (via
`aedisjoint_pairwise_family_of_pair_ae_disjoint`) at the T205 call site. -/
theorem aedisjoint_pairwise_T_p_family
    {N : тДХ} [NeZero N] (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) :
    (тЖС(Finset.univ : Finset (Option (Fin p))) : Set (Option (Fin p))).Pairwise
      (fun i j =>
        AEDisjoint ╬╝_hyp
          ((match i with
            | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
            | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
              (Gamma1_fundDomain_PSL N : Set тДН))
          ((match j with
            | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)
            | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) тДЭ)) тАв
              (Gamma1_fundDomain_PSL N : Set тДН))) := by
  intro i _ j _ hij
  match i, j, hij with
  | none, none, h => exact absurd rfl h
  | none, some b, _ =>
    exact (aedisjoint_glMap_M_infty_T_p_upper hp hpN b.val).symm
  | some b, none, _ => exact aedisjoint_glMap_M_infty_T_p_upper hp hpN b.val
  | some bтВБ, some bтВВ, hij =>
    refine aedisjoint_glMap_T_p_upper_pair hp.pos ?_
    intro h_eq
    apply hij
    have h_val : bтВБ.val = bтВВ.val := by
      have : (bтВБ.val : тДд) = (bтВВ.val : тДд) := by linarith
      exact_mod_cast this
    exact congr_arg some (Fin.ext h_val)

