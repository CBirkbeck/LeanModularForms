/-- **T092 finite-union bridge (pure measure-theoretic form).** -/
theorem setIntegral_biUnion_finset_ae
    {X ╬╣ : Type*} [MeasurableSpace X] {╬╝ : Measure X}
    {E : Type*} [NormedAddCommGroup E] [NormedSpace тДЭ E]
    (s : Finset ╬╣) {S : ╬╣ тЖТ Set X} {f : X тЖТ E}
    (hm : тИА i тИИ s, NullMeasurableSet (S i) ╬╝)
    (hd : (тЖСs : Set ╬╣).Pairwise (fun i j => AEDisjoint ╬╝ (S i) (S j)))
    (hfi : IntegrableOn f (тЛГ i тИИ s, S i) ╬╝) :
    тИл x in тЛГ i тИИ s, S i, f x тИВ╬╝ = тИС i тИИ s, тИл x in S i, f x тИВ╬╝ := by
  classical
  have h_biU : (тЛГ i тИИ s, S i) = тЛГ i : s, S i.val := by
    ext x; simp [Set.mem_iUnion]
  have hm' : тИА i : s, NullMeasurableSet (S i.val) ╬╝ :=
    fun i => hm i.val i.property
  have hd' : Pairwise (fun i j : s => AEDisjoint ╬╝ (S i.val) (S j.val)) := by
    intro i j hij
    exact hd (Finset.mem_coe.mpr i.property) (Finset.mem_coe.mpr j.property)
      (fun h => hij (Subtype.ext h))
  have hfi' : IntegrableOn f (тЛГ i : s, S i.val) ╬╝ := by
    rw [тЖР h_biU]; exact hfi
  rw [h_biU, integral_iUnion_ae hm' hd' hfi', tsum_fintype,
    Finset.sum_coe_sort s (fun i => тИл x in S i, f x тИВ╬╝)]

