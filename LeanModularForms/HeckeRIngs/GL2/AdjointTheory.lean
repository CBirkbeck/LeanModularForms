      (fun ╧Д => petersson k тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f)
        (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) g) тИг[k] M) ╧Д)
