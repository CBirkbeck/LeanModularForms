      (g тИг[k] (╬▓ * (mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ)))
  have h2 := peterssonInner_slash_adjoint_coset (k := k) ╬▓ h╬▓ q g f
  have h3 := peterssonInner_conj_symm k
      (╬▓ тАв ((mapGL тДЭ qтБ╗┬╣ : GL (Fin 2) тДЭ) тАв (fd : Set тДН)))
      (f тИг[k] peterssonAdj ╬▓) g
