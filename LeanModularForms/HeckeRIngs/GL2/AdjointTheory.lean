/-- **T128 per-`q` M_тИЮ vs T_p_upper(b) fd-AE-disjoint helper**.

For the Option `(Fin p)` family at fixed `q : SL(2, тДд)`, the `none` tile
`(glMap M_тИЮ ┬╖ mapGL qтБ╗┬╣) тАв fd` is AE-disjoint from each `some b` tile
`(glMap T_p_upper(b) ┬╖ mapGL qтБ╗┬╣) тАв fd`.

**Uses**: `aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne` with
`╧Г = q ┬╖ M_infty_Gamma1_factor(b)тБ╗┬╣ ┬╖ qтБ╗┬╣`, `h_inv_mul` from
`glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1` (reversed + conjugated),
PSL nontriviality from `M_infty_Gamma1_factor_psl_ne_one` preserved under
conjugation by `q`. -/
theorem aedisjoint_glMap_M_infty_T_p_upper_fd_per_q
    {N : тДХ} [NeZero N] {p : тДХ} (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (q : SL(2, тДд)) (b : тДХ) :
    AEDisjoint ╬╝_hyp
      (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set тДН))
      (((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) qтБ╗┬╣ : GL (Fin 2) тДЭ)) тАв
          (ModularGroup.fd : Set тДН)) := by
  set ╬▒тВБ : GL (Fin 2) тДЭ :=
    (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)
  set ╬▒тВВ : GL (Fin 2) тДЭ :=
    (glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
      ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ)
  have h_mapGL_mat_det_eq_one :
      (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ).det = 1 := by
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
        Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix (qтБ╗┬╣ : SL(2, тДд)).val) by
      rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, (qтБ╗┬╣ : SL(2, тДд)).property]
    simp
  have h_╬▒тВБ_det_pos : 0 < (╬▒тВБ : GL (Fin 2) тДЭ).det.val := by
    show 0 < ((╬▒тВБ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((╬▒тВБ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ) =
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) *
        (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ) :
          Matrix (Fin 2) (Fin 2) тДЭ) from Units.val_mul _ _,
      Matrix.det_mul, h_mapGL_mat_det_eq_one, mul_one]
    exact glMap_M_infty_det_pos N p hp.pos hpN
  have h_╬▒тВБ_inv_det_pos : 0 < (╬▒тВБтБ╗┬╣ : GL (Fin 2) тДЭ).det.val := by
    show 0 < (((╬▒тВБтБ╗┬╣).det : тДЭ╦г) : тДЭ)
    rw [show ((╬▒тВБтБ╗┬╣ : GL (Fin 2) тДЭ)).det = ╬▒тВБ.detтБ╗┬╣ from map_inv _ _,
      Units.val_inv_eq_inv_val]
    exact inv_pos.mpr h_╬▒тВБ_det_pos
  have h_inv_mul : ╬▒тВБтБ╗┬╣ * ╬▒тВВ =
      ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (q * (M_infty_Gamma1_factor N p hpN b)тБ╗┬╣ * qтБ╗┬╣) : GL (Fin 2) тДЭ) := by
    show (((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ *
        ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) *
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))) = _
    rw [mul_inv_rev]
    rw [show (((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ))тБ╗┬╣ =
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) q : GL (Fin 2) тДЭ) from by
        rw [тЖР map_inv]; simp]
    have h_inv_mul_M_infty :
        ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))тБ╗┬╣ *
          (glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ) =
        ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b))тБ╗┬╣ := by
      have h :=
        glMap_T_p_upper_inv_mul_M_infty_eq_mapGL_Gamma1 N p hp.pos hpN b
      rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* _) (M_infty_Gamma1_factor N p hpN b))тБ╗┬╣ =
          ((glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ)тБ╗┬╣ *
            (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))тБ╗┬╣ from by rw [h]]
      rw [mul_inv_rev, inv_inv]
    rw [mul_assoc ((mapGL тДЭ : SL(2, тДд) тЖТ* _) q : GL (Fin 2) тДЭ)
          (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ)тБ╗┬╣,
      тЖР mul_assoc ((glMap (M_infty N p hp.pos hpN) : GL (Fin 2) тДЭ))тБ╗┬╣
          (glMap (T_p_upper p hp.pos b) : GL (Fin 2) тДЭ)
          ((mapGL тДЭ : SL(2, тДд) тЖТ* _) qтБ╗┬╣ : GL (Fin 2) тДЭ),
      h_inv_mul_M_infty,
      тЖР mul_assoc,
      тЖР map_inv, тЖР map_mul, тЖР map_mul]
  have h_psl_factor_ne :
      (QuotientGroup.mk (M_infty_Gamma1_factor N p hpN b) : PSL(2, тДд)) тЙа 1 :=
    M_infty_Gamma1_factor_psl_ne_one N p hp hpN b
  have h_psl_factor_inv_ne :
      (QuotientGroup.mk (M_infty_Gamma1_factor N p hpN b)тБ╗┬╣ : PSL(2, тДд)) тЙа 1 := by
    intro heq
    apply h_psl_factor_ne
    rw [QuotientGroup.mk_inv] at heq
    exact inv_eq_one.mp heq
  have h_psl_conj_ne :
      (QuotientGroup.mk (q * (M_infty_Gamma1_factor N p hpN b)тБ╗┬╣ * qтБ╗┬╣) :
        PSL(2, тДд)) тЙа 1 := by
    intro heq
    apply h_psl_factor_inv_ne
    have hconj : (QuotientGroup.mk q : PSL(2, тДд)) *
            (QuotientGroup.mk (M_infty_Gamma1_factor N p hpN b)тБ╗┬╣ : PSL(2, тДд)) *
            (QuotientGroup.mk q : PSL(2, тДд))тБ╗┬╣ = 1 := by
      rw [тЖР QuotientGroup.mk_inv, тЖР QuotientGroup.mk_mul, тЖР QuotientGroup.mk_mul]
      exact heq
    rw [mul_inv_eq_one] at hconj
    exact mul_left_cancel (hconj.trans (mul_one _).symm)
  exact aedisjoint_glMap_smul_fd_of_mul_inv_eq_mapGL_PSL_ne ╬▒тВБ ╬▒тВВ
    (measurePreserving_glPos_smul _ h_╬▒тВБ_inv_det_pos)
    (q * (M_infty_Gamma1_factor N p hpN b)тБ╗┬╣ * qтБ╗┬╣)
    h_psl_conj_ne h_inv_mul

