          вҲ« П„ in Gamma_p_Оұ_fundDomain_PSL_canonical (N := N) Оұ, h П„ вҲӮОј_hyp := by
        rw [вҶҗ setIntegral_Gamma_p_Оұ_fundDomain_PSL_canonical_eq_sum
          (N := N) Оұ h h_int]

