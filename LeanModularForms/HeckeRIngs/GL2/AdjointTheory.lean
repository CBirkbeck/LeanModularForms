/-- **T090 helper: `glMap (T_p_upper p hp b)` has positive determinant `p`.**

Direct computation: the matrix of `T_p_upper(p, b)` is `!![1, b; 0, p]` over в„ҡ
(by `T_p_upper` definition), with determinant `p > 0`. -/
private theorem glMap_T_p_upper_det_pos (p : в„•) (hp : 0 < p) (b : в„•) :
    0 < (glMap (T_p_upper p hp b) : GL (Fin 2) в„қ).det.val := by
  show 0 < ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
    Matrix (Fin 2) (Fin 2) в„қ).det
  rw [show ((glMap (T_p_upper p hp b) : GL (Fin 2) в„қ) :
      Matrix (Fin 2) (Fin 2) в„қ) =
      ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ) from rfl]
  rw [show (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).map (algebraMap в„ҡ в„қ)).det =
      (algebraMap в„ҡ в„қ) (((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det) from
        (RingHom.map_det _ _).symm]
  rw [show ((T_p_upper p hp b : GL (Fin 2) в„ҡ).val).det = (p : в„ҡ) from by
    simp [T_p_upper, Matrix.GeneralLinearGroup.mkOfDetNeZero,
      Matrix.det_fin_two, Matrix.of_apply]]
  show 0 < (algebraMap в„ҡ в„қ) ((p : в„ҡ))
  rw [show (algebraMap в„ҡ в„қ) ((p : в„ҡ)) = ((p : в„ҡ) : в„қ) from rfl]
  exact_mod_cast hp

