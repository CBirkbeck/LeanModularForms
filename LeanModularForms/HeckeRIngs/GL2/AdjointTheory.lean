    have h_g : (QuotientGroup.mk g : SL(2, тДд) тз╕ Gamma1 N) = qтВВ' := hq
    have h_gтВВ : (QuotientGroup.mk gтВВ : SL(2, тДд) тз╕ Gamma1 N) = qтВВ' := hqтВВ
    rw [тЖР h_gтВБ, hh_def, QuotientGroup.eq]
    have hq_eq : (QuotientGroup.mk g : SL(2, тДд) тз╕ Gamma1 N) = QuotientGroup.mk gтВВ :=
      h_g.trans h_gтВВ.symm
    rw [QuotientGroup.eq] at hq_eq
    have : ((gтВВ * gтВБтБ╗┬╣)тБ╗┬╣ * g)тБ╗┬╣ * gтВБ = gтБ╗┬╣ * gтВВ := by group
