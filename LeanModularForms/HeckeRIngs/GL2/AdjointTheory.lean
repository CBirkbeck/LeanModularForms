open UpperHalfPlane ModularGroup MeasureTheory in
/-- Additivity of `peterssonInner` in the first argument (requires integrability).
Derived from `peterssonInner_add_right` via Hermitian symmetry. -/
private lemma peterssonInner_add_left (D : Set в„Қ) (fвӮҒ fвӮӮ g : в„Қ вҶ’ в„Ӯ)
    (hfвӮҒ : IntegrableOn (fun П„ => petersson k g fвӮҒ П„) D Ој_hyp)
    (hfвӮӮ : IntegrableOn (fun П„ => petersson k g fвӮӮ П„) D Ој_hyp) :
    peterssonInner k D (fвӮҒ + fвӮӮ) g =
      peterssonInner k D fвӮҒ g + peterssonInner k D fвӮӮ g := by
  have h1 := peterssonInner_conj_symm k D (fвӮҒ + fвӮӮ) g
  have h2 := peterssonInner_add_right k D g fвӮҒ fвӮӮ hfвӮҒ hfвӮӮ
  have h3a := peterssonInner_conj_symm k D fвӮҒ g
  have h3b := peterssonInner_conj_symm k D fвӮӮ g
  rw [вҶҗ h1, h2, map_add, h3a, h3b]

open UpperHalfPlane ModularGroup MeasureTheory ConjAct Pointwise in
/-- **T205 integrability helper (mixed SL/GL slash bridge).**
For `О“вӮҒ(N)` cusp forms `f, g`, a rational matrix `Оұ : GL (Fin 2) в„ҡ`, and an
`SL(2, в„Ө)` element `Оҙ`, the petersson integrand
`petersson k (вҮ‘f вҲЈ[k] Оҙ) ((вҮ‘g вҲЈ[k] Оұ) вҲЈ[k] Оҙ)` is integrable on the
`SL(2, в„Ө)`-fundamental domain `fd`.

**Proof.** After rewriting via `petersson_slash_SL k _ _ Оҙ` (since `Оҙ` is SL,
the outer slash pulls out as a change of variables `Оҙ вҖў П„`), the integrand
equals `petersson k вҮ‘f (вҮ‘g вҲЈ[k] Оұ) (Оҙ вҖў П„)`. The inner `вҮ‘g вҲЈ[k] Оұ` is the
coercion of the translated cusp form `CuspForm.translate g Оұ` of the
arithmetic conjugate subgroup `toConjAct ОұвҒ»В№ вҖў О“вӮҒ(N)` (arithmeticity via
`Subgroup.IsArithmetic.conj`). Applying `CuspFormClass.petersson_bounded_left`
separately to `f` with itself and to the translated `g` with itself yields
global bounds `вҖ–petersson k f f П„вҖ– вүӨ C_f` and `вҖ–petersson k (g вҲЈ Оұ) (g вҲЈ Оұ)
П„вҖ– вүӨ C_g`. AM-GM (`2|ab| вүӨ aВІ + bВІ`) combines these into a global bound
`вҖ–petersson k f (g вҲЈ Оұ) П„вҖ– вүӨ (C_f + C_g) / 2`, invariant under the `Оҙ вҖў П„`
shift. Combined with `hyperbolicMeasure_fd_lt_top`, `IntegrableOn.of_bound`
closes.

**Role in T205.** This is the single theorem-local bridge consumed to
discharge the four inline integrability witnesses in
`petN_heckeT_p_diamond_shift_core`, which land in the mixed-slash shape
`petersson k (cuspform вҲЈ SL) (cuspform вҲЈ GL в„ҡ вҲЈ SL)` that does not
match the existing T094 `integrableOn_petersson_slash` /
`integrableOn_petersson_glMap_smul_Gamma1_fundDomain` shapes. -/
theorem integrableOn_petersson_cuspform_mixed_slash_on_fd
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (Оұ : GL (Fin 2) в„ҡ) (Оҙ : SL(2, в„Ө)) :
    IntegrableOn (fun П„ => UpperHalfPlane.petersson k (вҮ‘f вҲЈ[k] Оҙ)
        ((вҮ‘g вҲЈ[k] ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ)) вҲЈ[k] Оҙ) П„)
      (ModularGroup.fd : Set UpperHalfPlane) Ој_hyp := by
  -- Step 1: Rewrite integrand using `petersson_slash_SL` (SL slash pulls out).
  rw [show (fun П„ => UpperHalfPlane.petersson k (вҮ‘f вҲЈ[k] Оҙ)
        ((вҮ‘g вҲЈ[k] ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ)) вҲЈ[k] Оҙ) П„) =
      (fun П„ => UpperHalfPlane.petersson k вҮ‘f
        (вҮ‘g вҲЈ[k] ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ)) (Оҙ вҖў П„)) from
      funext fun П„ => petersson_slash_SL k _ _ Оҙ П„]
  -- Step 2: Arithmeticity of the conjugate subgroup.
  haveI hArith :
      ((toConjAct ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№) вҖў
        ((Gamma1 N).map (mapGL в„қ))).IsArithmetic := by
    have h := Subgroup.IsArithmetic.conj ((Gamma1 N).map (mapGL в„қ)) ОұвҒ»В№
    have h_inv : ((ОұвҒ»В№ : GL (Fin 2) в„ҡ).map (Rat.castHom в„қ) : GL (Fin 2) в„қ) =
        ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№ := map_inv _ _
    rwa [h_inv] at h
  -- Step 3: The translated cusp form.
  let g_tr : CuspForm
      ((toConjAct ((Оұ.map (Rat.castHom в„қ) : GL (Fin 2) в„қ))вҒ»В№) вҖў
        ((Gamma1 N).map (mapGL в„қ))) k :=
    CuspForm.translate g ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ)
  have h_gtr_coe : (вҮ‘g_tr : UpperHalfPlane вҶ’ в„Ӯ) =
      вҮ‘g вҲЈ[k] ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ) := rfl
  -- Step 4: Global bounds via `petersson_bounded_left` on each form with itself.
  obtain вҹЁC_f, hC_fвҹ© := CuspFormClass.petersson_bounded_left k
    ((Gamma1 N).map (mapGL в„қ)) f f
  obtain вҹЁC_g, hC_gвҹ© := CuspFormClass.petersson_bounded_left k _ g_tr g_tr
  -- Step 5: AM-GM combines the two bounds globally.
  have h_AM_GM : вҲҖ П„,
      вҖ–UpperHalfPlane.petersson k вҮ‘f
          (вҮ‘g вҲЈ[k] ((Оұ.map (Rat.castHom в„қ)) : GL (Fin 2) в„қ)) П„вҖ– вүӨ
        (C_f + C_g) / 2 := by
    intro П„
    rw [вҶҗ h_gtr_coe]
    -- AM-GM at the integrand level: вҖ–petersson k f g_tr П„вҖ– вүӨ
    -- (вҖ–petersson k f f П„вҖ– + вҖ–petersson k g_tr g_tr П„вҖ–) / 2.
    have h_norm_ineq : вҖ–UpperHalfPlane.petersson k вҮ‘f вҮ‘g_tr П„вҖ– вүӨ
        (вҖ–UpperHalfPlane.petersson k вҮ‘f вҮ‘f П„вҖ– +
         вҖ–UpperHalfPlane.petersson k вҮ‘g_tr вҮ‘g_tr П„вҖ–) / 2 := by
      -- Expand all three `petersson` expressions as norm products.
      simp only [UpperHalfPlane.petersson, norm_mul, Complex.norm_conj]
      -- Goal now: вҖ–f П„вҖ– * вҖ–g_tr П„вҖ– * c вүӨ (вҖ–f П„вҖ– * вҖ–f П„вҖ– * c + вҖ–g_tr П„вҖ– * вҖ–g_tr П„вҖ– * c) / 2
      -- where c is some complex norm вүҘ 0.  Use AM-GM `(a - b)ВІ В· c вүҘ 0`.
      have h_im_nn : (0 : в„қ) вүӨ вҖ–((П„.im : в„Ӯ) ^ k)вҖ– := norm_nonneg _
      nlinarith [mul_nonneg (sq_nonneg (вҖ–(вҮ‘f) П„вҖ– - вҖ–(вҮ‘g_tr) П„вҖ–)) h_im_nn,
        sq_nonneg (вҖ–(вҮ‘f) П„вҖ– - вҖ–(вҮ‘g_tr) П„вҖ–), norm_nonneg (вҮ‘f П„),
        norm_nonneg (вҮ‘g_tr П„), h_im_nn]
    linarith [hC_f П„, hC_g П„]
  -- Step 6: Apply `IntegrableOn.of_bound` with the composed bound.
  refine IntegrableOn.of_bound hyperbolicMeasure_fd_lt_top ?_ ((C_f + C_g) / 2) ?_
  В· -- AEStronglyMeasurable: the composed function is continuous.
    refine ((petersson_continuous k (ModularFormClass.continuous f)
      ?_).comp (continuous_const_smul Оҙ)).aestronglyMeasurable.restrict
    rw [вҶҗ h_gtr_coe]
    exact ModularFormClass.continuous g_tr
  В· exact ae_of_all _ fun П„ => h_AM_GM (Оҙ вҖў П„)

/-! ### T092 / T094: Finset-additivity, finite-union bridge, and T_p-specific
AE-disjointness (DS Theorem 5.5.2(b) / T205 instantiation) -/

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T092 helper: `petersson` is linear in its second argument over finite sums.** -/
theorem petersson_sum_right {О№ : Type*} (s : Finset О№) (f : в„Қ вҶ’ в„Ӯ)
    (g : О№ вҶ’ в„Қ вҶ’ в„Ӯ) (П„ : в„Қ) :
    petersson k f (вҲ‘ i вҲҲ s, g i) П„ = вҲ‘ i вҲҲ s, petersson k f (g i) П„ := by
  simp only [petersson, Finset.sum_apply, Finset.mul_sum, Finset.sum_mul]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T092 helper: Finset additivity of `peterssonInner` in the first arg.** -/
theorem peterssonInner_sum_left
    {О№ : Type*} [DecidableEq О№] (s : Finset О№) (F : О№ вҶ’ в„Қ вҶ’ в„Ӯ)
    (g : в„Қ вҶ’ в„Ӯ) (D : Set в„Қ)
    (h_int : вҲҖ i вҲҲ s, IntegrableOn (fun П„ => petersson k g (F i) П„) D Ој_hyp) :
    peterssonInner k D (вҲ‘ i вҲҲ s, F i) g = вҲ‘ i вҲҲ s, peterssonInner k D (F i) g := by
  induction s using Finset.induction_on with
  | empty => simp [peterssonInner_zero_left]
  | insert i t hi ih =>
    rw [Finset.sum_insert hi]
    have h_i := h_int i (Finset.mem_insert_self i t)
    have h_t := fun j hj => h_int j (Finset.mem_insert_of_mem hj)
    have h_sum_int :
        IntegrableOn (fun П„ => petersson k g (вҲ‘ j вҲҲ t, F j) П„) D Ој_hyp := by
      have h_eq :
          (fun П„ => petersson k g (вҲ‘ j вҲҲ t, F j) П„) =
            fun П„ => вҲ‘ j вҲҲ t, petersson k g (F j) П„ := by
        funext П„; exact petersson_sum_right t g F П„
      rw [h_eq]
      exact MeasureTheory.integrable_finset_sum _ h_t
    rw [peterssonInner_add_left D (F i) (вҲ‘ j вҲҲ t, F j) g h_i h_sum_int,
      ih h_t, Finset.sum_insert hi]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 helper**: additive distribution of `peterssonInner` in the first
argument over a sum of the form `f0 + вҲ‘ i вҲҲ s, F i` (base term + Finset sum).
Combines `peterssonInner_add_left` + `peterssonInner_sum_left`. -/
private lemma peterssonInner_add_finset_sum_left
    {О№ : Type*} [DecidableEq О№] (s : Finset О№)
    (f0 : в„Қ вҶ’ в„Ӯ) (F : О№ вҶ’ в„Қ вҶ’ в„Ӯ) (g : в„Қ вҶ’ в„Ӯ) (D : Set в„Қ)
    (h0 : IntegrableOn (fun П„ => petersson k g f0 П„) D Ој_hyp)
    (hF : вҲҖ i вҲҲ s, IntegrableOn (fun П„ => petersson k g (F i) П„) D Ој_hyp) :
    peterssonInner k D (f0 + вҲ‘ i вҲҲ s, F i) g =
      peterssonInner k D f0 g + вҲ‘ i вҲҲ s, peterssonInner k D (F i) g := by
  have hsum : IntegrableOn (fun П„ => petersson k g (вҲ‘ i вҲҲ s, F i) П„) D Ој_hyp := by
    rw [show (fun П„ => petersson k g (вҲ‘ i вҲҲ s, F i) П„) =
        (fun П„ => вҲ‘ i вҲҲ s, petersson k g (F i) П„) from by
      funext П„; exact petersson_sum_right s g F П„]
    exact MeasureTheory.integrable_finset_sum _ hF
  rw [peterssonInner_add_left D f0 (вҲ‘ i вҲҲ s, F i) g h0 hsum,
    peterssonInner_sum_left s F g D hF]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 helper**: Finset additivity of `peterssonInner` in the second argument
(slot-2 analog of `peterssonInner_sum_left`). -/
lemma peterssonInner_sum_right
    {О№ : Type*} [DecidableEq О№] (s : Finset О№)
    (f : в„Қ вҶ’ в„Ӯ) (G : О№ вҶ’ в„Қ вҶ’ в„Ӯ) (D : Set в„Қ)
    (h_int : вҲҖ i вҲҲ s, IntegrableOn (fun П„ => petersson k f (G i) П„) D Ој_hyp) :
    peterssonInner k D f (вҲ‘ i вҲҲ s, G i) = вҲ‘ i вҲҲ s, peterssonInner k D f (G i) := by
  induction s using Finset.induction_on with
  | empty => simp [peterssonInner_zero_right]
  | insert i t hi ih =>
    rw [Finset.sum_insert hi]
    have h_i := h_int i (Finset.mem_insert_self i t)
    have h_t := fun j hj => h_int j (Finset.mem_insert_of_mem hj)
    have h_sum_int :
        IntegrableOn (fun П„ => petersson k f (вҲ‘ j вҲҲ t, G j) П„) D Ој_hyp := by
      have h_eq :
          (fun П„ => petersson k f (вҲ‘ j вҲҲ t, G j) П„) =
            fun П„ => вҲ‘ j вҲҲ t, petersson k f (G j) П„ := by
        funext П„; exact petersson_sum_right t f G П„
      rw [h_eq]
      exact MeasureTheory.integrable_finset_sum _ h_t
    rw [peterssonInner_add_right k D f (G i) (вҲ‘ j вҲҲ t, G j) h_i h_sum_int,
      ih h_t, Finset.sum_insert hi]

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T128 helper**: additive distribution of `peterssonInner` in the second
argument over a sum of the form `g0 + вҲ‘ i вҲҲ s, G i` (slot-2 analog of
`peterssonInner_add_finset_sum_left`). -/
private lemma peterssonInner_add_finset_sum_right
    {О№ : Type*} [DecidableEq О№] (s : Finset О№)
    (f : в„Қ вҶ’ в„Ӯ) (g0 : в„Қ вҶ’ в„Ӯ) (G : О№ вҶ’ в„Қ вҶ’ в„Ӯ) (D : Set в„Қ)
    (h0 : IntegrableOn (fun П„ => petersson k f g0 П„) D Ој_hyp)
    (hG : вҲҖ i вҲҲ s, IntegrableOn (fun П„ => petersson k f (G i) П„) D Ој_hyp) :
    peterssonInner k D f (g0 + вҲ‘ i вҲҲ s, G i) =
