/-- **T094: T_p-double-coset family `{T_p_upper(b)}_{b<p} вҲӘ {M_вҲһ}` вҖ” pairwise
AE-disjoint translates of `Gamma1_fundDomain_PSL N`.**

The `p + 1` elements of the `T_p` double coset, indexed by `Option (Fin p)`
with `none = M_вҲһ` and `some b = T_p_upper(b)`, translate the О“вӮҒ(N)-fundamental
domain into `p + 1` pairwise AE-disjoint translates. Composes directly with
`peterssonInner_sum_slash_adjoint_constantRHS` (via
`aedisjoint_pairwise_family_of_pair_ae_disjoint`) at the T205 call site. -/
theorem aedisjoint_pairwise_T_p_family
    {N : в„•} [NeZero N] (p : в„•) (hp : Nat.Prime p) (hpN : Nat.Coprime p N) :
    (вҶ‘(Finset.univ : Finset (Option (Fin p))) : Set (Option (Fin p))).Pairwise
      (fun i j =>
        AEDisjoint Ој_hyp
          ((match i with
            | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
            | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
              (Gamma1_fundDomain_PSL N : Set в„Қ))
          ((match j with
            | none => (glMap (M_infty N p hp.pos hpN) : GL (Fin 2) в„қ)
            | some b => (glMap (T_p_upper p hp.pos b.val) : GL (Fin 2) в„қ)) вҖў
              (Gamma1_fundDomain_PSL N : Set в„Қ))) := by
  intro i _ j _ hij
  match i, j, hij with
  | none, none, h => exact absurd rfl h
  | none, some b, _ =>
    exact (aedisjoint_glMap_M_infty_T_p_upper hp hpN b.val).symm
  | some b, none, _ => exact aedisjoint_glMap_M_infty_T_p_upper hp hpN b.val
  | some bвӮҒ, some bвӮӮ, hij =>
    refine aedisjoint_glMap_T_p_upper_pair hp.pos ?_
    intro h_eq
    apply hij
    have h_val : bвӮҒ.val = bвӮӮ.val := by
      have : (bвӮҒ.val : в„Ө) = (bвӮӮ.val : в„Ө) := by linarith
      exact_mod_cast this
    exact congr_arg some (Fin.ext h_val)

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 / T205 reusable: Petersson sum-of-slashes вҶ” aggregate Hecke-FD biUnion
for a finite family of GL(2,в„қ)вҒә representatives with a common adjoint cusp form.**

Combines the existing T094/T205 finite-family facts:
* `peterssonInner_sum_slash_adjoint_constantRHS` (sum-of-slashes вҶ’ biUnion via constant RHS)
* `integrableOn_petersson_biUnion_glMap_smul` (T094 integrability on biUnion)

into a single reusable bridge: for cusp forms `f, g, g'` with
`g вҲЈ peterssonAdj (Оұ i) = g'` for every `i вҲҲ s` (the "common-g'" hypothesis,
satisfied by the T_p Hecke double-coset family via
`slash_peterssonAdj_glMap_M_infty_eq_slash_T_p_lower` and
`slash_peterssonAdj_glMap_T_p_upper_eq_slash_T_p_lower` taking
`g' := g вҲЈ T_p_lower`):

```
peterssonInner k О“вӮҒ_FD (вҲ‘_i f вҲЈ Оұ_i) g
  = peterssonInner k (вӢғ_i Оұ_i вҖў О“вӮҒ_FD) f g'.
```

**Direct consumer for h_HeckeFD_swap.**  Specialized to the Option (Fin p)
T_p Hecke representatives `Оұ_T_p`, the LHS is `petN(T_p f, g)` (modulo
normalization) and the RHS is the aggregate-Hecke-FD form needed for
`h_HeckeFD_swap`.  This wrapper avoids re-deriving the T094 integrability
and finite-disjoint biUnion plumbing per call site. -/
theorem peterssonInner_T_p_family_sum_slashes_eq_aggregate
    {N : в„•} [NeZero N] {О№ : Type*} [DecidableEq О№] (s : Finset О№)
    (Оұ : О№ вҶ’ GL (Fin 2) в„қ) (hОұ : вҲҖ i вҲҲ s, 0 < (Оұ i).det.val)
    (f g g' : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (hadj : вҲҖ i вҲҲ s, вҮ‘g вҲЈ[k] peterssonAdj (Оұ i) = вҮ‘g')
    (hm : вҲҖ i вҲҲ s,
      NullMeasurableSet (Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp)
    (hd : (вҶ‘s : Set О№).Pairwise
      (fun i j => AEDisjoint Ој_hyp
        (Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
        (Оұ j вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))))
    (h_int_per : вҲҖ i вҲҲ s,
      IntegrableOn (fun П„ => petersson k вҮ‘g (вҮ‘f вҲЈ[k] Оұ i) П„)
        (Gamma1_fundDomain_PSL N) Ој_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N) (вҲ‘ i вҲҲ s, вҮ‘f вҲЈ[k] Оұ i) вҮ‘g =
      peterssonInner k
        (вӢғ i вҲҲ s, Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
        вҮ‘f вҮ‘g' :=
  peterssonInner_sum_slash_adjoint_constantRHS s Оұ hОұ
    (Gamma1_fundDomain_PSL N) вҮ‘f вҮ‘g вҮ‘g' hadj h_int_per hm hd
    (integrableOn_petersson_biUnion_glMap_smul s Оұ hОұ f g')

open UpperHalfPlane ModularGroup MeasureTheory in
/-- **T090 / T205 reusable: Petersson sum-of-slashes вҶ” aggregate Hecke-FD biUnion
with explicit union-integrability hypothesis (companion to
`peterssonInner_T_p_family_sum_slashes_eq_aggregate`).**

Same as `peterssonInner_T_p_family_sum_slashes_eq_aggregate` but takes
the RHS union integrability as an explicit hypothesis `hfi`, allowing
the common adjoint RHS `g'` to be a general function `в„Қ вҶ’ в„Ӯ` rather than
a О“вӮҒ(N)-cusp form.

**Use case for the T_p Hecke representatives.**  The common adjoint
RHS for the T_p family is `вҮ‘g вҲЈ[k] (glMap T_p_lower)`, which is **not**
a О“вӮҒ(N)-cusp form (`T_p_lower` does not normalize О“вӮҒ(N)).  This
companion wrapper accepts the union integrability of `petersson k вҮ‘f
(вҮ‘g вҲЈ[k] glMap T_p_lower)` as an explicit hypothesis, sidestepping the
need to bundle `g вҲЈ T_p_lower` as a CuspForm.

**Direct application** of `peterssonInner_sum_slash_adjoint_constantRHS`
without auto-deriving `hfi`. -/
theorem peterssonInner_T_p_family_sum_slashes_eq_aggregate_of_integrable
    {N : в„•} [NeZero N] {О№ : Type*} [DecidableEq О№] (s : Finset О№)
    (Оұ : О№ вҶ’ GL (Fin 2) в„қ) (hОұ : вҲҖ i вҲҲ s, 0 < (Оұ i).det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL в„қ)) k)
    (g' : в„Қ вҶ’ в„Ӯ)
    (hadj : вҲҖ i вҲҲ s, вҮ‘g вҲЈ[k] peterssonAdj (Оұ i) = g')
    (hm : вҲҖ i вҲҲ s,
      NullMeasurableSet (Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp)
    (hd : (вҶ‘s : Set О№).Pairwise
      (fun i j => AEDisjoint Ој_hyp
        (Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
        (Оұ j вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))))
    (h_int_per : вҲҖ i вҲҲ s,
      IntegrableOn (fun П„ => petersson k вҮ‘g (вҮ‘f вҲЈ[k] Оұ i) П„)
        (Gamma1_fundDomain_PSL N) Ој_hyp)
    (hfi : IntegrableOn (fun П„ => petersson k вҮ‘f g' П„)
      (вӢғ i вҲҲ s, Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ)) Ој_hyp) :
    peterssonInner k (Gamma1_fundDomain_PSL N) (вҲ‘ i вҲҲ s, вҮ‘f вҲЈ[k] Оұ i) вҮ‘g =
      peterssonInner k
        (вӢғ i вҲҲ s, Оұ i вҖў (Gamma1_fundDomain_PSL N : Set в„Қ))
        вҮ‘f g' :=
  peterssonInner_sum_slash_adjoint_constantRHS s Оұ hОұ
    (Gamma1_fundDomain_PSL N) вҮ‘f вҮ‘g g' hadj h_int_per hm hd hfi

