/-!
# Hecke adjoint theory and eigenform diagonalization

This file develops the adjoint theory of Hecke operators with respect to the
Petersson inner product, culminating in the existence of a simultaneous
eigenform basis for cusp form spaces.

## Main results

* `heckeT_p_adjoint` тАФ T_p* = тЯиpтЯйтБ╗┬╣ T_p (DiamondтАУShurman Thm 5.5.3)
* `diamondOp_petersson_unitary` тАФ `тЯиdтЯй` is unitary for pet
* `heckeT_n_petersson_normal` тАФ T_n is normal
* `exists_simultaneous_eigenform_basis` тАФ spectral theorem for Hecke operators

## References

* [DS] DiamondтАУShurman, *A First Course in Modular Forms*, ┬з5.5
* [Miy] Miyake, *Modular Forms*, ┬з4.5 (Thm 4.5.4тАУ4.5.5)
-/

noncomputable section

open CongruenceSubgroup Matrix.SpecialLinearGroup
open scoped Pointwise MatrixGroups ModularForm

variable {k : тДд}

/-! ### CuspForm тЖк ModularForm coercion

In Mathlib, `CuspForm` and `ModularForm` are parallel structures over
`SlashInvariantForm`. A cusp form is also a modular form since
`IsZeroAt тЖТ IsBoundedAt`. -/

namespace CuspForm

/-- Every cusp form is a modular form (zero at cusps implies bounded at cusps). -/
def toModularForm' {╬У : Subgroup (GL (Fin 2) тДЭ)}
    (f : CuspForm ╬У k) : ModularForm ╬У k where
  toSlashInvariantForm := f.toSlashInvariantForm
  holo' := f.holo'
  bdd_at_cusps' hc g hg := (f.zero_at_cusps' hc g hg).boundedAtFilter

end CuspForm

namespace HeckeRing.GL2

open CuspForm

variable {N : тДХ} [NeZero N]

/-! ### Hecke operators on cusp forms

The Hecke operators preserve cuspidality тАФ `IsZeroAt` is preserved by
the coset-sum construction. -/

/-- `GLтВВ(тДЪ)` maps cusps of `╬УтВБ(N)` to cusps of `╬УтВБ(N)`. -/
private lemma Gamma1_isCusp_glMap_smul' (A : GL (Fin 2) тДЪ) {c : OnePoint тДЭ}
    (hc : IsCusp c ((Gamma1 N).map (mapGL тДЭ))) :
    IsCusp (glMap A тАв c) ((Gamma1 N).map (mapGL тДЭ)) := by
  have hc_SL : IsCusp c ((тКд : Subgroup SL(2, тДд)).map (mapGL тДЭ)) :=
    hc.mono (Subgroup.map_mono le_top)
  rw [тЖР MonoidHom.range_eq_map] at hc_SL
  have hsmul_SL : IsCusp (glMap A тАв c) (mapGL тДЭ : SL(2, тДд) тЖТ* _).range := by
    rw [isCusp_SL2Z_iff] at hc_SL тКв
    obtain тЯиq, rflтЯй := hc_SL
    refine тЯиA тАв q, ?_тЯй
    show OnePoint.map (algebraMap тДЪ тДЭ) (A тАв q) =
      glMap A тАв OnePoint.map (algebraMap тДЪ тДЭ) q
    simp [OnePoint.map_smul, glMap]
  rw [MonoidHom.range_eq_map] at hsmul_SL
  haveI : ((Gamma1 N).map (mapGL тДЭ)).IsFiniteRelIndex
      ((тКд : Subgroup SL(2, тДд)).map (mapGL тДЭ)) := тЯиby
    rw [Subgroup.relIndex_map_map_of_injective _ _ mapGL_injective,
        Subgroup.relIndex_top_right]
    exact Subgroup.FiniteIndex.index_ne_zeroтЯй
  exact hsmul_SL.of_isFiniteRelIndex

/-- `T_p` preserves cuspidality. -/
theorem heckeT_p_zero_at_cusps (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    {c : OnePoint тДЭ} (hc : IsCusp c ((Gamma1 N).map (mapGL тДЭ))) :
    c.IsZeroAt (heckeT_p k p hp hpN f.toModularForm').toFun k := by
  show c.IsZeroAt (heckeT_p_fun k p hp hpN f.toModularForm') k
  simp only [heckeT_p_fun, heckeT_p_ut]
  apply OnePoint.IsZeroAt.add
  ┬╖ apply Finset.sum_induction _ (fun g => c.IsZeroAt g k)
      (fun _ _ ha hb => ha.add hb)
      ((0 : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k).zero_at_cusps' hc)
    intro b _
    exact OnePoint.IsZeroAt.smul_iff.mp
      (f.zero_at_cusps' (Gamma1_isCusp_glMap_smul' _ hc))
  ┬╖ -- Diamond operator term: (тЯиpтЯйf) тИг[k] T_p_lower
    -- Unfold IsZeroAt: need to show IsZeroAtImInfty for each ╬│ with ╬│ тАв тИЮ = c
    intro ╬│ h╬│
    -- Convert the GLтВВ(тДЪ) slash to GLтВВ(тДЭ) so we can combine with the GLтВВ(тДЭ) slash by ╬│
    show UpperHalfPlane.IsZeroAtImInfty
      ((тЗС((diamondOp k (ZMod.unitOfCoprime p hpN)) f.toModularForm') тИг[k]
        glMap (T_p_lower p hp.pos)) тИг[k] ╬│)
    rw [тЖР SlashAction.slash_mul]
    -- Unfold diamondOp to expose тЗСf тИг[k] mapGL тДЭ g, then combine slashes
    set g := (Gamma0MapUnits_surjective (ZMod.unitOfCoprime p hpN)).choose
    change UpperHalfPlane.IsZeroAtImInfty
      ((тЗСf.toModularForm' тИг[k] mapGL тДЭ (g : SL(2, тДд))) тИг[k]
        (glMap (T_p_lower p hp.pos) * ╬│))
    rw [тЖР SlashAction.slash_mul]
    -- Goal: IsZeroAtImInfty (тЗСf тИг[k] (mapGL тДЭ g * (glMap T_p_lower * ╬│)))
    -- The combined element sends тИЮ to mapGL тДЭ g тАв glMap T_p_lower тАв c
    -- Show mapGL тДЭ g тАв (glMap T_p_lower тАв c) is a ╬УтВБ-cusp
    have hc_lower : IsCusp (glMap (T_p_lower p hp.pos) тАв c)
        ((Gamma1 N).map (mapGL тДЭ)) := Gamma1_isCusp_glMap_smul' _ hc
    -- mapGL тДЭ g preserves ╬УтВБ-cusps by ╬УтВА-normality of ╬УтВБ
    have hconj : ConjAct.toConjAct (mapGL тДЭ (g : SL(2, тДд))) тАв
        (Gamma1 N).map (mapGL тДЭ) = (Gamma1 N).map (mapGL тДЭ) := by
      have := Gamma1_map_conjAct_eq тЯи(g : SL(2, тДд))тБ╗┬╣, (Gamma0 N).inv_mem g.propertyтЯй
      simpa [map_inv, ConjAct.toConjAct_inv, inv_inv, inv_smul_eq_iff] using this
    have hcusp : IsCusp (mapGL тДЭ (g : SL(2, тДд)) тАв glMap (T_p_lower p hp.pos) тАв c)
        ((Gamma1 N).map (mapGL тДЭ)) :=
      hconj тЦ╕ hc_lower.smul (mapGL тДЭ (g : SL(2, тДд)))
    apply f.zero_at_cusps' hcusp
    have hmul : (mapGL тДЭ (g : SL(2, тДд)) * (glMap (T_p_lower p hp.pos) * ╬│)) тАв
        (OnePoint.infty : OnePoint тДЭ) =
      mapGL тДЭ (g : SL(2, тДд)) тАв glMap (T_p_lower p hp.pos) тАв c := by
      simp [SemigroupAction.mul_smul, h╬│]
    exact hmul

/-- `T_p` restricted to cusp forms. -/
def heckeT_p_cusp (k : тДд) (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    CuspForm ((Gamma1 N).map (mapGL тДЭ)) k where
  toSlashInvariantForm := (heckeT_p k p hp hpN f.toModularForm').toSlashInvariantForm
  holo' := (heckeT_p k p hp hpN f.toModularForm').holo'
  zero_at_cusps' := heckeT_p_zero_at_cusps p hp hpN f

/-- `тЯиdтЯй` restricted to cusp forms. -/
def diamondOp_cusp (k : тДд) (d : (ZMod N)╦г)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    CuspForm ((Gamma1 N).map (mapGL тДЭ)) k :=
  diamondOpCusp k d f

/-- `T_p` (for all primes, including `p | N`) preserves cuspidality. -/
private theorem heckeT_p_all_zero_at_cusps (p : тДХ) (hp : Nat.Prime p)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    {c : OnePoint тДЭ} (hc : IsCusp c ((Gamma1 N).map (mapGL тДЭ))) :
    c.IsZeroAt ((heckeT_p_all k p hp) f.toModularForm').toFun k := by
  unfold heckeT_p_all
  split
  ┬╖ exact heckeT_p_zero_at_cusps p hp тА╣_тА║ f hc
  ┬╖ rename_i hpN
    show c.IsZeroAt (heckeT_p_ut k p hp.pos (тЗСf.toModularForm')) k
    simp only [heckeT_p_ut]
    apply Finset.sum_induction _ (fun g => c.IsZeroAt g k)
      (fun _ _ ha hb => ha.add hb)
      ((0 : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k).zero_at_cusps' hc)
    intro b _
    exact OnePoint.IsZeroAt.smul_iff.mp
      (f.zero_at_cusps' (Gamma1_isCusp_glMap_smul' _ hc))

/-- A `Module.End` on `ModularForm` preserves cuspidality if its output function
is zero at cusps for every cusp form input. This packages the zero-at-cusps
property for arbitrary `Module.End` operators built from cuspidality-preserving
components. -/
private def PreservesCusps (T : Module.End тДВ (ModularForm ((Gamma1 N).map (mapGL тДЭ)) k)) :
    Prop :=
  тИА (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) {c : OnePoint тДЭ},
    IsCusp c ((Gamma1 N).map (mapGL тДЭ)) тЖТ c.IsZeroAt (T f.toModularForm').toFun k

omit [NeZero N] in
private theorem preservesCusps_one :
    PreservesCusps (N := N) (k := k) 1 :=
  fun f _ hc => by simp; exact f.zero_at_cusps' hc

private theorem preservesCusps_heckeT_p_all (p : тДХ) (hp : Nat.Prime p) :
    PreservesCusps (N := N) (heckeT_p_all k p hp) :=
  fun f _ hc => heckeT_p_all_zero_at_cusps p hp f hc

private theorem preservesCusps_diamondOp_ext (p : тДХ) :
    PreservesCusps (N := N) (diamondOp_ext k p) := by
  intro f c hc
  unfold diamondOp_ext
  split
  ┬╖ exact (diamondOpCusp k (ZMod.unitOfCoprime p тА╣_тА║) f).zero_at_cusps' hc
  ┬╖ show c.IsZeroAt ((0 : ModularForm ((Gamma1 N).map (mapGL тДЭ)) k).toFun) k
    exact (0 : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k).zero_at_cusps' hc

omit [NeZero N] in
private theorem preservesCusps_mul {TтВБ TтВВ : Module.End тДВ (ModularForm ((Gamma1 N).map (mapGL тДЭ)) k)}
    (hтВБ : PreservesCusps TтВБ) (hтВВ : PreservesCusps TтВВ) :
    PreservesCusps (TтВБ * TтВВ) := by
  intro f c hc
  show c.IsZeroAt (TтВБ (TтВВ f.toModularForm')).toFun k
  -- TтВВ f.toModularForm' is a modular form whose toFun is zero at cusps (by hтВВ)
  -- So we can wrap it as a cusp form, then apply hтВБ
  let g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k :=
    { toSlashInvariantForm := (TтВВ f.toModularForm').toSlashInvariantForm
      holo' := (TтВВ f.toModularForm').holo'
      zero_at_cusps' := hтВВ f }
  exact hтВБ g hc

omit [NeZero N] in
private theorem preservesCusps_sub {TтВБ TтВВ : Module.End тДВ (ModularForm ((Gamma1 N).map (mapGL тДЭ)) k)}
    (hтВБ : PreservesCusps TтВБ) (hтВВ : PreservesCusps TтВВ) :
    PreservesCusps (TтВБ - TтВВ) := by
  intro f c hc
  -- Wrap TтВБ f and TтВВ f as cusp forms
  let gтВБ : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k :=
    { toSlashInvariantForm := (TтВБ f.toModularForm').toSlashInvariantForm
      holo' := (TтВБ f.toModularForm').holo'
      zero_at_cusps' := hтВБ f }
  let gтВВ : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k :=
    { toSlashInvariantForm := (TтВВ f.toModularForm').toSlashInvariantForm
      holo' := (TтВВ f.toModularForm').holo'
      zero_at_cusps' := hтВВ f }
  -- (TтВБ - TтВВ) f = TтВБ f - TтВВ f as modular forms, and gтВБ - gтВВ is a cusp form
  have hfun : ((TтВБ - TтВВ) f.toModularForm').toFun = (gтВБ - gтВВ).toFun := rfl
  rw [hfun]
  exact (gтВБ - gтВВ).zero_at_cusps' hc

omit [NeZero N] in
private theorem preservesCusps_smul (a : тДВ) {T : Module.End тДВ (ModularForm ((Gamma1 N).map (mapGL тДЭ)) k)}
    (hT : PreservesCusps T) :
    PreservesCusps (a тАв T) := by
  intro f c hc
  -- (a тАв T) f = a тАв (T f) as modular forms
  show c.IsZeroAt ((a тАв T f.toModularForm').toFun) k
  have hfun : (a тАв T f.toModularForm').toFun = a тАв (T f.toModularForm').toFun := by
    ext z; exact ModularForm.IsGLPos.smul_apply (T f.toModularForm') a z
  rw [hfun]
  intro g hg
  rw [ModularForm.smul_slash k g (T f.toModularForm').toFun a]
  exact (hT f hc g hg).smul (UpperHalfPlane.╧Г g a)

private theorem preservesCusps_heckeT_ppow (p : тДХ) (hp : Nat.Prime p) :
    тИА r : тДХ, PreservesCusps (N := N) (heckeT_ppow k p hp r) := by
  intro r
  induction r using Nat.strong_induction_on with
  | _ r ih =>
    match r with
    | 0 => exact preservesCusps_one
    | 1 => exact preservesCusps_heckeT_p_all p hp
    | r + 2 =>
      rw [heckeT_ppow_succ_succ]
      exact preservesCusps_sub
        (preservesCusps_mul (preservesCusps_heckeT_p_all p hp) (ih (r + 1) (by omega)))
        (preservesCusps_smul _ (preservesCusps_mul (preservesCusps_diamondOp_ext p)
          (ih r (by omega))))

private theorem preservesCusps_heckeT_n (n : тДХ) [NeZero n] :
    PreservesCusps (N := N) (k := k) (heckeT_n k n) := by
  -- heckeT_n k n = heckeT_n_aux k n, so it suffices to prove the aux version by induction
  show PreservesCusps (heckeT_n_aux k n)
  induction n using Nat.strong_induction_on with
  | _ m ih =>
    rw [heckeT_n_aux]
    split_ifs with hle
    ┬╖ exact preservesCusps_one
    ┬╖ push_neg at hle
      apply preservesCusps_mul (preservesCusps_heckeT_ppow m.minFac
        (Nat.minFac_prime (by omega)) _)
      exact ih _ (heckeT_n_unfold_lt m hle)

/-- `T_n` restricted to cusp forms. -/
def heckeT_n_cusp (k : тДд) (n : тДХ) [NeZero n]
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    CuspForm ((Gamma1 N).map (mapGL тДЭ)) k where
  toSlashInvariantForm := (heckeT_n k n f.toModularForm').toSlashInvariantForm
  holo' := (heckeT_n k n f.toModularForm').holo'
  zero_at_cusps' := fun hc => preservesCusps_heckeT_n n f hc

/-- Function-level decomposition for `heckeT_n_cusp`:
`T_m f = T_{p^v}(T_{m/p^v} f)` at each point. -/
theorem heckeT_n_cusp_unfold (m : тДХ) [NeZero m] (hm : 1 < m)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) (z : UpperHalfPlane) :
    let p := m.minFac
    let hp := Nat.minFac_prime (by omega : m тЙа 1)
    let v := m.factorization p
    have : NeZero (p ^ v) := тЯи(pow_pos hp.pos v).ne'тЯй
    have : NeZero (m / p ^ v) := тЯи(Nat.div_pos (Nat.le_of_dvd (by omega)
      (Nat.ordProj_dvd m p)) (pow_pos hp.pos v)).ne'тЯй
    (heckeT_n_cusp k m f) z =
      (heckeT_n_cusp k (p ^ v) (heckeT_n_cusp k (m / p ^ v) f)) z := by
  have hp' := Nat.minFac_prime (show m тЙа 1 by omega)
  have hv_pos := hp'.factorization_pos_of_dvd (by omega) (Nat.minFac_dvd m)
  haveI : NeZero (m.minFac ^ m.factorization m.minFac) := тЯи(pow_pos hp'.pos _).ne'тЯй
  haveI : NeZero (m / m.minFac ^ m.factorization m.minFac) :=
    тЯи(Nat.div_pos (Nat.le_of_dvd (by omega) (Nat.ordProj_dvd m m.minFac))
      (pow_pos hp'.pos _)).ne'тЯй
  -- Work at heckeT_n_aux level
  show (heckeT_n_aux k m f.toModularForm').toFun z =
    (heckeT_n_aux k _ (heckeT_n_aux k _ f.toModularForm')).toFun z
  rw [heckeT_n_aux, dif_neg (not_le.mpr hm), Module.End.mul_apply]
  -- LHS: heckeT_ppow(heckeT_n_aux(m/p^v)(f)).toFun z
  -- RHS: heckeT_n_aux(p^v)(heckeT_n_aux(m/p^v)(f)).toFun z
  -- heckeT_ppow = heckeT_n тЯиp^v, _тЯй = heckeT_n_aux(p^v) by prime_pow
  conv_lhs => rw [show heckeT_ppow (N := N) k m.minFac hp' (m.factorization m.minFac) =
      heckeT_n_aux k (m.minFac ^ m.factorization m.minFac) from
    (heckeT_n_prime_pow k hp' _ hv_pos).symm]

@[simp]
theorem heckeT_n_cusp_toModularForm' (n : тДХ) [NeZero n]
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    (heckeT_n_cusp k n f).toModularForm' = heckeT_n k n f.toModularForm' := by
  apply DFunLike.ext; intro ╧Д; rfl

variable (N) in
/-- `heckeT_n` decomposes into prime-power * quotient, with explicit arguments. -/
theorem heckeT_n_mul_ppow_quot [NeZero N] (m : тДХ) [NeZero m] (hm : 1 < m)
    (p : тДХ) (hp : Nat.Prime p)
    (hmp : p = m.minFac) (v : тДХ) (hmv : v = m.factorization p)
    (hv_pos : 0 < v) (hdiv_pos : 0 < m / p ^ v) :
    haveI : NeZero (p ^ v) := тЯи(pow_pos hp.pos v).ne'тЯй
    haveI : NeZero (m / p ^ v) := тЯиhdiv_pos.ne'тЯй
    heckeT_n (N := N) k m =
      heckeT_n (N := N) k (p ^ v) *
        heckeT_n (N := N) k (m / p ^ v) := by
  haveI : NeZero (p ^ v) := тЯи(pow_pos hp.pos v).ne'тЯй
  haveI : NeZero (m / p ^ v) := тЯиhdiv_pos.ne'тЯй
  subst hmp; subst hmv
  have h := heckeT_n_unfold (N := N) k m hm
  simp only [h]
  -- Goal: heckeT_ppow * heckeT_n = heckeT_n * heckeT_n
  congr 1
  exact (heckeT_n_prime_pow k (Nat.minFac_prime (by omega : m тЙа 1)) _
    ((Nat.minFac_prime (by omega : m тЙа 1)).factorization_pos_of_dvd (by omega)
      (Nat.minFac_dvd m))).symm

/-- `heckeT_n_cusp` decomposes as composition at each point:
`(T_n f)(z) = (T_{nтВБ}(T_{nтВВ} f))(z)` when `heckeT_n k n = heckeT_n k nтВБ * heckeT_n k nтВВ`
at the Module.End level. -/
theorem heckeT_n_cusp_mul_apply (nтВБ nтВВ : тДХ) [NeZero nтВБ] [NeZero nтВВ]
    (h_eq : haveI : NeZero (nтВБ * nтВВ) := тЯиNat.mul_pos (NeZero.pos nтВБ) (NeZero.pos nтВВ) |>.ne'тЯй
            heckeT_n (N := N) k (nтВБ * nтВВ) = heckeT_n k nтВБ * heckeT_n k nтВВ)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k)
    (z : UpperHalfPlane) :
    haveI : NeZero (nтВБ * nтВВ) := тЯиNat.mul_pos (NeZero.pos nтВБ) (NeZero.pos nтВВ) |>.ne'тЯй
    (heckeT_n_cusp k (nтВБ * nтВВ) f) z =
      (heckeT_n_cusp k nтВБ (heckeT_n_cusp k nтВВ f)) z := by
  haveI : NeZero (nтВБ * nтВВ) := тЯиNat.mul_pos (NeZero.pos nтВБ) (NeZero.pos nтВВ) |>.ne'тЯй
  show (heckeT_n k (nтВБ * nтВВ) f.toModularForm').toFun z =
    (heckeT_n k nтВБ (heckeT_n k nтВВ f.toModularForm')).toFun z
  rw [h_eq]; rfl

/-! ### Double coset identity for the adjoint (DS Theorem 5.5.3, algebraic part)

For `p` coprime to `N`, choose `m, n тИИ тДд` with `mp - nN = 1` (Bezout).
Then the matrix factorization `[p,0;0,1] = [1,n;N,mp]тБ╗┬╣ ┬╖ [1,0;0,p] ┬╖ [p,n;N,m]`
(where `[1,n;N,mp] тИИ ╬УтВБ(N)` and `[p,n;N,m] тИИ ╬УтВА(N)` with `m тЙб pтБ╗┬╣ mod N`)
gives the double coset identity:

  `╬УтВБ(N) [p,0;0,1] ╬УтВБ(N) = ╬УтВБ(N) [1,0;0,p] ╬УтВБ(N) ┬╖ ╬│тВА`

where `╬│тВА = [p,n;N,m]` represents `тЯиpтБ╗┬╣тЯй`. This is the algebraic heart of
`T_p* = тЯиpтЯйтБ╗┬╣ T_p`. -/

/-- The ╬УтВА(N) representative for the T_p adjoint double coset.

Given `p` coprime to `N`, use Bezout to find `m, n` with `mp - nN = 1`,
and construct `╬│тВА = [p, n; N, m] тИИ ╬УтВА(N)` with `m тЙб pтБ╗┬╣ mod N`.
This is the element from DS Theorem 5.5.3 that relates
`╬УтВБ(N)[p,0;0,1]╬УтВБ(N) = ╬УтВБ(N)[1,0;0,p]╬УтВБ(N) ┬╖ ╬│тВА`. -/
private noncomputable def adjointGamma0Rep (p N : тДХ) (hpN : Nat.Coprime p N) :
    тЖе(Gamma0 N) :=
  -- Use Bezout: gcdA(p,N) * p + gcdB(p,N) * N = gcd(p,N) = 1
  -- Build [p, -gcdB; N, gcdA] тИИ ╬УтВА(N). det = p┬╖gcdA + N┬╖gcdB = 1.
  let m := Int.gcdA p N
  let n := -(Int.gcdB p N)
  тЯитЯи!![(p : тДд), n; (N : тДд), m], by
      -- det = p * m - n * N = p * gcdA + gcdB * N = 1 (Bezout)
      have hbez := Int.gcd_eq_gcd_ab p N
      rw [show (Int.gcd (тЖСp) (тЖСN) : тДд) = 1 from by exact_mod_cast hpN] at hbez
      simp only [Matrix.det_fin_two_of]
      linarithтЯй, by
      -- ╬УтВА(N) membership: the (1,0) entry is N, and (N : ZMod N) = 0
      rw [Gamma0_mem]; simpтЯй

/-- The bottom-right entry of `adjointGamma0Rep` is `pтБ╗┬╣ mod N`:
`Gamma0MapUnits(╬│тВА) = тЯиpтЯйтБ╗┬╣`. This is because `m┬╖p тЙб 1 mod N` (Bezout). -/
private lemma adjointGamma0Rep_units (p N : тДХ) (hpN : Nat.Coprime p N) [NeZero N] :
    Gamma0MapUnits (adjointGamma0Rep p N hpN) =
      (ZMod.unitOfCoprime p hpN)тБ╗┬╣ := by
  -- The bottom-right entry of adjointGamma0Rep is gcdA(p,N).
  -- From Bezout: gcdA * p + gcdB * N = 1, so (gcdA : ZMod N) * p = 1,
  -- hence Gamma0MapUnits = unitOfCoprime(p)тБ╗┬╣.
  have hbez := Int.gcd_eq_gcd_ab p N
  rw [show (Int.gcd (тЖСp) (тЖСN) : тДд) = 1 from by exact_mod_cast hpN] at hbez
  -- Bezout in ZMod N: gcdA * p = 1
  have hmod : (Int.gcdA (тЖСp) (тЖСN) : ZMod N) * (p : ZMod N) = 1 := by
    have h := congr_arg (Int.cast : тДд тЖТ ZMod N) hbez
    simp only [Int.cast_one, Int.cast_add, Int.cast_mul, Int.cast_natCast,
      ZMod.natCast_self, zero_mul, add_zero] at h
    rw [mul_comm] at h; exact h.symm
  -- ╬│тВА-units * unitOfCoprime = 1, hence ╬│тВА-units = unitOfCoprimeтБ╗┬╣
  rw [eq_comm, inv_eq_of_mul_eq_one_left]
  ext
  simp only [Units.val_mul, Units.val_one, Gamma0MapUnits_val, ZMod.coe_unitOfCoprime]
  -- Goal: Gamma0Map N ╬│тВА * p = 1, where Gamma0Map extracts (1,1) entry
  -- Unfold to get the gcdA entry
  unfold adjointGamma0Rep Gamma0Map
  simp only [MonoidHom.coe_mk, OneHom.coe_mk]
  exact hmod

/-- **T128 R1 identity тАФ diamond via inverse `adjointGamma0Rep`**.
`тЗС(тЯиuтЯй f) = тЗСf тИг[k] mapGL ╬│тВАтБ╗┬╣` where `u = ZMod.unitOfCoprime p hpN` and
`╬│тВА = adjointGamma0Rep p N hpN`.  Direct consequence of
`Gamma0MapUnits ╬│тВА = uтБ╗┬╣` (`adjointGamma0Rep_units`) plus the MonoidHom
`map_inv` giving `Gamma0MapUnits ╬│тВАтБ╗┬╣ = u`, combined with
`diamondOpCusp_eq` at `(d := u, g := ╬│тВАтБ╗┬╣)`.

**Role in T128 symmetric closure.**  The residual `f тИг[k] mapGL ╬│тВАтБ╗┬╣`
exposed by the per-q ╬│тВА change-of-variable matches exactly the
first-slot `тЗСтЯиuтЯй f` of the symmetric form `petN(T_p f, g) = petN(тЯиuтЯйf, T_p g)`
once this identification is applied. -/
private lemma coe_diamondOp_cusp_eq_slash_adjointGamma0Rep_inv
    (p : тДХ) (hp : Nat.Prime p) (hpN : Nat.Coprime p N)
    (f : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    (тЗС(diamondOp_cusp k (ZMod.unitOfCoprime p hpN) f) :
        UpperHalfPlane тЖТ тДВ) =
      тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
        (((adjointGamma0Rep p N hpN : Gamma0 N) : SL(2, тДд))тБ╗┬╣) :
          GL (Fin 2) тДЭ) := by
  -- `Gamma0MapUnits ╬│тВАтБ╗┬╣ = (Gamma0MapUnits ╬│тВА)тБ╗┬╣ = (uтБ╗┬╣)тБ╗┬╣ = u`.
  have h_units : Gamma0MapUnits ((adjointGamma0Rep p N hpN)тБ╗┬╣ : Gamma0 N) =
      ZMod.unitOfCoprime p hpN := by
    rw [map_inv, adjointGamma0Rep_units, inv_inv]
  -- Apply `diamondOpCusp_eq` with the inverse representative.
  show (diamondOpCusp k (ZMod.unitOfCoprime p hpN) f : UpperHalfPlane тЖТ тДВ) = _
  rw [diamondOpCusp_eq k (ZMod.unitOfCoprime p hpN)
    ((adjointGamma0Rep p N hpN)тБ╗┬╣ : Gamma0 N) h_units]
  -- `diamondOpCuspAux k g f = f тИг[k] mapGL (g : SL(2, тДд))` at function level.
  rfl

/-- The ╬УтВБ(N) representative ╬│тВБтБ╗┬╣ for the triple product identity. Constructed
using Bezout coefficients `gcdA┬╖p + gcdB┬╖N = 1`, this is the matrix
`[[p┬╖gcdA, gcdB], [-N, 1]] тИИ SL(2,тДд)` with determinant `p┬╖gcdA - gcdB┬╖(-N) =
p┬╖gcdA + gcdB┬╖N = 1`. Its top-left entry is `p┬╖gcdA тЙб 1 mod N`, and (1,0)
entry is `-N тЙб 0`, so it lies in `╬УтВБ(N)`. -/
private noncomputable def adjointGamma1Rep (p N : тДХ) (hpN : Nat.Coprime p N) :
    SL(2, тДд) :=
  let a := Int.gcdA p N
  let b := Int.gcdB p N
  тЯи!![(p : тДд) * a, b; -(N : тДд), 1], by
    -- det = (p*a)*1 - b*(-N) = p*a + b*N = 1 (Bezout)
    have hbez := Int.gcd_eq_gcd_ab p N
    rw [show (Int.gcd (тЖСp) (тЖСN) : тДд) = 1 from by exact_mod_cast hpN] at hbez
    simp only [Matrix.det_fin_two_of]
    linarithтЯй

/-- `adjointGamma1Rep тИИ ╬УтВБ(N)`: top-left entry is `p┬╖gcdA тЙб 1 mod N`,
bottom-right is `1 тЙб 1`, (1,0) entry is `-N тЙб 0`. -/
private lemma adjointGamma1Rep_mem_Gamma1 (p N : тДХ) [NeZero N]
    (hpN : Nat.Coprime p N) :
    adjointGamma1Rep p N hpN тИИ Gamma1 N := by
  rw [Gamma1_mem]
  -- Top-left: p*gcdA, bottom-right: 1, (1,0): -N
  -- From Bezout: p*gcdA + gcdB*N = 1, so p*gcdA = 1 - gcdB*N тЙб 1 mod N.
  have hbez := Int.gcd_eq_gcd_ab p N
  rw [show (Int.gcd (тЖСp) (тЖСN) : тДд) = 1 from by exact_mod_cast hpN] at hbez
  refine тЯи?_, ?_, ?_тЯй
  ┬╖ -- (p*gcdA : ZMod N) = 1
    show (((adjointGamma1Rep p N hpN).val 0 0 : тДд) : ZMod N) = 1
    unfold adjointGamma1Rep
    -- Goal: ((p * Int.gcdA p N : тДд) : ZMod N) = 1
    have h : ((p : тДд) * Int.gcdA p N + Int.gcdB p N * N : ZMod N) = 1 := by
      have := congr_arg (Int.cast : тДд тЖТ ZMod N) hbez
      simp only [Int.cast_one, Int.cast_add, Int.cast_mul, Int.cast_natCast] at this
      push_cast; linear_combination -this
    simpa [ZMod.natCast_self] using h
  ┬╖ -- (1 : ZMod N) = 1
    show (((adjointGamma1Rep p N hpN).val 1 1 : тДд) : ZMod N) = 1
    unfold adjointGamma1Rep; simp
  ┬╖ -- (-N : ZMod N) = 0
    show (((adjointGamma1Rep p N hpN).val 1 0 : тДд) : ZMod N) = 0
    unfold adjointGamma1Rep; simp

/-! ### Hermitian adjoint of Hecke operators

The adjoint is defined via the Petersson inner product:
`тЯиT f, gтЯй = тЯиf, T* gтЯй` for all cusp forms f, g.

DiamondтАУShurman Proposition 5.5.2 gives the key identity:
`тЯиf|[╬▒], gтЯй = тЯиf, g|[╬▒']тЯй` where `╬▒' = det(╬▒) ┬╖ ╬▒тБ╗┬╣`.

For T_p, this yields T_p* = тЯиpтЯйтБ╗┬╣ T_p (Theorem 5.5.3). -/

/-! ### DS Proposition 5.5.2: GLтВВтБ║ change of variables for Petersson

The key analytic lemma for the Hecke adjoint. For `╬▒ тИИ GLтВВтБ║(тДЭ)`:

```
тИл_{D} petersson k (f|╬▒) g d╬╝ = тИл_{╬▒тБ╗┬╣тАвD} petersson k f (g|╬▒') d╬╝
```
where `╬▒' = det(╬▒)┬╖╬▒тБ╗┬╣`, using `instSMulInvMeasure_GLpos` for the change of
variables and `petersson_slash` for the integrand transformation.

This is combined with the coset sum structure of `petN` and the algebraic
double coset identity to prove `T_p* = тЯиpтЯйтБ╗┬╣ T_p` (DS Theorem 5.5.3). -/

section PeterssonAdjoint

open UpperHalfPlane MeasureTheory

-- Proof sketch for peterssonInner_slash_adjoint (DS Lemma 5.5.1 / Prop 5.5.2a):
-- 1. Insert `g = (gтИг╬▒)тИг╬▒тБ╗┬╣` to get both functions slashed by ╬▒:
--    `petersson k (fтИг╬▒) ((gтИг╬▒тБ╗┬╣)тИг╬▒) ╧Д = |det ╬▒|^{k-2} ┬╖ ╧Г ╬▒ ┬╖ petersson k f (gтИг╬▒тБ╗┬╣) (╬▒тАв╧Д)`.
-- 2. Change variables `╧Д тЖТ ╬▒тБ╗┬╣тАв╧Д` using `instSMulInvMeasure_GLpos`:
--    `тИл_D h(╧Д) d╬╝ = тИл_{╬▒тБ╗┬╣тАвD} h(╬▒тАв╧Д) d╬╝`.
-- 3. Simplify: the `|det ╬▒|^{k-2}` factor combines with `gтИг╬▒тБ╗┬╣` to give
--    `gтИг(det(╬▒)┬╖╬▒тБ╗┬╣) = gтИгadjugate(╬▒)` in the `petersson` integrand.

/-- The "Petersson adjoint" of a GLтВВ(тДЭ) element: `╬▒тАа = det(╬▒) ┬╖ ╬▒тБ╗┬╣ = adjugate(╬▒)`.
As a 2x2 matrix, `adjugate [[a,b],[c,d]] = [[d,-b],[-c,a]]`.
Since `det(adjugate ╬▒) = det(╬▒)^{n-1} тЙа 0`, the adjugate is in GLтВВ(тДЭ). -/
noncomputable def peterssonAdj (╬▒ : GL (Fin 2) тДЭ) : GL (Fin 2) тДЭ :=
  .mkOfDetNeZero (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate (by
    rw [Matrix.det_adjugate]
    exact pow_ne_zero _ ╬▒.det_ne_zero)

-- API for `slash_peterssonAdj_eq`: key facts about adjugate in GLтВВ.

/-- `det(peterssonAdj ╬▒) = det(╬▒)` for 2├Ч2 matrices (since det(adjugate) = det^{n-1}). -/
lemma peterssonAdj_det (╬▒ : GL (Fin 2) тДЭ) :
    (peterssonAdj ╬▒).det = ╬▒.det := by
  have hcoe : (peterssonAdj ╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate := by
    simp [peterssonAdj]
  ext
  show (peterssonAdj ╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).det =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).det
  rw [hcoe, Matrix.det_adjugate, Fintype.card_fin]
  ring

/-- Coercion: `peterssonAdj ╬▒` as a matrix equals the adjugate of `╬▒`. -/
lemma peterssonAdj_coe (╬▒ : GL (Fin 2) тДЭ) :
    (peterssonAdj ╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate := by
  simp [peterssonAdj]

/-- `peterssonAdj` is anti-multiplicative: `peterssonAdj(╬▒ * ╬▓) = peterssonAdj ╬▓ * peterssonAdj ╬▒`.
Follows from `Matrix.adjugate_mul_distrib`. -/
private lemma peterssonAdj_mul (╬▒ ╬▓ : GL (Fin 2) тДЭ) :
    peterssonAdj (╬▒ * ╬▓) = peterssonAdj ╬▓ * peterssonAdj ╬▒ := by
  apply Units.ext
  show (peterssonAdj (╬▒ * ╬▓) : Matrix (Fin 2) (Fin 2) тДЭ) =
    (peterssonAdj ╬▓ * peterssonAdj ╬▒ : GL (Fin 2) тДЭ).val
  rw [Units.val_mul, peterssonAdj_coe, peterssonAdj_coe, peterssonAdj_coe,
    Units.val_mul, Matrix.adjugate_mul_distrib]

/-- **T128 quotient helper тАФ right ╬УтВБ absorption**: for any
`╬│ тИИ Gamma1 N`, multiplying a representative `q` on the right by `╬│тБ╗┬╣`
keeps its class in `SL(2, тДд) тз╕ Gamma1 N`.

Direct application of `QuotientGroup.leftRel_apply`: the
left-coset-equivalence condition `(q * ╬│тБ╗┬╣)тБ╗┬╣ * q тИИ Gamma1 N` reduces to
`╬│ тИИ Gamma1 N` after `mul_inv_rev` + `inv_inv` + `mul_assoc` +
`inv_mul_cancel` + `mul_one`.

**Role in T128 aggregate bridge**: after the twist helper
`peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist` introduces
`(q ┬╖ ╬│тБ╗┬╣)тБ╗┬╣` factors in per-q shifted tiles, summing over `q :
SL(2, тДд) тз╕ Gamma1 N` preserves the index class by this lemma, enabling
sum-level reindexing that absorbs the `╬│тБ╗┬╣` discrepancy without
appealing to any per-q representative change. -/
private lemma Gamma1Quot_mk_mul_right_inv_eq
    (q ╬│ : SL(2, тДд)) (h╬│ : ╬│ тИИ Gamma1 N) :
    (тЯжq * ╬│тБ╗┬╣тЯз : SL(2, тДд) тз╕ Gamma1 N) = (тЯжqтЯз : SL(2, тДд) тз╕ Gamma1 N) := by
  rw [QuotientGroup.eq]
  show (q * ╬│тБ╗┬╣)тБ╗┬╣ * q тИИ Gamma1 N
  rw [mul_inv_rev, inv_inv, mul_assoc, inv_mul_cancel, mul_one]
  exact h╬│

/-- **T128 aggregate quotient-sum invariance**: reindex-identity form of
`Gamma1Quot_mk_mul_right_inv_eq`.  For any `╬│ тИИ Gamma1 N` and any
function `F : SL(2, тДд) тз╕ Gamma1 N тЖТ тДВ`, summing `F` applied to the
`╬│тБ╗┬╣`-twisted-out representative equals summing `F` directly over the
quotient.  Combines `Gamma1Quot_mk_mul_right_inv_eq` (class equality
`тЯжq.out ┬╖ ╬│тБ╗┬╣тЯз = тЯжq.outтЯз`) with `Quotient.out_eq q` (`тЯжq.outтЯз = q`)
pointwise. -/
private lemma sum_Gamma1Quot_mul_right_inv_eq
    (╬│ : SL(2, тДд)) (h╬│ : ╬│ тИИ Gamma1 N)
    (F : SL(2, тДд) тз╕ Gamma1 N тЖТ тДВ) :
    (тИС q : SL(2, тДд) тз╕ Gamma1 N,
        F (тЯж(q.out : SL(2, тДд)) * ╬│тБ╗┬╣тЯз)) =
      тИС q : SL(2, тДд) тз╕ Gamma1 N, F q := by
  refine Finset.sum_congr rfl ?_
  intro q _
  rw [Gamma1Quot_mk_mul_right_inv_eq _ ╬│ h╬│]
  exact congrArg F (Quotient.out_eq q)

/-- **Double-adjoint identity**: `peterssonAdj (peterssonAdj ╬▒) = ╬▒` for
any `╬▒ : GL (Fin 2) тДЭ`.  Follows from `Matrix.adjugate_adjugate` at
`Fintype.card (Fin 2) = 2`, where `(det ╬▒)^(2 - 2) тАв ╬▒ = ╬▒`. -/
lemma peterssonAdj_peterssonAdj (╬▒ : GL (Fin 2) тДЭ) :
    peterssonAdj (peterssonAdj ╬▒) = ╬▒ := by
  apply Units.ext
  ext i j
  have h╬▒coe := peterssonAdj_coe ╬▒
  change ((peterssonAdj ╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate) i j =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ) i j
  rw [h╬▒coe, Matrix.adjugate_fin_two, Matrix.adjugate_fin_two]
  fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]

/-- For an SL(2, тДд) element cast to GL(2, тДЭ), the `peterssonAdj` equals the group inverse.
Since SL elements have determinant 1, their adjugate equals their inverse. -/
lemma peterssonAdj_mapGL_SL_eq_inv (q : SL(2, тДд)) :
    peterssonAdj ((mapGL тДЭ q : GL (Fin 2) тДЭ)) = (mapGL тДЭ q : GL (Fin 2) тДЭ)тБ╗┬╣ := by
  apply Units.ext
  rw [peterssonAdj_coe, Matrix.coe_units_inv]
  -- Matrix.adjugate A = AтБ╗┬╣ when det A = 1. Use Matrix.inv_def + det = 1.
  have hdet : (mapGL тДЭ q : Matrix (Fin 2) (Fin 2) тДЭ).det = 1 := by
    have : (mapGL тДЭ q : Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix q.val) := by
      ext i j; simp [mapGL_coe_matrix, Int.castRingHom]
    rw [this, тЖР RingHom.map_det, q.property]
    simp
  rw [Matrix.inv_def, Ring.inverse_eq_inv', hdet]
  simp

/-- For an SL(2, тДд) element cast to GL(2, тДЭ), `(peterssonAdj ╬▒)тБ╗┬╣ = ╬▒`.
Direct corollary of `peterssonAdj_mapGL_SL_eq_inv` + `inv_inv`. -/
private lemma peterssonAdj_inv_mapGL_SL_eq_self (q : SL(2, тДд)) :
    (peterssonAdj ((mapGL тДЭ q : GL (Fin 2) тДЭ)))тБ╗┬╣ = (mapGL тДЭ q : GL (Fin 2) тДЭ) := by
  rw [peterssonAdj_mapGL_SL_eq_inv, inv_inv]

/-- Entry-level: `(╬▒тБ╗┬╣) i j = det(╬▒)тБ╗┬╣ * adjugate(╬▒) i j`. -/
private lemma GL_inv_entry (╬▒ : GL (Fin 2) тДЭ) (i j : Fin 2) :
    (╬▒тБ╗┬╣ : GL (Fin 2) тДЭ) i j =
      (╬▒.det.val)тБ╗┬╣ * (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate i j := by
  set A := (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ)
  have hdet : A.det тЙа 0 := ╬▒.det_ne_zero
  -- тЖС╬▒тБ╗┬╣ = AтБ╗┬╣ (nonsingular inverse)
  have hcoe : (тЖС╬▒тБ╗┬╣ : Matrix (Fin 2) (Fin 2) тДЭ) = AтБ╗┬╣ := Matrix.coe_units_inv ╬▒
  -- AтБ╗┬╣ = Ring.inverse(det A) тАв adjugate(A), and Ring.inverse = inv for a field
  have hinv : AтБ╗┬╣ = A.detтБ╗┬╣ тАв A.adjugate := by
    rw [Matrix.inv_def]
    congr 1
    exact Ring.inverse_eq_inv _
  have hdet_eq : A.det = ╬▒.det.val := rfl
  show (тЖС╬▒тБ╗┬╣ : Matrix _ _ тДЭ) i j = _
  rw [hcoe, hinv, Matrix.smul_apply, smul_eq_mul, hdet_eq]

/-- The peterssonAdj has the same M├╢bius action as ╬▒тБ╗┬╣: `peterssonAdj ╬▒ тАв ╧Д = ╬▒тБ╗┬╣ тАв ╧Д`.
This is because adjugate(╬▒) = det(╬▒) ┬╖ ╬▒тБ╗┬╣ as M├╢bius maps (scalar matrices act trivially). -/
private lemma peterssonAdj_smul_eq (╬▒ : GL (Fin 2) тДЭ) (╧Д : тДН) :
    (peterssonAdj ╬▒) тАв ╧Д = ╬▒тБ╗┬╣ тАв ╧Д := by
  -- num/denom of peterssonAdj ╬▒ differ from ╬▒тБ╗┬╣ by the factor det(╬▒), which cancels
  have hdet_ne : (╬▒.det.val : тДВ) тЙа 0 :=
    Complex.ofReal_ne_zero.mpr (Units.ne_zero ╬▒.det)
  have hadj_entry : тИА i j, (peterssonAdj ╬▒ : Matrix _ _ тДЭ) i j =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate i j := by
    intro i j; simp [peterssonAdj]
  have hdet_ne' : ╬▒.det.val тЙа 0 := Units.ne_zero ╬▒.det
  have hnum : num (peterssonAdj ╬▒) (╧Д : тДВ) = тЖС╬▒.det.val * num ╬▒тБ╗┬╣ (╧Д : тДВ) := by
    simp only [num, hadj_entry, GL_inv_entry]
    push_cast; field_simp
  have hdenom : denom (peterssonAdj ╬▒) (╧Д : тДВ) = тЖС╬▒.det.val * denom ╬▒тБ╗┬╣ (╧Д : тДВ) := by
    simp only [denom, hadj_entry, GL_inv_entry]
    push_cast; field_simp
  -- ╧Г agrees because det(peterssonAdj ╬▒) and det(╬▒тБ╗┬╣) have the same sign
  have h╧Г_eq : ╧Г (peterssonAdj ╬▒) = ╧Г ╬▒тБ╗┬╣ := by
    have hdet1 : (peterssonAdj ╬▒).det.val = ╬▒.det.val :=
      congr_arg Units.val (peterssonAdj_det ╬▒)
    have hdet2 : (╬▒тБ╗┬╣).det.val = (╬▒.det.val)тБ╗┬╣ := by
      show (╬▒тБ╗┬╣).det.val = _
      rw [show (╬▒тБ╗┬╣).det = ╬▒.detтБ╗┬╣ from map_inv (Matrix.GeneralLinearGroup.det) ╬▒]
      exact Units.val_inv_eq_inv_val _
    simp only [╧Г, hdet1, hdet2, inv_pos]
  ext1
  simp only [coe_smul, h╧Г_eq]
  congr 1
  rw [hnum, hdenom, mul_div_mul_left _ _ hdet_ne]

/-- `denom(peterssonAdj ╬▒, ╧Д) = det(╬▒) ┬╖ denom(╬▒тБ╗┬╣, ╧Д)`.
For adjugate `[[d,-b],[-c,a]]` vs inverse `[[d,-b],[-c,a]]/det`: the denominators
(bottom row ┬╖ [╧Д, 1]) differ by the factor det(╬▒). -/
private lemma peterssonAdj_denom (╬▒ : GL (Fin 2) тДЭ) (╧Д : тДН) :
    UpperHalfPlane.denom (peterssonAdj ╬▒) ╧Д =
      тЖС(╬▒.det.val) * UpperHalfPlane.denom ╬▒тБ╗┬╣ ╧Д := by
  have hadj_entry : тИА i j, (peterssonAdj ╬▒ : Matrix _ _ тДЭ) i j =
      (╬▒ : Matrix (Fin 2) (Fin 2) тДЭ).adjugate i j := by
    intro i j; simp [peterssonAdj]
  simp only [denom, hadj_entry, GL_inv_entry]
  push_cast
  have hdet_ne : (╬▒.det.val : тДВ) тЙа 0 :=
    Complex.ofReal_ne_zero.mpr (Units.ne_zero ╬▒.det)
  field_simp

/-- Pointwise: `g тИг[k] peterssonAdj ╬▒ = |det ╬▒|^{k-2} тАв (g тИг[k] ╬▒тБ╗┬╣)`.

Proof: By `ext ╧Д; simp [slash_apply]`, both sides evaluate to
`g(╬▒тБ╗┬╣тАв╧Д) * (det-power) * (denom)^{-k}`. Using `peterssonAdj_smul_eq` (same M├╢bius
action), `peterssonAdj_det` (same det), and `peterssonAdj_denom` (denom scales by det),
the det powers `|det|^{k-1} ┬╖ det^{-k}` on the LHS vs `|det|^{k-2} ┬╖ |detтБ╗┬╣|^{k-1}`
on the RHS both equal `det^{-1}`, so the ratio is `|det|^{k-2}`. -/
lemma slash_peterssonAdj_eq (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (g : тДН тЖТ тДВ) :
    g тИг[k] peterssonAdj ╬▒ = (тЖС(|╬▒.det.val| ^ (k - 2)) : тДВ) тАв (g тИг[k] ╬▒тБ╗┬╣) := by
  have habs : |╬▒.det.val| = ╬▒.det.val := abs_of_pos h╬▒
  have hdet_ne : (╬▒.det.val : тДВ) тЙа 0 :=
    Complex.ofReal_ne_zero.mpr (ne_of_gt h╬▒)
  have hdet_eq : (peterssonAdj ╬▒).det.val = ╬▒.det.val :=
    congr_arg Units.val (peterssonAdj_det ╬▒)
  have h╧Г_adj : ╧Г (peterssonAdj ╬▒) = ╧Г ╬▒тБ╗┬╣ := by
    simp only [╧Г, hdet_eq]
    have : (╬▒тБ╗┬╣).det.val = (╬▒.det.val)тБ╗┬╣ := by
      rw [show (╬▒тБ╗┬╣).det = ╬▒.detтБ╗┬╣ from map_inv (Matrix.GeneralLinearGroup.det) ╬▒]
      exact Units.val_inv_eq_inv_val _
    simp [this, inv_pos]
  have hdet_inv_abs : |(╬▒тБ╗┬╣).det.val| = (╬▒.det.val)тБ╗┬╣ := by
    rw [show (╬▒тБ╗┬╣).det = ╬▒.detтБ╗┬╣ from map_inv (Matrix.GeneralLinearGroup.det) ╬▒,
      Units.val_inv_eq_inv_val, abs_inv, habs]
  ext ╧Д
  have hD := denom_ne_zero ╬▒тБ╗┬╣ ╧Д
  simp only [ModularForm.slash_apply, Pi.smul_apply, smul_eq_mul, peterssonAdj_smul_eq,
    h╧Г_adj, hdet_eq, peterssonAdj_denom, mul_zpow, hdet_inv_abs, habs]
  -- Goal:
  -- ╧Г(g(..)) * тЖСd^(k-1) * (тЖСd^(-k) * D^(-k))
  -- = тЖС(d^(k-2)) * (╧Г(g(..)) * тЖСdтБ╗┬╣^(k-1) * D^(-k))
  -- where d = det ╬▒ : тДЭ (and тЖС is the тДЭтЖТтДВ cast)
  set d := ╬▒.det.val with hd_def
  -- Normalize the RHS coercions: тЖС(d^(k-2)) = (тЖСd)^(k-2) and тЖС(dтБ╗┬╣) = (тЖСd)тБ╗┬╣
  rw [show (тЖС(d ^ (k - 2)) : тДВ) = (тЖСd : тДВ) ^ (k - 2) from by push_cast; rfl]
  rw [show (тЖС(dтБ╗┬╣) : тДВ) = (тЖСd : тДВ)тБ╗┬╣ from Complex.ofReal_inv d]
  -- LHS: ╧Г(g(..)) * (тЖСd)^(k-1) * ((тЖСd)^(-k) * D^(-k))
  -- RHS: (тЖСd)^(k-2) * (╧Г(g(..)) * (тЖСd)тБ╗┬╣^(k-1) * D^(-k))
  -- Combine zpow factors on each side using zpow_add
  have hcd : (тЖСd : тДВ) тЙа 0 := hdet_ne
  -- Both sides equal ╧Г(g(..)) * (тЖСd)^(-1) * D^(-k)
  -- LHS: ╧Г(g(..)) * (тЖСd)^(k-1) * ((тЖСd)^(-k) * D^(-k))
  -- RHS: (тЖСd)^(k-2) * (╧Г(g(..)) * (тЖСd)тБ╗┬╣^(k-1) * D^(-k))
  set G := ╧Г ╬▒тБ╗┬╣ (g (╬▒тБ╗┬╣ тАв ╧Д)) with hG_def
  set D := denom ╬▒тБ╗┬╣ (тЖС╧Д) with hD_def
  suffices h : G * (тЖСd : тДВ) ^ (k - 1) * ((тЖСd : тДВ) ^ (-k) * D ^ (-k)) =
      (тЖСd : тДВ) ^ (k - 2) * (G * (тЖСd : тДВ)тБ╗┬╣ ^ (k - 1) * D ^ (-k)) by exact h
  rw [inv_zpow']
  -- Now RHS has (тЖСd)^(-(k-1)) instead of (тЖСd)тБ╗┬╣^(k-1)
  -- Both sides can be shown equal by combining zpow: k-1 + (-k) = -1 = (k-2) + (-(k-1))
  have h1 : (k - 1 : тДд) + (-k) = -1 := by omega
  have h2 : (k - 2 : тДд) + (-(k - 1)) = -1 := by omega
  calc G * (тЖСd : тДВ) ^ (k - 1) * ((тЖСd : тДВ) ^ (-k) * D ^ (-k))
      = G * ((тЖСd : тДВ) ^ (k - 1) * (тЖСd : тДВ) ^ (-k)) * D ^ (-k) := by ring
    _ = G * (тЖСd : тДВ) ^ (-1 : тДд) * D ^ (-k) := by rw [тЖР zpow_addтВА hcd, h1]
    _ = G * ((тЖСd : тДВ) ^ (k - 2) * (тЖСd : тДВ) ^ (-(k - 1))) * D ^ (-k) := by
          rw [тЖР zpow_addтВА hcd, h2]
    _ = (тЖСd : тДВ) ^ (k - 2) * (G * (тЖСd : тДВ) ^ (-(k - 1)) * D ^ (-k)) := by ring

/-- **GLтВВтБ║ Petersson adjoint** (DS Proposition 5.5.2a):
For `╬▒ тИИ GL(2,тДЭ)` with `det(╬▒) > 0`, and any measurable set `D тКЖ тДН`:
```
  peterssonInner k D (fтИг[k]╬▒) g = peterssonInner k (╬▒ тАв D) f (gтИг[k] adjugate(╬▒))
```

**Proof** (DS Lemma 5.5.1 / Prop 5.5.2a):
1. Write `g = (gтИг[k]╬▒тБ╗┬╣)тИг[k]╬▒` (by `slash_mul` + `inv_mul_cancel` + `slash_one`).
2. Apply `petersson_slash` to `petersson k (fтИг╬▒) ((gтИг╬▒тБ╗┬╣)тИг╬▒) ╧Д`:
   `= |det ╬▒|^{k-2} * ╧Г ╬▒ (petersson k f (gтИг╬▒тБ╗┬╣) (╬▒тАв╧Д))`
   `= |det ╬▒|^{k-2} * petersson k f (gтИг╬▒тБ╗┬╣) (╬▒тАв╧Д)`  (since `det ╬▒ > 0`, `╧Г ╬▒ = id`).
3. Change variables `тИл_{╬▒тАвD} h d╬╝ = тИл_D h(╬▒тАв┬╖) d╬╝` (by `instSMulInvMeasure_GLpos`):
   `тИл_D |det ╬▒|^{k-2} * petersson k f (gтИг╬▒тБ╗┬╣) (╬▒тАв┬╖) d╬╝`
   `= |det ╬▒|^{k-2} * тИл_{╬▒тАвD} petersson k f (gтИг╬▒тБ╗┬╣) d╬╝`
4. By `slash_peterssonAdj_eq`: `gтИгadj(╬▒) = |det ╬▒|^{k-2} тАв (gтИг╬▒тБ╗┬╣)`, so
   `petersson k f (gтИгadj(╬▒)) = |det ╬▒|^{k-2} * petersson k f (gтИг╬▒тБ╗┬╣)`.
5. The constant factors cancel, giving `peterssonInner k (╬▒тАвD) f (gтИгadj(╬▒))`. -/
theorem peterssonInner_slash_adjoint
    (D : Set тДН) (╬▒ : GL (Fin 2) тДЭ) (h╬▒ : 0 < ╬▒.det.val)
    (f g : тДН тЖТ тДВ) :
    peterssonInner k D (f тИг[k] ╬▒) g =
      peterssonInner k (╬▒ тАв D) f (g тИг[k] peterssonAdj ╬▒) := by
  -- Step 1: Write g = (g тИг[k] ╬▒тБ╗┬╣) тИг[k] ╬▒
  have hg_decomp : g = (g тИг[k] ╬▒тБ╗┬╣) тИг[k] ╬▒ := by
    rw [тЖР SlashAction.slash_mul, inv_mul_cancel, SlashAction.slash_one]
  -- Step 2: Rewrite using petersson_slash
  simp only [peterssonInner]
  -- Step 2: Use petersson_slash with g decomposed
  -- Key: petersson k (fтИг╬▒) g = petersson k (fтИг╬▒) ((gтИг╬▒тБ╗┬╣)тИг╬▒) (by hg_decomp)
  --     = |det ╬▒|^{k-2} * petersson k f (gтИг╬▒тБ╗┬╣) (╬▒тАв┬╖) (by petersson_slash + ╧Г ╬▒ = id)
  set g' := g тИг[k] ╬▒тБ╗┬╣
  have h_eq : тИА ╧Д, petersson k (f тИг[k] ╬▒) g ╧Д =
      тЖС|╬▒.det.val| ^ (k - 2) * petersson k f g' (╬▒ тАв ╧Д) := by
    intro ╧Д
    -- g = g' тИг[k] ╬▒
    have : g = g' тИг[k] ╬▒ := hg_decomp
    rw [this, petersson_slash, show ╧Г ╬▒ = RingHom.id тДВ from if_pos h╬▒, RingHom.id_apply]
  simp_rw [h_eq]
  -- Goal: тИл_D c * petersson k f g' (╬▒тАв╧Д) d╬╝ = тИл_{╬▒тАвD} petersson k f (gтИгadj) d╬╝
  -- Step 3: Change variables + absorb factor
  -- The key step: тИл_{╬▒тАвD} h d╬╝ = тИл_D h(╬▒тАв┬╖) d╬╝ (by MeasurePreserving)
  -- Combined with the det factor, everything works out.
  --
  -- We work backwards from the RHS:
  -- тИл_{╬▒тАвD} petersson k f (gтИгadj) d╬╝
  -- = тИл_{╬▒тАвD} petersson k f (c тАв g') d╬╝        (by slash_peterssonAdj_eq)
  -- = тИл_{╬▒тАвD} c * petersson k f g' d╬╝           (petersson is linear in 2nd arg)
  -- = c * тИл_{╬▒тАвD} petersson k f g' d╬╝           (pull constant)
  -- = c * тИл_D petersson k f g' (╬▒тАв╧Д) d╬╝         (change of variables)
  -- = тИл_D c * petersson k f g' (╬▒тАв╧Д) d╬╝         (push constant back)
  -- = LHS
  -- Work backwards from the RHS
  symm
  -- Step 3a: Rewrite g тИг[k] peterssonAdj ╬▒ = c тАв g' and simplify
  have hpet_adj : тИА ╧Д, petersson k f (g тИг[k] peterssonAdj ╬▒) ╧Д =
      тЖС|╬▒.det.val| ^ (k - 2) * petersson k f g' ╧Д := by
    intro ╧Д
    rw [slash_peterssonAdj_eq ╬▒ h╬▒ g]
    simp [petersson, Pi.smul_apply, smul_eq_mul]; ring
  simp_rw [hpet_adj]
  -- Goal: тИл_{╬▒тАвD} c * petersson k f g' d╬╝ = тИл_D c * petersson k f g' (╬▒тАв╧Д) d╬╝
  -- Step 3b: Change of variables using GLтВВтБ║ invariance
  set ╬▒' : GL(2, тДЭ)тБ║ := тЯи╬▒, h╬▒тЯй
  rw [show ╬▒ тАв D = (fun ╧Д => ╬▒' тАв ╧Д) '' D from by rw [Set.image_smul]; rfl]
  exact (measurePreserving_smul ╬▒' ╬╝_hyp).setIntegral_image_emb
    (measurableEmbedding_const_smul ╬▒') _ D

/-- **Hecke-representative wrapper around `peterssonInner_slash_adjoint`**
(Step 1 of the T205-d-SYMM chain, per expert review 2026-05-11).

CuspForm-typed specialisation of `peterssonInner_slash_adjoint`
(DS Proposition 5.5.2(a), integrated form). The analytic content is in
`peterssonInner_slash_adjoint`; this lemma is the named interface that
subsequent steps (T205-d-ADJ-CORR finite-correspondence aggregation,
T205-d-DIAMOND-SPEC T_p adjugate identification, T205-d-UNSYMM, T205-d-SYMM)
consume.

For `╬▓ тИИ GL(2, тДЭ)` with positive determinant (in practice a Hecke
representative for `╬▒ тИИ ╬ФтВА(N)` тАФ e.g. `╬▒ = diag(1, p)` at `╬УтВБ(N)` gives the
`p + 1` representatives `{T_p_upper(b)}_{b<p} тИк {T_p_lower}`) and any
measurable domain `D тКЖ тДН`, the slash on `f` at domain `D` matches a
domain-translated slash by `peterssonAdj ╬▓` on `g` over `╬▓ тАв D`. -/
theorem peterssonInner_slash_adjoint_for_heckeRep
    (D : Set тДН) (╬▓ : GL (Fin 2) тДЭ) (h╬▓ : 0 < ╬▓.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k D ((тЗСf : тДН тЖТ тДВ) тИг[k] ╬▓) тЗСg =
      peterssonInner k (╬▓ тАв D) тЗСf ((тЗСg : тДН тЖТ тДВ) тИг[k] peterssonAdj ╬▓) :=
  peterssonInner_slash_adjoint D ╬▓ h╬▓ тЗСf тЗСg

/-- **Per-`q`-coset Hecke-rep wrapper** (companion to
`peterssonInner_slash_adjoint_for_heckeRep`, Step 1 of T205-d-SYMM chain).

For each `╬УтВБ(N)`-coset `q` and Hecke-representative-like `╬▓ тИИ GL(2, тДЭ)` with
positive determinant, the petN per-`q` summand structure
```
  peterssonInner k fd ((тЗСf тИг[k] ╬▓) тИг[k] q.outтБ╗┬╣) (тЗСg тИг[k] q.outтБ╗┬╣)
```
re-expresses as a `╬▓`-translated tile integral via
1. `peterssonInner_smul_set_eq_slash` to swap the per-`q` slashes onto the
   domain (`fd тЖТ q.outтБ╗┬╣ тАв fd`),
2. `peterssonInner_slash_adjoint_for_heckeRep` to push `╬▓` from the `f`-slot
   onto the domain, putting the adjugate `peterssonAdj ╬▓` onto the `g`-slot.

This is the form T205-d-ADJ-CORR consumes per-(`╬▓`, `q`) summand. -/
theorem peterssonInner_slash_adjoint_for_heckeRep_per_q
    (q : SL(2, тДд) тз╕ Gamma1 N) (╬▓ : GL (Fin 2) тДЭ) (h╬▓ : 0 < ╬▓.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k fd
        (((тЗСf : тДН тЖТ тДВ) тИг[k] ╬▓) тИг[k] ((q.out : SL(2, тДд))тБ╗┬╣ : SL(2, тДд)))
        (тЗСg тИг[k] ((q.out : SL(2, тДд))тБ╗┬╣ : SL(2, тДд))) =
      peterssonInner k
        (╬▓ тАв (((q.out : SL(2, тДд))тБ╗┬╣ : SL(2, тДд)) тАв (fd : Set тДН)))
        тЗСf
        ((тЗСg : тДН тЖТ тДВ) тИг[k] peterssonAdj ╬▓) := by
  rw [тЖР peterssonInner_smul_set_eq_slash ((q.out : SL(2, тДд))тБ╗┬╣) fd
        ((тЗСf : тДН тЖТ тДВ) тИг[k] ╬▓) тЗСg]
  exact peterssonInner_slash_adjoint_for_heckeRep _ ╬▓ h╬▓ f g

/-- **LHS-distributed-summand тЖТ tile-form bridge** (consumer of
`peterssonInner_slash_adjoint_for_heckeRep_per_q`, immediate use by
T205-d-ADJ-CORR).

The per-`q`-coset summand form produced by
`petN_T_p_heckeT_p_LHS_sum_distributed` carries a single GLтВВ(тДЭ) slash
`╬▓ ┬╖ mapGL тДЭ q.outтБ╗┬╣` on the `f`-slot and a `mapGL тДЭ q.outтБ╗┬╣` slash on
the `g`-slot.  Via `SlashAction.slash_mul` (splitting the `f`-slot slash)
and the per-q ADJ-WRAPPER, this rewrites to the tile-translated form
`peterssonInner k (╬▓ тАв (q.outтБ╗┬╣ тАв fd)) тЗСf (тЗСg тИг[k] peterssonAdj ╬▓)`. -/
theorem peterssonInner_LHS_distributed_summand_to_tile_form
    (q : SL(2, тДд) тз╕ Gamma1 N) (╬▓ : GL (Fin 2) тДЭ) (h╬▓ : 0 < ╬▓.det.val)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k fd
        ((тЗСf : тДН тЖТ тДВ) тИг[k] (╬▓ * ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)))
        (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ)
          (q.out : SL(2, тДд))тБ╗┬╣ : GL (Fin 2) тДЭ)) =
      peterssonInner k
        (╬▓ тАв (((q.out : SL(2, тДд))тБ╗┬╣ : SL(2, тДд)) тАв (fd : Set тДН)))
        тЗСf
        ((тЗСg : тДН тЖТ тДВ) тИг[k] peterssonAdj ╬▓) := by
  rw [SlashAction.slash_mul k ╬▓
        ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) (q.out : SL(2, тДд))тБ╗┬╣ :
          GL (Fin 2) тДЭ) (тЗСf : тДН тЖТ тДВ)]
  exact peterssonInner_slash_adjoint_for_heckeRep_per_q q ╬▓ h╬▓ f g

/-- **T128 generic SL-domain-equivariance of `peterssonInner`**.  For
`╬│ : SL(2, тДд)` and functions `F, G : тДН тЖТ тДВ` both fixed by the
`mapGL тДЭ ╬│`-slash action, the domain translation by `mapGL тДЭ ╬│` leaves
`peterssonInner k _ F G` invariant.

Shortcut route via `peterssonInner_slash_adjoint`: apply it with
`f := F`, `g := G тИг[k] ╬▒` (where `╬▒ := mapGL тДЭ ╬│`), then use
`peterssonAdj_mapGL_SL_eq_inv` (`peterssonAdj ╬▒ = ╬▒тБ╗┬╣` since SL has
det 1), `SlashAction.slash_mul` + `mul_inv_cancel` +
`SlashAction.slash_one` to collapse `(G тИг[k] ╬▒) тИг[k] ╬▒тБ╗┬╣ = G`, and
finally `hF`, `hG` to absorb the residual slashes.

**Determinant positivity of `mapGL ╬│`**: det = 1 via `╬│.property`
(SL-determinant), lifted to тДЭ via `RingHom.map_det` + `Int.castRingHom`. -/
private lemma peterssonInner_mapGL_smul_eq_of_slash_invariant
    (D : Set тДН) (╬│ : SL(2, тДд)) (F G : тДН тЖТ тДВ)
    (hF : F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) = F)
    (hG : G тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) = G) :
    peterssonInner k
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) тАв D) F G =
      peterssonInner k D F G := by
  have h╬▒ : 0 <
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)).det.val := by
    show 0 < (((mapGL тДЭ ╬│ : GL (Fin 2) тДЭ)) : Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((mapGL тДЭ ╬│ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix ╬│.val) from by rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, ╬│.property]
    norm_num
  have h := peterssonInner_slash_adjoint (k := k) D
    (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)) h╬▒ F
    (G тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)))
  rw [peterssonAdj_mapGL_SL_eq_inv ╬│] at h
  rw [show ((G тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)))
          тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ))тБ╗┬╣) =
        G from by
      rw [тЖР SlashAction.slash_mul, mul_inv_cancel, SlashAction.slash_one]] at h
  rw [hF, hG] at h
  exact h.symm

/-- **T128 ╬УтВБ(N)-specialization of SL-domain-equivariance**.  For any
`╬│ тИИ Gamma1 N` and cusp forms `f, g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k`,
the `peterssonInner`-domain translation by `mapGL тДЭ ╬│` is invariant.
Discharges the two slash-invariance hypotheses of
`peterssonInner_mapGL_smul_eq_of_slash_invariant` via `slash_Gamma1_eq`
using the same coercion pattern as
`peterssonInner_T_p_lower_slash_adj_coset_right_Gamma1_twist`. -/
private lemma peterssonInner_mapGL_smul_eq_of_Gamma1
    (D : Set тДН) (╬│ : SL(2, тДд)) (h╬│ : ╬│ тИИ Gamma1 N)
    (f g : CuspForm ((Gamma1 N).map (mapGL тДЭ)) k) :
    peterssonInner k
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) тАв D)
        тЗСf тЗСg =
      peterssonInner k D тЗСf тЗСg := by
  have hf : (тЗСf тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ :
      GL (Fin 2) тДЭ)) = тЗСf := by
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) =
          ((╬│ : SL(2, тДд)) : GL (Fin 2) тДЭ) from rfl, тЖР ModularForm.SL_slash]
    exact slash_Gamma1_eq f ╬│ h╬│
  have hg : (тЗСg тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ :
      GL (Fin 2) тДЭ)) = тЗСg := by
    rw [show ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) =
          ((╬│ : SL(2, тДд)) : GL (Fin 2) тДЭ) from rfl, тЖР ModularForm.SL_slash]
    exact slash_Gamma1_eq g ╬│ h╬│
  exact peterssonInner_mapGL_smul_eq_of_slash_invariant D ╬│ тЗСf тЗСg hf hg

/-- **T090 SL-domain pullback identity for `peterssonInner`.**
For ╬│ : SL(2, тДд) and arbitrary F, G : тДН тЖТ тДВ, the SL-tile integral
`peterssonInner k ((mapGL тДЭ ╬│) тАв D) F G` equals the fd-domain integral
with slash by mapGL ╬│ on both slots.  No slash-invariance hypothesis is
needed (compare with `peterssonInner_mapGL_smul_eq_of_slash_invariant`,
which assumes F, G are slash-fixed by mapGL ╬│ and concludes the same as
`peterssonInner k D F G`; here the conclusion is in slash-form, capturing
the genuine pullback transformation).

**Proof.**  `peterssonInner_slash_adjoint` with ╬▒ := mapGL ╬│ (det = 1
since ╬│ тИИ SL) yields
`peterssonInner k D (F тИг mapGL ╬│) (G тИг mapGL ╬│) =
peterssonInner k (mapGL ╬│ тАв D) F ((G тИг mapGL ╬│) тИг peterssonAdj (mapGL ╬│))`.
For SL elements, `peterssonAdj (mapGL ╬│) = (mapGL ╬│)тБ╗┬╣`
(`peterssonAdj_mapGL_SL_eq_inv`); the RHS slot collapses
`(G тИг mapGL ╬│) тИг (mapGL ╬│)тБ╗┬╣ = G` via slash composition + group inverse. -/
private lemma peterssonInner_mapGL_smul_eq_slash
    (D : Set тДН) (╬│ : SL(2, тДд)) (F G : тДН тЖТ тДВ) :
    peterssonInner k
        (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ) тАв D) F G =
      peterssonInner k D
        (F тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ))
        (G тИг[k] ((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)) := by
  have h╬▒ : 0 <
      (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)).det.val := by
    show 0 < (((mapGL тДЭ ╬│ : GL (Fin 2) тДЭ)) : Matrix (Fin 2) (Fin 2) тДЭ).det
    rw [show ((mapGL тДЭ ╬│ : GL (Fin 2) тДЭ) : Matrix (Fin 2) (Fin 2) тДЭ) =
        ((Int.castRingHom тДЭ).mapMatrix ╬│.val) from by rw [mapGL_coe_matrix]; rfl]
    rw [тЖР RingHom.map_det, ╬│.property]
    norm_num
  have h := peterssonInner_slash_adjoint (k := k) D
    (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)) h╬▒ F
    (G тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)))
  rw [peterssonAdj_mapGL_SL_eq_inv ╬│] at h
  rw [show ((G тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ)))
          тИг[k] (((mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ) ╬│ : GL (Fin 2) тДЭ))тБ╗┬╣) =
        G from by
      rw [тЖР SlashAction.slash_mul, mul_inv_cancel, SlashAction.slash_one]] at h
  exact h.symm

end PeterssonAdjoint

/-! ### T090 Hecke conjugate intersection group `╬У_p(╬▒)`

Foundational infrastructure for the **aggregate full-Hecke-family swap**
`h_HeckeFD_swap` (DS Thm 5.5.3 sum-level Hecke adjoint).  As established in
prior T090 stints, the per-╬▒ individual SL-tile balance is mathematically
unsatisfiable: `(тЯиpтЯйтБ╗┬╣f) тИг glMap M_тИЮ` is invariant only under
`╬▒тБ╗┬╣ ╬УтВБ(N) ╬▒ тИй ╬УтВБ(N) =: ╬У_p(╬▒)`, **not** under ╬УтВБ(N).  The full DS Thm
5.5.3 route therefore necessarily passes through the conjugate
intersection group `╬У_p(╬▒)` and its fundamental domain.

Mathlib provides `CongruenceSubgroup.conjGL` (`Mathlib.NumberTheory.ModularForms.CongruenceSubgroups`)
as the conjugate `╬▒тБ╗┬╣ ┬╖ ╬У ┬╖ ╬▒ тИй SL(2,тДд)`, plus `IsCongruenceSubgroup.conjGL`
showing it is itself a congruence subgroup.  Combined with the standard
`╬УтВБ(N) тКУ K` intersection, this gives the conjugate intersection group
`╬У_p(╬▒) := ╬УтВБ(N) тКУ conjGL ╬УтВБ(N) ╬▒`, the kernel of the right Hecke action
of ╬▒ on the ╬УтВБ(N)-coset space.

This subsection provides the minimal foundational infrastructure
(definition + finite-index + congruence-subgroup-ness) needed downstream
for fundamental-domain transport between ╬УтВБ(N)-FD and ╬▒ тАв ╬У_p(╬▒)-FD
(the geometric content underlying `h_HeckeFD_swap`). -/

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 Hecke conjugate intersection group `╬У_p(╬▒)`.**

For `╬▒ тИИ GL(2, тДЪ)`, the kernel of the right Hecke action of ╬▒ on
`╬УтВБ(N)`-coset space:
```
╬У_p(╬▒) := ╬УтВБ(N) тИй ╬▒тБ╗┬╣ ┬╖ ╬УтВБ(N) ┬╖ ╬▒ тКЖ SL(2, тДд)
```
i.e., ╬│ тИИ ╬У_p(╬▒) iff both ╬│ тИИ ╬УтВБ(N) and ╬▒ ╬│ ╬▒тБ╗┬╣ тИИ ╬УтВБ(N).

Defined via Mathlib's `conjGL` (which gives `╬▒тБ╗┬╣ ┬╖ ╬УтВБ(N) ┬╖ ╬▒ тИй SL(2,тДд)`
as a Subgroup of SL(2, тДд)) intersected with `╬УтВБ(N)`.

**Key role.**  This is the natural fundamental group whose FD `╬▒ тАв ╬У_p(╬▒)\тДН`
sits inside the ╬УтВБ(N)-FD and on which the slash-adjoint identity for
non-╬УтВБ(N)-normalizing ╬▒ becomes valid (DS Thm 5.5.3 proof structure). -/
noncomputable def Gamma_p_╬▒ (╬▒ : GL (Fin 2) тДЪ) : Subgroup SL(2, тДд) :=
  conjGL (Gamma1 N) (╬▒.map (Rat.castHom тДЭ)) тКУ Gamma1 N

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `╬У_p(╬▒)` has finite index in `SL(2, тДд)`.**

Both factors of the intersection have finite index:
* `(Gamma1 N).FiniteIndex` via `instFiniteIndexGamma1`
  (mathlib `CongruenceSubgroups.lean`);
* `(conjGL (Gamma1 N) (╬▒.map (Rat.castHom тДЭ))).FiniteIndex` via
  `IsCongruenceSubgroup.conjGL` + `IsCongruenceSubgroup.finiteIndex`
  (mathlib `CongruenceSubgroups.lean`).

The inf instance
`[FiniteIndex H] [FiniteIndex K] : FiniteIndex (H тКУ K)`
(mathlib `GroupTheory/Index.lean`) closes the goal.

**Demoted from `instance` to `theorem`** to avoid potential typeclass-search
overhead when downstream code does not need it as an instance (matching
the `Gamma_p_╬▒_finiteIndex_in_Gamma1` pattern).  Use it explicitly via
`haveI := Gamma_p_╬▒_finiteIndex ╬▒`. -/
theorem Gamma_p_╬▒_finiteIndex (╬▒ : GL (Fin 2) тДЪ) :
    (Gamma_p_╬▒ (N := N) ╬▒).FiniteIndex := by
  show (conjGL (Gamma1 N) (╬▒.map (Rat.castHom тДЭ)) тКУ Gamma1 N).FiniteIndex
  haveI : (conjGL (Gamma1 N) (╬▒.map (Rat.castHom тДЭ))).FiniteIndex :=
    ((Gamma1_is_congruence N).conjGL ╬▒).finiteIndex
  exact inferInstance

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `╬У_p(╬▒) тЙд ╬УтВБ(N)`.**

Trivial right-inf inclusion: by definition `Gamma_p_╬▒ ╬▒ := conjGL ╬УтВБ(N) ╬▒ тКУ ╬УтВБ(N)`,
so `Gamma_p_╬▒ ╬▒ тЙд ╬УтВБ(N)` is `inf_le_right`. -/
lemma Gamma_p_╬▒_le_Gamma1 (╬▒ : GL (Fin 2) тДЪ) :
    Gamma_p_╬▒ (N := N) ╬▒ тЙд Gamma1 N :=
  inf_le_right

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `╬У_p(╬▒)` has finite index in `╬УтВБ(N)`.**

As a finite-index subgroup of `SL(2, тДд)` (via `Gamma_p_╬▒_finiteIndex`)
intersected with `╬УтВБ(N)`, the corresponding subgroup of `╬УтВБ(N)` (via
`Subgroup.subgroupOf`) is itself finite-index, by mathlib's
`instFiniteIndex_subgroupOf`.

**Demoted to a theorem** (not an instance) to avoid potential
typeclass-search overhead when downstream code does not need it as an
instance. Use it explicitly via
`have h := Gamma_p_╬▒_finiteIndex_in_Gamma1 ╬▒`. -/
theorem Gamma_p_╬▒_finiteIndex_in_Gamma1 (╬▒ : GL (Fin 2) тДЪ) :
    ((Gamma_p_╬▒ (N := N) ╬▒).subgroupOf (Gamma1 N)).FiniteIndex := by
  haveI : (Gamma_p_╬▒ (N := N) ╬▒).FiniteIndex := Gamma_p_╬▒_finiteIndex ╬▒
  exact Subgroup.instFiniteIndex_subgroupOf _ _

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 `╬У_p(╬▒)` conjugation embedding.**

For ╬│ тИИ ╬У_p(╬▒), the conjugate `╬▒ ┬╖ ╬│ ┬╖ ╬▒тБ╗┬╣` (interpreted in GL(2, тДЭ) via
`mapGL тДЭ`) is the lift of an element of `╬УтВБ(N) тКЖ SL(2, тДд)`.  Concretely:
there exists `╬┤ тИИ ╬УтВБ(N)` such that `(mapGL тДЭ ╬┤ : GL (Fin 2) тДЭ) = ╬▒' ┬╖ mapGL тДЭ ╬│ ┬╖ ╬▒'тБ╗┬╣`,
where `╬▒' := ╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ`.

This is the defining property of the conjugate intersection group: ╬│
lies in `╬У_p(╬▒)` iff `╬▒ ╬│ ╬▒тБ╗┬╣` is itself an SL(2, тДд)-element of ╬УтВБ(N).
The map `╬│ тЖж ╬┤` is the conjugation isomorphism `╬У_p(╬▒) тЙЕ ╬▒ ┬╖ ╬У_p(╬▒) ┬╖ ╬▒тБ╗┬╣`
(both subgroups of SL(2, тДд), the latter expressed via the conjugate
inclusion `╬▒ ╬│ ╬▒тБ╗┬╣ тИИ ╬УтВБ(N)`).

**Direct unfolding** of `╬У_p(╬▒) := conjGL ╬УтВБ(N) ╬▒ тКУ ╬УтВБ(N)` and
`mem_conjGL`. -/
lemma Gamma_p_╬▒_conj_mem_Gamma1 (╬▒ : GL (Fin 2) тДЪ)
    {╬│ : SL(2, тДд)} (h╬│ : ╬│ тИИ Gamma_p_╬▒ (N := N) ╬▒) :
    тИГ ╬┤ тИИ Gamma1 N,
      ((mapGL тДЭ ╬┤ : GL (Fin 2) тДЭ)) =
        (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) *
          (mapGL тДЭ ╬│ : GL (Fin 2) тДЭ) *
          ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣ := by
  rcases h╬│ with тЯиh_conj, _тЯй
  rcases mem_conjGL.mp h_conj with тЯи╬┤, h╬┤_mem, h╬┤_eqтЯй
  exact тЯи╬┤, h╬┤_mem, h╬┤_eqтЯй

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 conjGL тЖФ ConjAct.toConjAct GL-level identity.**

For a subgroup `╬У тЙд SL(2, тДд)` and `g : GL (Fin 2) тДЭ`, the GL-image of
`conjGL ╬У g` (the `mapGL тДЭ`-lift to GL(2,тДЭ)) equals the GL-conjugate
`ConjAct.toConjAct gтБ╗┬╣ тАв ╬У.map (mapGL тДЭ)` intersected with the image
of `mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ`.

**Direct unfolding** of `conjGL` (defined as
`((toConjAct gтБ╗┬╣) тАв (╬У.map (mapGL тДЭ))).comap (mapGL тДЭ)`) followed by
`Subgroup.map_comap_eq`.  The `mapGL тДЭ`-image of a `comap` along
`mapGL тДЭ` equals the original subgroup intersected with the range.

**Direct API for `IsFundamentalDomain.smul_of_eq_conjAct`.** Combined
with the SLтЖТGL outer-group bridge (for the FD-shift route via
PSL2Action's `instSMulInvMeasure_GLpos`), this is the precise identity
witnessing the conjugate-subgroup form `HтВВ = ConjAct.toConjAct gтБ╗┬╣ тАв HтВБ`
needed by the manager's `smul_of_eq_conjAct` (PeterssonLevelN.lean:428). -/
lemma conjGL_map_eq_conjAct_inv_smul_inter
    (╬У : Subgroup SL(2, тДд)) (g : GL (Fin 2) тДЭ) :
    (conjGL ╬У g).map (mapGL тДЭ) =
      (ConjAct.toConjAct gтБ╗┬╣ тАв (╬У.map (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ))) тКУ
        (mapGL тДЭ : SL(2, тДд) тЖТ* GL (Fin 2) тДЭ).range := by
  rw [conjGL, Subgroup.map_comap_eq, inf_comm]

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 conjugation-by-╬▒ function `╬У_p(╬▒) тЖТ ╬УтВБ(N)`.**

Noncomputable function extracting from the existential
`Gamma_p_╬▒_conj_mem_Gamma1` the unique `╬┤ тИИ ╬УтВБ(N)` satisfying
`mapGL тДЭ ╬┤ = ╬▒ ┬╖ mapGL тДЭ ╬│ ┬╖ ╬▒тБ╗┬╣`.  The element is unique by
`mapGL_injective` (the inclusion `SL(2, тДд) тЖТ GL (Fin 2) тДЭ` is injective),
so the function is well-defined.

**Reusable API.**  Combined with `Gamma_p_╬▒_conjBy_spec` (the defining
equality) this is the conjugation embedding `╬У_p(╬▒) тЖк ╬УтВБ(N)` at the
SL(2, тДд)-element level. -/
noncomputable def Gamma_p_╬▒_conjBy (╬▒ : GL (Fin 2) тДЪ)
    (╬│ : Gamma_p_╬▒ (N := N) ╬▒) : Gamma1 N :=
  тЯиClassical.choose (Gamma_p_╬▒_conj_mem_Gamma1 ╬▒ ╬│.property),
    (Classical.choose_spec (Gamma_p_╬▒_conj_mem_Gamma1 ╬▒ ╬│.property)).1тЯй

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 defining equality of `Gamma_p_╬▒_conjBy`.**

`mapGL тДЭ (Gamma_p_╬▒_conjBy ╬▒ ╬│ : SL(2, тДд)) = ╬▒ ┬╖ mapGL тДЭ ╬│ ┬╖ ╬▒тБ╗┬╣`
in `GL (Fin 2) тДЭ`. -/
lemma Gamma_p_╬▒_conjBy_spec (╬▒ : GL (Fin 2) тДЪ)
    (╬│ : Gamma_p_╬▒ (N := N) ╬▒) :
    (mapGL тДЭ ((Gamma_p_╬▒_conjBy ╬▒ ╬│ : SL(2, тДд))) : GL (Fin 2) тДЭ) =
      (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) *
        (mapGL тДЭ ((╬│ : SL(2, тДд))) : GL (Fin 2) тДЭ) *
        ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣ :=
  (Classical.choose_spec (Gamma_p_╬▒_conj_mem_Gamma1 ╬▒ ╬│.property)).2

open CongruenceSubgroup Pointwise ConjAct in
/-- **T090 injectivity of `Gamma_p_╬▒_conjBy`.**

The conjugation-by-╬▒ function `╬У_p(╬▒) тЖТ ╬УтВБ(N)` is injective.

**Proof.**  If `Gamma_p_╬▒_conjBy ╬▒ ╬│тВБ = Gamma_p_╬▒_conjBy ╬▒ ╬│тВВ` as elements
of `╬УтВБ(N)`, their `mapGL тДЭ` lifts agree.  By `Gamma_p_╬▒_conjBy_spec`
applied to both sides, `╬▒ ┬╖ mapGL тДЭ ╬│тВБ ┬╖ ╬▒тБ╗┬╣ = ╬▒ ┬╖ mapGL тДЭ ╬│тВВ ┬╖ ╬▒тБ╗┬╣`.
Cancellation in the GL(2, тДЭ) group yields `mapGL тДЭ ╬│тВБ = mapGL тДЭ ╬│тВВ`,
and `mapGL_injective` recovers `╬│тВБ = ╬│тВВ` as SL(2, тДд) elements; then
`Subtype.ext` finishes. -/
lemma Gamma_p_╬▒_conjBy_injective (╬▒ : GL (Fin 2) тДЪ) :
    Function.Injective (Gamma_p_╬▒_conjBy (N := N) ╬▒) := by
  intro ╬│тВБ ╬│тВВ h
  apply Subtype.ext
  -- Step 1: from h, derive equality of mapGL lifts of conjugates.
  have h_mapGL :
      (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) *
        (mapGL тДЭ ((╬│тВБ : SL(2, тДд))) : GL (Fin 2) тДЭ) *
        ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣ =
      (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) *
        (mapGL тДЭ ((╬│тВВ : SL(2, тДд))) : GL (Fin 2) тДЭ) *
        ((╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ))тБ╗┬╣ := by
    have hh : (Gamma_p_╬▒_conjBy ╬▒ ╬│тВБ : SL(2, тДд)) =
        (Gamma_p_╬▒_conjBy ╬▒ ╬│тВВ : SL(2, тДд)) := congrArg Subtype.val h
    have h1 := Gamma_p_╬▒_conjBy_spec ╬▒ ╬│тВБ
    have h2 := Gamma_p_╬▒_conjBy_spec ╬▒ ╬│тВВ
    rw [тЖР h1, hh, h2]
  -- Step 2: cancel ╬▒ on left and ╬▒тБ╗┬╣ on right via calc.
  have h_╬│ : (mapGL тДЭ ((╬│тВБ : SL(2, тДд))) : GL (Fin 2) тДЭ) =
      mapGL тДЭ ((╬│тВВ : SL(2, тДд))) := by
    have h_step1 : (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) *
        (mapGL тДЭ ((╬│тВБ : SL(2, тДд))) : GL (Fin 2) тДЭ) =
        (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ) * mapGL тДЭ ((╬│тВВ : SL(2, тДд))) := by
      have hh1 := congrArg (┬╖ * (╬▒.map (Rat.castHom тДЭ) : GL (Fin 2) тДЭ)) h_mapGL
      simp only [inv_mul_cancel_right] at hh1
      exact hh1
    exact mul_left_cancel h_step1
  -- Step 3: mapGL_injective lifts to SL(2, тДд).
  exact mapGL_injective h_╬│

