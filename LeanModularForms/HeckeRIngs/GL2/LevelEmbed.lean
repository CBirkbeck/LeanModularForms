import LeanModularForms.HeckeRIngs.GL2.Gamma1Pair

/-!
# Level Embeddings and Primitive Form Infrastructure

Defines the level-raising inclusion `Gamma1(M*l) Ôëñ Gamma1(M)` and the submodule
of cusp forms coming from lower levels (`cuspFormsFromLowerLevels`).

## Main definitions

* `Gamma1_le_of_dvd` ÔÇö if `M Ôêú N` then `Gamma1 N Ôëñ Gamma1 M` and `Gamma0 N Ôëñ Gamma0 M`
* `cuspFormRestrict` ÔÇö restriction of invariance group along a subgroup inclusion
* `cuspFormsFromLowerLevels` ÔÇö cusp forms generated by level-raising from proper divisors:
    `S_k^1(N, ¤ç) = Ôêæ_{M | N, M Ôëá N} Ôêæ_{l * M = N} image(levelEmbed l)`

These are the **definition-level** prerequisites for Phase 6 (primitive form theory,
Miyake ┬º4.6). The actual level-embedding linear map `f(z) Ôåª f(lz)` and the primitive
space `S_k^0 = (S_k^1)ÔèÑ` require the Petersson inner product (Phase 4) and the
slash-action compatibility (Phase 2/3).

## References

* Miyake, *Modular Forms*, ┬º4.6 (Lemma 4.6.1, p.162)
* DiamondÔÇôShurman, *A First Course in Modular Forms*, ┬º5.7
-/

open Matrix Matrix.SpecialLinearGroup CongruenceSubgroup

open scoped MatrixGroups ModularForm

namespace HeckeRing.GL2

/-- `Gamma1(N) Ôëñ Gamma1(M)` when `M Ôêú N`: if `a Ôëí 1 mod N` then `a Ôëí 1 mod M`,
and if `N Ôêú c` then `M Ôêú c`. -/
theorem Gamma1_le_of_dvd {M N : Ôäò} (h : M Ôêú N) :
    Gamma1 N Ôëñ Gamma1 M := by
  intro A hA
  rw [Gamma1_mem] at hA Ôèó
  obtain Ôƒ¿ha, hd, hcÔƒ® := hA
  set ¤å := ZMod.castHom h (ZMod M)
  refine Ôƒ¿?_, ?_, ?_Ôƒ®
  ┬À simpa [map_intCast, map_one] using congr_arg ¤å ha
  ┬À simpa [map_intCast, map_one] using congr_arg ¤å hd
  ┬À simpa [map_intCast, map_zero] using congr_arg ¤å hc

/-- `Gamma0(N) Ôëñ Gamma0(M)` when `M Ôêú N`: if `N Ôêú c` then `M Ôêú c`. -/
theorem Gamma0_le_of_dvd {M N : Ôäò} (h : M Ôêú N) :
    Gamma0 N Ôëñ Gamma0 M := by
  intro A hA
  rw [Gamma0_mem] at hA Ôèó
  simpa [map_intCast, map_zero] using congr_arg (ZMod.castHom h (ZMod M)) hA

/-- `Gamma1(N) Ôëñ Gamma0(N)` (standard inclusion, for convenience). -/
theorem Gamma1_le_Gamma0 (N : Ôäò) : Gamma1 N Ôëñ Gamma0 N :=
  Gamma1_in_Gamma0 N

/-- The set of proper-divisor level pairs `(M, l)` with `M * l = N` and `M Ôëá N`.
These are the sources for level-raising into `S_k(N, ¤ç)`. -/
def lowerLevelPairs (N : Ôäò) : Set (Ôäò ├ù Ôäò) :=
  {p | p.1 * p.2 = N Ôêº 0 < p.1 Ôêº 1 < p.2}

/-- The set of proper divisors of N that are valid source levels (multiples of
the conductor `m_¤ç`). For a Dirichlet character `¤ç` mod `N`, the valid source
levels `M` satisfy `m_¤ç Ôêú M Ôêú N` with `M Ôëá N`.

Note: the conductor `m_¤ç` is available via `DirichletCharacter.conductor`. -/
def validSourceLevels (N : Ôäò) (m_¤ç : Ôäò) : Set Ôäò :=
  {M | m_¤ç Ôêú M Ôêº M Ôêú N Ôêº M Ôëá N Ôêº 0 < M}

end HeckeRing.GL2
